{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R1FdXPWsif3ptj35vXBsYK","type":"tool_result","content":"1\t\"\"\"Pure operations on typed Plan objects (validate, migrate, mutate, schedule).\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom collections.abc import Iterator\n6\t\n7\tfrom bob_tools.planfile.model import Plan, PlanValidationError, Task\n8\t\n9\t\n10\tdef bug_count(plan: Plan) -> int:\n11\t    \"\"\"Return the number of bug tasks in ``plan``.\n12\t\n13\t    Returns ``0`` when ``plan.bugs is None`` (no Bugs section was parsed)\n14\t    and the count of top-level bug tasks otherwise. Verification scripts\n15\t    use this to surface a concrete count rather than the ambiguous\n16\t    ``bugs={p.bugs is not None}`` boolean (where ``bugs=False`` can be\n17\t    misread as \"the Bugs section exists but is empty\" instead of \"no\n18\t    Bugs section was found\"). The count covers root tasks only; nested\n19\t    subtask counts are left for callers that need them.\n20\t    \"\"\"\n21\t    if plan.bugs is None:\n22\t        return 0\n23\t    return len(plan.bugs.tasks)\n24\t\n25\t\n26\tdef _iter_tasks(tasks: tuple[Task, ...]) -> Iterator[Task]:\n27\t    \"\"\"Yield every task in ``tasks``, descending into ``children`` first.\"\"\"\n28\t    for task in tasks:\n29\t        yield task\n30\t        yield from _iter_tasks(task.children)\n31\t\n32\t\n33\tdef _iter_plan_tasks(plan: Plan) -> Iterator[Task]:\n34\t    \"\"\"Yield every Task in the plan: phase tasks, subsection tasks, bugs.\"\"\"\n35\t    for phase in plan.phases:\n36\t        yield from _iter_tasks(phase.tasks)\n37\t        for subsection in phase.subsections:\n38\t            yield from _iter_tasks(subsection.tasks)\n39\t    if plan.bugs is not None:\n40\t        yield from _iter_tasks(plan.bugs.tasks)\n41\t\n42\t\n43\tdef validate_plan(plan: Plan) -> None:\n44\t    \"\"\"Validate referential integrity of ``@deps`` references in ``plan``.\n45\t\n46\t    Every task ID listed in any task's ``deps`` must resolve to the\n47\t    ``task_id`` of some task in the plan. Otherwise raise\n48\t    :class:`PlanValidationError` carrying one message per missing\n49\t    reference (design doc section 8 phase A: \"validation requires\n50\t    referenced IDs to exist in the plan\").\n51\t\n52\t    Parse-time concerns (syntax, structure) are not re-checked here; the\n53\t    parser raises :class:`PlanSyntaxError` for those. Validation only\n54\t    cross-checks references between already-parsed objects.\n55\t    \"\"\"\n56\t    known_ids: set[str] = {\n57\t        task.task_id for task in _iter_plan_tasks(plan) if task.task_id is not None\n58\t    }\n59\t\n60\t    errors: list[str] = []\n61\t    for task in _iter_plan_tasks(plan):\n62\t        for dep in task.deps:\n63\t            if dep not in known_ids:\n64\t                ref = (\n65\t                    task.task_id\n66\t                    if task.task_id is not None\n67\t                    else (f\"line {task.line_number}\")\n68\t                )\n69\t                errors.append(f\"task {ref} references unknown dep {dep}\")\n70\t\n71\t    if errors:\n72\t        raise PlanValidationError(errors)\n73\t"}]},"parent_tool_use_id":null,"session_id":"c61f1cb6-aab2-436d-a134-c2d01c95bc3d","uuid":"eb022eea-2c99-450c-a3c2-c35dfac71803","timestamp":"2026-05-16T13:48:58.261Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/operations.py","content":"\"\"\"Pure operations on typed Plan objects (validate, migrate, mutate, schedule).\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Iterator\n\nfrom bob_tools.planfile.model import Plan, PlanValidationError, Task\n\n\ndef bug_count(plan: Plan) -> int:\n    \"\"\"Return the number of bug tasks in ``plan``.\n\n    Returns ``0`` when ``plan.bugs is None`` (no Bugs section was parsed)\n    and the count of top-level bug tasks otherwise. Verification scripts\n    use this to surface a concrete count rather than the ambiguous\n    ``bugs={p.bugs is not None}`` boolean (where ``bugs=False`` can be\n    misread as \"the Bugs section exists but is empty\" instead of \"no\n    Bugs section was found\"). The count covers root tasks only; nested\n    subtask counts are left for callers that need them.\n    \"\"\"\n    if plan.bugs is None:\n        return 0\n    return len(plan.bugs.tasks)\n\n\ndef _iter_tasks(tasks: tuple[Task, ...]) -> Iterator[Task]:\n    \"\"\"Yield every task in ``tasks``, descending into ``children`` first.\"\"\"\n    for task in tasks:\n        yield task\n        yield from _iter_tasks(task.children)\n\n\ndef _iter_plan_tasks(plan: Plan) -> Iterator[Task]:\n    \"\"\"Yield every Task in the plan: phase tasks, subsection tasks, bugs.\"\"\"\n    for phase in plan.phases:\n        yield from _iter_tasks(phase.tasks)\n        for subsection in phase.subsections:\n            yield from _iter_tasks(subsection.tasks)\n    if plan.bugs is not None:\n        yield from _iter_tasks(plan.bugs.tasks)\n\n\ndef validate_plan(plan: Plan) -> None:\n    \"\"\"Validate referential integrity of ``@deps`` references in ``plan``.\n\n    Every task ID listed in any task's ``deps`` must resolve to the\n    ``task_id`` of some task in the plan. Otherwise raise\n    :class:`PlanValidationError` carrying one message per missing\n    reference (design doc section 8 phase A: \"validation requires\n    referenced IDs to exist in the plan\").\n\n    Parse-time concerns (syntax, structure) are not re-checked here; the\n    parser raises :class:`PlanSyntaxError` for those. Validation only\n    cross-checks references between already-parsed objects.\n    \"\"\"\n    known_ids: set[str] = {\n        task.task_id for task in _iter_plan_tasks(plan) if task.task_id is not None\n    }\n\n    errors: list[str] = []\n    for task in _iter_plan_tasks(plan):\n        for dep in task.deps:\n            if dep not in known_ids:\n                ref = (\n                    task.task_id\n                    if task.task_id is not None\n                    else (f\"line {task.line_number}\")\n                )\n                errors.append(f\"task {ref} references unknown dep {dep}\")\n\n    if errors:\n        raise PlanValidationError(errors)\n","numLines":73,"startLine":1,"totalLines":73}}}
