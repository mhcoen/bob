{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tjdwohfjm7XQM4d7VZTMxb","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom collections.abc import Sequence\n7\tfrom dataclasses import dataclass, field\n8\tfrom pathlib import Path\n9\tfrom typing import Protocol, TypeVar\n10\t\n11\tfrom bob_tools.planfile.model import (\n12\t    BugsSection,\n13\t    Phase,\n14\t    Plan,\n15\t    RuledOut,\n16\t    Subsection,\n17\t    Task,\n18\t    TaskStatus,\n19\t)\n20\t\n21\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n22\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n23\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n24\t\n25\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n26\t# caller strips any inter-tag whitespace between iterations.\n27\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n28\t\n29\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n30\t# after the closing bracket (with the single separating space removed).\n31\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n32\t\n33\t# Content of an annotation (the bytes between `[` and `]`): an\n34\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n35\t# value. The required whitespace after the colon is what distinguishes\n36\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n37\t# after its colon).\n38\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n39\t\n40\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n41\t# token, and optional trailing text. Matches mcloop's `parse`, which\n42\t# treats a line as RULEDOUT when its stripped form starts with the\n43\t# literal bracket token.\n44\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n45\t\n46\t# Deps sibling line: optional indent, the literal `@deps` token, then\n47\t# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n48\t# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n49\t# group captures the remainder of the line; splitting on whitespace\n50\t# and validating each ID is a higher-level step.\n51\t_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n52\t\n53\t# Stage/Phase heading: any heading level whose title contains\n54\t# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n55\t# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n56\t# pattern to also pull out the keyword and the title text after the\n57\t# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n58\t# (no bare digits) — see design doc section 2.5.\n59\t_STAGE_RE = re.compile(\n60\t    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n61\t    re.IGNORECASE,\n62\t)\n63\t\n64\t# Bugs heading: any heading level whose title is exactly ``Bugs``.\n65\t# Mirrors mcloop's ``BUGS_RE``.\n66\t_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n67\t\n68\t# Subsection heading: ``###`` followed by free title text. Only level-3\n69\t# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n70\t# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n71\t# group following tasks until another subsection or phase ends them.\n72\t_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n73\t\n74\t# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n75\t# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n76\t# Recognized only at the start of the task body, before any flag tags.\n77\t_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n78\t\n79\t\n80\tdef parse_plan(\n81\t    text: str,\n82\t    *,\n83\t    strict: bool = False,\n84\t    source_path: Path | None = None,\n85\t) -> Plan:\n86\t    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n87\t\n88\t    ``strict=False`` (the default) is compatibility mode — accepts the\n89\t    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n90\t    line, optional task IDs, no phase-id comments). ``strict=True``\n91\t    enables the format additions in design doc section 4 (magic line,\n92\t    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n93\t\n94\t    Stage 2.5.1 wired the signature; 2.5.2 (this) walks ``text`` line\n95\t    by line, tracking the current phase (or bugs section), the current\n96\t    subsection within a phase, and a stack of open tasks by indent.\n97\t    Each task line opens or closes scopes by indent comparison, matching\n98\t    mcloop's logic in ``checklist.py:parse``. ``@deps`` and\n99\t    ``[RULEDOUT]`` sibling lines are routed via :func:`_attach_deps`\n100\t    and :func:`_attach_ruledout` and accumulated on the parent task.\n101\t    Project title and preamble prose extraction land in 2.5.3;\n102\t    syntax-error reporting in 2.5.4; strict-mode behavior in Stage 3.\n103\t    \"\"\"\n104\t    del strict\n105\t    lines = text.splitlines()\n106\t\n107\t    phases_b: list[_PhaseBuilder] = []\n108\t    bugs_b: _BugsBuilder | None = None\n109\t    current_phase: _PhaseBuilder | None = None\n110\t    current_subsection: _SubsectionBuilder | None = None\n111\t    in_bugs = False\n112\t    stack: list[_TaskBuilder] = []\n113\t\n114\t    for idx, line in enumerate(lines):\n115\t        line_number = idx + 1\n116\t\n117\t        heading = _parse_phase_heading(line)\n118\t        if heading is not None:\n119\t            ordinal, keyword, title = heading\n120\t            current_phase = _PhaseBuilder(\n121\t                ordinal=ordinal,\n122\t                keyword=keyword,\n123\t                title=title,\n124\t                line_number=line_number,\n125\t            )\n126\t            phases_b.append(current_phase)\n127\t            current_subsection = None\n128\t            in_bugs = False\n129\t            stack.clear()\n130\t            continue\n131\t\n132\t        if _BUGS_RE.match(line):\n133\t            bugs_b = _BugsBuilder(line_number=line_number)\n134\t            current_phase = None\n135\t            current_subsection = None\n136\t            in_bugs = True\n137\t            stack.clear()\n138\t            continue\n139\t\n140\t        if not in_bugs and current_phase is not None:\n141\t            sm = _SUBSECTION_RE.match(line)\n142\t            if sm is not None:\n143\t                current_subsection = _SubsectionBuilder(\n144\t                    title=sm.group(1).strip(),\n145\t                    line_number=line_number,\n146\t                )\n147\t                current_phase.subsections.append(current_subsection)\n148\t                stack.clear()\n149\t                continue\n150\t\n151\t        scope_tasks = _current_scope_tasks(\n152\t            in_bugs=in_bugs,\n153\t            bugs_b=bugs_b,\n154\t            current_subsection=current_subsection,\n155\t            current_phase=current_phase,\n156\t        )\n157\t\n158\t        ro = _parse_ruledout_line(line, line_number)\n159\t        if ro is not None:\n160\t            indent = len(ro.indent)\n161\t            roots = scope_tasks if scope_tasks is not None else []\n162\t            target = _attach_ruledout(indent, stack, roots)\n163\t            if target is not None:\n164\t                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n165\t            continue\n166\t\n167\t        dm = _DEPS_RE.match(line)\n168\t        if dm is not None:\n169\t            indent = len(dm.group(1))\n170\t            target, _lenient = _attach_deps(indent, stack)\n171\t            if target is not None:\n172\t                target.deps.extend(dm.group(2).split())\n173\t            continue\n174\t\n175\t        raw = _parse_task_line(line, line_number)\n176\t        if raw is None:\n177\t            continue\n178\t\n179\t        builder = _build_task(raw)\n180\t        indent = builder.indent_level\n181\t\n182\t        while stack and stack[-1].indent_level >= indent:\n183\t            stack.pop()\n184\t\n185\t        if stack:\n186\t            stack[-1].children.append(builder)\n187\t        elif scope_tasks is not None:\n188\t            scope_tasks.append(builder)\n189\t        # else: task line before any phase/bugs — silently dropped in\n190\t        # compat mode; strict mode (2.5.4) will surface this as a\n191\t        # PlanSyntaxError.\n192\t\n193\t        stack.append(builder)\n194\t\n195\t    return Plan(\n196\t        magic_version=None,\n197\t        project_title=\"\",\n198\t        preamble=\"\",\n199\t        phases=tuple(p.freeze() for p in phases_b),\n200\t        bugs=bugs_b.freeze() if bugs_b is not None else None,\n201\t        source_path=source_path,\n202\t    )\n203\t\n204\t\n205\tdef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n206\t    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n207\t\n208\t    Returns ``None`` for non-matching lines. The keyword is normalized\n209\t    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n210\t    keeps the keyword cosmetic, so the canonicalizer can choose to\n211\t    preserve original casing if it wants — the typed model only needs\n212\t    one stable form.\n213\t    \"\"\"\n214\t    m = _STAGE_RE.match(line)\n215\t    if m is None:\n216\t        return None\n217\t    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n218\t\n219\t\n220\tdef _extract_task_id(text: str) -> tuple[str | None, str]:\n221\t    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n222\t\n223\t    Per design doc section 4.2 grammar, the task ID is the first token\n224\t    in the body after the checkbox. Returns ``(None, text)`` when no\n225\t    leading task ID is present; task IDs are optional in compat mode\n226\t    and mandatory in strict mode (enforced separately in Stage 3).\n227\t    \"\"\"\n228\t    m = _TASK_ID_RE.match(text)\n229\t    if m is None:\n230\t        return None, text\n231\t    return m.group(1), text[m.end() :]\n232\t\n233\t\n234\tdef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n235\t    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n236\t\n237\t    Order matters: annotations come first (they live at end of line\n238\t    and would otherwise be swallowed by the action tag's args, which\n239\t    span to end of line). Task ID, then flag tags, then action tag run\n240\t    left-to-right. The remaining text is the task description.\n241\t    \"\"\"\n242\t    annotations, remaining = _extract_annotations(raw.text)\n243\t    task_id, remaining = _extract_task_id(remaining)\n244\t    flag_tags, remaining = _extract_flag_tags(remaining)\n245\t    action_tag, remaining = _extract_action_tag(remaining)\n246\t    return _TaskBuilder(\n247\t        task_id=task_id,\n248\t        text=remaining.strip(),\n249\t        status=TaskStatus.from_marker(raw.status_char),\n250\t        flag_tags=flag_tags,\n251\t        action_tag=action_tag,\n252\t        annotations=annotations,\n253\t        indent_level=len(raw.indent),\n254\t        line_number=raw.line_number,\n255\t    )\n256\t\n257\t\n258\tdef _current_scope_tasks(\n259\t    *,\n260\t    in_bugs: bool,\n261\t    bugs_b: _BugsBuilder | None,\n262\t    current_subsection: _SubsectionBuilder | None,\n263\t    current_phase: _PhaseBuilder | None,\n264\t) -> list[_TaskBuilder] | None:\n265\t    \"\"\"Pick the root-task list for the active section.\n266\t\n267\t    The order encodes the grammar: a Bugs section excludes phase scope;\n268\t    inside a phase, a current subsection captures following tasks until\n269\t    the next subsection or phase. Returns ``None`` when no section is\n270\t    active — i.e. the input has not yet introduced a phase or bugs\n271\t    heading, so any task/sibling line is an orphan.\n272\t    \"\"\"\n273\t    if in_bugs:\n274\t        return bugs_b.tasks if bugs_b is not None else None\n275\t    if current_subsection is not None:\n276\t        return current_subsection.tasks\n277\t    if current_phase is not None:\n278\t        return current_phase.tasks\n279\t    return None\n280\t\n281\t\n282\t@dataclass(frozen=True)\n283\tclass _RawTaskLine:\n284\t    \"\"\"Recognize-step output of `_parse_task_line`.\n285\t\n286\t    Stage 2 of the parser splits recognize-then-classify. This record\n287\t    is the recognize step: indent text, status marker, body text, and\n288\t    source line number. Higher-level functions classify the body into\n289\t    task id, tags, deps, and prose.\n290\t    \"\"\"\n291\t\n292\t    indent: str\n293\t    status_char: str\n294\t    text: str\n295\t    line_number: int\n296\t\n297\t\n298\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n299\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n300\t    m = _CHECKBOX_RE.match(line)\n301\t    if m is None:\n302\t        return None\n303\t    return _RawTaskLine(\n304\t        indent=m.group(1),\n305\t        status_char=m.group(2),\n306\t        text=m.group(3),\n307\t        line_number=line_number,\n308\t    )\n309\t\n310\t\n311\t@dataclass(frozen=True)\n312\tclass _RawRuledOut:\n313\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n314\t\n315\t    A RULEDOUT line is a sibling of the task it pertains to (design\n316\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n317\t    captures only indent, body text, and source line number; attaching\n318\t    the line to its parent task by indentation is a higher-level step.\n319\t    \"\"\"\n320\t\n321\t    indent: str\n322\t    text: str\n323\t    line_number: int\n324\t\n325\t\n326\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n327\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n328\t\n329\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n330\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n331\t    whitespace on the body text is stripped; an empty body is allowed.\n332\t    \"\"\"\n333\t    m = _RULEDOUT_RE.match(line)\n334\t    if m is None:\n335\t        return None\n336\t    return _RawRuledOut(\n337\t        indent=m.group(1),\n338\t        text=m.group(2).strip(),\n339\t        line_number=line_number,\n340\t    )\n341\t\n342\t\n343\tclass _HasIndentLevel(Protocol):\n344\t    \"\"\"Anything with an integer ``indent_level`` attribute.\n345\t\n346\t    Used by :func:`_attach_ruledout` so it can resolve attachment over\n347\t    either the eventual frozen ``Task`` model objects or the mutable\n348\t    builder records the parser uses while constructing them.\n349\t    \"\"\"\n350\t\n351\t    @property\n352\t    def indent_level(self) -> int: ...\n353\t\n354\t\n355\t_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n356\t\n357\t\n358\tdef _attach_ruledout(\n359\t    indent: int,\n360\t    stack: Sequence[_T],\n361\t    root_tasks: Sequence[_T],\n362\t) -> _T | None:\n363\t    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n364\t\n365\t    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n366\t    the open-ancestor stack from innermost to outermost and return the\n367\t    first task whose indent is strictly less than the RULEDOUT line's\n368\t    indent. If no such ancestor exists in the current phase, fall back\n369\t    to the most recent root task (mcloop's \"orphan\" handling). Returns\n370\t    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n371\t    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n372\t    the caller should drop.\n373\t    \"\"\"\n374\t    for task in reversed(stack):\n375\t        if task.indent_level < indent:\n376\t            return task\n377\t    if root_tasks:\n378\t        return root_tasks[-1]\n379\t    return None\n380\t\n381\t\n382\tdef _attach_deps(\n383\t    indent: int,\n384\t    stack: Sequence[_T],\n385\t) -> tuple[_T | None, bool]:\n386\t    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n387\t\n388\t    Walks the open-ancestor stack from innermost (top) to outermost.\n389\t    Returns ``(parent, False)`` for the strict form — first ancestor\n390\t    whose indent is strictly less than the deps line's indent. Returns\n391\t    ``(parent, True)`` for the lenient form — first ancestor at the\n392\t    same indent as the deps line, which callers should report as a\n393\t    validation warning (the deps was not indented under its task).\n394\t    Returns ``(None, False)`` when no candidate exists; the caller\n395\t    should drop the line.\n396\t\n397\t    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n398\t    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n399\t    indent is malformed input rather than an orphan that needs adopting.\n400\t    \"\"\"\n401\t    for task in reversed(stack):\n402\t        if task.indent_level < indent:\n403\t            return task, False\n404\t        if task.indent_level == indent:\n405\t            return task, True\n406\t    return None, False\n407\t\n408\t\n409\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n410\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n411\t\n412\t    Per design doc section 4.3, flag tags are recognized only at the\n413\t    leading position. The caller is responsible for stripping the task\n414\t    ID (if any) first. A bracketed flag form appearing later in the\n415\t    text is prose and is left in place.\n416\t    \"\"\"\n417\t    tags: list[str] = []\n418\t    remaining = text\n419\t    while True:\n420\t        m = _FLAG_TAG_RE.match(remaining)\n421\t        if m is None:\n422\t            break\n423\t        tags.append(m.group(1))\n424\t        remaining = remaining[m.end() :].lstrip()\n425\t    return tuple(tags), remaining\n426\t\n427\t\n428\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n429\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n430\t\n431\t    Per design doc section 4.3, the action tag is recognized only at\n432\t    the leading position, after any flag tags. The argument string is\n433\t    the text from the closing bracket to end of line, with the single\n434\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n435\t    are prose and are left in place.\n436\t\n437\t    Returns ``(None, text)`` when no leading action tag is present;\n438\t    otherwise consumes the rest of the line as the argument string\n439\t    and returns ``((action, args), \"\")``.\n440\t    \"\"\"\n441\t    m = _ACTION_TAG_RE.match(text)\n442\t    if m is None:\n443\t        return None, text\n444\t    action = m.group(1)\n445\t    args = text[m.end() :].lstrip()\n446\t    return (action, args), \"\"\n447\t\n448\t\n449\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n450\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n451\t\n452\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n453\t    are bracketed, and are separated from the preceding text by\n454\t    whitespace. Multiple annotations are allowed. Values may contain\n455\t    balanced bracket pairs; this function scans right-to-left with\n456\t    bracket-depth tracking so nested brackets stay inside a single\n457\t    annotation rather than being misparsed as a separate one.\n458\t\n459\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n460\t    accepts any identifier-shaped key. Validation of allowed keys is\n461\t    a separate concern.\n462\t    \"\"\"\n463\t    annotations: list[tuple[str, str]] = []\n464\t    remaining = text\n465\t    while True:\n466\t        rstripped = remaining.rstrip()\n467\t        if not rstripped.endswith(\"]\"):\n468\t            remaining = rstripped\n469\t            break\n470\t        start = _find_matching_open_bracket(rstripped)\n471\t        if start is None:\n472\t            remaining = rstripped\n473\t            break\n474\t        # An annotation must be separated from preceding text by\n475\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n476\t        # character is part of the task text, not an annotation.\n477\t        if start > 0 and not rstripped[start - 1].isspace():\n478\t            remaining = rstripped\n479\t            break\n480\t        content = rstripped[start + 1 : -1]\n481\t        m = _ANNOTATION_CONTENT_RE.match(content)\n482\t        if m is None:\n483\t            remaining = rstripped\n484\t            break\n485\t        annotations.insert(0, (m.group(1), m.group(2)))\n486\t        remaining = rstripped[:start].rstrip()\n487\t    return tuple(annotations), remaining\n488\t\n489\t\n490\tdef _find_matching_open_bracket(s: str) -> int | None:\n491\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n492\t\n493\t    Walks right-to-left tracking bracket depth so balanced nested\n494\t    brackets inside the candidate annotation are stepped over.\n495\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n496\t    opener.\n497\t    \"\"\"\n498\t    if not s.endswith(\"]\"):\n499\t        return None\n500\t    depth = 0\n501\t    for i in range(len(s) - 1, -1, -1):\n502\t        c = s[i]\n503\t        if c == \"]\":\n504\t            depth += 1\n505\t        elif c == \"[\":\n506\t            depth -= 1\n507\t            if depth == 0:\n508\t                return i\n509\t    return None\n510\t\n511\t\n512\t# Mutable builder records used while walking the input. The public\n513\t# model dataclasses are frozen, so the parser builds with these and\n514\t# calls ``freeze`` to produce the immutable tree at the end. Each\n515\t# builder also satisfies the ``_HasIndentLevel`` protocol so the\n516\t# existing ``_attach_*`` helpers operate on them directly.\n517\t\n518\t\n519\t@dataclass\n520\tclass _TaskBuilder:\n521\t    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n522\t\n523\t    task_id: str | None\n524\t    text: str\n525\t    status: TaskStatus\n526\t    flag_tags: tuple[str, ...]\n527\t    action_tag: tuple[str, str] | None\n528\t    annotations: tuple[tuple[str, str], ...]\n529\t    indent_level: int\n530\t    line_number: int\n531\t    deps: list[str] = field(default_factory=list)\n532\t    children: list[_TaskBuilder] = field(default_factory=list)\n533\t    ruled_out: list[RuledOut] = field(default_factory=list)\n534\t\n535\t    def freeze(self) -> Task:\n536\t        return Task(\n537\t            task_id=self.task_id,\n538\t            text=self.text,\n539\t            status=self.status,\n540\t            flag_tags=self.flag_tags,\n541\t            action_tag=self.action_tag,\n542\t            annotations=self.annotations,\n543\t            deps=tuple(self.deps),\n544\t            children=tuple(c.freeze() for c in self.children),\n545\t            ruled_out=tuple(self.ruled_out),\n546\t            indent_level=self.indent_level,\n547\t            line_number=self.line_number,\n548\t        )\n549\t\n550\t\n551\t@dataclass\n552\tclass _SubsectionBuilder:\n553\t    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n554\t\n555\t    title: str\n556\t    line_number: int\n557\t    prose: str = \"\"\n558\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n559\t\n560\t    def freeze(self) -> Subsection:\n561\t        return Subsection(\n562\t            title=self.title,\n563\t            prose=self.prose,\n564\t            tasks=tuple(t.freeze() for t in self.tasks),\n565\t            line_number=self.line_number,\n566\t        )\n567\t\n568\t\n569\t@dataclass\n570\tclass _PhaseBuilder:\n571\t    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n572\t\n573\t    ordinal: int\n574\t    keyword: str\n575\t    title: str\n576\t    line_number: int\n577\t    phase_id: str | None = None\n578\t    phase_id_source: str = \"none\"\n579\t    prose: str = \"\"\n580\t    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n581\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n582\t\n583\t    def freeze(self) -> Phase:\n584\t        return Phase(\n585\t            phase_id=self.phase_id,\n586\t            phase_id_source=self.phase_id_source,\n587\t            ordinal=self.ordinal,\n588\t            keyword=self.keyword,\n589\t            title=self.title,\n590\t            prose=self.prose,\n591\t            subsections=tuple(s.freeze() for s in self.subsections),\n592\t            tasks=tuple(t.freeze() for t in self.tasks),\n593\t            line_number=self.line_number,\n594\t        )\n595\t\n596\t\n597\t@dataclass\n598\tclass _BugsBuilder:\n599\t    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n600\t\n601\t    line_number: int\n602\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n603\t\n604\t    def freeze(self) -> BugsSection:\n605\t        return BugsSection(\n606\t            tasks=tuple(t.freeze() for t in self.tasks),\n607\t            line_number=self.line_number,\n608\t        )\n609\t"}]},"parent_tool_use_id":null,"session_id":"17f18e8b-2608-44d2-8d2d-3883ebd2b7ba","uuid":"6615d2c2-ebb4-465f-bc1c-b238babfd09a","timestamp":"2026-05-16T02:47:22.858Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections.abc import Sequence\nfrom dataclasses import dataclass, field\nfrom pathlib import Path\nfrom typing import Protocol, TypeVar\n\nfrom bob_tools.planfile.model import (\n    BugsSection,\n    Phase,\n    Plan,\n    RuledOut,\n    Subsection,\n    Task,\n    TaskStatus,\n)\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n# Deps sibling line: optional indent, the literal `@deps` token, then\n# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n# group captures the remainder of the line; splitting on whitespace\n# and validating each ID is a higher-level step.\n_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n\n# Stage/Phase heading: any heading level whose title contains\n# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n# pattern to also pull out the keyword and the title text after the\n# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n# (no bare digits) — see design doc section 2.5.\n_STAGE_RE = re.compile(\n    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n    re.IGNORECASE,\n)\n\n# Bugs heading: any heading level whose title is exactly ``Bugs``.\n# Mirrors mcloop's ``BUGS_RE``.\n_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n\n# Subsection heading: ``###`` followed by free title text. Only level-3\n# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n# group following tasks until another subsection or phase ends them.\n_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n\n# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n# Recognized only at the start of the task body, before any flag tags.\n_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n\n\ndef parse_plan(\n    text: str,\n    *,\n    strict: bool = False,\n    source_path: Path | None = None,\n) -> Plan:\n    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n\n    ``strict=False`` (the default) is compatibility mode — accepts the\n    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n    line, optional task IDs, no phase-id comments). ``strict=True``\n    enables the format additions in design doc section 4 (magic line,\n    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n\n    Stage 2.5.1 wired the signature; 2.5.2 (this) walks ``text`` line\n    by line, tracking the current phase (or bugs section), the current\n    subsection within a phase, and a stack of open tasks by indent.\n    Each task line opens or closes scopes by indent comparison, matching\n    mcloop's logic in ``checklist.py:parse``. ``@deps`` and\n    ``[RULEDOUT]`` sibling lines are routed via :func:`_attach_deps`\n    and :func:`_attach_ruledout` and accumulated on the parent task.\n    Project title and preamble prose extraction land in 2.5.3;\n    syntax-error reporting in 2.5.4; strict-mode behavior in Stage 3.\n    \"\"\"\n    del strict\n    lines = text.splitlines()\n\n    phases_b: list[_PhaseBuilder] = []\n    bugs_b: _BugsBuilder | None = None\n    current_phase: _PhaseBuilder | None = None\n    current_subsection: _SubsectionBuilder | None = None\n    in_bugs = False\n    stack: list[_TaskBuilder] = []\n\n    for idx, line in enumerate(lines):\n        line_number = idx + 1\n\n        heading = _parse_phase_heading(line)\n        if heading is not None:\n            ordinal, keyword, title = heading\n            current_phase = _PhaseBuilder(\n                ordinal=ordinal,\n                keyword=keyword,\n                title=title,\n                line_number=line_number,\n            )\n            phases_b.append(current_phase)\n            current_subsection = None\n            in_bugs = False\n            stack.clear()\n            continue\n\n        if _BUGS_RE.match(line):\n            bugs_b = _BugsBuilder(line_number=line_number)\n            current_phase = None\n            current_subsection = None\n            in_bugs = True\n            stack.clear()\n            continue\n\n        if not in_bugs and current_phase is not None:\n            sm = _SUBSECTION_RE.match(line)\n            if sm is not None:\n                current_subsection = _SubsectionBuilder(\n                    title=sm.group(1).strip(),\n                    line_number=line_number,\n                )\n                current_phase.subsections.append(current_subsection)\n                stack.clear()\n                continue\n\n        scope_tasks = _current_scope_tasks(\n            in_bugs=in_bugs,\n            bugs_b=bugs_b,\n            current_subsection=current_subsection,\n            current_phase=current_phase,\n        )\n\n        ro = _parse_ruledout_line(line, line_number)\n        if ro is not None:\n            indent = len(ro.indent)\n            roots = scope_tasks if scope_tasks is not None else []\n            target = _attach_ruledout(indent, stack, roots)\n            if target is not None:\n                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n            continue\n\n        dm = _DEPS_RE.match(line)\n        if dm is not None:\n            indent = len(dm.group(1))\n            target, _lenient = _attach_deps(indent, stack)\n            if target is not None:\n                target.deps.extend(dm.group(2).split())\n            continue\n\n        raw = _parse_task_line(line, line_number)\n        if raw is None:\n            continue\n\n        builder = _build_task(raw)\n        indent = builder.indent_level\n\n        while stack and stack[-1].indent_level >= indent:\n            stack.pop()\n\n        if stack:\n            stack[-1].children.append(builder)\n        elif scope_tasks is not None:\n            scope_tasks.append(builder)\n        # else: task line before any phase/bugs — silently dropped in\n        # compat mode; strict mode (2.5.4) will surface this as a\n        # PlanSyntaxError.\n\n        stack.append(builder)\n\n    return Plan(\n        magic_version=None,\n        project_title=\"\",\n        preamble=\"\",\n        phases=tuple(p.freeze() for p in phases_b),\n        bugs=bugs_b.freeze() if bugs_b is not None else None,\n        source_path=source_path,\n    )\n\n\ndef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n\n    Returns ``None`` for non-matching lines. The keyword is normalized\n    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n    keeps the keyword cosmetic, so the canonicalizer can choose to\n    preserve original casing if it wants — the typed model only needs\n    one stable form.\n    \"\"\"\n    m = _STAGE_RE.match(line)\n    if m is None:\n        return None\n    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n\n\ndef _extract_task_id(text: str) -> tuple[str | None, str]:\n    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n\n    Per design doc section 4.2 grammar, the task ID is the first token\n    in the body after the checkbox. Returns ``(None, text)`` when no\n    leading task ID is present; task IDs are optional in compat mode\n    and mandatory in strict mode (enforced separately in Stage 3).\n    \"\"\"\n    m = _TASK_ID_RE.match(text)\n    if m is None:\n        return None, text\n    return m.group(1), text[m.end() :]\n\n\ndef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n\n    Order matters: annotations come first (they live at end of line\n    and would otherwise be swallowed by the action tag's args, which\n    span to end of line). Task ID, then flag tags, then action tag run\n    left-to-right. The remaining text is the task description.\n    \"\"\"\n    annotations, remaining = _extract_annotations(raw.text)\n    task_id, remaining = _extract_task_id(remaining)\n    flag_tags, remaining = _extract_flag_tags(remaining)\n    action_tag, remaining = _extract_action_tag(remaining)\n    return _TaskBuilder(\n        task_id=task_id,\n        text=remaining.strip(),\n        status=TaskStatus.from_marker(raw.status_char),\n        flag_tags=flag_tags,\n        action_tag=action_tag,\n        annotations=annotations,\n        indent_level=len(raw.indent),\n        line_number=raw.line_number,\n    )\n\n\ndef _current_scope_tasks(\n    *,\n    in_bugs: bool,\n    bugs_b: _BugsBuilder | None,\n    current_subsection: _SubsectionBuilder | None,\n    current_phase: _PhaseBuilder | None,\n) -> list[_TaskBuilder] | None:\n    \"\"\"Pick the root-task list for the active section.\n\n    The order encodes the grammar: a Bugs section excludes phase scope;\n    inside a phase, a current subsection captures following tasks until\n    the next subsection or phase. Returns ``None`` when no section is\n    active — i.e. the input has not yet introduced a phase or bugs\n    heading, so any task/sibling line is an orphan.\n    \"\"\"\n    if in_bugs:\n        return bugs_b.tasks if bugs_b is not None else None\n    if current_subsection is not None:\n        return current_subsection.tasks\n    if current_phase is not None:\n        return current_phase.tasks\n    return None\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\nclass _HasIndentLevel(Protocol):\n    \"\"\"Anything with an integer ``indent_level`` attribute.\n\n    Used by :func:`_attach_ruledout` so it can resolve attachment over\n    either the eventual frozen ``Task`` model objects or the mutable\n    builder records the parser uses while constructing them.\n    \"\"\"\n\n    @property\n    def indent_level(self) -> int: ...\n\n\n_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n\n\ndef _attach_ruledout(\n    indent: int,\n    stack: Sequence[_T],\n    root_tasks: Sequence[_T],\n) -> _T | None:\n    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n\n    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n    the open-ancestor stack from innermost to outermost and return the\n    first task whose indent is strictly less than the RULEDOUT line's\n    indent. If no such ancestor exists in the current phase, fall back\n    to the most recent root task (mcloop's \"orphan\" handling). Returns\n    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n    the caller should drop.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task\n    if root_tasks:\n        return root_tasks[-1]\n    return None\n\n\ndef _attach_deps(\n    indent: int,\n    stack: Sequence[_T],\n) -> tuple[_T | None, bool]:\n    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n\n    Walks the open-ancestor stack from innermost (top) to outermost.\n    Returns ``(parent, False)`` for the strict form — first ancestor\n    whose indent is strictly less than the deps line's indent. Returns\n    ``(parent, True)`` for the lenient form — first ancestor at the\n    same indent as the deps line, which callers should report as a\n    validation warning (the deps was not indented under its task).\n    Returns ``(None, False)`` when no candidate exists; the caller\n    should drop the line.\n\n    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n    indent is malformed input rather than an orphan that needs adopting.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task, False\n        if task.indent_level == indent:\n            return task, True\n    return None, False\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n\n\n# Mutable builder records used while walking the input. The public\n# model dataclasses are frozen, so the parser builds with these and\n# calls ``freeze`` to produce the immutable tree at the end. Each\n# builder also satisfies the ``_HasIndentLevel`` protocol so the\n# existing ``_attach_*`` helpers operate on them directly.\n\n\n@dataclass\nclass _TaskBuilder:\n    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n\n    task_id: str | None\n    text: str\n    status: TaskStatus\n    flag_tags: tuple[str, ...]\n    action_tag: tuple[str, str] | None\n    annotations: tuple[tuple[str, str], ...]\n    indent_level: int\n    line_number: int\n    deps: list[str] = field(default_factory=list)\n    children: list[_TaskBuilder] = field(default_factory=list)\n    ruled_out: list[RuledOut] = field(default_factory=list)\n\n    def freeze(self) -> Task:\n        return Task(\n            task_id=self.task_id,\n            text=self.text,\n            status=self.status,\n            flag_tags=self.flag_tags,\n            action_tag=self.action_tag,\n            annotations=self.annotations,\n            deps=tuple(self.deps),\n            children=tuple(c.freeze() for c in self.children),\n            ruled_out=tuple(self.ruled_out),\n            indent_level=self.indent_level,\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _SubsectionBuilder:\n    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n\n    title: str\n    line_number: int\n    prose: str = \"\"\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Subsection:\n        return Subsection(\n            title=self.title,\n            prose=self.prose,\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _PhaseBuilder:\n    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n\n    ordinal: int\n    keyword: str\n    title: str\n    line_number: int\n    phase_id: str | None = None\n    phase_id_source: str = \"none\"\n    prose: str = \"\"\n    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Phase:\n        return Phase(\n            phase_id=self.phase_id,\n            phase_id_source=self.phase_id_source,\n            ordinal=self.ordinal,\n            keyword=self.keyword,\n            title=self.title,\n            prose=self.prose,\n            subsections=tuple(s.freeze() for s in self.subsections),\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _BugsBuilder:\n    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n\n    line_number: int\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> BugsSection:\n        return BugsSection(\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n","numLines":609,"startLine":1,"totalLines":609}}}
