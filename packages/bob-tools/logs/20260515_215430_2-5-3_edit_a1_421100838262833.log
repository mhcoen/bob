{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dc93gg49PgNftTAMKeKxyp","type":"tool_result","content":"1\t\"\"\"Tests for bob_tools.planfile.parser building blocks.\n2\t\n3\tStage 2 task-line recognizers and tag extractors:\n4\t\n5\t  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n6\t    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n7\t  - ``_parse_task_line`` returns a raw record on checkbox lines and\n8\t    ``None`` on anything else.\n9\t  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n10\t    sibling lines and returns indent, body, and source line number.\n11\t  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n12\t    line: nearest strictly-less-indented open ancestor, with fallback\n13\t    to the most recent root task (mcloop's ``parse`` parity). The\n14\t    parse-then-attach composition test confirms multiple RULEDOUT\n15\t    lines on one task are collected in source order.\n16\t  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n17\t    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n18\t    enforces that at least one ID follows the keyword.\n19\t  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n20\t    sibling line: the innermost open ancestor at strictly-less indent\n21\t    is the strict-form parent; an ancestor at equal indent is the\n22\t    lenient-form parent (caller should warn). No root-task fallback.\n23\t    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n24\t    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n25\t  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n26\t    tokens, in isolation and combination, and leaves non-leading\n27\t    occurrences as prose (design doc section 4.3).\n28\t  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n29\t    treats the rest of the line as its argument string; non-leading\n30\t    occurrences are prose.\n31\t  - ``_extract_annotations`` consumes trailing ``[key: value]``\n32\t    annotations, handles multiple annotations and nested brackets in\n33\t    values, and leaves bracketed prose that is not separated from\n34\t    preceding text by whitespace in place.\n35\t\"\"\"\n36\t\n37\tfrom __future__ import annotations\n38\t\n39\tfrom dataclasses import dataclass\n40\t\n41\timport pytest\n42\t\n43\tfrom bob_tools.planfile.model import TaskStatus\n44\tfrom bob_tools.planfile.parser import (\n45\t    _CHECKBOX_RE,\n46\t    _DEPS_RE,\n47\t    _attach_deps,\n48\t    _attach_ruledout,\n49\t    _extract_action_tag,\n50\t    _extract_annotations,\n51\t    _extract_flag_tags,\n52\t    _parse_ruledout_line,\n53\t    _parse_task_line,\n54\t    parse_plan,\n55\t)\n56\t\n57\t\n58\t@dataclass\n59\tclass _FakeTask:\n60\t    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n61\t\n62\t    indent_level: int\n63\t    name: str = \"\"\n64\t\n65\t\n66\tclass TestCheckboxRe:\n67\t    @pytest.mark.parametrize(\n68\t        (\"line\", \"indent\", \"marker\", \"text\"),\n69\t        [\n70\t            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n71\t            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n72\t            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n73\t            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n74\t            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n75\t        ],\n76\t    )\n77\t    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n78\t        m = _CHECKBOX_RE.match(line)\n79\t        assert m is not None\n80\t        assert m.group(1) == indent\n81\t        assert m.group(2) == marker\n82\t        assert m.group(3) == text\n83\t\n84\t    @pytest.mark.parametrize(\n85\t        \"line\",\n86\t        [\n87\t            \"\",\n88\t            \"## Stage 1: Core\",\n89\t            \"- [] missing space inside brackets\",\n90\t            \"- [y] unsupported marker\",\n91\t            \"- [ ]\",\n92\t            \"* [ ] wrong bullet\",\n93\t            \"Plain prose line\",\n94\t        ],\n95\t    )\n96\t    def test_non_matches(self, line: str) -> None:\n97\t        assert _CHECKBOX_RE.match(line) is None\n98\t\n99\t\n100\tclass TestParseTaskLine:\n101\t    def test_match_returns_raw_record(self) -> None:\n102\t        rec = _parse_task_line(\"  - [x] foo\", 7)\n103\t        assert rec is not None\n104\t        assert rec.indent == \"  \"\n105\t        assert rec.status_char == \"x\"\n106\t        assert rec.text == \"foo\"\n107\t        assert rec.line_number == 7\n108\t\n109\t    def test_match_failed_marker(self) -> None:\n110\t        rec = _parse_task_line(\"- [!] bad\", 12)\n111\t        assert rec is not None\n112\t        assert rec.status_char == \"!\"\n113\t        assert rec.line_number == 12\n114\t\n115\t    def test_non_task_returns_none(self) -> None:\n116\t        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n117\t        assert _parse_task_line(\"\", 2) is None\n118\t        assert _parse_task_line(\"Some prose\", 3) is None\n119\t\n120\t\n121\tclass TestParseRuledOutLine:\n122\t    def test_indented_with_text(self) -> None:\n123\t        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n124\t        assert rec is not None\n125\t        assert rec.indent == \"  \"\n126\t        assert rec.text == \"tried restart\"\n127\t        assert rec.line_number == 5\n128\t\n129\t    def test_top_level_with_text(self) -> None:\n130\t        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n131\t        assert rec is not None\n132\t        assert rec.indent == \"\"\n133\t        assert rec.text == \"orphan approach\"\n134\t\n135\t    def test_empty_body(self) -> None:\n136\t        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n137\t        assert rec is not None\n138\t        assert rec.indent == \"    \"\n139\t        assert rec.text == \"\"\n140\t\n141\t    def test_trailing_whitespace_stripped(self) -> None:\n142\t        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n143\t        assert rec is not None\n144\t        assert rec.text == \"foo\"\n145\t\n146\t    def test_non_leading_token_is_not_match(self) -> None:\n147\t        # A RULEDOUT token that appears mid-line is prose, not a\n148\t        # RULEDOUT line. Only the leading-position form is recognized.\n149\t        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n150\t\n151\t    def test_similar_token_does_not_match(self) -> None:\n152\t        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n153\t        # immediately after the keyword.\n154\t        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n155\t\n156\t    def test_non_ruledout_lines_return_none(self) -> None:\n157\t        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n158\t        assert _parse_ruledout_line(\"\", 2) is None\n159\t        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n160\t\n161\t\n162\tclass TestAttachRuledOut:\n163\t    def test_nearest_strict_less_indent_wins(self) -> None:\n164\t        root = _FakeTask(indent_level=0, name=\"root\")\n165\t        child = _FakeTask(indent_level=2, name=\"child\")\n166\t        grand = _FakeTask(indent_level=4, name=\"grand\")\n167\t        # RULEDOUT at indent 4 sits as a sibling under `child`\n168\t        # (indent 2): it attaches to `child`, not to `grand` even\n169\t        # though `grand` is deeper in the stack.\n170\t        attached = _attach_ruledout(4, [root, child, grand], [root])\n171\t        assert attached is child\n172\t\n173\t    def test_skips_equal_indent_in_stack(self) -> None:\n174\t        # Equal indent is not \"strictly less\", so the equal-indent\n175\t        # entry is skipped and the search continues outward.\n176\t        root = _FakeTask(indent_level=0, name=\"root\")\n177\t        same = _FakeTask(indent_level=2, name=\"same\")\n178\t        attached = _attach_ruledout(2, [root, same], [root])\n179\t        assert attached is root\n180\t\n181\t    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n182\t        # A column-0 RULEDOUT after the stack has been popped (e.g.\n183\t        # following a same-indent sibling) finds no strictly-less\n184\t        # ancestor, so it attaches to the last root task.\n185\t        a = _FakeTask(indent_level=0, name=\"a\")\n186\t        b = _FakeTask(indent_level=0, name=\"b\")\n187\t        attached = _attach_ruledout(0, [], [a, b])\n188\t        assert attached is b\n189\t\n190\t    def test_no_ancestors_no_roots_returns_none(self) -> None:\n191\t        # A stray [RULEDOUT] before any task in the phase has nothing\n192\t        # to attach to; the caller is expected to drop it.\n193\t        assert _attach_ruledout(0, [], []) is None\n194\t\n195\t    def test_empty_stack_uses_root_fallback(self) -> None:\n196\t        root = _FakeTask(indent_level=0, name=\"root\")\n197\t        attached = _attach_ruledout(2, [], [root])\n198\t        assert attached is root\n199\t\n200\t    def test_multiple_ruledouts_on_one_task_collected_in_order(self) -> None:\n201\t        # Compose the building blocks the orchestration layer will use:\n202\t        # parse each [RULEDOUT] line, route it to its parent via\n203\t        # _attach_ruledout, then append to the parent's list. Three\n204\t        # sibling RULEDOUTs at the child indent must all land on the\n205\t        # same parent and stay in source order.\n206\t        root = _FakeTask(indent_level=0, name=\"root\")\n207\t        child = _FakeTask(indent_level=2, name=\"child\")\n208\t        stack = [root, child]\n209\t        roots = [root]\n210\t\n211\t        lines = [\n212\t            (\"    [RULEDOUT] first approach\", 10),\n213\t            (\"    [RULEDOUT] second approach\", 11),\n214\t            (\"    [RULEDOUT] third approach\", 12),\n215\t        ]\n216\t        collected: dict[str, list[tuple[str, int]]] = {}\n217\t        for raw_line, line_number in lines:\n218\t            rec = _parse_ruledout_line(raw_line, line_number)\n219\t            assert rec is not None\n220\t            target = _attach_ruledout(len(rec.indent), stack, roots)\n221\t            assert target is child\n222\t            collected.setdefault(target.name, []).append((rec.text, rec.line_number))\n223\t\n224\t        assert collected == {\n225\t            \"child\": [\n226\t                (\"first approach\", 10),\n227\t                (\"second approach\", 11),\n228\t                (\"third approach\", 12),\n229\t            ],\n230\t        }\n231\t\n232\t\n233\tclass TestDepsRe:\n234\t    def test_single_id(self) -> None:\n235\t        m = _DEPS_RE.match(\"@deps T-000001\")\n236\t        assert m is not None\n237\t        assert m.group(1) == \"\"\n238\t        assert m.group(2).split() == [\"T-000001\"]\n239\t\n240\t    def test_multiple_ids(self) -> None:\n241\t        m = _DEPS_RE.match(\"@deps T-000001 T-000002 T-000003\")\n242\t        assert m is not None\n243\t        assert m.group(1) == \"\"\n244\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\", \"T-000003\"]\n245\t\n246\t    def test_indented_captures_indent(self) -> None:\n247\t        m = _DEPS_RE.match(\"    @deps T-000001 T-000002\")\n248\t        assert m is not None\n249\t        assert m.group(1) == \"    \"\n250\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n251\t\n252\t    def test_extra_inter_id_whitespace_collapses_on_split(self) -> None:\n253\t        # Variable spacing between IDs is normalized by str.split().\n254\t        m = _DEPS_RE.match(\"@deps T-000001    T-000002\")\n255\t        assert m is not None\n256\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n257\t\n258\t    @pytest.mark.parametrize(\n259\t        \"line\",\n260\t        [\n261\t            \"\",\n262\t            \"- [ ] regular task\",\n263\t            \"@dep T-000001\",\n264\t            \"@deps\",\n265\t            \"@deps \",\n266\t            \" @deps_ T-000001\",\n267\t        ],\n268\t    )\n269\t    def test_non_deps_lines(self, line: str) -> None:\n270\t        assert _DEPS_RE.match(line) is None\n271\t\n272\t\n273\tclass TestAttachDeps:\n274\t    def test_strict_form_deps_indented_under_parent(self) -> None:\n275\t        # Canonical form: @deps is indented strictly more than the\n276\t        # task it references. Parent's indent is strictly less than\n277\t        # the deps line's, so attachment is strict (no warning).\n278\t        parent = _FakeTask(indent_level=0, name=\"parent\")\n279\t        target, lenient = _attach_deps(2, [parent])\n280\t        assert target is parent\n281\t        assert lenient is False\n282\t\n283\t    def test_lenient_form_same_indent_warns(self) -> None:\n284\t        # \"Forgot to indent\" form: @deps at the same indent as its\n285\t        # task. Still attaches, but flagged as lenient so callers can\n286\t        # emit a validation warning.\n287\t        parent = _FakeTask(indent_level=0, name=\"parent\")\n288\t        target, lenient = _attach_deps(0, [parent])\n289\t        assert target is parent\n290\t        assert lenient is True\n291\t\n292\t    def test_strict_attaches_to_innermost_ancestor(self) -> None:\n293\t        # With multiple open ancestors the innermost strictly-less-\n294\t        # indented one wins — not the outermost.\n295\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n296\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n297\t        target, lenient = _attach_deps(4, [outer, inner])\n298\t        assert target is inner\n299\t        assert lenient is False\n300\t\n301\t    def test_lenient_uses_top_of_stack_at_same_indent(self) -> None:\n302\t        # Top of stack is at deps' indent — lenient attachment to the\n303\t        # immediately preceding task.\n304\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n305\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n306\t        target, lenient = _attach_deps(2, [outer, inner])\n307\t        assert target is inner\n308\t        assert lenient is True\n309\t\n310\t    def test_outdented_deps_walks_past_deeper_top(self) -> None:\n311\t        # The most recent task is more indented than @deps, so it is\n312\t        # skipped; the search continues outward and lands on the\n313\t        # equal-indent ancestor as a lenient match.\n314\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n315\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n316\t        target, lenient = _attach_deps(0, [outer, inner])\n317\t        assert target is outer\n318\t        assert lenient is True\n319\t\n320\t    def test_empty_stack_returns_none(self) -> None:\n321\t        # A @deps line before any task in scope has nothing to attach\n322\t        # to — the caller is expected to drop it. No root-task fallback\n323\t        # is provided, unlike _attach_ruledout.\n324\t        target, lenient = _attach_deps(0, [])\n325\t        assert target is None\n326\t        assert lenient is False\n327\t\n328\t    def test_all_ancestors_more_indented_returns_none(self) -> None:\n329\t        # Pathological: deps outdented past every known ancestor.\n330\t        # Stack-walk finds no candidate at lesser-or-equal indent.\n331\t        deep = _FakeTask(indent_level=4, name=\"deep\")\n332\t        target, lenient = _attach_deps(2, [deep])\n333\t        assert target is None\n334\t        assert lenient is False\n335\t\n336\t    def test_parse_and_attach_to_nested_subtask(self) -> None:\n337\t        # Compose _DEPS_RE with _attach_deps: a deeply-indented @deps\n338\t        # line resolves to the innermost open ancestor at strictly-less\n339\t        # indent — i.e. the nested subtask, not the root task. This is\n340\t        # the end-to-end shape the higher-level parser will use.\n341\t        root = _FakeTask(indent_level=0, name=\"root\")\n342\t        child = _FakeTask(indent_level=2, name=\"child\")\n343\t        grand = _FakeTask(indent_level=4, name=\"grand\")\n344\t        stack = [root, child, grand]\n345\t\n346\t        m = _DEPS_RE.match(\"      @deps T-000001 T-000002\")\n347\t        assert m is not None\n348\t        indent = len(m.group(1))\n349\t        ids = m.group(2).split()\n350\t\n351\t        target, lenient = _attach_deps(indent, stack)\n352\t        assert target is grand\n353\t        assert lenient is False\n354\t        assert ids == [\"T-000001\", \"T-000002\"]\n355\t\n356\t\n357\tclass TestExtractFlagTags:\n358\t    def test_no_tags(self) -> None:\n359\t        tags, rest = _extract_flag_tags(\"plain task text\")\n360\t        assert tags == ()\n361\t        assert rest == \"plain task text\"\n362\t\n363\t    def test_user(self) -> None:\n364\t        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n365\t        assert tags == (\"USER\",)\n366\t        assert rest == \"verify the menu\"\n367\t\n368\t    def test_batch(self) -> None:\n369\t        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n370\t        assert tags == (\"BATCH\",)\n371\t        assert rest == \"sub-task group\"\n372\t\n373\t    def test_user_and_batch_combined(self) -> None:\n374\t        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n375\t        assert tags == (\"USER\", \"BATCH\")\n376\t        assert rest == \"both flags\"\n377\t\n378\t    def test_adjacent_tags_without_separator(self) -> None:\n379\t        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n380\t        assert tags == (\"USER\", \"BATCH\")\n381\t        assert rest == \"no gap\"\n382\t\n383\t    def test_non_leading_tag_is_prose(self) -> None:\n384\t        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n385\t        assert tags == ()\n386\t        assert rest == \"Document the [USER] tag\"\n387\t\n388\t    def test_only_first_run_is_tags(self) -> None:\n389\t        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n390\t        assert tags == (\"USER\",)\n391\t        assert rest == \"middle [BATCH] later\"\n392\t\n393\t    def test_empty_input(self) -> None:\n394\t        tags, rest = _extract_flag_tags(\"\")\n395\t        assert tags == ()\n396\t        assert rest == \"\"\n397\t\n398\t\n399\tclass TestExtractActionTag:\n400\t    def test_no_action_tag(self) -> None:\n401\t        tag, rest = _extract_action_tag(\"plain task text\")\n402\t        assert tag is None\n403\t        assert rest == \"plain task text\"\n404\t\n405\t    def test_action_with_args(self) -> None:\n406\t        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n407\t        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n408\t        assert rest == \"\"\n409\t\n410\t    def test_action_without_args(self) -> None:\n411\t        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n412\t        assert tag == (\"noop\", \"\")\n413\t        assert rest == \"\"\n414\t\n415\t    def test_args_extend_to_end_of_line(self) -> None:\n416\t        # Argument string is text from closing bracket to end of line;\n417\t        # bracketed-looking content in args stays in args.\n418\t        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n419\t        assert tag == (\"run\", \"do [feat: x]\")\n420\t        assert rest == \"\"\n421\t\n422\t    def test_non_leading_auto_is_prose(self) -> None:\n423\t        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n424\t        assert tag is None\n425\t        assert rest == \"Document the [AUTO:run] tag\"\n426\t\n427\t\n428\tclass TestExtractAnnotations:\n429\t    def test_no_annotation(self) -> None:\n430\t        ann, rest = _extract_annotations(\"plain task text\")\n431\t        assert ann == ()\n432\t        assert rest == \"plain task text\"\n433\t\n434\t    def test_single_feat(self) -> None:\n435\t        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n436\t        assert ann == ((\"feat\", '\"menu wired\"'),)\n437\t        assert rest == \"do thing\"\n438\t\n439\t    def test_single_fix(self) -> None:\n440\t        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n441\t        assert ann == ((\"fix\", '\"race\"'),)\n442\t        assert rest == \"fixed it\"\n443\t\n444\t    def test_multiple_annotations_preserve_order(self) -> None:\n445\t        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n446\t        assert ann == (\n447\t            (\"feat\", '\"first\"'),\n448\t            (\"fix\", '\"second\"'),\n449\t        )\n450\t        assert rest == \"do thing\"\n451\t\n452\t    def test_nested_brackets_in_value(self) -> None:\n453\t        # Balanced brackets inside the value are stepped over by the\n454\t        # right-to-left depth scan and stay inside the annotation.\n455\t        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n456\t        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n457\t        assert rest == \"do thing\"\n458\t\n459\t    def test_unquoted_nested_brackets_in_value(self) -> None:\n460\t        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n461\t        assert ann == ((\"feat\", \"a [b] c\"),)\n462\t        assert rest == \"do\"\n463\t\n464\t    def test_prose_bracket_without_separator_is_text(self) -> None:\n465\t        # A `[` abutting a non-whitespace character is task text, not\n466\t        # the start of an annotation.\n467\t        ann, rest = _extract_annotations(\"see config[feat: x]\")\n468\t        assert ann == ()\n469\t        assert rest == \"see config[feat: x]\"\n470\t\n471\t    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n472\t        # `[AUTO:run]` has no whitespace after its colon and so is not\n473\t        # an annotation under this extractor's rules.\n474\t        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n475\t        assert ann == ()\n476\t        assert rest == \"[AUTO:run] cmd\"\n477\t\n478\t    def test_unmatched_open_bracket(self) -> None:\n479\t        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n480\t        assert ann == ()\n481\t        assert rest == \"dangling brackets feat ]\"\n482\t\n483\t    def test_annotation_alone_consumes_to_empty(self) -> None:\n484\t        ann, rest = _extract_annotations('[feat: \"lone\"]')\n485\t        assert ann == ((\"feat\", '\"lone\"'),)\n486\t        assert rest == \"\"\n487\t\n488\t\n489\tclass TestTagInteractions:\n490\t    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n491\t        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n492\t        # Annotation must be stripped before action tag, because action\n493\t        # tag args span to end of line.\n494\t        ann, after_ann = _extract_annotations(text)\n495\t        assert ann == ((\"feat\", '\"done\"'),)\n496\t        tags, after_flags = _extract_flag_tags(after_ann)\n497\t        assert tags == (\"BATCH\",)\n498\t        action, after_action = _extract_action_tag(after_flags)\n499\t        assert action == (\"run_cli\", \"mcloop --dry-run\")\n500\t        assert after_action == \"\"\n501\t\n502\t    def test_flags_and_plain_text(self) -> None:\n503\t        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n504\t        assert ann == ()\n505\t        tags, after_flags = _extract_flag_tags(after_ann)\n506\t        assert tags == (\"USER\", \"BATCH\")\n507\t        action, after_action = _extract_action_tag(after_flags)\n508\t        assert action is None\n509\t        assert after_action == \"verify thing\"\n510\t\n511\t    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n512\t        text = \"Implement [USER] and [AUTO:run] tokenization\"\n513\t        ann, after_ann = _extract_annotations(text)\n514\t        tags, after_flags = _extract_flag_tags(after_ann)\n515\t        action, after_action = _extract_action_tag(after_flags)\n516\t        assert ann == ()\n517\t        assert tags == ()\n518\t        assert action is None\n519\t        assert after_action == text\n520\t\n521\t\n522\tclass TestParsePlanStateMachine:\n523\t    \"\"\"End-to-end tests for the parse_plan walker.\n524\t\n525\t    The state machine in 2.5.2 is responsible for the section-vs-task\n526\t    bookkeeping that earlier building blocks do not own: routing tasks\n527\t    into the right phase or subsection, opening/closing the indent\n528\t    stack at phase/subsection/bugs boundaries, and dispatching ``@deps``\n529\t    and ``[RULEDOUT]`` siblings to the parent task. Tests below\n530\t    exercise each of those responsibilities independently and then in\n531\t    combination on a small but representative plan.\n532\t    \"\"\"\n533\t\n534\t    def test_empty_text_returns_empty_plan(self) -> None:\n535\t        plan = parse_plan(\"\")\n536\t        assert plan.phases == ()\n537\t        assert plan.bugs is None\n538\t        assert plan.project_title == \"\"\n539\t\n540\t    def test_single_phase_with_tasks(self) -> None:\n541\t        text = \"## Stage 1: Core\\n\\n- [ ] first task\\n- [x] second task\\n\"\n542\t        plan = parse_plan(text)\n543\t        assert len(plan.phases) == 1\n544\t        phase = plan.phases[0]\n545\t        assert phase.ordinal == 1\n546\t        assert phase.keyword == \"Stage\"\n547\t        assert phase.title == \"Core\"\n548\t        assert phase.line_number == 1\n549\t        assert len(phase.tasks) == 2\n550\t        assert phase.tasks[0].text == \"first task\"\n551\t        assert phase.tasks[0].status is TaskStatus.TODO\n552\t        assert phase.tasks[0].line_number == 3\n553\t        assert phase.tasks[1].status is TaskStatus.DONE\n554\t\n555\t    def test_phase_heading_keyword_normalized(self) -> None:\n556\t        # \"Phase\" and \"Stage\" are accepted interchangeably and the\n557\t        # keyword captures which form was used (capitalized).\n558\t        plan = parse_plan(\"# Phase 2: Implementation\\n- [ ] x\\n\")\n559\t        assert plan.phases[0].keyword == \"Phase\"\n560\t        assert plan.phases[0].ordinal == 2\n561\t        assert plan.phases[0].title == \"Implementation\"\n562\t\n563\t    def test_phase_with_non_bare_digit_id_is_not_a_phase_heading(self) -> None:\n564\t        # `## Phase phase_001:` is the legacy strict-form heading; per\n565\t        # design doc section 2.5 it does NOT match the bare-digit\n566\t        # STAGE_RE and so is invisible to the compat parser. The tasks\n567\t        # that follow have no enclosing phase and are dropped.\n568\t        text = \"## Phase phase_001: Core\\n- [ ] orphan task\\n\"\n569\t        plan = parse_plan(text)\n570\t        assert plan.phases == ()\n571\t        assert plan.bugs is None\n572\t\n573\t    def test_indent_stack_builds_task_tree(self) -> None:\n574\t        text = (\n575\t            \"## Stage 1: Core\\n\"\n576\t            \"- [ ] parent\\n\"\n577\t            \"  - [ ] child a\\n\"\n578\t            \"    - [ ] grandchild\\n\"\n579\t            \"  - [ ] child b\\n\"\n580\t            \"- [ ] second root\\n\"\n581\t        )\n582\t        plan = parse_plan(text)\n583\t        phase = plan.phases[0]\n584\t        assert len(phase.tasks) == 2\n585\t        parent, second_root = phase.tasks\n586\t        assert parent.text == \"parent\"\n587\t        assert second_root.text == \"second root\"\n588\t        assert len(parent.children) == 2\n589\t        child_a, child_b = parent.children\n590\t        assert child_a.text == \"child a\"\n591\t        assert child_b.text == \"child b\"\n592\t        assert len(child_a.children) == 1\n593\t        assert child_a.children[0].text == \"grandchild\"\n594\t\n595\t    def test_subsection_captures_following_tasks(self) -> None:\n596\t        text = (\n597\t            \"## Stage 1: Core\\n\"\n598\t            \"- [ ] phase task\\n\"\n599\t            \"\\n\"\n600\t            \"### Manual verification\\n\"\n601\t            \"- [ ] sub task one\\n\"\n602\t            \"- [ ] sub task two\\n\"\n603\t        )\n604\t        plan = parse_plan(text)\n605\t        phase = plan.phases[0]\n606\t        assert len(phase.tasks) == 1\n607\t        assert phase.tasks[0].text == \"phase task\"\n608\t        assert len(phase.subsections) == 1\n609\t        sub = phase.subsections[0]\n610\t        assert sub.title == \"Manual verification\"\n611\t        assert tuple(t.text for t in sub.tasks) == (\"sub task one\", \"sub task two\")\n612\t\n613\t    def test_new_phase_resets_indent_stack(self) -> None:\n614\t        # An indented task in the second phase must be treated as a\n615\t        # root of that phase, not as a child of the previous phase's\n616\t        # last task. (mcloop's parser does this via stack.clear().)\n617\t        text = (\n618\t            \"## Stage 1: A\\n- [ ] one\\n  - [ ] one-child\\n## Stage 2: B\\n  - [ ] two\\n\"\n619\t        )\n620\t        plan = parse_plan(text)\n621\t        assert len(plan.phases) == 2\n622\t        assert len(plan.phases[0].tasks) == 1\n623\t        assert plan.phases[0].tasks[0].children[0].text == \"one-child\"\n624\t        assert len(plan.phases[1].tasks) == 1\n625\t        assert plan.phases[1].tasks[0].text == \"two\"\n626\t        assert plan.phases[1].tasks[0].children == ()\n627\t\n628\t    def test_bugs_section_collects_tasks(self) -> None:\n629\t        text = (\n630\t            \"## Stage 1: Core\\n\"\n631\t            \"- [ ] phase task\\n\"\n632\t            \"## Bugs\\n\"\n633\t            \"- [ ] crash on empty input\\n\"\n634\t            \"- [x] fixed memory leak\\n\"\n635\t        )\n636\t        plan = parse_plan(text)\n637\t        assert plan.bugs is not None\n638\t        assert tuple(t.text for t in plan.bugs.tasks) == (\n639\t            \"crash on empty input\",\n640\t            \"fixed memory leak\",\n641\t        )\n642\t        # The phase still owns its own task; bugs is a peer section.\n643\t        assert plan.phases[0].tasks[0].text == \"phase task\"\n644\t\n645\t    def test_task_body_classification_is_applied(self) -> None:\n646\t        text = (\n647\t            \"## Stage 1: Core\\n\"\n648\t            '- [ ] T-000001: [BATCH] do thing [feat: \"x\"]\\n'\n649\t            \"- [ ] T-000002: [AUTO:run_cli] mcloop --dry-run\\n\"\n650\t        )\n651\t        plan = parse_plan(text)\n652\t        first, second = plan.phases[0].tasks\n653\t        assert first.task_id == \"T-000001\"\n654\t        assert first.flag_tags == (\"BATCH\",)\n655\t        assert first.annotations == ((\"feat\", '\"x\"'),)\n656\t        assert first.text == \"do thing\"\n657\t        assert second.task_id == \"T-000002\"\n658\t        assert second.action_tag == (\"run_cli\", \"mcloop --dry-run\")\n659\t        assert second.text == \"\"\n660\t\n661\t    def test_ruledout_attaches_to_parent_task(self) -> None:\n662\t        text = (\n663\t            \"## Stage 1: Core\\n\"\n664\t            \"- [ ] parent\\n\"\n665\t            \"  [RULEDOUT] tried restart\\n\"\n666\t            \"  [RULEDOUT] tried reinstall\\n\"\n667\t        )\n668\t        plan = parse_plan(text)\n669\t        parent = plan.phases[0].tasks[0]\n670\t        assert tuple(r.text for r in parent.ruled_out) == (\n671\t            \"tried restart\",\n672\t            \"tried reinstall\",\n673\t        )\n674\t\n675\t    def test_deps_attaches_to_preceding_task(self) -> None:\n676\t        text = (\n677\t            \"## Stage 1: Core\\n\"\n678\t            \"- [ ] T-000001: first\\n\"\n679\t            \"- [ ] T-000002: second\\n\"\n680\t            \"  @deps T-000001\\n\"\n681\t        )\n682\t        plan = parse_plan(text)\n683\t        first, second = plan.phases[0].tasks\n684\t        assert first.deps == ()\n685\t        assert second.deps == (\"T-000001\",)\n686\t\n687\t    def test_combined_phase_subsection_bugs_round_trip_structure(self) -> None:\n688\t        text = (\n689\t            \"## Stage 1: Core\\n\"\n690\t            \"- [ ] T-000001: [BATCH] parent\\n\"\n691\t            \"  - [ ] T-000002: child a\\n\"\n692\t            \"    [RULEDOUT] tried polling\\n\"\n693\t            \"  - [ ] T-000003: child b\\n\"\n694\t            \"    @deps T-000002\\n\"\n695\t            \"\\n\"\n696\t            \"### Manual verification\\n\"\n697\t            \"- [ ] T-000004: [USER] run smoke test\\n\"\n698\t            \"\\n\"\n699\t            \"## Bugs\\n\"\n700\t            \"- [ ] T-000009: crash on empty PLAN.md\\n\"\n701\t        )\n702\t        plan = parse_plan(text)\n703\t        assert len(plan.phases) == 1\n704\t        phase = plan.phases[0]\n705\t        parent = phase.tasks[0]\n706\t        assert parent.task_id == \"T-000001\"\n707\t        assert parent.flag_tags == (\"BATCH\",)\n708\t        child_a, child_b = parent.children\n709\t        assert child_a.task_id == \"T-000002\"\n710\t        assert tuple(r.text for r in child_a.ruled_out) == (\"tried polling\",)\n711\t        assert child_b.deps == (\"T-000002\",)\n712\t        assert len(phase.subsections) == 1\n713\t        manual = phase.subsections[0]\n714\t        assert manual.title == \"Manual verification\"\n715\t        assert manual.tasks[0].flag_tags == (\"USER\",)\n716\t        assert plan.bugs is not None\n717\t        assert plan.bugs.tasks[0].task_id == \"T-000009\"\n718\t\n719\t    def test_tasks_before_any_section_are_dropped_in_compat_mode(self) -> None:\n720\t        # No phase or bugs heading has been seen yet, so a task line is\n721\t        # an orphan. Compat mode drops silently; strict mode (2.5.4)\n722\t        # will surface this as a PlanSyntaxError. Either way no tasks\n723\t        # appear on the resulting Plan.\n724\t        plan = parse_plan(\"- [ ] orphan\\n## Stage 1: Core\\n- [ ] real\\n\")\n725\t        assert len(plan.phases) == 1\n726\t        assert tuple(t.text for t in plan.phases[0].tasks) == (\"real\",)\n727\t\n728\t    def test_source_path_passes_through(self) -> None:\n729\t        from pathlib import Path\n730\t\n731\t        path = Path(\"/tmp/PLAN.md\")\n732\t        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\", source_path=path)\n733\t        assert plan.source_path == path\n734\t"}]},"parent_tool_use_id":null,"session_id":"17f18e8b-2608-44d2-8d2d-3883ebd2b7ba","uuid":"7afbfbbf-332b-4d53-b0ba-f22dc3037d65","timestamp":"2026-05-16T02:47:28.793Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"\"\"\"Tests for bob_tools.planfile.parser building blocks.\n\nStage 2 task-line recognizers and tag extractors:\n\n  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n  - ``_parse_task_line`` returns a raw record on checkbox lines and\n    ``None`` on anything else.\n  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n    sibling lines and returns indent, body, and source line number.\n  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n    line: nearest strictly-less-indented open ancestor, with fallback\n    to the most recent root task (mcloop's ``parse`` parity). The\n    parse-then-attach composition test confirms multiple RULEDOUT\n    lines on one task are collected in source order.\n  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n    enforces that at least one ID follows the keyword.\n  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n    sibling line: the innermost open ancestor at strictly-less indent\n    is the strict-form parent; an ancestor at equal indent is the\n    lenient-form parent (caller should warn). No root-task fallback.\n    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n    tokens, in isolation and combination, and leaves non-leading\n    occurrences as prose (design doc section 4.3).\n  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n    treats the rest of the line as its argument string; non-leading\n    occurrences are prose.\n  - ``_extract_annotations`` consumes trailing ``[key: value]``\n    annotations, handles multiple annotations and nested brackets in\n    values, and leaves bracketed prose that is not separated from\n    preceding text by whitespace in place.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\n\nimport pytest\n\nfrom bob_tools.planfile.model import TaskStatus\nfrom bob_tools.planfile.parser import (\n    _CHECKBOX_RE,\n    _DEPS_RE,\n    _attach_deps,\n    _attach_ruledout,\n    _extract_action_tag,\n    _extract_annotations,\n    _extract_flag_tags,\n    _parse_ruledout_line,\n    _parse_task_line,\n    parse_plan,\n)\n\n\n@dataclass\nclass _FakeTask:\n    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n\n    indent_level: int\n    name: str = \"\"\n\n\nclass TestCheckboxRe:\n    @pytest.mark.parametrize(\n        (\"line\", \"indent\", \"marker\", \"text\"),\n        [\n            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n        ],\n    )\n    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n        m = _CHECKBOX_RE.match(line)\n        assert m is not None\n        assert m.group(1) == indent\n        assert m.group(2) == marker\n        assert m.group(3) == text\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"## Stage 1: Core\",\n            \"- [] missing space inside brackets\",\n            \"- [y] unsupported marker\",\n            \"- [ ]\",\n            \"* [ ] wrong bullet\",\n            \"Plain prose line\",\n        ],\n    )\n    def test_non_matches(self, line: str) -> None:\n        assert _CHECKBOX_RE.match(line) is None\n\n\nclass TestParseTaskLine:\n    def test_match_returns_raw_record(self) -> None:\n        rec = _parse_task_line(\"  - [x] foo\", 7)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.status_char == \"x\"\n        assert rec.text == \"foo\"\n        assert rec.line_number == 7\n\n    def test_match_failed_marker(self) -> None:\n        rec = _parse_task_line(\"- [!] bad\", 12)\n        assert rec is not None\n        assert rec.status_char == \"!\"\n        assert rec.line_number == 12\n\n    def test_non_task_returns_none(self) -> None:\n        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n        assert _parse_task_line(\"\", 2) is None\n        assert _parse_task_line(\"Some prose\", 3) is None\n\n\nclass TestParseRuledOutLine:\n    def test_indented_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.text == \"tried restart\"\n        assert rec.line_number == 5\n\n    def test_top_level_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n        assert rec is not None\n        assert rec.indent == \"\"\n        assert rec.text == \"orphan approach\"\n\n    def test_empty_body(self) -> None:\n        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n        assert rec is not None\n        assert rec.indent == \"    \"\n        assert rec.text == \"\"\n\n    def test_trailing_whitespace_stripped(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n        assert rec is not None\n        assert rec.text == \"foo\"\n\n    def test_non_leading_token_is_not_match(self) -> None:\n        # A RULEDOUT token that appears mid-line is prose, not a\n        # RULEDOUT line. Only the leading-position form is recognized.\n        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n\n    def test_similar_token_does_not_match(self) -> None:\n        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n        # immediately after the keyword.\n        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n\n    def test_non_ruledout_lines_return_none(self) -> None:\n        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n        assert _parse_ruledout_line(\"\", 2) is None\n        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n\n\nclass TestAttachRuledOut:\n    def test_nearest_strict_less_indent_wins(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        grand = _FakeTask(indent_level=4, name=\"grand\")\n        # RULEDOUT at indent 4 sits as a sibling under `child`\n        # (indent 2): it attaches to `child`, not to `grand` even\n        # though `grand` is deeper in the stack.\n        attached = _attach_ruledout(4, [root, child, grand], [root])\n        assert attached is child\n\n    def test_skips_equal_indent_in_stack(self) -> None:\n        # Equal indent is not \"strictly less\", so the equal-indent\n        # entry is skipped and the search continues outward.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        same = _FakeTask(indent_level=2, name=\"same\")\n        attached = _attach_ruledout(2, [root, same], [root])\n        assert attached is root\n\n    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n        # A column-0 RULEDOUT after the stack has been popped (e.g.\n        # following a same-indent sibling) finds no strictly-less\n        # ancestor, so it attaches to the last root task.\n        a = _FakeTask(indent_level=0, name=\"a\")\n        b = _FakeTask(indent_level=0, name=\"b\")\n        attached = _attach_ruledout(0, [], [a, b])\n        assert attached is b\n\n    def test_no_ancestors_no_roots_returns_none(self) -> None:\n        # A stray [RULEDOUT] before any task in the phase has nothing\n        # to attach to; the caller is expected to drop it.\n        assert _attach_ruledout(0, [], []) is None\n\n    def test_empty_stack_uses_root_fallback(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        attached = _attach_ruledout(2, [], [root])\n        assert attached is root\n\n    def test_multiple_ruledouts_on_one_task_collected_in_order(self) -> None:\n        # Compose the building blocks the orchestration layer will use:\n        # parse each [RULEDOUT] line, route it to its parent via\n        # _attach_ruledout, then append to the parent's list. Three\n        # sibling RULEDOUTs at the child indent must all land on the\n        # same parent and stay in source order.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        stack = [root, child]\n        roots = [root]\n\n        lines = [\n            (\"    [RULEDOUT] first approach\", 10),\n            (\"    [RULEDOUT] second approach\", 11),\n            (\"    [RULEDOUT] third approach\", 12),\n        ]\n        collected: dict[str, list[tuple[str, int]]] = {}\n        for raw_line, line_number in lines:\n            rec = _parse_ruledout_line(raw_line, line_number)\n            assert rec is not None\n            target = _attach_ruledout(len(rec.indent), stack, roots)\n            assert target is child\n            collected.setdefault(target.name, []).append((rec.text, rec.line_number))\n\n        assert collected == {\n            \"child\": [\n                (\"first approach\", 10),\n                (\"second approach\", 11),\n                (\"third approach\", 12),\n            ],\n        }\n\n\nclass TestDepsRe:\n    def test_single_id(self) -> None:\n        m = _DEPS_RE.match(\"@deps T-000001\")\n        assert m is not None\n        assert m.group(1) == \"\"\n        assert m.group(2).split() == [\"T-000001\"]\n\n    def test_multiple_ids(self) -> None:\n        m = _DEPS_RE.match(\"@deps T-000001 T-000002 T-000003\")\n        assert m is not None\n        assert m.group(1) == \"\"\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\", \"T-000003\"]\n\n    def test_indented_captures_indent(self) -> None:\n        m = _DEPS_RE.match(\"    @deps T-000001 T-000002\")\n        assert m is not None\n        assert m.group(1) == \"    \"\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n\n    def test_extra_inter_id_whitespace_collapses_on_split(self) -> None:\n        # Variable spacing between IDs is normalized by str.split().\n        m = _DEPS_RE.match(\"@deps T-000001    T-000002\")\n        assert m is not None\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"- [ ] regular task\",\n            \"@dep T-000001\",\n            \"@deps\",\n            \"@deps \",\n            \" @deps_ T-000001\",\n        ],\n    )\n    def test_non_deps_lines(self, line: str) -> None:\n        assert _DEPS_RE.match(line) is None\n\n\nclass TestAttachDeps:\n    def test_strict_form_deps_indented_under_parent(self) -> None:\n        # Canonical form: @deps is indented strictly more than the\n        # task it references. Parent's indent is strictly less than\n        # the deps line's, so attachment is strict (no warning).\n        parent = _FakeTask(indent_level=0, name=\"parent\")\n        target, lenient = _attach_deps(2, [parent])\n        assert target is parent\n        assert lenient is False\n\n    def test_lenient_form_same_indent_warns(self) -> None:\n        # \"Forgot to indent\" form: @deps at the same indent as its\n        # task. Still attaches, but flagged as lenient so callers can\n        # emit a validation warning.\n        parent = _FakeTask(indent_level=0, name=\"parent\")\n        target, lenient = _attach_deps(0, [parent])\n        assert target is parent\n        assert lenient is True\n\n    def test_strict_attaches_to_innermost_ancestor(self) -> None:\n        # With multiple open ancestors the innermost strictly-less-\n        # indented one wins — not the outermost.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(4, [outer, inner])\n        assert target is inner\n        assert lenient is False\n\n    def test_lenient_uses_top_of_stack_at_same_indent(self) -> None:\n        # Top of stack is at deps' indent — lenient attachment to the\n        # immediately preceding task.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(2, [outer, inner])\n        assert target is inner\n        assert lenient is True\n\n    def test_outdented_deps_walks_past_deeper_top(self) -> None:\n        # The most recent task is more indented than @deps, so it is\n        # skipped; the search continues outward and lands on the\n        # equal-indent ancestor as a lenient match.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(0, [outer, inner])\n        assert target is outer\n        assert lenient is True\n\n    def test_empty_stack_returns_none(self) -> None:\n        # A @deps line before any task in scope has nothing to attach\n        # to — the caller is expected to drop it. No root-task fallback\n        # is provided, unlike _attach_ruledout.\n        target, lenient = _attach_deps(0, [])\n        assert target is None\n        assert lenient is False\n\n    def test_all_ancestors_more_indented_returns_none(self) -> None:\n        # Pathological: deps outdented past every known ancestor.\n        # Stack-walk finds no candidate at lesser-or-equal indent.\n        deep = _FakeTask(indent_level=4, name=\"deep\")\n        target, lenient = _attach_deps(2, [deep])\n        assert target is None\n        assert lenient is False\n\n    def test_parse_and_attach_to_nested_subtask(self) -> None:\n        # Compose _DEPS_RE with _attach_deps: a deeply-indented @deps\n        # line resolves to the innermost open ancestor at strictly-less\n        # indent — i.e. the nested subtask, not the root task. This is\n        # the end-to-end shape the higher-level parser will use.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        grand = _FakeTask(indent_level=4, name=\"grand\")\n        stack = [root, child, grand]\n\n        m = _DEPS_RE.match(\"      @deps T-000001 T-000002\")\n        assert m is not None\n        indent = len(m.group(1))\n        ids = m.group(2).split()\n\n        target, lenient = _attach_deps(indent, stack)\n        assert target is grand\n        assert lenient is False\n        assert ids == [\"T-000001\", \"T-000002\"]\n\n\nclass TestExtractFlagTags:\n    def test_no_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"plain task text\")\n        assert tags == ()\n        assert rest == \"plain task text\"\n\n    def test_user(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n        assert tags == (\"USER\",)\n        assert rest == \"verify the menu\"\n\n    def test_batch(self) -> None:\n        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n        assert tags == (\"BATCH\",)\n        assert rest == \"sub-task group\"\n\n    def test_user_and_batch_combined(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"both flags\"\n\n    def test_adjacent_tags_without_separator(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"no gap\"\n\n    def test_non_leading_tag_is_prose(self) -> None:\n        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n        assert tags == ()\n        assert rest == \"Document the [USER] tag\"\n\n    def test_only_first_run_is_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n        assert tags == (\"USER\",)\n        assert rest == \"middle [BATCH] later\"\n\n    def test_empty_input(self) -> None:\n        tags, rest = _extract_flag_tags(\"\")\n        assert tags == ()\n        assert rest == \"\"\n\n\nclass TestExtractActionTag:\n    def test_no_action_tag(self) -> None:\n        tag, rest = _extract_action_tag(\"plain task text\")\n        assert tag is None\n        assert rest == \"plain task text\"\n\n    def test_action_with_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n        assert rest == \"\"\n\n    def test_action_without_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n        assert tag == (\"noop\", \"\")\n        assert rest == \"\"\n\n    def test_args_extend_to_end_of_line(self) -> None:\n        # Argument string is text from closing bracket to end of line;\n        # bracketed-looking content in args stays in args.\n        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n        assert tag == (\"run\", \"do [feat: x]\")\n        assert rest == \"\"\n\n    def test_non_leading_auto_is_prose(self) -> None:\n        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n        assert tag is None\n        assert rest == \"Document the [AUTO:run] tag\"\n\n\nclass TestExtractAnnotations:\n    def test_no_annotation(self) -> None:\n        ann, rest = _extract_annotations(\"plain task text\")\n        assert ann == ()\n        assert rest == \"plain task text\"\n\n    def test_single_feat(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n        assert ann == ((\"feat\", '\"menu wired\"'),)\n        assert rest == \"do thing\"\n\n    def test_single_fix(self) -> None:\n        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n        assert ann == ((\"fix\", '\"race\"'),)\n        assert rest == \"fixed it\"\n\n    def test_multiple_annotations_preserve_order(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n        assert ann == (\n            (\"feat\", '\"first\"'),\n            (\"fix\", '\"second\"'),\n        )\n        assert rest == \"do thing\"\n\n    def test_nested_brackets_in_value(self) -> None:\n        # Balanced brackets inside the value are stepped over by the\n        # right-to-left depth scan and stay inside the annotation.\n        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n        assert rest == \"do thing\"\n\n    def test_unquoted_nested_brackets_in_value(self) -> None:\n        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n        assert ann == ((\"feat\", \"a [b] c\"),)\n        assert rest == \"do\"\n\n    def test_prose_bracket_without_separator_is_text(self) -> None:\n        # A `[` abutting a non-whitespace character is task text, not\n        # the start of an annotation.\n        ann, rest = _extract_annotations(\"see config[feat: x]\")\n        assert ann == ()\n        assert rest == \"see config[feat: x]\"\n\n    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n        # `[AUTO:run]` has no whitespace after its colon and so is not\n        # an annotation under this extractor's rules.\n        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n        assert ann == ()\n        assert rest == \"[AUTO:run] cmd\"\n\n    def test_unmatched_open_bracket(self) -> None:\n        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n        assert ann == ()\n        assert rest == \"dangling brackets feat ]\"\n\n    def test_annotation_alone_consumes_to_empty(self) -> None:\n        ann, rest = _extract_annotations('[feat: \"lone\"]')\n        assert ann == ((\"feat\", '\"lone\"'),)\n        assert rest == \"\"\n\n\nclass TestTagInteractions:\n    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n        # Annotation must be stripped before action tag, because action\n        # tag args span to end of line.\n        ann, after_ann = _extract_annotations(text)\n        assert ann == ((\"feat\", '\"done\"'),)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"BATCH\",)\n        action, after_action = _extract_action_tag(after_flags)\n        assert action == (\"run_cli\", \"mcloop --dry-run\")\n        assert after_action == \"\"\n\n    def test_flags_and_plain_text(self) -> None:\n        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n        assert ann == ()\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"USER\", \"BATCH\")\n        action, after_action = _extract_action_tag(after_flags)\n        assert action is None\n        assert after_action == \"verify thing\"\n\n    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n        text = \"Implement [USER] and [AUTO:run] tokenization\"\n        ann, after_ann = _extract_annotations(text)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        action, after_action = _extract_action_tag(after_flags)\n        assert ann == ()\n        assert tags == ()\n        assert action is None\n        assert after_action == text\n\n\nclass TestParsePlanStateMachine:\n    \"\"\"End-to-end tests for the parse_plan walker.\n\n    The state machine in 2.5.2 is responsible for the section-vs-task\n    bookkeeping that earlier building blocks do not own: routing tasks\n    into the right phase or subsection, opening/closing the indent\n    stack at phase/subsection/bugs boundaries, and dispatching ``@deps``\n    and ``[RULEDOUT]`` siblings to the parent task. Tests below\n    exercise each of those responsibilities independently and then in\n    combination on a small but representative plan.\n    \"\"\"\n\n    def test_empty_text_returns_empty_plan(self) -> None:\n        plan = parse_plan(\"\")\n        assert plan.phases == ()\n        assert plan.bugs is None\n        assert plan.project_title == \"\"\n\n    def test_single_phase_with_tasks(self) -> None:\n        text = \"## Stage 1: Core\\n\\n- [ ] first task\\n- [x] second task\\n\"\n        plan = parse_plan(text)\n        assert len(plan.phases) == 1\n        phase = plan.phases[0]\n        assert phase.ordinal == 1\n        assert phase.keyword == \"Stage\"\n        assert phase.title == \"Core\"\n        assert phase.line_number == 1\n        assert len(phase.tasks) == 2\n        assert phase.tasks[0].text == \"first task\"\n        assert phase.tasks[0].status is TaskStatus.TODO\n        assert phase.tasks[0].line_number == 3\n        assert phase.tasks[1].status is TaskStatus.DONE\n\n    def test_phase_heading_keyword_normalized(self) -> None:\n        # \"Phase\" and \"Stage\" are accepted interchangeably and the\n        # keyword captures which form was used (capitalized).\n        plan = parse_plan(\"# Phase 2: Implementation\\n- [ ] x\\n\")\n        assert plan.phases[0].keyword == \"Phase\"\n        assert plan.phases[0].ordinal == 2\n        assert plan.phases[0].title == \"Implementation\"\n\n    def test_phase_with_non_bare_digit_id_is_not_a_phase_heading(self) -> None:\n        # `## Phase phase_001:` is the legacy strict-form heading; per\n        # design doc section 2.5 it does NOT match the bare-digit\n        # STAGE_RE and so is invisible to the compat parser. The tasks\n        # that follow have no enclosing phase and are dropped.\n        text = \"## Phase phase_001: Core\\n- [ ] orphan task\\n\"\n        plan = parse_plan(text)\n        assert plan.phases == ()\n        assert plan.bugs is None\n\n    def test_indent_stack_builds_task_tree(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] parent\\n\"\n            \"  - [ ] child a\\n\"\n            \"    - [ ] grandchild\\n\"\n            \"  - [ ] child b\\n\"\n            \"- [ ] second root\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert len(phase.tasks) == 2\n        parent, second_root = phase.tasks\n        assert parent.text == \"parent\"\n        assert second_root.text == \"second root\"\n        assert len(parent.children) == 2\n        child_a, child_b = parent.children\n        assert child_a.text == \"child a\"\n        assert child_b.text == \"child b\"\n        assert len(child_a.children) == 1\n        assert child_a.children[0].text == \"grandchild\"\n\n    def test_subsection_captures_following_tasks(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] phase task\\n\"\n            \"\\n\"\n            \"### Manual verification\\n\"\n            \"- [ ] sub task one\\n\"\n            \"- [ ] sub task two\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert len(phase.tasks) == 1\n        assert phase.tasks[0].text == \"phase task\"\n        assert len(phase.subsections) == 1\n        sub = phase.subsections[0]\n        assert sub.title == \"Manual verification\"\n        assert tuple(t.text for t in sub.tasks) == (\"sub task one\", \"sub task two\")\n\n    def test_new_phase_resets_indent_stack(self) -> None:\n        # An indented task in the second phase must be treated as a\n        # root of that phase, not as a child of the previous phase's\n        # last task. (mcloop's parser does this via stack.clear().)\n        text = (\n            \"## Stage 1: A\\n- [ ] one\\n  - [ ] one-child\\n## Stage 2: B\\n  - [ ] two\\n\"\n        )\n        plan = parse_plan(text)\n        assert len(plan.phases) == 2\n        assert len(plan.phases[0].tasks) == 1\n        assert plan.phases[0].tasks[0].children[0].text == \"one-child\"\n        assert len(plan.phases[1].tasks) == 1\n        assert plan.phases[1].tasks[0].text == \"two\"\n        assert plan.phases[1].tasks[0].children == ()\n\n    def test_bugs_section_collects_tasks(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] phase task\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] crash on empty input\\n\"\n            \"- [x] fixed memory leak\\n\"\n        )\n        plan = parse_plan(text)\n        assert plan.bugs is not None\n        assert tuple(t.text for t in plan.bugs.tasks) == (\n            \"crash on empty input\",\n            \"fixed memory leak\",\n        )\n        # The phase still owns its own task; bugs is a peer section.\n        assert plan.phases[0].tasks[0].text == \"phase task\"\n\n    def test_task_body_classification_is_applied(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            '- [ ] T-000001: [BATCH] do thing [feat: \"x\"]\\n'\n            \"- [ ] T-000002: [AUTO:run_cli] mcloop --dry-run\\n\"\n        )\n        plan = parse_plan(text)\n        first, second = plan.phases[0].tasks\n        assert first.task_id == \"T-000001\"\n        assert first.flag_tags == (\"BATCH\",)\n        assert first.annotations == ((\"feat\", '\"x\"'),)\n        assert first.text == \"do thing\"\n        assert second.task_id == \"T-000002\"\n        assert second.action_tag == (\"run_cli\", \"mcloop --dry-run\")\n        assert second.text == \"\"\n\n    def test_ruledout_attaches_to_parent_task(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] parent\\n\"\n            \"  [RULEDOUT] tried restart\\n\"\n            \"  [RULEDOUT] tried reinstall\\n\"\n        )\n        plan = parse_plan(text)\n        parent = plan.phases[0].tasks[0]\n        assert tuple(r.text for r in parent.ruled_out) == (\n            \"tried restart\",\n            \"tried reinstall\",\n        )\n\n    def test_deps_attaches_to_preceding_task(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] T-000001: first\\n\"\n            \"- [ ] T-000002: second\\n\"\n            \"  @deps T-000001\\n\"\n        )\n        plan = parse_plan(text)\n        first, second = plan.phases[0].tasks\n        assert first.deps == ()\n        assert second.deps == (\"T-000001\",)\n\n    def test_combined_phase_subsection_bugs_round_trip_structure(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] T-000001: [BATCH] parent\\n\"\n            \"  - [ ] T-000002: child a\\n\"\n            \"    [RULEDOUT] tried polling\\n\"\n            \"  - [ ] T-000003: child b\\n\"\n            \"    @deps T-000002\\n\"\n            \"\\n\"\n            \"### Manual verification\\n\"\n            \"- [ ] T-000004: [USER] run smoke test\\n\"\n            \"\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] T-000009: crash on empty PLAN.md\\n\"\n        )\n        plan = parse_plan(text)\n        assert len(plan.phases) == 1\n        phase = plan.phases[0]\n        parent = phase.tasks[0]\n        assert parent.task_id == \"T-000001\"\n        assert parent.flag_tags == (\"BATCH\",)\n        child_a, child_b = parent.children\n        assert child_a.task_id == \"T-000002\"\n        assert tuple(r.text for r in child_a.ruled_out) == (\"tried polling\",)\n        assert child_b.deps == (\"T-000002\",)\n        assert len(phase.subsections) == 1\n        manual = phase.subsections[0]\n        assert manual.title == \"Manual verification\"\n        assert manual.tasks[0].flag_tags == (\"USER\",)\n        assert plan.bugs is not None\n        assert plan.bugs.tasks[0].task_id == \"T-000009\"\n\n    def test_tasks_before_any_section_are_dropped_in_compat_mode(self) -> None:\n        # No phase or bugs heading has been seen yet, so a task line is\n        # an orphan. Compat mode drops silently; strict mode (2.5.4)\n        # will surface this as a PlanSyntaxError. Either way no tasks\n        # appear on the resulting Plan.\n        plan = parse_plan(\"- [ ] orphan\\n## Stage 1: Core\\n- [ ] real\\n\")\n        assert len(plan.phases) == 1\n        assert tuple(t.text for t in plan.phases[0].tasks) == (\"real\",)\n\n    def test_source_path_passes_through(self) -> None:\n        from pathlib import Path\n\n        path = Path(\"/tmp/PLAN.md\")\n        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\", source_path=path)\n        assert plan.source_path == path\n","numLines":734,"startLine":1,"totalLines":734}}}
