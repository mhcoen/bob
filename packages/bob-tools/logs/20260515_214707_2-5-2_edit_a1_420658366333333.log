{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017nEXQYF8WKRDwHBvGGKcb2","type":"tool_result","content":"1\t\"\"\"Markdown checklist parser. Reads and writes `- [ ]` items.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom dataclasses import dataclass, field\n7\tfrom pathlib import Path\n8\t\n9\tCHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n10\t# Section headers: any heading level (# or more) whose title contains\n11\t# \"Stage N\" or \"Phase N\" anywhere in the line. The number is captured.\n12\tSTAGE_RE = re.compile(r\"^#+\\s+.*?\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n13\t# Bugs header: any heading level followed by \"Bugs\" as the title.\n14\tBUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n15\t# H1 headers (single `#` followed by space). Used by the structural\n16\t# sanity check to detect duplicated top-level headings (a hallmark\n17\t# corruption pattern in PLAN.md files that have been bad-edited).\n18\t_H1_RE = re.compile(r\"^#\\s+(.+)$\")\n19\t# Pattern for extracting a stage/phase number from a stage string\n20\t# (the header text with leading # and whitespace stripped).\n21\t_STAGE_NUM_RE = re.compile(r\"\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n22\t_USER_TAG = \"[USER]\"\n23\t_BATCH_TAG = \"[BATCH]\"\n24\t_AUTO_TAG_RE = re.compile(r\"\\[AUTO:(\\w+)\\]\")\n25\t\n26\t\n27\tclass PlanCorruptionError(Exception):\n28\t    \"\"\"Raised when parse() detects structural corruption in a checklist.\n29\t\n30\t    The check is conservative: only flags anomalies that are very\n31\t    unlikely to be intentional (duplicate top-level headings, multiple\n32\t    ``## Bugs`` sections, repeated phase/stage numbers). Auto-fixing\n33\t    is deliberately not attempted; an attempt to silently \"correct\"\n34\t    structural corruption is exactly the operation that produces it.\n35\t\n36\t    Callers that intentionally pass malformed input (tests, dry-run\n37\t    inspection of an in-progress edit) can pass ``check_structure=False``\n38\t    to ``parse()``.\n39\t    \"\"\"\n40\t\n41\t\n42\t@dataclass\n43\tclass Task:\n44\t    text: str\n45\t    checked: bool\n46\t    failed: bool\n47\t    line_number: int\n48\t    indent_level: int\n49\t    stage: str = \"\"\n50\t    children: list[Task] = field(default_factory=list)\n51\t    eliminated: list[str] = field(default_factory=list)\n52\t\n53\t\n54\tdef count_unchecked(tasks: list[Task]) -> int:\n55\t    \"\"\"Recursively count unchecked, non-failed tasks.\"\"\"\n56\t    n = 0\n57\t    for t in tasks:\n58\t        if not t.checked and not t.failed:\n59\t            n += 1\n60\t        n += count_unchecked(t.children)\n61\t    return n\n62\t\n63\t\n64\tdef parse_description(path: str | Path) -> str:\n65\t    \"\"\"Extract prose before the first checkbox as a project description.\"\"\"\n66\t    lines = Path(path).read_text().splitlines()\n67\t    desc_lines = []\n68\t    for line in lines:\n69\t        if CHECKBOX_RE.match(line):\n70\t            break\n71\t        desc_lines.append(line)\n72\t    return \"\\n\".join(desc_lines).strip()\n73\t\n74\t\n75\tdef _check_structural_sanity(lines: list[str], path: str | Path) -> None:\n76\t    \"\"\"Scan a checklist file for structural corruption signals.\n77\t\n78\t    Three anomalies are flagged. Each has been observed in real\n79\t    PLAN.md corruption incidents and none has a legitimate use:\n80\t\n81\t    1. Duplicate H1 headings with identical title text — typically\n82\t       indicates a botched insertion that left the original tail in\n83\t       place, producing two copies of the document's top header.\n84\t    2. Multiple ``## Bugs`` sections (any heading level) — there\n85\t       should only ever be one.\n86\t    3. Duplicate phase/stage numbers across stage headers — e.g. two\n87\t       different headers both numbered ``Phase 2``. This breaks\n88\t       ``task_label`` (which prefixes labels with the stage number)\n89\t       and almost always signals merged content from two attempts at\n90\t       the same phase.\n91\t\n92\t    Raises ``PlanCorruptionError`` listing every anomaly found, with\n93\t    line numbers, so the user can locate and fix the corruption.\n94\t    \"\"\"\n95\t    h1_titles: dict[str, list[int]] = {}\n96\t    bugs_lines: list[int] = []\n97\t    stage_nums: dict[str, list[int]] = {}\n98\t\n99\t    for i, line in enumerate(lines):\n100\t        # Order matters: STAGE_RE matches lines that are also H1s\n101\t        # (e.g. ``# Phase 1: Bootstrapping``). A header is either a\n102\t        # stage header OR a plain H1 OR a Bugs header — never two of\n103\t        # those at once. Check stage first so we don't double-count\n104\t        # ``# Phase N`` as both an H1 duplicate and a stage duplicate.\n105\t        stage_match = STAGE_RE.match(line)\n106\t        if stage_match:\n107\t            num = stage_match.group(1)\n108\t            stage_nums.setdefault(num, []).append(i)\n109\t            continue\n110\t\n111\t        if BUGS_RE.match(line):\n112\t            bugs_lines.append(i)\n113\t            continue\n114\t\n115\t        h1_match = _H1_RE.match(line)\n116\t        if h1_match:\n117\t            # Only single-# headings (true H1s). _H1_RE already enforces\n118\t            # this; check that it's not actually a deeper heading caught\n119\t            # by accident.\n120\t            if line.startswith(\"# \") and not line.startswith(\"## \"):\n121\t                title = h1_match.group(1).strip()\n122\t                h1_titles.setdefault(title, []).append(i)\n123\t\n124\t    problems: list[str] = []\n125\t\n126\t    for title, line_nums in h1_titles.items():\n127\t        if len(line_nums) > 1:\n128\t            locs = \", \".join(str(n + 1) for n in line_nums)\n129\t            problems.append(f\"duplicate top-level heading '# {title}' at lines {locs}\")\n130\t\n131\t    if len(bugs_lines) > 1:\n132\t        locs = \", \".join(str(n + 1) for n in bugs_lines)\n133\t        problems.append(f\"multiple Bugs sections at lines {locs}\")\n134\t\n135\t    for num, line_nums in stage_nums.items():\n136\t        if len(line_nums) > 1:\n137\t            locs = \", \".join(str(n + 1) for n in line_nums)\n138\t            problems.append(f\"duplicate Phase/Stage {num} at lines {locs}\")\n139\t\n140\t    if problems:\n141\t        joined = \"\\n  - \".join(problems)\n142\t        raise PlanCorruptionError(\n143\t            f\"Structural corruption detected in {path}:\\n  - {joined}\\n\"\n144\t            \"Fix the file manually. mcloop will not modify a corrupted\"\n145\t            \" PLAN.md because doing so risks compounding the corruption.\"\n146\t            \" If the apparent corruption is intentional, pass\"\n147\t            \" check_structure=False to parse().\"\n148\t        )\n149\t\n150\t\n151\tdef parse(path: str | Path, check_structure: bool = True) -> list[Task]:\n152\t    \"\"\"Read a markdown file and return a tree of Task objects.\n153\t\n154\t    Section headers are any markdown heading (``#``, ``##``, ...)\n155\t    whose title contains ``Stage N`` or ``Phase N`` anywhere in\n156\t    the line.  Tasks under such a header are tagged with the full\n157\t    header text (minus leading ``#`` and whitespace).  Tasks\n158\t    before any section header have stage ``\"\"``.\n159\t\n160\t    The ``## Bugs`` header (any heading level) is treated as a\n161\t    special section with stage ``\"Bugs\"``.\n162\t\n163\t    When ``check_structure`` is True (the default), the file is\n164\t    scanned for structural corruption first and ``PlanCorruptionError``\n165\t    is raised on detection. Set ``check_structure=False`` to skip\n166\t    the check (used by tests that intentionally pass malformed input).\n167\t    \"\"\"\n168\t    lines = Path(path).read_text().splitlines()\n169\t    if check_structure:\n170\t        _check_structural_sanity(lines, path)\n171\t    root_tasks: list[Task] = []\n172\t    stack: list[Task] = []\n173\t    current_stage = \"\"\n174\t\n175\t    for i, line in enumerate(lines):\n176\t        # Detect section headers (any heading level containing\n177\t        # \"Stage N\" or \"Phase N\")\n178\t        if STAGE_RE.match(line):\n179\t            current_stage = line.lstrip(\"#\").strip()\n180\t            stack.clear()\n181\t            continue\n182\t\n183\t        # Detect Bugs header (any heading level)\n184\t        if BUGS_RE.match(line):\n185\t            current_stage = \"Bugs\"\n186\t            stack.clear()\n187\t            continue\n188\t\n189\t        # Collect [RULEDOUT] lines and attach to the parent task.\n190\t        # The line's indentation determines which task it belongs to:\n191\t        # it attaches to the nearest task with strictly less indentation.\n192\t        stripped = line.strip()\n193\t        if stripped.startswith(\"[RULEDOUT]\"):\n194\t            elim_indent = len(line) - len(line.lstrip())\n195\t            for t in reversed(stack):\n196\t                if t.indent_level < elim_indent:\n197\t                    t.eliminated.append(stripped)\n198\t                    break\n199\t            else:\n200\t                # No parent found (top-level [RULEDOUT]), attach\n201\t                # to the most recent root task if one exists.\n202\t                if root_tasks:\n203\t                    root_tasks[-1].eliminated.append(stripped)\n204\t            continue\n205\t\n206\t        m = CHECKBOX_RE.match(line)\n207\t        if not m:\n208\t            continue\n209\t\n210\t        indent = len(m.group(1))\n211\t        marker = m.group(2)\n212\t        checked = marker in (\"x\", \"X\")\n213\t        failed = marker == \"!\"\n214\t        text = m.group(3).strip()\n215\t        task = Task(\n216\t            text=text,\n217\t            checked=checked,\n218\t            failed=failed,\n219\t            line_number=i,\n220\t            indent_level=indent,\n221\t            stage=current_stage,\n222\t        )\n223\t\n224\t        while stack and stack[-1].indent_level >= indent:\n225\t            stack.pop()\n226\t\n227\t        if stack:\n228\t            stack[-1].children.append(task)\n229\t        else:\n230\t            root_tasks.append(task)\n231\t\n232\t        stack.append(task)\n233\t\n234\t    return root_tasks\n235\t\n236\t\n237\tdef get_eliminated(tasks: list[Task], target: Task) -> list[str]:\n238\t    \"\"\"Collect all [RULEDOUT] entries for a task, including from ancestors.\n239\t\n240\t    Walks the task tree to find the target and collects eliminated\n241\t    entries from every ancestor along the path.\n242\t    \"\"\"\n243\t    result: list[str] = []\n244\t\n245\t    def _search(task_list: list[Task], inherited: list[str]) -> bool:\n246\t        for task in task_list:\n247\t            combined = inherited + task.eliminated\n248\t            if task is target:\n249\t                result.extend(combined)\n250\t                return True\n251\t            if task.children and _search(task.children, combined):\n252\t                return True\n253\t        return False\n254\t\n255\t    _search(tasks, [])\n256\t    return result\n257\t\n258\t\n259\tdef find_parent(tasks: list[Task], target: Task) -> Task | None:\n260\t    \"\"\"Find the parent of a target task in the tree.\n261\t\n262\t    Returns None if the target is a root task.\n263\t    \"\"\"\n264\t\n265\t    def _search(task_list: list[Task]) -> Task | None:\n266\t        for task in task_list:\n267\t            if target in task.children:\n268\t                return task\n269\t            found = _search(task.children)\n270\t            if found is not None:\n271\t                return found\n272\t        return None\n273\t\n274\t    return _search(tasks)\n275\t\n276\t\n277\tdef get_stages(tasks: list[Task]) -> list[str]:\n278\t    \"\"\"Return ordered list of unique stage names found in tasks.\n279\t\n280\t    Returns ``[]`` if no tasks have stage labels (flat plan).\n281\t    \"\"\"\n282\t    seen: set[str] = set()\n283\t    stages: list[str] = []\n284\t\n285\t    def _collect(task_list: list[Task]) -> None:\n286\t        for task in task_list:\n287\t            if task.stage and task.stage != \"Bugs\" and task.stage not in seen:\n288\t                seen.add(task.stage)\n289\t                stages.append(task.stage)\n290\t            _collect(task.children)\n291\t\n292\t    _collect(tasks)\n293\t    return stages\n294\t\n295\t\n296\tdef _stage_complete(tasks: list[Task], stage: str) -> bool:\n297\t    \"\"\"Return True if all tasks in the given stage are checked.\n298\t\n299\t    Failed tasks ([!]) do NOT count as complete. A stage with\n300\t    failed tasks is stuck, not done.\n301\t    \"\"\"\n302\t\n303\t    def _check(task_list: list[Task]) -> bool:\n304\t        for task in task_list:\n305\t            if task.stage == stage:\n306\t                if not task.checked:\n307\t                    return False\n308\t            if not _check(task.children):\n309\t                return False\n310\t        return True\n311\t\n312\t    return _check(tasks)\n313\t\n314\t\n315\tdef current_stage(tasks: list[Task]) -> str | None:\n316\t    \"\"\"Return the name of the first incomplete stage.\n317\t\n318\t    Returns ``None`` if all stages are complete or there are no\n319\t    stages.\n320\t    \"\"\"\n321\t    stages = get_stages(tasks)\n322\t    if not stages:\n323\t        return None\n324\t    for stage in stages:\n325\t        if not _stage_complete(tasks, stage):\n326\t            return stage\n327\t    return None\n328\t\n329\t\n330\tdef stage_status(tasks: list[Task]) -> str:\n331\t    \"\"\"Return a status string for the summary.\n332\t\n333\t    Possible values:\n334\t    - ``\"no_stages\"``: plan has no stage headers\n335\t    - ``\"in_progress\"``: stages exist but none completed yet\n336\t    - ``\"stage_complete:<name>\"``: a stage just finished,\n337\t      more stages remain\n338\t    - ``\"all_complete\"``: all stages are done\n339\t    \"\"\"\n340\t    stages = get_stages(tasks)\n341\t    if not stages:\n342\t        return \"no_stages\"\n343\t\n344\t    last_complete = None\n345\t    for stage in stages:\n346\t        if _stage_complete(tasks, stage):\n347\t            last_complete = stage\n348\t        else:\n349\t            if last_complete:\n350\t                return f\"stage_complete:{last_complete}\"\n351\t            return \"in_progress\"\n352\t\n353\t    return \"all_complete\"\n354\t\n355\t\n356\tdef _search_tasks(\n357\t    task_list: list[Task],\n358\t    *,\n359\t    is_subtask: bool = False,\n360\t    required_stage: str | None = None,\n361\t    skip_stages: set[str] | None = None,\n362\t) -> Task | None:\n363\t    \"\"\"Depth-first search for the next unchecked leaf task.\n364\t\n365\t    Shared logic used by both ``find_next`` and ``_search_in_stage``.\n366\t    *required_stage* restricts matches to tasks in that stage.\n367\t    *skip_stages* skips tasks in those stages.\n368\t    \"\"\"\n369\t    for task in task_list:\n370\t        # A failed subtask blocks all later siblings under the\n371\t        # same parent (implicit sequential dependency).\n372\t        # Root-level tasks are treated as independent.\n373\t        if task.failed:\n374\t            if is_subtask:\n375\t                return None\n376\t            continue\n377\t\n378\t        if task.checked:\n379\t            continue\n380\t\n381\t        if skip_stages and task.stage in skip_stages:\n382\t            continue\n383\t\n384\t        if required_stage is not None and task.stage != required_stage:\n385\t            continue\n386\t\n387\t        if task.children:\n388\t            child = _search_tasks(\n389\t                task.children,\n390\t                is_subtask=True,\n391\t                required_stage=required_stage,\n392\t                skip_stages=skip_stages,\n393\t            )\n394\t            if child:\n395\t                return child\n396\t            # Don't return the parent if any child failed;\n397\t            # the parent can never complete in that state.\n398\t            if any(c.failed for c in task.children):\n399\t                if is_subtask:\n400\t                    return None\n401\t                continue\n402\t            return task\n403\t\n404\t        return task\n405\t    return None\n406\t\n407\t\n408\tdef has_unchecked_bugs(tasks: list[Task]) -> bool:\n409\t    \"\"\"Return True if there are unchecked bug tasks.\n410\t\n411\t    Accepts any of these shapes:\n412\t    - Tasks under a ``## Bugs`` header (any heading level, any case).\n413\t    - A standalone bug file with no stage/phase headers: every\n414\t      unchecked task counts as a bug. This covers files with no\n415\t      header, a non-matching header (``## Known bugs``,\n416\t      ``## Open bugs``, ``# Bugs to fix``), or a bare checklist.\n417\t    \"\"\"\n418\t    if _search_in_stage(tasks, \"Bugs\") is not None:\n419\t        return True\n420\t    if get_stages(tasks):\n421\t        return False\n422\t\n423\t    def _any_unchecked(task_list: list[Task]) -> bool:\n424\t        for t in task_list:\n425\t            if not t.checked and not t.failed:\n426\t                return True\n427\t            if _any_unchecked(t.children):\n428\t                return True\n429\t        return False\n430\t\n431\t    return _any_unchecked(tasks)\n432\t\n433\t\n434\tdef find_next(tasks: list[Task]) -> Task | None:\n435\t    \"\"\"Depth-first search for the next unchecked leaf task.\n436\t\n437\t    Bug tasks (under ``## Bugs``) have absolute priority and are\n438\t    returned before any feature/stage tasks.\n439\t\n440\t    If the plan uses stages (``## Stage N:`` headers), only\n441\t    returns tasks from the first incomplete stage.  Returns\n442\t    ``None`` when the current stage is fully complete, even if\n443\t    later stages have unchecked tasks.\n444\t    \"\"\"\n445\t    # Priority: bug tasks first\n446\t    bug_task = _search_in_stage(tasks, \"Bugs\")\n447\t    if bug_task:\n448\t        return bug_task\n449\t\n450\t    active_stage = current_stage(tasks)\n451\t    has_stages = len(get_stages(tasks)) > 0\n452\t\n453\t    # Skip bug tasks (already handled above) and non-active stages\n454\t    skip_stages = {\"Bugs\"}\n455\t\n456\t    return _search_tasks(\n457\t        tasks,\n458\t        required_stage=active_stage if has_stages else None,\n459\t        skip_stages=skip_stages,\n460\t    )\n461\t\n462\t\n463\tdef _search_in_stage(tasks: list[Task], stage: str) -> Task | None:\n464\t    \"\"\"Search for the next unchecked leaf in a specific stage.\"\"\"\n465\t\n466\t    def _search(task_list: list[Task], is_subtask: bool = False) -> Task | None:\n467\t        return _search_tasks(task_list, is_subtask=is_subtask, required_stage=stage)\n468\t\n469\t    return _search(tasks)\n470\t\n471\t\n472\tdef _find_task_line(lines: list[str], task: Task) -> int:\n473\t    \"\"\"Find task line by line_number, falling back to text match.\n474\t\n475\t    Primary key is the line_number recorded at parse time.  If the\n476\t    file was modified between parse and check-off (e.g. Claude Code\n477\t    edited PLAN.md during execution), the stored line_number may be\n478\t    stale, so we fall back to searching by text.\n479\t    \"\"\"\n480\t    # Primary: use stored line_number if it still points to the right task.\n481\t    # Validate text, indent_level, and stage to detect stale line numbers\n482\t    # (e.g. file was edited externally and lines shifted).\n483\t    if task.line_number < len(lines):\n484\t        m = CHECKBOX_RE.match(lines[task.line_number])\n485\t        if m and m.group(3).strip() == task.text and len(m.group(1)) == task.indent_level:\n486\t            # Verify stage by scanning headers above this line\n487\t            line_stage = \"\"\n488\t            for j in range(task.line_number):\n489\t                if STAGE_RE.match(lines[j]):\n490\t                    line_stage = lines[j].lstrip(\"#\").strip()\n491\t                elif BUGS_RE.match(lines[j]):\n492\t                    line_stage = \"Bugs\"\n493\t            if line_stage == task.stage:\n494\t                return task.line_number\n495\t\n496\t    # Fallback: text search with indent_level and stage validation.\n497\t    # Track the current stage as we scan so we can disambiguate\n498\t    # duplicate task texts that appear in different stages or at\n499\t    # different indentation levels.\n500\t    # Collect all candidates and pick the one nearest to the original\n501\t    # line_number, preferring unchecked tasks.\n502\t    current_stage = \"\"\n503\t    unchecked: list[int] = []\n504\t    checked: list[int] = []\n505\t    for i, line in enumerate(lines):\n506\t        if STAGE_RE.match(line):\n507\t            current_stage = line.lstrip(\"#\").strip()\n508\t            continue\n509\t        if BUGS_RE.match(line):\n510\t            current_stage = \"Bugs\"\n511\t            continue\n512\t        m = CHECKBOX_RE.match(line)\n513\t        if not m or m.group(3).strip() != task.text:\n514\t            continue\n515\t        indent = len(m.group(1))\n516\t        if indent != task.indent_level:\n517\t            continue\n518\t        if current_stage != task.stage:\n519\t            continue\n520\t        if m.group(2) == \" \":\n521\t            unchecked.append(i)\n522\t        else:\n523\t            checked.append(i)\n524\t    # Prefer unchecked matches; fall back to checked ones.\n525\t    candidates = unchecked or checked\n526\t    if candidates:\n527\t        return min(candidates, key=lambda idx: abs(idx - task.line_number))\n528\t\n529\t    raise IndexError(\n530\t        f\"Task not found: line {task.line_number} stale and no text match for '{task.text}'\"\n531\t    )\n532\t\n533\t\n534\tdef check_off(path: str | Path, task: Task) -> None:\n535\t    \"\"\"Rewrite `- [ ]` to `- [x]` at the task's line number.\n536\t\n537\t    Also auto-checks parent tasks when all their children are done.\n538\t    If the task cannot be found (e.g. file was overwritten during\n539\t    execution), prints a warning instead of crashing.\n540\t    \"\"\"\n541\t    p = Path(path)\n542\t    lines = p.read_text().splitlines()\n543\t    try:\n544\t        _check_line(lines, _find_task_line(lines, task))\n545\t    except (IndexError, ValueError):\n546\t        print(\n547\t            f\"Warning: could not check off task (file may have been modified): {task.text}\",\n548\t            flush=True,\n549\t        )\n550\t        return\n551\t\n552\t    p.write_text(\"\\n\".join(lines) + \"\\n\")\n553\t    try:\n554\t        _auto_check_parents(p)\n555\t    except (IndexError, ValueError):\n556\t        pass\n557\t\n558\t\n559\tdef mark_failed(path: str | Path, task: Task) -> None:\n560\t    \"\"\"Rewrite `- [ ]` or `- [x]` to `- [!]` at the task's line number.\n561\t\n562\t    Claude Code sometimes checks off a task during execution before\n563\t    mcloop's post-task checks run.  If checks then fail, the line\n564\t    will contain ``- [x]`` rather than ``- [ ]``.  Handle both.\n565\t    \"\"\"\n566\t    p = Path(path)\n567\t    lines = p.read_text().splitlines()\n568\t    try:\n569\t        idx = _find_task_line(lines, task)\n570\t    except IndexError:\n571\t        print(\n572\t            f\"Warning: could not mark task as failed (file may have been modified): {task.text}\",\n573\t            flush=True,\n574\t        )\n575\t        return\n576\t    line = lines[idx]\n577\t    if \"- [ ]\" in line:\n578\t        new_line = line.replace(\"- [ ]\", \"- [!]\", 1)\n579\t    elif \"- [x]\" in line or \"- [X]\" in line:\n580\t        new_line = re.sub(r\"- \\[[xX]\\]\", \"- [!]\", line, count=1)\n581\t    else:\n582\t        new_line = line\n583\t    if new_line == line:\n584\t        print(\n585\t            f\"Warning: could not mark task as failed (no checkbox found): {task.text}\",\n586\t            flush=True,\n587\t        )\n588\t        return\n589\t    lines[idx] = new_line\n590\t    p.write_text(\"\\n\".join(lines) + \"\\n\")\n591\t\n592\t\n593\tdef clear_failed_markers(path: str | Path) -> int:\n594\t    \"\"\"Rewrite every `- [!]` back to `- [ ]` in *path*.\n595\t\n596\t    Returns the number of lines changed. Missing files return 0.\n597\t    Used by ``mcloop --retry`` to reset previously-failed tasks so the\n598\t    loop picks them up again on the next run. The file is only written\n599\t    when at least one line actually changes, to avoid spurious mtime\n600\t    bumps.\n601\t    \"\"\"\n602\t    p = Path(path)\n603\t    if not p.exists():\n604\t        return 0\n605\t    lines = p.read_text().splitlines()\n606\t    changed = 0\n607\t    # Anchor to checkbox syntax: optional indent, the dash, a space, the\n608\t    # `[!]` marker, then a space. Matching anywhere in the line corrupted\n609\t    # prose that happened to contain the literal \"- [!]\" sequence.\n610\t    failed_marker_re = re.compile(r\"^(\\s*)- \\[!\\] \")\n611\t    for i, line in enumerate(lines):\n612\t        new_line = failed_marker_re.sub(r\"\\1- [ ] \", line, count=1)\n613\t        if new_line != line:\n614\t            lines[i] = new_line\n615\t            changed += 1\n616\t    if changed:\n617\t        p.write_text(\"\\n\".join(lines) + \"\\n\")\n618\t    return changed\n619\t\n620\t\n621\tdef _check_line(lines: list[str], line_number: int) -> None:\n622\t    \"\"\"Replace `- [ ]` with `- [x]` on the given line.\"\"\"\n623\t    line = lines[line_number]\n624\t    lines[line_number] = line.replace(\"- [ ]\", \"- [x]\", 1)\n625\t\n626\t\n627\tdef is_user_task(task: Task) -> bool:\n628\t    \"\"\"Return True if the task requires user observation.\n629\t\n630\t    Tasks marked with [USER] in their text require the user to\n631\t    perform an action and report back what they observed.\n632\t    \"\"\"\n633\t    return _USER_TAG in task.text\n634\t\n635\t\n636\tdef user_task_instructions(task: Task) -> str:\n637\t    \"\"\"Extract the instruction text from a [USER] task.\n638\t\n639\t    Removes the [USER] tag and returns the remaining text,\n640\t    which describes what the user should do and observe.\n641\t    \"\"\"\n642\t    return task.text.replace(_USER_TAG, \"\").strip()\n643\t\n644\t\n645\tdef is_batch_task(task: Task) -> bool:\n646\t    \"\"\"Return True if the task is marked for batch execution.\n647\t\n648\t    Tasks marked with [BATCH] in their text have all their\n649\t    unchecked children combined into a single session.\n650\t    \"\"\"\n651\t    return _BATCH_TAG in task.text\n652\t\n653\t\n654\tdef get_batch_children(task: Task) -> list[Task]:\n655\t    \"\"\"Collect consecutive unchecked children eligible for batching.\n656\t\n657\t    Starts from the first unchecked child and collects until\n658\t    hitting a [USER] or [AUTO] task, or running out of children.\n659\t    Already checked children are skipped.  Failed children are\n660\t    skipped when they appear before any non-failed child, but once\n661\t    at least one non-failed child has been seen (checked or collected)\n662\t    a failed child stops collection (the failure is a dependency\n663\t    barrier).\n664\t    \"\"\"\n665\t    batch: list[Task] = []\n666\t    seen_non_failed = False\n667\t    for child in task.children:\n668\t        if child.checked:\n669\t            seen_non_failed = True\n670\t            continue\n671\t        if child.failed:\n672\t            if batch or seen_non_failed:\n673\t                break\n674\t            continue\n675\t        if is_user_task(child) or is_auto_task(child):\n676\t            break\n677\t        batch.append(child)\n678\t    return batch\n679\t\n680\t\n681\tdef is_auto_task(task: Task) -> bool:\n682\t    \"\"\"Return True if the task is an automated observation.\n683\t\n684\t    Tasks marked with [AUTO:<action>] in their text are performed\n685\t    automatically by mcloop using process_monitor, app_interact,\n686\t    or web_interact, without pausing for user input.\n687\t    \"\"\"\n688\t    return bool(_AUTO_TAG_RE.search(task.text))\n689\t\n690\t\n691\tdef parse_auto_task(task: Task) -> tuple[str, str]:\n692\t    \"\"\"Parse an [AUTO:<action>] task into (action, args).\n693\t\n694\t    Returns (action, args) where action is the keyword after AUTO:\n695\t    (e.g. 'run_cli', 'run_gui', 'screenshot') and args is the\n696\t    remaining text after the tag.\n697\t    \"\"\"\n698\t    m = _AUTO_TAG_RE.search(task.text)\n699\t    if not m:\n700\t        return (\"\", \"\")\n701\t    action = m.group(1)\n702\t    # Everything after the [AUTO:action] tag is the argument\n703\t    after_tag = task.text[m.end() :].strip()\n704\t    return (action, after_tag)\n705\t\n706\t\n707\tdef purge_completed_bugs(path: str | Path) -> None:\n708\t    \"\"\"Remove all checked-off items from BUGS.md.\n709\t\n710\t    Called after the last open bug is completed. Bug tasks are\n711\t    generated noise from the reviewer or crash diagnostics, not\n712\t    design decisions worth preserving.\n713\t\n714\t    Works for both standalone BUGS.md (entire file is bugs) and\n715\t    legacy plans with an inline ``## Bugs`` section.\n716\t    \"\"\"\n717\t    p = Path(path)\n718\t    lines = p.read_text().splitlines()\n719\t\n720\t    new_lines: list[str] = []\n721\t    for line in lines:\n722\t        m = CHECKBOX_RE.match(line)\n723\t        if m and m.group(2) in (\"x\", \"X\"):\n724\t            continue\n725\t        new_lines.append(line)\n726\t\n727\t    p.write_text(\"\\n\".join(new_lines) + \"\\n\")\n728\t\n729\t\n730\tdef _auto_check_parents(path: Path) -> None:\n731\t    \"\"\"Re-parse and check off any parent whose children are all done.\n732\t\n733\t    Internal call: skip the structural sanity check. This function is\n734\t    invoked immediately after ``check_off`` writes a single line, so the\n735\t    file's structure has not changed since it was last validated by an\n736\t    external ``parse()`` call. Re-validating here would risk raising\n737\t    ``PlanCorruptionError`` from inside a check-off operation, which\n738\t    would obscure the real failure mode.\n739\t    \"\"\"\n740\t    tasks = parse(path, check_structure=False)\n741\t    lines = path.read_text().splitlines()\n742\t    changed = False\n743\t\n744\t    def visit(task_list: list[Task]) -> None:\n745\t        nonlocal changed\n746\t        for task in task_list:\n747\t            if task.children:\n748\t                visit(task.children)\n749\t                if not task.checked and all(c.checked for c in task.children):\n750\t                    _check_line(lines, _find_task_line(lines, task))\n751\t                    task.checked = True\n752\t                    changed = True\n753\t\n754\t    visit(tasks)\n755\t    if changed:\n756\t        path.write_text(\"\\n\".join(lines) + \"\\n\")\n757\t\n758\t\n759\tdef task_label(tasks: list[Task], target: Task) -> str:\n760\t    \"\"\"Return a label like '6.3' or '6.3.2' for a task's position.\n761\t\n762\t    The first number is the stage/phase number extracted from\n763\t    the section header (any heading level containing ``Stage N``\n764\t    or ``Phase N``).  Tasks without a section header use a\n765\t    global positional index.  Subtask numbers are relative to\n766\t    their parent.\n767\t    \"\"\"\n768\t    # Extract stage/phase number from the stage string.\n769\t    # Matches \"Stage N\" or \"Phase N\" anywhere in the header text.\n770\t    stage_num = \"\"\n771\t    if target.stage:\n772\t        m = _STAGE_NUM_RE.search(target.stage)\n773\t        if m:\n774\t            stage_num = m.group(1)\n775\t\n776\t    # Filter root tasks to only those in the same stage\n777\t    if stage_num:\n778\t        stage_tasks = [t for t in tasks if t.stage == target.stage]\n779\t    else:\n780\t        stage_tasks = tasks\n781\t\n782\t    def _search(task_list: list[Task], prefix: str) -> str | None:\n783\t        for i, task in enumerate(task_list, 1):\n784\t            lbl = f\"{prefix}{i}\" if prefix else str(i)\n785\t            if task is target:\n786\t                return lbl\n787\t            if task.children:\n788\t                found = _search(task.children, f\"{lbl}.\")\n789\t                if found:\n790\t                    return found\n791\t        return None\n792\t\n793\t    result = _search(stage_tasks, f\"{stage_num}.\" if stage_num else \"\")\n794\t    return result or \"?\"\n795\t"}]},"parent_tool_use_id":null,"session_id":"c0ad05b9-4ddd-4925-a04d-c46811d784c5","uuid":"0ec225a4-b97f-4d56-af3a-fafc8c612cb1","timestamp":"2026-05-16T02:39:17.933Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/mcloop/mcloop/checklist.py","content":"\"\"\"Markdown checklist parser. Reads and writes `- [ ]` items.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom dataclasses import dataclass, field\nfrom pathlib import Path\n\nCHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n# Section headers: any heading level (# or more) whose title contains\n# \"Stage N\" or \"Phase N\" anywhere in the line. The number is captured.\nSTAGE_RE = re.compile(r\"^#+\\s+.*?\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n# Bugs header: any heading level followed by \"Bugs\" as the title.\nBUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n# H1 headers (single `#` followed by space). Used by the structural\n# sanity check to detect duplicated top-level headings (a hallmark\n# corruption pattern in PLAN.md files that have been bad-edited).\n_H1_RE = re.compile(r\"^#\\s+(.+)$\")\n# Pattern for extracting a stage/phase number from a stage string\n# (the header text with leading # and whitespace stripped).\n_STAGE_NUM_RE = re.compile(r\"\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n_USER_TAG = \"[USER]\"\n_BATCH_TAG = \"[BATCH]\"\n_AUTO_TAG_RE = re.compile(r\"\\[AUTO:(\\w+)\\]\")\n\n\nclass PlanCorruptionError(Exception):\n    \"\"\"Raised when parse() detects structural corruption in a checklist.\n\n    The check is conservative: only flags anomalies that are very\n    unlikely to be intentional (duplicate top-level headings, multiple\n    ``## Bugs`` sections, repeated phase/stage numbers). Auto-fixing\n    is deliberately not attempted; an attempt to silently \"correct\"\n    structural corruption is exactly the operation that produces it.\n\n    Callers that intentionally pass malformed input (tests, dry-run\n    inspection of an in-progress edit) can pass ``check_structure=False``\n    to ``parse()``.\n    \"\"\"\n\n\n@dataclass\nclass Task:\n    text: str\n    checked: bool\n    failed: bool\n    line_number: int\n    indent_level: int\n    stage: str = \"\"\n    children: list[Task] = field(default_factory=list)\n    eliminated: list[str] = field(default_factory=list)\n\n\ndef count_unchecked(tasks: list[Task]) -> int:\n    \"\"\"Recursively count unchecked, non-failed tasks.\"\"\"\n    n = 0\n    for t in tasks:\n        if not t.checked and not t.failed:\n            n += 1\n        n += count_unchecked(t.children)\n    return n\n\n\ndef parse_description(path: str | Path) -> str:\n    \"\"\"Extract prose before the first checkbox as a project description.\"\"\"\n    lines = Path(path).read_text().splitlines()\n    desc_lines = []\n    for line in lines:\n        if CHECKBOX_RE.match(line):\n            break\n        desc_lines.append(line)\n    return \"\\n\".join(desc_lines).strip()\n\n\ndef _check_structural_sanity(lines: list[str], path: str | Path) -> None:\n    \"\"\"Scan a checklist file for structural corruption signals.\n\n    Three anomalies are flagged. Each has been observed in real\n    PLAN.md corruption incidents and none has a legitimate use:\n\n    1. Duplicate H1 headings with identical title text — typically\n       indicates a botched insertion that left the original tail in\n       place, producing two copies of the document's top header.\n    2. Multiple ``## Bugs`` sections (any heading level) — there\n       should only ever be one.\n    3. Duplicate phase/stage numbers across stage headers — e.g. two\n       different headers both numbered ``Phase 2``. This breaks\n       ``task_label`` (which prefixes labels with the stage number)\n       and almost always signals merged content from two attempts at\n       the same phase.\n\n    Raises ``PlanCorruptionError`` listing every anomaly found, with\n    line numbers, so the user can locate and fix the corruption.\n    \"\"\"\n    h1_titles: dict[str, list[int]] = {}\n    bugs_lines: list[int] = []\n    stage_nums: dict[str, list[int]] = {}\n\n    for i, line in enumerate(lines):\n        # Order matters: STAGE_RE matches lines that are also H1s\n        # (e.g. ``# Phase 1: Bootstrapping``). A header is either a\n        # stage header OR a plain H1 OR a Bugs header — never two of\n        # those at once. Check stage first so we don't double-count\n        # ``# Phase N`` as both an H1 duplicate and a stage duplicate.\n        stage_match = STAGE_RE.match(line)\n        if stage_match:\n            num = stage_match.group(1)\n            stage_nums.setdefault(num, []).append(i)\n            continue\n\n        if BUGS_RE.match(line):\n            bugs_lines.append(i)\n            continue\n\n        h1_match = _H1_RE.match(line)\n        if h1_match:\n            # Only single-# headings (true H1s). _H1_RE already enforces\n            # this; check that it's not actually a deeper heading caught\n            # by accident.\n            if line.startswith(\"# \") and not line.startswith(\"## \"):\n                title = h1_match.group(1).strip()\n                h1_titles.setdefault(title, []).append(i)\n\n    problems: list[str] = []\n\n    for title, line_nums in h1_titles.items():\n        if len(line_nums) > 1:\n            locs = \", \".join(str(n + 1) for n in line_nums)\n            problems.append(f\"duplicate top-level heading '# {title}' at lines {locs}\")\n\n    if len(bugs_lines) > 1:\n        locs = \", \".join(str(n + 1) for n in bugs_lines)\n        problems.append(f\"multiple Bugs sections at lines {locs}\")\n\n    for num, line_nums in stage_nums.items():\n        if len(line_nums) > 1:\n            locs = \", \".join(str(n + 1) for n in line_nums)\n            problems.append(f\"duplicate Phase/Stage {num} at lines {locs}\")\n\n    if problems:\n        joined = \"\\n  - \".join(problems)\n        raise PlanCorruptionError(\n            f\"Structural corruption detected in {path}:\\n  - {joined}\\n\"\n            \"Fix the file manually. mcloop will not modify a corrupted\"\n            \" PLAN.md because doing so risks compounding the corruption.\"\n            \" If the apparent corruption is intentional, pass\"\n            \" check_structure=False to parse().\"\n        )\n\n\ndef parse(path: str | Path, check_structure: bool = True) -> list[Task]:\n    \"\"\"Read a markdown file and return a tree of Task objects.\n\n    Section headers are any markdown heading (``#``, ``##``, ...)\n    whose title contains ``Stage N`` or ``Phase N`` anywhere in\n    the line.  Tasks under such a header are tagged with the full\n    header text (minus leading ``#`` and whitespace).  Tasks\n    before any section header have stage ``\"\"``.\n\n    The ``## Bugs`` header (any heading level) is treated as a\n    special section with stage ``\"Bugs\"``.\n\n    When ``check_structure`` is True (the default), the file is\n    scanned for structural corruption first and ``PlanCorruptionError``\n    is raised on detection. Set ``check_structure=False`` to skip\n    the check (used by tests that intentionally pass malformed input).\n    \"\"\"\n    lines = Path(path).read_text().splitlines()\n    if check_structure:\n        _check_structural_sanity(lines, path)\n    root_tasks: list[Task] = []\n    stack: list[Task] = []\n    current_stage = \"\"\n\n    for i, line in enumerate(lines):\n        # Detect section headers (any heading level containing\n        # \"Stage N\" or \"Phase N\")\n        if STAGE_RE.match(line):\n            current_stage = line.lstrip(\"#\").strip()\n            stack.clear()\n            continue\n\n        # Detect Bugs header (any heading level)\n        if BUGS_RE.match(line):\n            current_stage = \"Bugs\"\n            stack.clear()\n            continue\n\n        # Collect [RULEDOUT] lines and attach to the parent task.\n        # The line's indentation determines which task it belongs to:\n        # it attaches to the nearest task with strictly less indentation.\n        stripped = line.strip()\n        if stripped.startswith(\"[RULEDOUT]\"):\n            elim_indent = len(line) - len(line.lstrip())\n            for t in reversed(stack):\n                if t.indent_level < elim_indent:\n                    t.eliminated.append(stripped)\n                    break\n            else:\n                # No parent found (top-level [RULEDOUT]), attach\n                # to the most recent root task if one exists.\n                if root_tasks:\n                    root_tasks[-1].eliminated.append(stripped)\n            continue\n\n        m = CHECKBOX_RE.match(line)\n        if not m:\n            continue\n\n        indent = len(m.group(1))\n        marker = m.group(2)\n        checked = marker in (\"x\", \"X\")\n        failed = marker == \"!\"\n        text = m.group(3).strip()\n        task = Task(\n            text=text,\n            checked=checked,\n            failed=failed,\n            line_number=i,\n            indent_level=indent,\n            stage=current_stage,\n        )\n\n        while stack and stack[-1].indent_level >= indent:\n            stack.pop()\n\n        if stack:\n            stack[-1].children.append(task)\n        else:\n            root_tasks.append(task)\n\n        stack.append(task)\n\n    return root_tasks\n\n\ndef get_eliminated(tasks: list[Task], target: Task) -> list[str]:\n    \"\"\"Collect all [RULEDOUT] entries for a task, including from ancestors.\n\n    Walks the task tree to find the target and collects eliminated\n    entries from every ancestor along the path.\n    \"\"\"\n    result: list[str] = []\n\n    def _search(task_list: list[Task], inherited: list[str]) -> bool:\n        for task in task_list:\n            combined = inherited + task.eliminated\n            if task is target:\n                result.extend(combined)\n                return True\n            if task.children and _search(task.children, combined):\n                return True\n        return False\n\n    _search(tasks, [])\n    return result\n\n\ndef find_parent(tasks: list[Task], target: Task) -> Task | None:\n    \"\"\"Find the parent of a target task in the tree.\n\n    Returns None if the target is a root task.\n    \"\"\"\n\n    def _search(task_list: list[Task]) -> Task | None:\n        for task in task_list:\n            if target in task.children:\n                return task\n            found = _search(task.children)\n            if found is not None:\n                return found\n        return None\n\n    return _search(tasks)\n\n\ndef get_stages(tasks: list[Task]) -> list[str]:\n    \"\"\"Return ordered list of unique stage names found in tasks.\n\n    Returns ``[]`` if no tasks have stage labels (flat plan).\n    \"\"\"\n    seen: set[str] = set()\n    stages: list[str] = []\n\n    def _collect(task_list: list[Task]) -> None:\n        for task in task_list:\n            if task.stage and task.stage != \"Bugs\" and task.stage not in seen:\n                seen.add(task.stage)\n                stages.append(task.stage)\n            _collect(task.children)\n\n    _collect(tasks)\n    return stages\n\n\ndef _stage_complete(tasks: list[Task], stage: str) -> bool:\n    \"\"\"Return True if all tasks in the given stage are checked.\n\n    Failed tasks ([!]) do NOT count as complete. A stage with\n    failed tasks is stuck, not done.\n    \"\"\"\n\n    def _check(task_list: list[Task]) -> bool:\n        for task in task_list:\n            if task.stage == stage:\n                if not task.checked:\n                    return False\n            if not _check(task.children):\n                return False\n        return True\n\n    return _check(tasks)\n\n\ndef current_stage(tasks: list[Task]) -> str | None:\n    \"\"\"Return the name of the first incomplete stage.\n\n    Returns ``None`` if all stages are complete or there are no\n    stages.\n    \"\"\"\n    stages = get_stages(tasks)\n    if not stages:\n        return None\n    for stage in stages:\n        if not _stage_complete(tasks, stage):\n            return stage\n    return None\n\n\ndef stage_status(tasks: list[Task]) -> str:\n    \"\"\"Return a status string for the summary.\n\n    Possible values:\n    - ``\"no_stages\"``: plan has no stage headers\n    - ``\"in_progress\"``: stages exist but none completed yet\n    - ``\"stage_complete:<name>\"``: a stage just finished,\n      more stages remain\n    - ``\"all_complete\"``: all stages are done\n    \"\"\"\n    stages = get_stages(tasks)\n    if not stages:\n        return \"no_stages\"\n\n    last_complete = None\n    for stage in stages:\n        if _stage_complete(tasks, stage):\n            last_complete = stage\n        else:\n            if last_complete:\n                return f\"stage_complete:{last_complete}\"\n            return \"in_progress\"\n\n    return \"all_complete\"\n\n\ndef _search_tasks(\n    task_list: list[Task],\n    *,\n    is_subtask: bool = False,\n    required_stage: str | None = None,\n    skip_stages: set[str] | None = None,\n) -> Task | None:\n    \"\"\"Depth-first search for the next unchecked leaf task.\n\n    Shared logic used by both ``find_next`` and ``_search_in_stage``.\n    *required_stage* restricts matches to tasks in that stage.\n    *skip_stages* skips tasks in those stages.\n    \"\"\"\n    for task in task_list:\n        # A failed subtask blocks all later siblings under the\n        # same parent (implicit sequential dependency).\n        # Root-level tasks are treated as independent.\n        if task.failed:\n            if is_subtask:\n                return None\n            continue\n\n        if task.checked:\n            continue\n\n        if skip_stages and task.stage in skip_stages:\n            continue\n\n        if required_stage is not None and task.stage != required_stage:\n            continue\n\n        if task.children:\n            child = _search_tasks(\n                task.children,\n                is_subtask=True,\n                required_stage=required_stage,\n                skip_stages=skip_stages,\n            )\n            if child:\n                return child\n            # Don't return the parent if any child failed;\n            # the parent can never complete in that state.\n            if any(c.failed for c in task.children):\n                if is_subtask:\n                    return None\n                continue\n            return task\n\n        return task\n    return None\n\n\ndef has_unchecked_bugs(tasks: list[Task]) -> bool:\n    \"\"\"Return True if there are unchecked bug tasks.\n\n    Accepts any of these shapes:\n    - Tasks under a ``## Bugs`` header (any heading level, any case).\n    - A standalone bug file with no stage/phase headers: every\n      unchecked task counts as a bug. This covers files with no\n      header, a non-matching header (``## Known bugs``,\n      ``## Open bugs``, ``# Bugs to fix``), or a bare checklist.\n    \"\"\"\n    if _search_in_stage(tasks, \"Bugs\") is not None:\n        return True\n    if get_stages(tasks):\n        return False\n\n    def _any_unchecked(task_list: list[Task]) -> bool:\n        for t in task_list:\n            if not t.checked and not t.failed:\n                return True\n            if _any_unchecked(t.children):\n                return True\n        return False\n\n    return _any_unchecked(tasks)\n\n\ndef find_next(tasks: list[Task]) -> Task | None:\n    \"\"\"Depth-first search for the next unchecked leaf task.\n\n    Bug tasks (under ``## Bugs``) have absolute priority and are\n    returned before any feature/stage tasks.\n\n    If the plan uses stages (``## Stage N:`` headers), only\n    returns tasks from the first incomplete stage.  Returns\n    ``None`` when the current stage is fully complete, even if\n    later stages have unchecked tasks.\n    \"\"\"\n    # Priority: bug tasks first\n    bug_task = _search_in_stage(tasks, \"Bugs\")\n    if bug_task:\n        return bug_task\n\n    active_stage = current_stage(tasks)\n    has_stages = len(get_stages(tasks)) > 0\n\n    # Skip bug tasks (already handled above) and non-active stages\n    skip_stages = {\"Bugs\"}\n\n    return _search_tasks(\n        tasks,\n        required_stage=active_stage if has_stages else None,\n        skip_stages=skip_stages,\n    )\n\n\ndef _search_in_stage(tasks: list[Task], stage: str) -> Task | None:\n    \"\"\"Search for the next unchecked leaf in a specific stage.\"\"\"\n\n    def _search(task_list: list[Task], is_subtask: bool = False) -> Task | None:\n        return _search_tasks(task_list, is_subtask=is_subtask, required_stage=stage)\n\n    return _search(tasks)\n\n\ndef _find_task_line(lines: list[str], task: Task) -> int:\n    \"\"\"Find task line by line_number, falling back to text match.\n\n    Primary key is the line_number recorded at parse time.  If the\n    file was modified between parse and check-off (e.g. Claude Code\n    edited PLAN.md during execution), the stored line_number may be\n    stale, so we fall back to searching by text.\n    \"\"\"\n    # Primary: use stored line_number if it still points to the right task.\n    # Validate text, indent_level, and stage to detect stale line numbers\n    # (e.g. file was edited externally and lines shifted).\n    if task.line_number < len(lines):\n        m = CHECKBOX_RE.match(lines[task.line_number])\n        if m and m.group(3).strip() == task.text and len(m.group(1)) == task.indent_level:\n            # Verify stage by scanning headers above this line\n            line_stage = \"\"\n            for j in range(task.line_number):\n                if STAGE_RE.match(lines[j]):\n                    line_stage = lines[j].lstrip(\"#\").strip()\n                elif BUGS_RE.match(lines[j]):\n                    line_stage = \"Bugs\"\n            if line_stage == task.stage:\n                return task.line_number\n\n    # Fallback: text search with indent_level and stage validation.\n    # Track the current stage as we scan so we can disambiguate\n    # duplicate task texts that appear in different stages or at\n    # different indentation levels.\n    # Collect all candidates and pick the one nearest to the original\n    # line_number, preferring unchecked tasks.\n    current_stage = \"\"\n    unchecked: list[int] = []\n    checked: list[int] = []\n    for i, line in enumerate(lines):\n        if STAGE_RE.match(line):\n            current_stage = line.lstrip(\"#\").strip()\n            continue\n        if BUGS_RE.match(line):\n            current_stage = \"Bugs\"\n            continue\n        m = CHECKBOX_RE.match(line)\n        if not m or m.group(3).strip() != task.text:\n            continue\n        indent = len(m.group(1))\n        if indent != task.indent_level:\n            continue\n        if current_stage != task.stage:\n            continue\n        if m.group(2) == \" \":\n            unchecked.append(i)\n        else:\n            checked.append(i)\n    # Prefer unchecked matches; fall back to checked ones.\n    candidates = unchecked or checked\n    if candidates:\n        return min(candidates, key=lambda idx: abs(idx - task.line_number))\n\n    raise IndexError(\n        f\"Task not found: line {task.line_number} stale and no text match for '{task.text}'\"\n    )\n\n\ndef check_off(path: str | Path, task: Task) -> None:\n    \"\"\"Rewrite `- [ ]` to `- [x]` at the task's line number.\n\n    Also auto-checks parent tasks when all their children are done.\n    If the task cannot be found (e.g. file was overwritten during\n    execution), prints a warning instead of crashing.\n    \"\"\"\n    p = Path(path)\n    lines = p.read_text().splitlines()\n    try:\n        _check_line(lines, _find_task_line(lines, task))\n    except (IndexError, ValueError):\n        print(\n            f\"Warning: could not check off task (file may have been modified): {task.text}\",\n            flush=True,\n        )\n        return\n\n    p.write_text(\"\\n\".join(lines) + \"\\n\")\n    try:\n        _auto_check_parents(p)\n    except (IndexError, ValueError):\n        pass\n\n\ndef mark_failed(path: str | Path, task: Task) -> None:\n    \"\"\"Rewrite `- [ ]` or `- [x]` to `- [!]` at the task's line number.\n\n    Claude Code sometimes checks off a task during execution before\n    mcloop's post-task checks run.  If checks then fail, the line\n    will contain ``- [x]`` rather than ``- [ ]``.  Handle both.\n    \"\"\"\n    p = Path(path)\n    lines = p.read_text().splitlines()\n    try:\n        idx = _find_task_line(lines, task)\n    except IndexError:\n        print(\n            f\"Warning: could not mark task as failed (file may have been modified): {task.text}\",\n            flush=True,\n        )\n        return\n    line = lines[idx]\n    if \"- [ ]\" in line:\n        new_line = line.replace(\"- [ ]\", \"- [!]\", 1)\n    elif \"- [x]\" in line or \"- [X]\" in line:\n        new_line = re.sub(r\"- \\[[xX]\\]\", \"- [!]\", line, count=1)\n    else:\n        new_line = line\n    if new_line == line:\n        print(\n            f\"Warning: could not mark task as failed (no checkbox found): {task.text}\",\n            flush=True,\n        )\n        return\n    lines[idx] = new_line\n    p.write_text(\"\\n\".join(lines) + \"\\n\")\n\n\ndef clear_failed_markers(path: str | Path) -> int:\n    \"\"\"Rewrite every `- [!]` back to `- [ ]` in *path*.\n\n    Returns the number of lines changed. Missing files return 0.\n    Used by ``mcloop --retry`` to reset previously-failed tasks so the\n    loop picks them up again on the next run. The file is only written\n    when at least one line actually changes, to avoid spurious mtime\n    bumps.\n    \"\"\"\n    p = Path(path)\n    if not p.exists():\n        return 0\n    lines = p.read_text().splitlines()\n    changed = 0\n    # Anchor to checkbox syntax: optional indent, the dash, a space, the\n    # `[!]` marker, then a space. Matching anywhere in the line corrupted\n    # prose that happened to contain the literal \"- [!]\" sequence.\n    failed_marker_re = re.compile(r\"^(\\s*)- \\[!\\] \")\n    for i, line in enumerate(lines):\n        new_line = failed_marker_re.sub(r\"\\1- [ ] \", line, count=1)\n        if new_line != line:\n            lines[i] = new_line\n            changed += 1\n    if changed:\n        p.write_text(\"\\n\".join(lines) + \"\\n\")\n    return changed\n\n\ndef _check_line(lines: list[str], line_number: int) -> None:\n    \"\"\"Replace `- [ ]` with `- [x]` on the given line.\"\"\"\n    line = lines[line_number]\n    lines[line_number] = line.replace(\"- [ ]\", \"- [x]\", 1)\n\n\ndef is_user_task(task: Task) -> bool:\n    \"\"\"Return True if the task requires user observation.\n\n    Tasks marked with [USER] in their text require the user to\n    perform an action and report back what they observed.\n    \"\"\"\n    return _USER_TAG in task.text\n\n\ndef user_task_instructions(task: Task) -> str:\n    \"\"\"Extract the instruction text from a [USER] task.\n\n    Removes the [USER] tag and returns the remaining text,\n    which describes what the user should do and observe.\n    \"\"\"\n    return task.text.replace(_USER_TAG, \"\").strip()\n\n\ndef is_batch_task(task: Task) -> bool:\n    \"\"\"Return True if the task is marked for batch execution.\n\n    Tasks marked with [BATCH] in their text have all their\n    unchecked children combined into a single session.\n    \"\"\"\n    return _BATCH_TAG in task.text\n\n\ndef get_batch_children(task: Task) -> list[Task]:\n    \"\"\"Collect consecutive unchecked children eligible for batching.\n\n    Starts from the first unchecked child and collects until\n    hitting a [USER] or [AUTO] task, or running out of children.\n    Already checked children are skipped.  Failed children are\n    skipped when they appear before any non-failed child, but once\n    at least one non-failed child has been seen (checked or collected)\n    a failed child stops collection (the failure is a dependency\n    barrier).\n    \"\"\"\n    batch: list[Task] = []\n    seen_non_failed = False\n    for child in task.children:\n        if child.checked:\n            seen_non_failed = True\n            continue\n        if child.failed:\n            if batch or seen_non_failed:\n                break\n            continue\n        if is_user_task(child) or is_auto_task(child):\n            break\n        batch.append(child)\n    return batch\n\n\ndef is_auto_task(task: Task) -> bool:\n    \"\"\"Return True if the task is an automated observation.\n\n    Tasks marked with [AUTO:<action>] in their text are performed\n    automatically by mcloop using process_monitor, app_interact,\n    or web_interact, without pausing for user input.\n    \"\"\"\n    return bool(_AUTO_TAG_RE.search(task.text))\n\n\ndef parse_auto_task(task: Task) -> tuple[str, str]:\n    \"\"\"Parse an [AUTO:<action>] task into (action, args).\n\n    Returns (action, args) where action is the keyword after AUTO:\n    (e.g. 'run_cli', 'run_gui', 'screenshot') and args is the\n    remaining text after the tag.\n    \"\"\"\n    m = _AUTO_TAG_RE.search(task.text)\n    if not m:\n        return (\"\", \"\")\n    action = m.group(1)\n    # Everything after the [AUTO:action] tag is the argument\n    after_tag = task.text[m.end() :].strip()\n    return (action, after_tag)\n\n\ndef purge_completed_bugs(path: str | Path) -> None:\n    \"\"\"Remove all checked-off items from BUGS.md.\n\n    Called after the last open bug is completed. Bug tasks are\n    generated noise from the reviewer or crash diagnostics, not\n    design decisions worth preserving.\n\n    Works for both standalone BUGS.md (entire file is bugs) and\n    legacy plans with an inline ``## Bugs`` section.\n    \"\"\"\n    p = Path(path)\n    lines = p.read_text().splitlines()\n\n    new_lines: list[str] = []\n    for line in lines:\n        m = CHECKBOX_RE.match(line)\n        if m and m.group(2) in (\"x\", \"X\"):\n            continue\n        new_lines.append(line)\n\n    p.write_text(\"\\n\".join(new_lines) + \"\\n\")\n\n\ndef _auto_check_parents(path: Path) -> None:\n    \"\"\"Re-parse and check off any parent whose children are all done.\n\n    Internal call: skip the structural sanity check. This function is\n    invoked immediately after ``check_off`` writes a single line, so the\n    file's structure has not changed since it was last validated by an\n    external ``parse()`` call. Re-validating here would risk raising\n    ``PlanCorruptionError`` from inside a check-off operation, which\n    would obscure the real failure mode.\n    \"\"\"\n    tasks = parse(path, check_structure=False)\n    lines = path.read_text().splitlines()\n    changed = False\n\n    def visit(task_list: list[Task]) -> None:\n        nonlocal changed\n        for task in task_list:\n            if task.children:\n                visit(task.children)\n                if not task.checked and all(c.checked for c in task.children):\n                    _check_line(lines, _find_task_line(lines, task))\n                    task.checked = True\n                    changed = True\n\n    visit(tasks)\n    if changed:\n        path.write_text(\"\\n\".join(lines) + \"\\n\")\n\n\ndef task_label(tasks: list[Task], target: Task) -> str:\n    \"\"\"Return a label like '6.3' or '6.3.2' for a task's position.\n\n    The first number is the stage/phase number extracted from\n    the section header (any heading level containing ``Stage N``\n    or ``Phase N``).  Tasks without a section header use a\n    global positional index.  Subtask numbers are relative to\n    their parent.\n    \"\"\"\n    # Extract stage/phase number from the stage string.\n    # Matches \"Stage N\" or \"Phase N\" anywhere in the header text.\n    stage_num = \"\"\n    if target.stage:\n        m = _STAGE_NUM_RE.search(target.stage)\n        if m:\n            stage_num = m.group(1)\n\n    # Filter root tasks to only those in the same stage\n    if stage_num:\n        stage_tasks = [t for t in tasks if t.stage == target.stage]\n    else:\n        stage_tasks = tasks\n\n    def _search(task_list: list[Task], prefix: str) -> str | None:\n        for i, task in enumerate(task_list, 1):\n            lbl = f\"{prefix}{i}\" if prefix else str(i)\n            if task is target:\n                return lbl\n            if task.children:\n                found = _search(task.children, f\"{lbl}.\")\n                if found:\n                    return found\n        return None\n\n    result = _search(stage_tasks, f\"{stage_num}.\" if stage_num else \"\")\n    return result or \"?\"\n","numLines":795,"startLine":1,"totalLines":795}}}
