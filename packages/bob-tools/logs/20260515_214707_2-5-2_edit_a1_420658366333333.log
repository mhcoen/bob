{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016RXuLYR1p9SQL6RoJMdErv","type":"tool_result","content":"1\t\"\"\"Tests for bob_tools.planfile.parser building blocks.\n2\t\n3\tStage 2 task-line recognizers and tag extractors:\n4\t\n5\t  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n6\t    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n7\t  - ``_parse_task_line`` returns a raw record on checkbox lines and\n8\t    ``None`` on anything else.\n9\t  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n10\t    sibling lines and returns indent, body, and source line number.\n11\t  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n12\t    line: nearest strictly-less-indented open ancestor, with fallback\n13\t    to the most recent root task (mcloop's ``parse`` parity). The\n14\t    parse-then-attach composition test confirms multiple RULEDOUT\n15\t    lines on one task are collected in source order.\n16\t  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n17\t    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n18\t    enforces that at least one ID follows the keyword.\n19\t  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n20\t    sibling line: the innermost open ancestor at strictly-less indent\n21\t    is the strict-form parent; an ancestor at equal indent is the\n22\t    lenient-form parent (caller should warn). No root-task fallback.\n23\t    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n24\t    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n25\t  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n26\t    tokens, in isolation and combination, and leaves non-leading\n27\t    occurrences as prose (design doc section 4.3).\n28\t  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n29\t    treats the rest of the line as its argument string; non-leading\n30\t    occurrences are prose.\n31\t  - ``_extract_annotations`` consumes trailing ``[key: value]``\n32\t    annotations, handles multiple annotations and nested brackets in\n33\t    values, and leaves bracketed prose that is not separated from\n34\t    preceding text by whitespace in place.\n35\t\"\"\"\n36\t\n37\tfrom __future__ import annotations\n38\t\n39\tfrom dataclasses import dataclass\n40\t\n41\timport pytest\n42\t\n43\tfrom bob_tools.planfile.parser import (\n44\t    _CHECKBOX_RE,\n45\t    _DEPS_RE,\n46\t    _attach_deps,\n47\t    _attach_ruledout,\n48\t    _extract_action_tag,\n49\t    _extract_annotations,\n50\t    _extract_flag_tags,\n51\t    _parse_ruledout_line,\n52\t    _parse_task_line,\n53\t)\n54\t\n55\t\n56\t@dataclass\n57\tclass _FakeTask:\n58\t    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n59\t\n60\t    indent_level: int\n61\t    name: str = \"\"\n62\t\n63\t\n64\tclass TestCheckboxRe:\n65\t    @pytest.mark.parametrize(\n66\t        (\"line\", \"indent\", \"marker\", \"text\"),\n67\t        [\n68\t            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n69\t            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n70\t            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n71\t            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n72\t            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n73\t        ],\n74\t    )\n75\t    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n76\t        m = _CHECKBOX_RE.match(line)\n77\t        assert m is not None\n78\t        assert m.group(1) == indent\n79\t        assert m.group(2) == marker\n80\t        assert m.group(3) == text\n81\t\n82\t    @pytest.mark.parametrize(\n83\t        \"line\",\n84\t        [\n85\t            \"\",\n86\t            \"## Stage 1: Core\",\n87\t            \"- [] missing space inside brackets\",\n88\t            \"- [y] unsupported marker\",\n89\t            \"- [ ]\",\n90\t            \"* [ ] wrong bullet\",\n91\t            \"Plain prose line\",\n92\t        ],\n93\t    )\n94\t    def test_non_matches(self, line: str) -> None:\n95\t        assert _CHECKBOX_RE.match(line) is None\n96\t\n97\t\n98\tclass TestParseTaskLine:\n99\t    def test_match_returns_raw_record(self) -> None:\n100\t        rec = _parse_task_line(\"  - [x] foo\", 7)\n101\t        assert rec is not None\n102\t        assert rec.indent == \"  \"\n103\t        assert rec.status_char == \"x\"\n104\t        assert rec.text == \"foo\"\n105\t        assert rec.line_number == 7\n106\t\n107\t    def test_match_failed_marker(self) -> None:\n108\t        rec = _parse_task_line(\"- [!] bad\", 12)\n109\t        assert rec is not None\n110\t        assert rec.status_char == \"!\"\n111\t        assert rec.line_number == 12\n112\t\n113\t    def test_non_task_returns_none(self) -> None:\n114\t        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n115\t        assert _parse_task_line(\"\", 2) is None\n116\t        assert _parse_task_line(\"Some prose\", 3) is None\n117\t\n118\t\n119\tclass TestParseRuledOutLine:\n120\t    def test_indented_with_text(self) -> None:\n121\t        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n122\t        assert rec is not None\n123\t        assert rec.indent == \"  \"\n124\t        assert rec.text == \"tried restart\"\n125\t        assert rec.line_number == 5\n126\t\n127\t    def test_top_level_with_text(self) -> None:\n128\t        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n129\t        assert rec is not None\n130\t        assert rec.indent == \"\"\n131\t        assert rec.text == \"orphan approach\"\n132\t\n133\t    def test_empty_body(self) -> None:\n134\t        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n135\t        assert rec is not None\n136\t        assert rec.indent == \"    \"\n137\t        assert rec.text == \"\"\n138\t\n139\t    def test_trailing_whitespace_stripped(self) -> None:\n140\t        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n141\t        assert rec is not None\n142\t        assert rec.text == \"foo\"\n143\t\n144\t    def test_non_leading_token_is_not_match(self) -> None:\n145\t        # A RULEDOUT token that appears mid-line is prose, not a\n146\t        # RULEDOUT line. Only the leading-position form is recognized.\n147\t        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n148\t\n149\t    def test_similar_token_does_not_match(self) -> None:\n150\t        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n151\t        # immediately after the keyword.\n152\t        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n153\t\n154\t    def test_non_ruledout_lines_return_none(self) -> None:\n155\t        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n156\t        assert _parse_ruledout_line(\"\", 2) is None\n157\t        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n158\t\n159\t\n160\tclass TestAttachRuledOut:\n161\t    def test_nearest_strict_less_indent_wins(self) -> None:\n162\t        root = _FakeTask(indent_level=0, name=\"root\")\n163\t        child = _FakeTask(indent_level=2, name=\"child\")\n164\t        grand = _FakeTask(indent_level=4, name=\"grand\")\n165\t        # RULEDOUT at indent 4 sits as a sibling under `child`\n166\t        # (indent 2): it attaches to `child`, not to `grand` even\n167\t        # though `grand` is deeper in the stack.\n168\t        attached = _attach_ruledout(4, [root, child, grand], [root])\n169\t        assert attached is child\n170\t\n171\t    def test_skips_equal_indent_in_stack(self) -> None:\n172\t        # Equal indent is not \"strictly less\", so the equal-indent\n173\t        # entry is skipped and the search continues outward.\n174\t        root = _FakeTask(indent_level=0, name=\"root\")\n175\t        same = _FakeTask(indent_level=2, name=\"same\")\n176\t        attached = _attach_ruledout(2, [root, same], [root])\n177\t        assert attached is root\n178\t\n179\t    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n180\t        # A column-0 RULEDOUT after the stack has been popped (e.g.\n181\t        # following a same-indent sibling) finds no strictly-less\n182\t        # ancestor, so it attaches to the last root task.\n183\t        a = _FakeTask(indent_level=0, name=\"a\")\n184\t        b = _FakeTask(indent_level=0, name=\"b\")\n185\t        attached = _attach_ruledout(0, [], [a, b])\n186\t        assert attached is b\n187\t\n188\t    def test_no_ancestors_no_roots_returns_none(self) -> None:\n189\t        # A stray [RULEDOUT] before any task in the phase has nothing\n190\t        # to attach to; the caller is expected to drop it.\n191\t        assert _attach_ruledout(0, [], []) is None\n192\t\n193\t    def test_empty_stack_uses_root_fallback(self) -> None:\n194\t        root = _FakeTask(indent_level=0, name=\"root\")\n195\t        attached = _attach_ruledout(2, [], [root])\n196\t        assert attached is root\n197\t\n198\t    def test_multiple_ruledouts_on_one_task_collected_in_order(self) -> None:\n199\t        # Compose the building blocks the orchestration layer will use:\n200\t        # parse each [RULEDOUT] line, route it to its parent via\n201\t        # _attach_ruledout, then append to the parent's list. Three\n202\t        # sibling RULEDOUTs at the child indent must all land on the\n203\t        # same parent and stay in source order.\n204\t        root = _FakeTask(indent_level=0, name=\"root\")\n205\t        child = _FakeTask(indent_level=2, name=\"child\")\n206\t        stack = [root, child]\n207\t        roots = [root]\n208\t\n209\t        lines = [\n210\t            (\"    [RULEDOUT] first approach\", 10),\n211\t            (\"    [RULEDOUT] second approach\", 11),\n212\t            (\"    [RULEDOUT] third approach\", 12),\n213\t        ]\n214\t        collected: dict[str, list[tuple[str, int]]] = {}\n215\t        for raw_line, line_number in lines:\n216\t            rec = _parse_ruledout_line(raw_line, line_number)\n217\t            assert rec is not None\n218\t            target = _attach_ruledout(len(rec.indent), stack, roots)\n219\t            assert target is child\n220\t            collected.setdefault(target.name, []).append((rec.text, rec.line_number))\n221\t\n222\t        assert collected == {\n223\t            \"child\": [\n224\t                (\"first approach\", 10),\n225\t                (\"second approach\", 11),\n226\t                (\"third approach\", 12),\n227\t            ],\n228\t        }\n229\t\n230\t\n231\tclass TestDepsRe:\n232\t    def test_single_id(self) -> None:\n233\t        m = _DEPS_RE.match(\"@deps T-000001\")\n234\t        assert m is not None\n235\t        assert m.group(1) == \"\"\n236\t        assert m.group(2).split() == [\"T-000001\"]\n237\t\n238\t    def test_multiple_ids(self) -> None:\n239\t        m = _DEPS_RE.match(\"@deps T-000001 T-000002 T-000003\")\n240\t        assert m is not None\n241\t        assert m.group(1) == \"\"\n242\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\", \"T-000003\"]\n243\t\n244\t    def test_indented_captures_indent(self) -> None:\n245\t        m = _DEPS_RE.match(\"    @deps T-000001 T-000002\")\n246\t        assert m is not None\n247\t        assert m.group(1) == \"    \"\n248\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n249\t\n250\t    def test_extra_inter_id_whitespace_collapses_on_split(self) -> None:\n251\t        # Variable spacing between IDs is normalized by str.split().\n252\t        m = _DEPS_RE.match(\"@deps T-000001    T-000002\")\n253\t        assert m is not None\n254\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n255\t\n256\t    @pytest.mark.parametrize(\n257\t        \"line\",\n258\t        [\n259\t            \"\",\n260\t            \"- [ ] regular task\",\n261\t            \"@dep T-000001\",\n262\t            \"@deps\",\n263\t            \"@deps \",\n264\t            \" @deps_ T-000001\",\n265\t        ],\n266\t    )\n267\t    def test_non_deps_lines(self, line: str) -> None:\n268\t        assert _DEPS_RE.match(line) is None\n269\t\n270\t\n271\tclass TestAttachDeps:\n272\t    def test_strict_form_deps_indented_under_parent(self) -> None:\n273\t        # Canonical form: @deps is indented strictly more than the\n274\t        # task it references. Parent's indent is strictly less than\n275\t        # the deps line's, so attachment is strict (no warning).\n276\t        parent = _FakeTask(indent_level=0, name=\"parent\")\n277\t        target, lenient = _attach_deps(2, [parent])\n278\t        assert target is parent\n279\t        assert lenient is False\n280\t\n281\t    def test_lenient_form_same_indent_warns(self) -> None:\n282\t        # \"Forgot to indent\" form: @deps at the same indent as its\n283\t        # task. Still attaches, but flagged as lenient so callers can\n284\t        # emit a validation warning.\n285\t        parent = _FakeTask(indent_level=0, name=\"parent\")\n286\t        target, lenient = _attach_deps(0, [parent])\n287\t        assert target is parent\n288\t        assert lenient is True\n289\t\n290\t    def test_strict_attaches_to_innermost_ancestor(self) -> None:\n291\t        # With multiple open ancestors the innermost strictly-less-\n292\t        # indented one wins — not the outermost.\n293\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n294\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n295\t        target, lenient = _attach_deps(4, [outer, inner])\n296\t        assert target is inner\n297\t        assert lenient is False\n298\t\n299\t    def test_lenient_uses_top_of_stack_at_same_indent(self) -> None:\n300\t        # Top of stack is at deps' indent — lenient attachment to the\n301\t        # immediately preceding task.\n302\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n303\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n304\t        target, lenient = _attach_deps(2, [outer, inner])\n305\t        assert target is inner\n306\t        assert lenient is True\n307\t\n308\t    def test_outdented_deps_walks_past_deeper_top(self) -> None:\n309\t        # The most recent task is more indented than @deps, so it is\n310\t        # skipped; the search continues outward and lands on the\n311\t        # equal-indent ancestor as a lenient match.\n312\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n313\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n314\t        target, lenient = _attach_deps(0, [outer, inner])\n315\t        assert target is outer\n316\t        assert lenient is True\n317\t\n318\t    def test_empty_stack_returns_none(self) -> None:\n319\t        # A @deps line before any task in scope has nothing to attach\n320\t        # to — the caller is expected to drop it. No root-task fallback\n321\t        # is provided, unlike _attach_ruledout.\n322\t        target, lenient = _attach_deps(0, [])\n323\t        assert target is None\n324\t        assert lenient is False\n325\t\n326\t    def test_all_ancestors_more_indented_returns_none(self) -> None:\n327\t        # Pathological: deps outdented past every known ancestor.\n328\t        # Stack-walk finds no candidate at lesser-or-equal indent.\n329\t        deep = _FakeTask(indent_level=4, name=\"deep\")\n330\t        target, lenient = _attach_deps(2, [deep])\n331\t        assert target is None\n332\t        assert lenient is False\n333\t\n334\t    def test_parse_and_attach_to_nested_subtask(self) -> None:\n335\t        # Compose _DEPS_RE with _attach_deps: a deeply-indented @deps\n336\t        # line resolves to the innermost open ancestor at strictly-less\n337\t        # indent — i.e. the nested subtask, not the root task. This is\n338\t        # the end-to-end shape the higher-level parser will use.\n339\t        root = _FakeTask(indent_level=0, name=\"root\")\n340\t        child = _FakeTask(indent_level=2, name=\"child\")\n341\t        grand = _FakeTask(indent_level=4, name=\"grand\")\n342\t        stack = [root, child, grand]\n343\t\n344\t        m = _DEPS_RE.match(\"      @deps T-000001 T-000002\")\n345\t        assert m is not None\n346\t        indent = len(m.group(1))\n347\t        ids = m.group(2).split()\n348\t\n349\t        target, lenient = _attach_deps(indent, stack)\n350\t        assert target is grand\n351\t        assert lenient is False\n352\t        assert ids == [\"T-000001\", \"T-000002\"]\n353\t\n354\t\n355\tclass TestExtractFlagTags:\n356\t    def test_no_tags(self) -> None:\n357\t        tags, rest = _extract_flag_tags(\"plain task text\")\n358\t        assert tags == ()\n359\t        assert rest == \"plain task text\"\n360\t\n361\t    def test_user(self) -> None:\n362\t        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n363\t        assert tags == (\"USER\",)\n364\t        assert rest == \"verify the menu\"\n365\t\n366\t    def test_batch(self) -> None:\n367\t        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n368\t        assert tags == (\"BATCH\",)\n369\t        assert rest == \"sub-task group\"\n370\t\n371\t    def test_user_and_batch_combined(self) -> None:\n372\t        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n373\t        assert tags == (\"USER\", \"BATCH\")\n374\t        assert rest == \"both flags\"\n375\t\n376\t    def test_adjacent_tags_without_separator(self) -> None:\n377\t        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n378\t        assert tags == (\"USER\", \"BATCH\")\n379\t        assert rest == \"no gap\"\n380\t\n381\t    def test_non_leading_tag_is_prose(self) -> None:\n382\t        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n383\t        assert tags == ()\n384\t        assert rest == \"Document the [USER] tag\"\n385\t\n386\t    def test_only_first_run_is_tags(self) -> None:\n387\t        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n388\t        assert tags == (\"USER\",)\n389\t        assert rest == \"middle [BATCH] later\"\n390\t\n391\t    def test_empty_input(self) -> None:\n392\t        tags, rest = _extract_flag_tags(\"\")\n393\t        assert tags == ()\n394\t        assert rest == \"\"\n395\t\n396\t\n397\tclass TestExtractActionTag:\n398\t    def test_no_action_tag(self) -> None:\n399\t        tag, rest = _extract_action_tag(\"plain task text\")\n400\t        assert tag is None\n401\t        assert rest == \"plain task text\"\n402\t\n403\t    def test_action_with_args(self) -> None:\n404\t        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n405\t        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n406\t        assert rest == \"\"\n407\t\n408\t    def test_action_without_args(self) -> None:\n409\t        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n410\t        assert tag == (\"noop\", \"\")\n411\t        assert rest == \"\"\n412\t\n413\t    def test_args_extend_to_end_of_line(self) -> None:\n414\t        # Argument string is text from closing bracket to end of line;\n415\t        # bracketed-looking content in args stays in args.\n416\t        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n417\t        assert tag == (\"run\", \"do [feat: x]\")\n418\t        assert rest == \"\"\n419\t\n420\t    def test_non_leading_auto_is_prose(self) -> None:\n421\t        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n422\t        assert tag is None\n423\t        assert rest == \"Document the [AUTO:run] tag\"\n424\t\n425\t\n426\tclass TestExtractAnnotations:\n427\t    def test_no_annotation(self) -> None:\n428\t        ann, rest = _extract_annotations(\"plain task text\")\n429\t        assert ann == ()\n430\t        assert rest == \"plain task text\"\n431\t\n432\t    def test_single_feat(self) -> None:\n433\t        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n434\t        assert ann == ((\"feat\", '\"menu wired\"'),)\n435\t        assert rest == \"do thing\"\n436\t\n437\t    def test_single_fix(self) -> None:\n438\t        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n439\t        assert ann == ((\"fix\", '\"race\"'),)\n440\t        assert rest == \"fixed it\"\n441\t\n442\t    def test_multiple_annotations_preserve_order(self) -> None:\n443\t        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n444\t        assert ann == (\n445\t            (\"feat\", '\"first\"'),\n446\t            (\"fix\", '\"second\"'),\n447\t        )\n448\t        assert rest == \"do thing\"\n449\t\n450\t    def test_nested_brackets_in_value(self) -> None:\n451\t        # Balanced brackets inside the value are stepped over by the\n452\t        # right-to-left depth scan and stay inside the annotation.\n453\t        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n454\t        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n455\t        assert rest == \"do thing\"\n456\t\n457\t    def test_unquoted_nested_brackets_in_value(self) -> None:\n458\t        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n459\t        assert ann == ((\"feat\", \"a [b] c\"),)\n460\t        assert rest == \"do\"\n461\t\n462\t    def test_prose_bracket_without_separator_is_text(self) -> None:\n463\t        # A `[` abutting a non-whitespace character is task text, not\n464\t        # the start of an annotation.\n465\t        ann, rest = _extract_annotations(\"see config[feat: x]\")\n466\t        assert ann == ()\n467\t        assert rest == \"see config[feat: x]\"\n468\t\n469\t    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n470\t        # `[AUTO:run]` has no whitespace after its colon and so is not\n471\t        # an annotation under this extractor's rules.\n472\t        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n473\t        assert ann == ()\n474\t        assert rest == \"[AUTO:run] cmd\"\n475\t\n476\t    def test_unmatched_open_bracket(self) -> None:\n477\t        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n478\t        assert ann == ()\n479\t        assert rest == \"dangling brackets feat ]\"\n480\t\n481\t    def test_annotation_alone_consumes_to_empty(self) -> None:\n482\t        ann, rest = _extract_annotations('[feat: \"lone\"]')\n483\t        assert ann == ((\"feat\", '\"lone\"'),)\n484\t        assert rest == \"\"\n485\t\n486\t\n487\tclass TestTagInteractions:\n488\t    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n489\t        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n490\t        # Annotation must be stripped before action tag, because action\n491\t        # tag args span to end of line.\n492\t        ann, after_ann = _extract_annotations(text)\n493\t        assert ann == ((\"feat\", '\"done\"'),)\n494\t        tags, after_flags = _extract_flag_tags(after_ann)\n495\t        assert tags == (\"BATCH\",)\n496\t        action, after_action = _extract_action_tag(after_flags)\n497\t        assert action == (\"run_cli\", \"mcloop --dry-run\")\n498\t        assert after_action == \"\"\n499\t\n500\t    def test_flags_and_plain_text(self) -> None:\n501\t        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n502\t        assert ann == ()\n503\t        tags, after_flags = _extract_flag_tags(after_ann)\n504\t        assert tags == (\"USER\", \"BATCH\")\n505\t        action, after_action = _extract_action_tag(after_flags)\n506\t        assert action is None\n507\t        assert after_action == \"verify thing\"\n508\t\n509\t    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n510\t        text = \"Implement [USER] and [AUTO:run] tokenization\"\n511\t        ann, after_ann = _extract_annotations(text)\n512\t        tags, after_flags = _extract_flag_tags(after_ann)\n513\t        action, after_action = _extract_action_tag(after_flags)\n514\t        assert ann == ()\n515\t        assert tags == ()\n516\t        assert action is None\n517\t        assert after_action == text\n518\t"}]},"parent_tool_use_id":null,"session_id":"c0ad05b9-4ddd-4925-a04d-c46811d784c5","uuid":"4f9517d4-2195-4642-ae95-e329faef9f9b","timestamp":"2026-05-16T02:38:51.157Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"\"\"\"Tests for bob_tools.planfile.parser building blocks.\n\nStage 2 task-line recognizers and tag extractors:\n\n  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n  - ``_parse_task_line`` returns a raw record on checkbox lines and\n    ``None`` on anything else.\n  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n    sibling lines and returns indent, body, and source line number.\n  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n    line: nearest strictly-less-indented open ancestor, with fallback\n    to the most recent root task (mcloop's ``parse`` parity). The\n    parse-then-attach composition test confirms multiple RULEDOUT\n    lines on one task are collected in source order.\n  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n    enforces that at least one ID follows the keyword.\n  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n    sibling line: the innermost open ancestor at strictly-less indent\n    is the strict-form parent; an ancestor at equal indent is the\n    lenient-form parent (caller should warn). No root-task fallback.\n    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n    tokens, in isolation and combination, and leaves non-leading\n    occurrences as prose (design doc section 4.3).\n  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n    treats the rest of the line as its argument string; non-leading\n    occurrences are prose.\n  - ``_extract_annotations`` consumes trailing ``[key: value]``\n    annotations, handles multiple annotations and nested brackets in\n    values, and leaves bracketed prose that is not separated from\n    preceding text by whitespace in place.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\n\nimport pytest\n\nfrom bob_tools.planfile.parser import (\n    _CHECKBOX_RE,\n    _DEPS_RE,\n    _attach_deps,\n    _attach_ruledout,\n    _extract_action_tag,\n    _extract_annotations,\n    _extract_flag_tags,\n    _parse_ruledout_line,\n    _parse_task_line,\n)\n\n\n@dataclass\nclass _FakeTask:\n    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n\n    indent_level: int\n    name: str = \"\"\n\n\nclass TestCheckboxRe:\n    @pytest.mark.parametrize(\n        (\"line\", \"indent\", \"marker\", \"text\"),\n        [\n            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n        ],\n    )\n    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n        m = _CHECKBOX_RE.match(line)\n        assert m is not None\n        assert m.group(1) == indent\n        assert m.group(2) == marker\n        assert m.group(3) == text\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"## Stage 1: Core\",\n            \"- [] missing space inside brackets\",\n            \"- [y] unsupported marker\",\n            \"- [ ]\",\n            \"* [ ] wrong bullet\",\n            \"Plain prose line\",\n        ],\n    )\n    def test_non_matches(self, line: str) -> None:\n        assert _CHECKBOX_RE.match(line) is None\n\n\nclass TestParseTaskLine:\n    def test_match_returns_raw_record(self) -> None:\n        rec = _parse_task_line(\"  - [x] foo\", 7)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.status_char == \"x\"\n        assert rec.text == \"foo\"\n        assert rec.line_number == 7\n\n    def test_match_failed_marker(self) -> None:\n        rec = _parse_task_line(\"- [!] bad\", 12)\n        assert rec is not None\n        assert rec.status_char == \"!\"\n        assert rec.line_number == 12\n\n    def test_non_task_returns_none(self) -> None:\n        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n        assert _parse_task_line(\"\", 2) is None\n        assert _parse_task_line(\"Some prose\", 3) is None\n\n\nclass TestParseRuledOutLine:\n    def test_indented_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.text == \"tried restart\"\n        assert rec.line_number == 5\n\n    def test_top_level_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n        assert rec is not None\n        assert rec.indent == \"\"\n        assert rec.text == \"orphan approach\"\n\n    def test_empty_body(self) -> None:\n        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n        assert rec is not None\n        assert rec.indent == \"    \"\n        assert rec.text == \"\"\n\n    def test_trailing_whitespace_stripped(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n        assert rec is not None\n        assert rec.text == \"foo\"\n\n    def test_non_leading_token_is_not_match(self) -> None:\n        # A RULEDOUT token that appears mid-line is prose, not a\n        # RULEDOUT line. Only the leading-position form is recognized.\n        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n\n    def test_similar_token_does_not_match(self) -> None:\n        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n        # immediately after the keyword.\n        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n\n    def test_non_ruledout_lines_return_none(self) -> None:\n        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n        assert _parse_ruledout_line(\"\", 2) is None\n        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n\n\nclass TestAttachRuledOut:\n    def test_nearest_strict_less_indent_wins(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        grand = _FakeTask(indent_level=4, name=\"grand\")\n        # RULEDOUT at indent 4 sits as a sibling under `child`\n        # (indent 2): it attaches to `child`, not to `grand` even\n        # though `grand` is deeper in the stack.\n        attached = _attach_ruledout(4, [root, child, grand], [root])\n        assert attached is child\n\n    def test_skips_equal_indent_in_stack(self) -> None:\n        # Equal indent is not \"strictly less\", so the equal-indent\n        # entry is skipped and the search continues outward.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        same = _FakeTask(indent_level=2, name=\"same\")\n        attached = _attach_ruledout(2, [root, same], [root])\n        assert attached is root\n\n    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n        # A column-0 RULEDOUT after the stack has been popped (e.g.\n        # following a same-indent sibling) finds no strictly-less\n        # ancestor, so it attaches to the last root task.\n        a = _FakeTask(indent_level=0, name=\"a\")\n        b = _FakeTask(indent_level=0, name=\"b\")\n        attached = _attach_ruledout(0, [], [a, b])\n        assert attached is b\n\n    def test_no_ancestors_no_roots_returns_none(self) -> None:\n        # A stray [RULEDOUT] before any task in the phase has nothing\n        # to attach to; the caller is expected to drop it.\n        assert _attach_ruledout(0, [], []) is None\n\n    def test_empty_stack_uses_root_fallback(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        attached = _attach_ruledout(2, [], [root])\n        assert attached is root\n\n    def test_multiple_ruledouts_on_one_task_collected_in_order(self) -> None:\n        # Compose the building blocks the orchestration layer will use:\n        # parse each [RULEDOUT] line, route it to its parent via\n        # _attach_ruledout, then append to the parent's list. Three\n        # sibling RULEDOUTs at the child indent must all land on the\n        # same parent and stay in source order.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        stack = [root, child]\n        roots = [root]\n\n        lines = [\n            (\"    [RULEDOUT] first approach\", 10),\n            (\"    [RULEDOUT] second approach\", 11),\n            (\"    [RULEDOUT] third approach\", 12),\n        ]\n        collected: dict[str, list[tuple[str, int]]] = {}\n        for raw_line, line_number in lines:\n            rec = _parse_ruledout_line(raw_line, line_number)\n            assert rec is not None\n            target = _attach_ruledout(len(rec.indent), stack, roots)\n            assert target is child\n            collected.setdefault(target.name, []).append((rec.text, rec.line_number))\n\n        assert collected == {\n            \"child\": [\n                (\"first approach\", 10),\n                (\"second approach\", 11),\n                (\"third approach\", 12),\n            ],\n        }\n\n\nclass TestDepsRe:\n    def test_single_id(self) -> None:\n        m = _DEPS_RE.match(\"@deps T-000001\")\n        assert m is not None\n        assert m.group(1) == \"\"\n        assert m.group(2).split() == [\"T-000001\"]\n\n    def test_multiple_ids(self) -> None:\n        m = _DEPS_RE.match(\"@deps T-000001 T-000002 T-000003\")\n        assert m is not None\n        assert m.group(1) == \"\"\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\", \"T-000003\"]\n\n    def test_indented_captures_indent(self) -> None:\n        m = _DEPS_RE.match(\"    @deps T-000001 T-000002\")\n        assert m is not None\n        assert m.group(1) == \"    \"\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n\n    def test_extra_inter_id_whitespace_collapses_on_split(self) -> None:\n        # Variable spacing between IDs is normalized by str.split().\n        m = _DEPS_RE.match(\"@deps T-000001    T-000002\")\n        assert m is not None\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"- [ ] regular task\",\n            \"@dep T-000001\",\n            \"@deps\",\n            \"@deps \",\n            \" @deps_ T-000001\",\n        ],\n    )\n    def test_non_deps_lines(self, line: str) -> None:\n        assert _DEPS_RE.match(line) is None\n\n\nclass TestAttachDeps:\n    def test_strict_form_deps_indented_under_parent(self) -> None:\n        # Canonical form: @deps is indented strictly more than the\n        # task it references. Parent's indent is strictly less than\n        # the deps line's, so attachment is strict (no warning).\n        parent = _FakeTask(indent_level=0, name=\"parent\")\n        target, lenient = _attach_deps(2, [parent])\n        assert target is parent\n        assert lenient is False\n\n    def test_lenient_form_same_indent_warns(self) -> None:\n        # \"Forgot to indent\" form: @deps at the same indent as its\n        # task. Still attaches, but flagged as lenient so callers can\n        # emit a validation warning.\n        parent = _FakeTask(indent_level=0, name=\"parent\")\n        target, lenient = _attach_deps(0, [parent])\n        assert target is parent\n        assert lenient is True\n\n    def test_strict_attaches_to_innermost_ancestor(self) -> None:\n        # With multiple open ancestors the innermost strictly-less-\n        # indented one wins — not the outermost.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(4, [outer, inner])\n        assert target is inner\n        assert lenient is False\n\n    def test_lenient_uses_top_of_stack_at_same_indent(self) -> None:\n        # Top of stack is at deps' indent — lenient attachment to the\n        # immediately preceding task.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(2, [outer, inner])\n        assert target is inner\n        assert lenient is True\n\n    def test_outdented_deps_walks_past_deeper_top(self) -> None:\n        # The most recent task is more indented than @deps, so it is\n        # skipped; the search continues outward and lands on the\n        # equal-indent ancestor as a lenient match.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(0, [outer, inner])\n        assert target is outer\n        assert lenient is True\n\n    def test_empty_stack_returns_none(self) -> None:\n        # A @deps line before any task in scope has nothing to attach\n        # to — the caller is expected to drop it. No root-task fallback\n        # is provided, unlike _attach_ruledout.\n        target, lenient = _attach_deps(0, [])\n        assert target is None\n        assert lenient is False\n\n    def test_all_ancestors_more_indented_returns_none(self) -> None:\n        # Pathological: deps outdented past every known ancestor.\n        # Stack-walk finds no candidate at lesser-or-equal indent.\n        deep = _FakeTask(indent_level=4, name=\"deep\")\n        target, lenient = _attach_deps(2, [deep])\n        assert target is None\n        assert lenient is False\n\n    def test_parse_and_attach_to_nested_subtask(self) -> None:\n        # Compose _DEPS_RE with _attach_deps: a deeply-indented @deps\n        # line resolves to the innermost open ancestor at strictly-less\n        # indent — i.e. the nested subtask, not the root task. This is\n        # the end-to-end shape the higher-level parser will use.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        grand = _FakeTask(indent_level=4, name=\"grand\")\n        stack = [root, child, grand]\n\n        m = _DEPS_RE.match(\"      @deps T-000001 T-000002\")\n        assert m is not None\n        indent = len(m.group(1))\n        ids = m.group(2).split()\n\n        target, lenient = _attach_deps(indent, stack)\n        assert target is grand\n        assert lenient is False\n        assert ids == [\"T-000001\", \"T-000002\"]\n\n\nclass TestExtractFlagTags:\n    def test_no_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"plain task text\")\n        assert tags == ()\n        assert rest == \"plain task text\"\n\n    def test_user(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n        assert tags == (\"USER\",)\n        assert rest == \"verify the menu\"\n\n    def test_batch(self) -> None:\n        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n        assert tags == (\"BATCH\",)\n        assert rest == \"sub-task group\"\n\n    def test_user_and_batch_combined(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"both flags\"\n\n    def test_adjacent_tags_without_separator(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"no gap\"\n\n    def test_non_leading_tag_is_prose(self) -> None:\n        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n        assert tags == ()\n        assert rest == \"Document the [USER] tag\"\n\n    def test_only_first_run_is_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n        assert tags == (\"USER\",)\n        assert rest == \"middle [BATCH] later\"\n\n    def test_empty_input(self) -> None:\n        tags, rest = _extract_flag_tags(\"\")\n        assert tags == ()\n        assert rest == \"\"\n\n\nclass TestExtractActionTag:\n    def test_no_action_tag(self) -> None:\n        tag, rest = _extract_action_tag(\"plain task text\")\n        assert tag is None\n        assert rest == \"plain task text\"\n\n    def test_action_with_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n        assert rest == \"\"\n\n    def test_action_without_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n        assert tag == (\"noop\", \"\")\n        assert rest == \"\"\n\n    def test_args_extend_to_end_of_line(self) -> None:\n        # Argument string is text from closing bracket to end of line;\n        # bracketed-looking content in args stays in args.\n        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n        assert tag == (\"run\", \"do [feat: x]\")\n        assert rest == \"\"\n\n    def test_non_leading_auto_is_prose(self) -> None:\n        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n        assert tag is None\n        assert rest == \"Document the [AUTO:run] tag\"\n\n\nclass TestExtractAnnotations:\n    def test_no_annotation(self) -> None:\n        ann, rest = _extract_annotations(\"plain task text\")\n        assert ann == ()\n        assert rest == \"plain task text\"\n\n    def test_single_feat(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n        assert ann == ((\"feat\", '\"menu wired\"'),)\n        assert rest == \"do thing\"\n\n    def test_single_fix(self) -> None:\n        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n        assert ann == ((\"fix\", '\"race\"'),)\n        assert rest == \"fixed it\"\n\n    def test_multiple_annotations_preserve_order(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n        assert ann == (\n            (\"feat\", '\"first\"'),\n            (\"fix\", '\"second\"'),\n        )\n        assert rest == \"do thing\"\n\n    def test_nested_brackets_in_value(self) -> None:\n        # Balanced brackets inside the value are stepped over by the\n        # right-to-left depth scan and stay inside the annotation.\n        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n        assert rest == \"do thing\"\n\n    def test_unquoted_nested_brackets_in_value(self) -> None:\n        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n        assert ann == ((\"feat\", \"a [b] c\"),)\n        assert rest == \"do\"\n\n    def test_prose_bracket_without_separator_is_text(self) -> None:\n        # A `[` abutting a non-whitespace character is task text, not\n        # the start of an annotation.\n        ann, rest = _extract_annotations(\"see config[feat: x]\")\n        assert ann == ()\n        assert rest == \"see config[feat: x]\"\n\n    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n        # `[AUTO:run]` has no whitespace after its colon and so is not\n        # an annotation under this extractor's rules.\n        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n        assert ann == ()\n        assert rest == \"[AUTO:run] cmd\"\n\n    def test_unmatched_open_bracket(self) -> None:\n        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n        assert ann == ()\n        assert rest == \"dangling brackets feat ]\"\n\n    def test_annotation_alone_consumes_to_empty(self) -> None:\n        ann, rest = _extract_annotations('[feat: \"lone\"]')\n        assert ann == ((\"feat\", '\"lone\"'),)\n        assert rest == \"\"\n\n\nclass TestTagInteractions:\n    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n        # Annotation must be stripped before action tag, because action\n        # tag args span to end of line.\n        ann, after_ann = _extract_annotations(text)\n        assert ann == ((\"feat\", '\"done\"'),)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"BATCH\",)\n        action, after_action = _extract_action_tag(after_flags)\n        assert action == (\"run_cli\", \"mcloop --dry-run\")\n        assert after_action == \"\"\n\n    def test_flags_and_plain_text(self) -> None:\n        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n        assert ann == ()\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"USER\", \"BATCH\")\n        action, after_action = _extract_action_tag(after_flags)\n        assert action is None\n        assert after_action == \"verify thing\"\n\n    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n        text = \"Implement [USER] and [AUTO:run] tokenization\"\n        ann, after_ann = _extract_annotations(text)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        action, after_action = _extract_action_tag(after_flags)\n        assert ann == ()\n        assert tags == ()\n        assert action is None\n        assert after_action == text\n","numLines":518,"startLine":1,"totalLines":518}}}
