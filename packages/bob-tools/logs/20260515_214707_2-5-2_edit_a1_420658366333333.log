{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GWP5sMt4Fnj19ymz5JEwvA","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom collections.abc import Sequence\n7\tfrom dataclasses import dataclass\n8\tfrom pathlib import Path\n9\tfrom typing import Protocol, TypeVar\n10\t\n11\tfrom bob_tools.planfile.model import Plan\n12\t\n13\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n14\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n15\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n16\t\n17\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n18\t# caller strips any inter-tag whitespace between iterations.\n19\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n20\t\n21\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n22\t# after the closing bracket (with the single separating space removed).\n23\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n24\t\n25\t# Content of an annotation (the bytes between `[` and `]`): an\n26\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n27\t# value. The required whitespace after the colon is what distinguishes\n28\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n29\t# after its colon).\n30\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n31\t\n32\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n33\t# token, and optional trailing text. Matches mcloop's `parse`, which\n34\t# treats a line as RULEDOUT when its stripped form starts with the\n35\t# literal bracket token.\n36\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n37\t\n38\t# Deps sibling line: optional indent, the literal `@deps` token, then\n39\t# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n40\t# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n41\t# group captures the remainder of the line; splitting on whitespace\n42\t# and validating each ID is a higher-level step.\n43\t_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n44\t\n45\t\n46\tdef parse_plan(\n47\t    text: str,\n48\t    *,\n49\t    strict: bool = False,\n50\t    source_path: Path | None = None,\n51\t) -> Plan:\n52\t    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n53\t\n54\t    ``strict=False`` (the default) is compatibility mode — accepts the\n55\t    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n56\t    line, optional task IDs, no phase-id comments). ``strict=True``\n57\t    enables the format additions in design doc section 4 (magic line,\n58\t    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n59\t\n60\t    Stage 2.5.1 wires the signature only: callers may pass ``strict``\n61\t    and ``source_path`` and receive a :class:`Plan`. The state machine\n62\t    that walks ``text`` into phases, subsections, tasks, and bugs is\n63\t    added in 2.5.2; project title and prose extraction in 2.5.3;\n64\t    syntax-error reporting in 2.5.4. Strict-mode behavior lands in\n65\t    Stage 3. Until then ``parse_plan`` returns an empty plan that\n66\t    carries through ``source_path`` for downstream error messages.\n67\t    \"\"\"\n68\t    del text, strict\n69\t    return Plan(\n70\t        magic_version=None,\n71\t        project_title=\"\",\n72\t        preamble=\"\",\n73\t        phases=(),\n74\t        bugs=None,\n75\t        source_path=source_path,\n76\t    )\n77\t\n78\t\n79\t@dataclass(frozen=True)\n80\tclass _RawTaskLine:\n81\t    \"\"\"Recognize-step output of `_parse_task_line`.\n82\t\n83\t    Stage 2 of the parser splits recognize-then-classify. This record\n84\t    is the recognize step: indent text, status marker, body text, and\n85\t    source line number. Higher-level functions classify the body into\n86\t    task id, tags, deps, and prose.\n87\t    \"\"\"\n88\t\n89\t    indent: str\n90\t    status_char: str\n91\t    text: str\n92\t    line_number: int\n93\t\n94\t\n95\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n96\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n97\t    m = _CHECKBOX_RE.match(line)\n98\t    if m is None:\n99\t        return None\n100\t    return _RawTaskLine(\n101\t        indent=m.group(1),\n102\t        status_char=m.group(2),\n103\t        text=m.group(3),\n104\t        line_number=line_number,\n105\t    )\n106\t\n107\t\n108\t@dataclass(frozen=True)\n109\tclass _RawRuledOut:\n110\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n111\t\n112\t    A RULEDOUT line is a sibling of the task it pertains to (design\n113\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n114\t    captures only indent, body text, and source line number; attaching\n115\t    the line to its parent task by indentation is a higher-level step.\n116\t    \"\"\"\n117\t\n118\t    indent: str\n119\t    text: str\n120\t    line_number: int\n121\t\n122\t\n123\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n124\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n125\t\n126\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n127\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n128\t    whitespace on the body text is stripped; an empty body is allowed.\n129\t    \"\"\"\n130\t    m = _RULEDOUT_RE.match(line)\n131\t    if m is None:\n132\t        return None\n133\t    return _RawRuledOut(\n134\t        indent=m.group(1),\n135\t        text=m.group(2).strip(),\n136\t        line_number=line_number,\n137\t    )\n138\t\n139\t\n140\tclass _HasIndentLevel(Protocol):\n141\t    \"\"\"Anything with an integer ``indent_level`` attribute.\n142\t\n143\t    Used by :func:`_attach_ruledout` so it can resolve attachment over\n144\t    either the eventual frozen ``Task`` model objects or the mutable\n145\t    builder records the parser uses while constructing them.\n146\t    \"\"\"\n147\t\n148\t    @property\n149\t    def indent_level(self) -> int: ...\n150\t\n151\t\n152\t_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n153\t\n154\t\n155\tdef _attach_ruledout(\n156\t    indent: int,\n157\t    stack: Sequence[_T],\n158\t    root_tasks: Sequence[_T],\n159\t) -> _T | None:\n160\t    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n161\t\n162\t    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n163\t    the open-ancestor stack from innermost to outermost and return the\n164\t    first task whose indent is strictly less than the RULEDOUT line's\n165\t    indent. If no such ancestor exists in the current phase, fall back\n166\t    to the most recent root task (mcloop's \"orphan\" handling). Returns\n167\t    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n168\t    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n169\t    the caller should drop.\n170\t    \"\"\"\n171\t    for task in reversed(stack):\n172\t        if task.indent_level < indent:\n173\t            return task\n174\t    if root_tasks:\n175\t        return root_tasks[-1]\n176\t    return None\n177\t\n178\t\n179\tdef _attach_deps(\n180\t    indent: int,\n181\t    stack: Sequence[_T],\n182\t) -> tuple[_T | None, bool]:\n183\t    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n184\t\n185\t    Walks the open-ancestor stack from innermost (top) to outermost.\n186\t    Returns ``(parent, False)`` for the strict form — first ancestor\n187\t    whose indent is strictly less than the deps line's indent. Returns\n188\t    ``(parent, True)`` for the lenient form — first ancestor at the\n189\t    same indent as the deps line, which callers should report as a\n190\t    validation warning (the deps was not indented under its task).\n191\t    Returns ``(None, False)`` when no candidate exists; the caller\n192\t    should drop the line.\n193\t\n194\t    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n195\t    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n196\t    indent is malformed input rather than an orphan that needs adopting.\n197\t    \"\"\"\n198\t    for task in reversed(stack):\n199\t        if task.indent_level < indent:\n200\t            return task, False\n201\t        if task.indent_level == indent:\n202\t            return task, True\n203\t    return None, False\n204\t\n205\t\n206\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n207\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n208\t\n209\t    Per design doc section 4.3, flag tags are recognized only at the\n210\t    leading position. The caller is responsible for stripping the task\n211\t    ID (if any) first. A bracketed flag form appearing later in the\n212\t    text is prose and is left in place.\n213\t    \"\"\"\n214\t    tags: list[str] = []\n215\t    remaining = text\n216\t    while True:\n217\t        m = _FLAG_TAG_RE.match(remaining)\n218\t        if m is None:\n219\t            break\n220\t        tags.append(m.group(1))\n221\t        remaining = remaining[m.end() :].lstrip()\n222\t    return tuple(tags), remaining\n223\t\n224\t\n225\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n226\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n227\t\n228\t    Per design doc section 4.3, the action tag is recognized only at\n229\t    the leading position, after any flag tags. The argument string is\n230\t    the text from the closing bracket to end of line, with the single\n231\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n232\t    are prose and are left in place.\n233\t\n234\t    Returns ``(None, text)`` when no leading action tag is present;\n235\t    otherwise consumes the rest of the line as the argument string\n236\t    and returns ``((action, args), \"\")``.\n237\t    \"\"\"\n238\t    m = _ACTION_TAG_RE.match(text)\n239\t    if m is None:\n240\t        return None, text\n241\t    action = m.group(1)\n242\t    args = text[m.end() :].lstrip()\n243\t    return (action, args), \"\"\n244\t\n245\t\n246\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n247\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n248\t\n249\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n250\t    are bracketed, and are separated from the preceding text by\n251\t    whitespace. Multiple annotations are allowed. Values may contain\n252\t    balanced bracket pairs; this function scans right-to-left with\n253\t    bracket-depth tracking so nested brackets stay inside a single\n254\t    annotation rather than being misparsed as a separate one.\n255\t\n256\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n257\t    accepts any identifier-shaped key. Validation of allowed keys is\n258\t    a separate concern.\n259\t    \"\"\"\n260\t    annotations: list[tuple[str, str]] = []\n261\t    remaining = text\n262\t    while True:\n263\t        rstripped = remaining.rstrip()\n264\t        if not rstripped.endswith(\"]\"):\n265\t            remaining = rstripped\n266\t            break\n267\t        start = _find_matching_open_bracket(rstripped)\n268\t        if start is None:\n269\t            remaining = rstripped\n270\t            break\n271\t        # An annotation must be separated from preceding text by\n272\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n273\t        # character is part of the task text, not an annotation.\n274\t        if start > 0 and not rstripped[start - 1].isspace():\n275\t            remaining = rstripped\n276\t            break\n277\t        content = rstripped[start + 1 : -1]\n278\t        m = _ANNOTATION_CONTENT_RE.match(content)\n279\t        if m is None:\n280\t            remaining = rstripped\n281\t            break\n282\t        annotations.insert(0, (m.group(1), m.group(2)))\n283\t        remaining = rstripped[:start].rstrip()\n284\t    return tuple(annotations), remaining\n285\t\n286\t\n287\tdef _find_matching_open_bracket(s: str) -> int | None:\n288\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n289\t\n290\t    Walks right-to-left tracking bracket depth so balanced nested\n291\t    brackets inside the candidate annotation are stepped over.\n292\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n293\t    opener.\n294\t    \"\"\"\n295\t    if not s.endswith(\"]\"):\n296\t        return None\n297\t    depth = 0\n298\t    for i in range(len(s) - 1, -1, -1):\n299\t        c = s[i]\n300\t        if c == \"]\":\n301\t            depth += 1\n302\t        elif c == \"[\":\n303\t            depth -= 1\n304\t            if depth == 0:\n305\t                return i\n306\t    return None\n307\t"}]},"parent_tool_use_id":null,"session_id":"c0ad05b9-4ddd-4925-a04d-c46811d784c5","uuid":"33783f7f-7487-4d06-94a5-fa1b4eb7ccd3","timestamp":"2026-05-16T02:38:24.132Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections.abc import Sequence\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Protocol, TypeVar\n\nfrom bob_tools.planfile.model import Plan\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n# Deps sibling line: optional indent, the literal `@deps` token, then\n# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n# group captures the remainder of the line; splitting on whitespace\n# and validating each ID is a higher-level step.\n_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n\n\ndef parse_plan(\n    text: str,\n    *,\n    strict: bool = False,\n    source_path: Path | None = None,\n) -> Plan:\n    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n\n    ``strict=False`` (the default) is compatibility mode — accepts the\n    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n    line, optional task IDs, no phase-id comments). ``strict=True``\n    enables the format additions in design doc section 4 (magic line,\n    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n\n    Stage 2.5.1 wires the signature only: callers may pass ``strict``\n    and ``source_path`` and receive a :class:`Plan`. The state machine\n    that walks ``text`` into phases, subsections, tasks, and bugs is\n    added in 2.5.2; project title and prose extraction in 2.5.3;\n    syntax-error reporting in 2.5.4. Strict-mode behavior lands in\n    Stage 3. Until then ``parse_plan`` returns an empty plan that\n    carries through ``source_path`` for downstream error messages.\n    \"\"\"\n    del text, strict\n    return Plan(\n        magic_version=None,\n        project_title=\"\",\n        preamble=\"\",\n        phases=(),\n        bugs=None,\n        source_path=source_path,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\nclass _HasIndentLevel(Protocol):\n    \"\"\"Anything with an integer ``indent_level`` attribute.\n\n    Used by :func:`_attach_ruledout` so it can resolve attachment over\n    either the eventual frozen ``Task`` model objects or the mutable\n    builder records the parser uses while constructing them.\n    \"\"\"\n\n    @property\n    def indent_level(self) -> int: ...\n\n\n_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n\n\ndef _attach_ruledout(\n    indent: int,\n    stack: Sequence[_T],\n    root_tasks: Sequence[_T],\n) -> _T | None:\n    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n\n    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n    the open-ancestor stack from innermost to outermost and return the\n    first task whose indent is strictly less than the RULEDOUT line's\n    indent. If no such ancestor exists in the current phase, fall back\n    to the most recent root task (mcloop's \"orphan\" handling). Returns\n    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n    the caller should drop.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task\n    if root_tasks:\n        return root_tasks[-1]\n    return None\n\n\ndef _attach_deps(\n    indent: int,\n    stack: Sequence[_T],\n) -> tuple[_T | None, bool]:\n    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n\n    Walks the open-ancestor stack from innermost (top) to outermost.\n    Returns ``(parent, False)`` for the strict form — first ancestor\n    whose indent is strictly less than the deps line's indent. Returns\n    ``(parent, True)`` for the lenient form — first ancestor at the\n    same indent as the deps line, which callers should report as a\n    validation warning (the deps was not indented under its task).\n    Returns ``(None, False)`` when no candidate exists; the caller\n    should drop the line.\n\n    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n    indent is malformed input rather than an orphan that needs adopting.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task, False\n        if task.indent_level == indent:\n            return task, True\n    return None, False\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n","numLines":307,"startLine":1,"totalLines":307}}}
