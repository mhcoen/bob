{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015UsJyFi3NqpBSFX5WVTorN","type":"tool_result","content":"1\t\"\"\"Tests for bob_tools.planfile.parser building blocks.\n2\t\n3\tStage 2 task-line recognizers and tag extractors:\n4\t\n5\t  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n6\t    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n7\t  - ``_parse_task_line`` returns a raw record on checkbox lines and\n8\t    ``None`` on anything else.\n9\t  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n10\t    sibling lines and returns indent, body, and source line number.\n11\t  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n12\t    line: nearest strictly-less-indented open ancestor, with fallback\n13\t    to the most recent root task (mcloop's ``parse`` parity). The\n14\t    parse-then-attach composition test confirms multiple RULEDOUT\n15\t    lines on one task are collected in source order.\n16\t  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n17\t    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n18\t    enforces that at least one ID follows the keyword.\n19\t  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n20\t    sibling line: the innermost open ancestor at strictly-less indent\n21\t    is the strict-form parent; an ancestor at equal indent is the\n22\t    lenient-form parent (caller should warn). No root-task fallback.\n23\t    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n24\t    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n25\t  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n26\t    tokens, in isolation and combination, and leaves non-leading\n27\t    occurrences as prose (design doc section 4.3).\n28\t  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n29\t    treats the rest of the line as its argument string; non-leading\n30\t    occurrences are prose.\n31\t  - ``_extract_annotations`` consumes trailing ``[key: value]``\n32\t    annotations, handles multiple annotations and nested brackets in\n33\t    values, and leaves bracketed prose that is not separated from\n34\t    preceding text by whitespace in place.\n35\t\"\"\"\n36\t\n37\tfrom __future__ import annotations\n38\t\n39\tfrom dataclasses import dataclass\n40\tfrom pathlib import Path\n41\t\n42\timport pytest\n43\t\n44\tfrom bob_tools.planfile.model import PlanSyntaxError, TaskStatus\n45\tfrom bob_tools.planfile.parser import (\n46\t    _CHECKBOX_RE,\n47\t    _DEPS_RE,\n48\t    _attach_deps,\n49\t    _attach_ruledout,\n50\t    _extract_action_tag,\n51\t    _extract_annotations,\n52\t    _extract_flag_tags,\n53\t    _parse_ruledout_line,\n54\t    _parse_task_line,\n55\t    parse_plan,\n56\t)\n57\t\n58\t\n59\t@dataclass\n60\tclass _FakeTask:\n61\t    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n62\t\n63\t    indent_level: int\n64\t    name: str = \"\"\n65\t\n66\t\n67\tclass TestCheckboxRe:\n68\t    @pytest.mark.parametrize(\n69\t        (\"line\", \"indent\", \"marker\", \"text\"),\n70\t        [\n71\t            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n72\t            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n73\t            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n74\t            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n75\t            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n76\t        ],\n77\t    )\n78\t    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n79\t        m = _CHECKBOX_RE.match(line)\n80\t        assert m is not None\n81\t        assert m.group(1) == indent\n82\t        assert m.group(2) == marker\n83\t        assert m.group(3) == text\n84\t\n85\t    @pytest.mark.parametrize(\n86\t        \"line\",\n87\t        [\n88\t            \"\",\n89\t            \"## Stage 1: Core\",\n90\t            \"- [] missing space inside brackets\",\n91\t            \"- [y] unsupported marker\",\n92\t            \"- [ ]\",\n93\t            \"* [ ] wrong bullet\",\n94\t            \"Plain prose line\",\n95\t        ],\n96\t    )\n97\t    def test_non_matches(self, line: str) -> None:\n98\t        assert _CHECKBOX_RE.match(line) is None\n99\t\n100\t\n101\tclass TestParseTaskLine:\n102\t    def test_match_returns_raw_record(self) -> None:\n103\t        rec = _parse_task_line(\"  - [x] foo\", 7)\n104\t        assert rec is not None\n105\t        assert rec.indent == \"  \"\n106\t        assert rec.status_char == \"x\"\n107\t        assert rec.text == \"foo\"\n108\t        assert rec.line_number == 7\n109\t\n110\t    def test_match_failed_marker(self) -> None:\n111\t        rec = _parse_task_line(\"- [!] bad\", 12)\n112\t        assert rec is not None\n113\t        assert rec.status_char == \"!\"\n114\t        assert rec.line_number == 12\n115\t\n116\t    def test_non_task_returns_none(self) -> None:\n117\t        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n118\t        assert _parse_task_line(\"\", 2) is None\n119\t        assert _parse_task_line(\"Some prose\", 3) is None\n120\t\n121\t\n122\tclass TestParseRuledOutLine:\n123\t    def test_indented_with_text(self) -> None:\n124\t        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n125\t        assert rec is not None\n126\t        assert rec.indent == \"  \"\n127\t        assert rec.text == \"tried restart\"\n128\t        assert rec.line_number == 5\n129\t\n130\t    def test_top_level_with_text(self) -> None:\n131\t        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n132\t        assert rec is not None\n133\t        assert rec.indent == \"\"\n134\t        assert rec.text == \"orphan approach\"\n135\t\n136\t    def test_empty_body(self) -> None:\n137\t        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n138\t        assert rec is not None\n139\t        assert rec.indent == \"    \"\n140\t        assert rec.text == \"\"\n141\t\n142\t    def test_trailing_whitespace_stripped(self) -> None:\n143\t        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n144\t        assert rec is not None\n145\t        assert rec.text == \"foo\"\n146\t\n147\t    def test_non_leading_token_is_not_match(self) -> None:\n148\t        # A RULEDOUT token that appears mid-line is prose, not a\n149\t        # RULEDOUT line. Only the leading-position form is recognized.\n150\t        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n151\t\n152\t    def test_similar_token_does_not_match(self) -> None:\n153\t        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n154\t        # immediately after the keyword.\n155\t        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n156\t\n157\t    def test_non_ruledout_lines_return_none(self) -> None:\n158\t        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n159\t        assert _parse_ruledout_line(\"\", 2) is None\n160\t        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n161\t\n162\t\n163\tclass TestAttachRuledOut:\n164\t    def test_nearest_strict_less_indent_wins(self) -> None:\n165\t        root = _FakeTask(indent_level=0, name=\"root\")\n166\t        child = _FakeTask(indent_level=2, name=\"child\")\n167\t        grand = _FakeTask(indent_level=4, name=\"grand\")\n168\t        # RULEDOUT at indent 4 sits as a sibling under `child`\n169\t        # (indent 2): it attaches to `child`, not to `grand` even\n170\t        # though `grand` is deeper in the stack.\n171\t        attached = _attach_ruledout(4, [root, child, grand], [root])\n172\t        assert attached is child\n173\t\n174\t    def test_skips_equal_indent_in_stack(self) -> None:\n175\t        # Equal indent is not \"strictly less\", so the equal-indent\n176\t        # entry is skipped and the search continues outward.\n177\t        root = _FakeTask(indent_level=0, name=\"root\")\n178\t        same = _FakeTask(indent_level=2, name=\"same\")\n179\t        attached = _attach_ruledout(2, [root, same], [root])\n180\t        assert attached is root\n181\t\n182\t    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n183\t        # A column-0 RULEDOUT after the stack has been popped (e.g.\n184\t        # following a same-indent sibling) finds no strictly-less\n185\t        # ancestor, so it attaches to the last root task.\n186\t        a = _FakeTask(indent_level=0, name=\"a\")\n187\t        b = _FakeTask(indent_level=0, name=\"b\")\n188\t        attached = _attach_ruledout(0, [], [a, b])\n189\t        assert attached is b\n190\t\n191\t    def test_no_ancestors_no_roots_returns_none(self) -> None:\n192\t        # A stray [RULEDOUT] before any task in the phase has nothing\n193\t        # to attach to; the caller is expected to drop it.\n194\t        assert _attach_ruledout(0, [], []) is None\n195\t\n196\t    def test_empty_stack_uses_root_fallback(self) -> None:\n197\t        root = _FakeTask(indent_level=0, name=\"root\")\n198\t        attached = _attach_ruledout(2, [], [root])\n199\t        assert attached is root\n200\t\n201\t    def test_multiple_ruledouts_on_one_task_collected_in_order(self) -> None:\n202\t        # Compose the building blocks the orchestration layer will use:\n203\t        # parse each [RULEDOUT] line, route it to its parent via\n204\t        # _attach_ruledout, then append to the parent's list. Three\n205\t        # sibling RULEDOUTs at the child indent must all land on the\n206\t        # same parent and stay in source order.\n207\t        root = _FakeTask(indent_level=0, name=\"root\")\n208\t        child = _FakeTask(indent_level=2, name=\"child\")\n209\t        stack = [root, child]\n210\t        roots = [root]\n211\t\n212\t        lines = [\n213\t            (\"    [RULEDOUT] first approach\", 10),\n214\t            (\"    [RULEDOUT] second approach\", 11),\n215\t            (\"    [RULEDOUT] third approach\", 12),\n216\t        ]\n217\t        collected: dict[str, list[tuple[str, int]]] = {}\n218\t        for raw_line, line_number in lines:\n219\t            rec = _parse_ruledout_line(raw_line, line_number)\n220\t            assert rec is not None\n221\t            target = _attach_ruledout(len(rec.indent), stack, roots)\n222\t            assert target is child\n223\t            collected.setdefault(target.name, []).append((rec.text, rec.line_number))\n224\t\n225\t        assert collected == {\n226\t            \"child\": [\n227\t                (\"first approach\", 10),\n228\t                (\"second approach\", 11),\n229\t                (\"third approach\", 12),\n230\t            ],\n231\t        }\n232\t\n233\t\n234\tclass TestDepsRe:\n235\t    def test_single_id(self) -> None:\n236\t        m = _DEPS_RE.match(\"@deps T-000001\")\n237\t        assert m is not None\n238\t        assert m.group(1) == \"\"\n239\t        assert m.group(2).split() == [\"T-000001\"]\n240\t\n241\t    def test_multiple_ids(self) -> None:\n242\t        m = _DEPS_RE.match(\"@deps T-000001 T-000002 T-000003\")\n243\t        assert m is not None\n244\t        assert m.group(1) == \"\"\n245\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\", \"T-000003\"]\n246\t\n247\t    def test_indented_captures_indent(self) -> None:\n248\t        m = _DEPS_RE.match(\"    @deps T-000001 T-000002\")\n249\t        assert m is not None\n250\t        assert m.group(1) == \"    \"\n251\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n252\t\n253\t    def test_extra_inter_id_whitespace_collapses_on_split(self) -> None:\n254\t        # Variable spacing between IDs is normalized by str.split().\n255\t        m = _DEPS_RE.match(\"@deps T-000001    T-000002\")\n256\t        assert m is not None\n257\t        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n258\t\n259\t    @pytest.mark.parametrize(\n260\t        \"line\",\n261\t        [\n262\t            \"\",\n263\t            \"- [ ] regular task\",\n264\t            \"@dep T-000001\",\n265\t            \"@deps\",\n266\t            \"@deps \",\n267\t            \" @deps_ T-000001\",\n268\t        ],\n269\t    )\n270\t    def test_non_deps_lines(self, line: str) -> None:\n271\t        assert _DEPS_RE.match(line) is None\n272\t\n273\t\n274\tclass TestAttachDeps:\n275\t    def test_strict_form_deps_indented_under_parent(self) -> None:\n276\t        # Canonical form: @deps is indented strictly more than the\n277\t        # task it references. Parent's indent is strictly less than\n278\t        # the deps line's, so attachment is strict (no warning).\n279\t        parent = _FakeTask(indent_level=0, name=\"parent\")\n280\t        target, lenient = _attach_deps(2, [parent])\n281\t        assert target is parent\n282\t        assert lenient is False\n283\t\n284\t    def test_lenient_form_same_indent_warns(self) -> None:\n285\t        # \"Forgot to indent\" form: @deps at the same indent as its\n286\t        # task. Still attaches, but flagged as lenient so callers can\n287\t        # emit a validation warning.\n288\t        parent = _FakeTask(indent_level=0, name=\"parent\")\n289\t        target, lenient = _attach_deps(0, [parent])\n290\t        assert target is parent\n291\t        assert lenient is True\n292\t\n293\t    def test_strict_attaches_to_innermost_ancestor(self) -> None:\n294\t        # With multiple open ancestors the innermost strictly-less-\n295\t        # indented one wins — not the outermost.\n296\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n297\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n298\t        target, lenient = _attach_deps(4, [outer, inner])\n299\t        assert target is inner\n300\t        assert lenient is False\n301\t\n302\t    def test_lenient_uses_top_of_stack_at_same_indent(self) -> None:\n303\t        # Top of stack is at deps' indent — lenient attachment to the\n304\t        # immediately preceding task.\n305\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n306\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n307\t        target, lenient = _attach_deps(2, [outer, inner])\n308\t        assert target is inner\n309\t        assert lenient is True\n310\t\n311\t    def test_outdented_deps_walks_past_deeper_top(self) -> None:\n312\t        # The most recent task is more indented than @deps, so it is\n313\t        # skipped; the search continues outward and lands on the\n314\t        # equal-indent ancestor as a lenient match.\n315\t        outer = _FakeTask(indent_level=0, name=\"outer\")\n316\t        inner = _FakeTask(indent_level=2, name=\"inner\")\n317\t        target, lenient = _attach_deps(0, [outer, inner])\n318\t        assert target is outer\n319\t        assert lenient is True\n320\t\n321\t    def test_empty_stack_returns_none(self) -> None:\n322\t        # A @deps line before any task in scope has nothing to attach\n323\t        # to — the caller is expected to drop it. No root-task fallback\n324\t        # is provided, unlike _attach_ruledout.\n325\t        target, lenient = _attach_deps(0, [])\n326\t        assert target is None\n327\t        assert lenient is False\n328\t\n329\t    def test_all_ancestors_more_indented_returns_none(self) -> None:\n330\t        # Pathological: deps outdented past every known ancestor.\n331\t        # Stack-walk finds no candidate at lesser-or-equal indent.\n332\t        deep = _FakeTask(indent_level=4, name=\"deep\")\n333\t        target, lenient = _attach_deps(2, [deep])\n334\t        assert target is None\n335\t        assert lenient is False\n336\t\n337\t    def test_parse_and_attach_to_nested_subtask(self) -> None:\n338\t        # Compose _DEPS_RE with _attach_deps: a deeply-indented @deps\n339\t        # line resolves to the innermost open ancestor at strictly-less\n340\t        # indent — i.e. the nested subtask, not the root task. This is\n341\t        # the end-to-end shape the higher-level parser will use.\n342\t        root = _FakeTask(indent_level=0, name=\"root\")\n343\t        child = _FakeTask(indent_level=2, name=\"child\")\n344\t        grand = _FakeTask(indent_level=4, name=\"grand\")\n345\t        stack = [root, child, grand]\n346\t\n347\t        m = _DEPS_RE.match(\"      @deps T-000001 T-000002\")\n348\t        assert m is not None\n349\t        indent = len(m.group(1))\n350\t        ids = m.group(2).split()\n351\t\n352\t        target, lenient = _attach_deps(indent, stack)\n353\t        assert target is grand\n354\t        assert lenient is False\n355\t        assert ids == [\"T-000001\", \"T-000002\"]\n356\t\n357\t\n358\tclass TestExtractFlagTags:\n359\t    def test_no_tags(self) -> None:\n360\t        tags, rest = _extract_flag_tags(\"plain task text\")\n361\t        assert tags == ()\n362\t        assert rest == \"plain task text\"\n363\t\n364\t    def test_user(self) -> None:\n365\t        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n366\t        assert tags == (\"USER\",)\n367\t        assert rest == \"verify the menu\"\n368\t\n369\t    def test_batch(self) -> None:\n370\t        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n371\t        assert tags == (\"BATCH\",)\n372\t        assert rest == \"sub-task group\"\n373\t\n374\t    def test_user_and_batch_combined(self) -> None:\n375\t        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n376\t        assert tags == (\"USER\", \"BATCH\")\n377\t        assert rest == \"both flags\"\n378\t\n379\t    def test_adjacent_tags_without_separator(self) -> None:\n380\t        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n381\t        assert tags == (\"USER\", \"BATCH\")\n382\t        assert rest == \"no gap\"\n383\t\n384\t    def test_non_leading_tag_is_prose(self) -> None:\n385\t        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n386\t        assert tags == ()\n387\t        assert rest == \"Document the [USER] tag\"\n388\t\n389\t    def test_only_first_run_is_tags(self) -> None:\n390\t        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n391\t        assert tags == (\"USER\",)\n392\t        assert rest == \"middle [BATCH] later\"\n393\t\n394\t    def test_empty_input(self) -> None:\n395\t        tags, rest = _extract_flag_tags(\"\")\n396\t        assert tags == ()\n397\t        assert rest == \"\"\n398\t\n399\t\n400\tclass TestExtractActionTag:\n401\t    def test_no_action_tag(self) -> None:\n402\t        tag, rest = _extract_action_tag(\"plain task text\")\n403\t        assert tag is None\n404\t        assert rest == \"plain task text\"\n405\t\n406\t    def test_action_with_args(self) -> None:\n407\t        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n408\t        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n409\t        assert rest == \"\"\n410\t\n411\t    def test_action_without_args(self) -> None:\n412\t        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n413\t        assert tag == (\"noop\", \"\")\n414\t        assert rest == \"\"\n415\t\n416\t    def test_args_extend_to_end_of_line(self) -> None:\n417\t        # Argument string is text from closing bracket to end of line;\n418\t        # bracketed-looking content in args stays in args.\n419\t        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n420\t        assert tag == (\"run\", \"do [feat: x]\")\n421\t        assert rest == \"\"\n422\t\n423\t    def test_non_leading_auto_is_prose(self) -> None:\n424\t        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n425\t        assert tag is None\n426\t        assert rest == \"Document the [AUTO:run] tag\"\n427\t\n428\t\n429\tclass TestExtractAnnotations:\n430\t    def test_no_annotation(self) -> None:\n431\t        ann, rest = _extract_annotations(\"plain task text\")\n432\t        assert ann == ()\n433\t        assert rest == \"plain task text\"\n434\t\n435\t    def test_single_feat(self) -> None:\n436\t        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n437\t        assert ann == ((\"feat\", '\"menu wired\"'),)\n438\t        assert rest == \"do thing\"\n439\t\n440\t    def test_single_fix(self) -> None:\n441\t        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n442\t        assert ann == ((\"fix\", '\"race\"'),)\n443\t        assert rest == \"fixed it\"\n444\t\n445\t    def test_multiple_annotations_preserve_order(self) -> None:\n446\t        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n447\t        assert ann == (\n448\t            (\"feat\", '\"first\"'),\n449\t            (\"fix\", '\"second\"'),\n450\t        )\n451\t        assert rest == \"do thing\"\n452\t\n453\t    def test_nested_brackets_in_value(self) -> None:\n454\t        # Balanced brackets inside the value are stepped over by the\n455\t        # right-to-left depth scan and stay inside the annotation.\n456\t        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n457\t        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n458\t        assert rest == \"do thing\"\n459\t\n460\t    def test_unquoted_nested_brackets_in_value(self) -> None:\n461\t        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n462\t        assert ann == ((\"feat\", \"a [b] c\"),)\n463\t        assert rest == \"do\"\n464\t\n465\t    def test_prose_bracket_without_separator_is_text(self) -> None:\n466\t        # A `[` abutting a non-whitespace character is task text, not\n467\t        # the start of an annotation.\n468\t        ann, rest = _extract_annotations(\"see config[feat: x]\")\n469\t        assert ann == ()\n470\t        assert rest == \"see config[feat: x]\"\n471\t\n472\t    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n473\t        # `[AUTO:run]` has no whitespace after its colon and so is not\n474\t        # an annotation under this extractor's rules.\n475\t        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n476\t        assert ann == ()\n477\t        assert rest == \"[AUTO:run] cmd\"\n478\t\n479\t    def test_unmatched_open_bracket(self) -> None:\n480\t        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n481\t        assert ann == ()\n482\t        assert rest == \"dangling brackets feat ]\"\n483\t\n484\t    def test_annotation_alone_consumes_to_empty(self) -> None:\n485\t        ann, rest = _extract_annotations('[feat: \"lone\"]')\n486\t        assert ann == ((\"feat\", '\"lone\"'),)\n487\t        assert rest == \"\"\n488\t\n489\t\n490\tclass TestTagInteractions:\n491\t    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n492\t        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n493\t        # Annotation must be stripped before action tag, because action\n494\t        # tag args span to end of line.\n495\t        ann, after_ann = _extract_annotations(text)\n496\t        assert ann == ((\"feat\", '\"done\"'),)\n497\t        tags, after_flags = _extract_flag_tags(after_ann)\n498\t        assert tags == (\"BATCH\",)\n499\t        action, after_action = _extract_action_tag(after_flags)\n500\t        assert action == (\"run_cli\", \"mcloop --dry-run\")\n501\t        assert after_action == \"\"\n502\t\n503\t    def test_flags_and_plain_text(self) -> None:\n504\t        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n505\t        assert ann == ()\n506\t        tags, after_flags = _extract_flag_tags(after_ann)\n507\t        assert tags == (\"USER\", \"BATCH\")\n508\t        action, after_action = _extract_action_tag(after_flags)\n509\t        assert action is None\n510\t        assert after_action == \"verify thing\"\n511\t\n512\t    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n513\t        text = \"Implement [USER] and [AUTO:run] tokenization\"\n514\t        ann, after_ann = _extract_annotations(text)\n515\t        tags, after_flags = _extract_flag_tags(after_ann)\n516\t        action, after_action = _extract_action_tag(after_flags)\n517\t        assert ann == ()\n518\t        assert tags == ()\n519\t        assert action is None\n520\t        assert after_action == text\n521\t\n522\t\n523\tclass TestParsePlanStateMachine:\n524\t    \"\"\"End-to-end tests for the parse_plan walker.\n525\t\n526\t    The state machine in 2.5.2 is responsible for the section-vs-task\n527\t    bookkeeping that earlier building blocks do not own: routing tasks\n528\t    into the right phase or subsection, opening/closing the indent\n529\t    stack at phase/subsection/bugs boundaries, and dispatching ``@deps``\n530\t    and ``[RULEDOUT]`` siblings to the parent task. Tests below\n531\t    exercise each of those responsibilities independently and then in\n532\t    combination on a small but representative plan.\n533\t    \"\"\"\n534\t\n535\t    def test_empty_text_returns_empty_plan(self) -> None:\n536\t        plan = parse_plan(\"\")\n537\t        assert plan.phases == ()\n538\t        assert plan.bugs is None\n539\t        assert plan.project_title == \"\"\n540\t\n541\t    def test_single_phase_with_tasks(self) -> None:\n542\t        text = \"## Stage 1: Core\\n\\n- [ ] first task\\n- [x] second task\\n\"\n543\t        plan = parse_plan(text)\n544\t        assert len(plan.phases) == 1\n545\t        phase = plan.phases[0]\n546\t        assert phase.ordinal == 1\n547\t        assert phase.keyword == \"Stage\"\n548\t        assert phase.title == \"Core\"\n549\t        assert phase.line_number == 1\n550\t        assert len(phase.tasks) == 2\n551\t        assert phase.tasks[0].text == \"first task\"\n552\t        assert phase.tasks[0].status is TaskStatus.TODO\n553\t        assert phase.tasks[0].line_number == 3\n554\t        assert phase.tasks[1].status is TaskStatus.DONE\n555\t\n556\t    def test_phase_heading_keyword_normalized(self) -> None:\n557\t        # \"Phase\" and \"Stage\" are accepted interchangeably and the\n558\t        # keyword captures which form was used (capitalized).\n559\t        plan = parse_plan(\"# Phase 2: Implementation\\n- [ ] x\\n\")\n560\t        assert plan.phases[0].keyword == \"Phase\"\n561\t        assert plan.phases[0].ordinal == 2\n562\t        assert plan.phases[0].title == \"Implementation\"\n563\t\n564\t    def test_phase_with_non_bare_digit_id_is_not_a_phase_heading(self) -> None:\n565\t        # `## Phase phase_001:` is the legacy strict-form heading; per\n566\t        # design doc section 2.5 it does NOT match the bare-digit\n567\t        # STAGE_RE and so is invisible to the compat parser. The tasks\n568\t        # that follow have no enclosing phase and are dropped.\n569\t        text = \"## Phase phase_001: Core\\n- [ ] orphan task\\n\"\n570\t        plan = parse_plan(text)\n571\t        assert plan.phases == ()\n572\t        assert plan.bugs is None\n573\t\n574\t    def test_indent_stack_builds_task_tree(self) -> None:\n575\t        text = (\n576\t            \"## Stage 1: Core\\n\"\n577\t            \"- [ ] parent\\n\"\n578\t            \"  - [ ] child a\\n\"\n579\t            \"    - [ ] grandchild\\n\"\n580\t            \"  - [ ] child b\\n\"\n581\t            \"- [ ] second root\\n\"\n582\t        )\n583\t        plan = parse_plan(text)\n584\t        phase = plan.phases[0]\n585\t        assert len(phase.tasks) == 2\n586\t        parent, second_root = phase.tasks\n587\t        assert parent.text == \"parent\"\n588\t        assert second_root.text == \"second root\"\n589\t        assert len(parent.children) == 2\n590\t        child_a, child_b = parent.children\n591\t        assert child_a.text == \"child a\"\n592\t        assert child_b.text == \"child b\"\n593\t        assert len(child_a.children) == 1\n594\t        assert child_a.children[0].text == \"grandchild\"\n595\t\n596\t    def test_subsection_captures_following_tasks(self) -> None:\n597\t        text = (\n598\t            \"## Stage 1: Core\\n\"\n599\t            \"- [ ] phase task\\n\"\n600\t            \"\\n\"\n601\t            \"### Manual verification\\n\"\n602\t            \"- [ ] sub task one\\n\"\n603\t            \"- [ ] sub task two\\n\"\n604\t        )\n605\t        plan = parse_plan(text)\n606\t        phase = plan.phases[0]\n607\t        assert len(phase.tasks) == 1\n608\t        assert phase.tasks[0].text == \"phase task\"\n609\t        assert len(phase.subsections) == 1\n610\t        sub = phase.subsections[0]\n611\t        assert sub.title == \"Manual verification\"\n612\t        assert tuple(t.text for t in sub.tasks) == (\"sub task one\", \"sub task two\")\n613\t\n614\t    def test_new_phase_resets_indent_stack(self) -> None:\n615\t        # An indented task in the second phase must be treated as a\n616\t        # root of that phase, not as a child of the previous phase's\n617\t        # last task. (mcloop's parser does this via stack.clear().)\n618\t        text = (\n619\t            \"## Stage 1: A\\n- [ ] one\\n  - [ ] one-child\\n## Stage 2: B\\n  - [ ] two\\n\"\n620\t        )\n621\t        plan = parse_plan(text)\n622\t        assert len(plan.phases) == 2\n623\t        assert len(plan.phases[0].tasks) == 1\n624\t        assert plan.phases[0].tasks[0].children[0].text == \"one-child\"\n625\t        assert len(plan.phases[1].tasks) == 1\n626\t        assert plan.phases[1].tasks[0].text == \"two\"\n627\t        assert plan.phases[1].tasks[0].children == ()\n628\t\n629\t    def test_bugs_section_collects_tasks(self) -> None:\n630\t        text = (\n631\t            \"## Stage 1: Core\\n\"\n632\t            \"- [ ] phase task\\n\"\n633\t            \"## Bugs\\n\"\n634\t            \"- [ ] crash on empty input\\n\"\n635\t            \"- [x] fixed memory leak\\n\"\n636\t        )\n637\t        plan = parse_plan(text)\n638\t        assert plan.bugs is not None\n639\t        assert tuple(t.text for t in plan.bugs.tasks) == (\n640\t            \"crash on empty input\",\n641\t            \"fixed memory leak\",\n642\t        )\n643\t        # The phase still owns its own task; bugs is a peer section.\n644\t        assert plan.phases[0].tasks[0].text == \"phase task\"\n645\t\n646\t    def test_task_body_classification_is_applied(self) -> None:\n647\t        text = (\n648\t            \"## Stage 1: Core\\n\"\n649\t            '- [ ] T-000001: [BATCH] do thing [feat: \"x\"]\\n'\n650\t            \"- [ ] T-000002: [AUTO:run_cli] mcloop --dry-run\\n\"\n651\t        )\n652\t        plan = parse_plan(text)\n653\t        first, second = plan.phases[0].tasks\n654\t        assert first.task_id == \"T-000001\"\n655\t        assert first.flag_tags == (\"BATCH\",)\n656\t        assert first.annotations == ((\"feat\", '\"x\"'),)\n657\t        assert first.text == \"do thing\"\n658\t        assert second.task_id == \"T-000002\"\n659\t        assert second.action_tag == (\"run_cli\", \"mcloop --dry-run\")\n660\t        assert second.text == \"\"\n661\t\n662\t    def test_ruledout_attaches_to_parent_task(self) -> None:\n663\t        text = (\n664\t            \"## Stage 1: Core\\n\"\n665\t            \"- [ ] parent\\n\"\n666\t            \"  [RULEDOUT] tried restart\\n\"\n667\t            \"  [RULEDOUT] tried reinstall\\n\"\n668\t        )\n669\t        plan = parse_plan(text)\n670\t        parent = plan.phases[0].tasks[0]\n671\t        assert tuple(r.text for r in parent.ruled_out) == (\n672\t            \"tried restart\",\n673\t            \"tried reinstall\",\n674\t        )\n675\t\n676\t    def test_deps_attaches_to_preceding_task(self) -> None:\n677\t        text = (\n678\t            \"## Stage 1: Core\\n\"\n679\t            \"- [ ] T-000001: first\\n\"\n680\t            \"- [ ] T-000002: second\\n\"\n681\t            \"  @deps T-000001\\n\"\n682\t        )\n683\t        plan = parse_plan(text)\n684\t        first, second = plan.phases[0].tasks\n685\t        assert first.deps == ()\n686\t        assert second.deps == (\"T-000001\",)\n687\t\n688\t    def test_combined_phase_subsection_bugs_round_trip_structure(self) -> None:\n689\t        text = (\n690\t            \"## Stage 1: Core\\n\"\n691\t            \"- [ ] T-000001: [BATCH] parent\\n\"\n692\t            \"  - [ ] T-000002: child a\\n\"\n693\t            \"    [RULEDOUT] tried polling\\n\"\n694\t            \"  - [ ] T-000003: child b\\n\"\n695\t            \"    @deps T-000002\\n\"\n696\t            \"\\n\"\n697\t            \"### Manual verification\\n\"\n698\t            \"- [ ] T-000004: [USER] run smoke test\\n\"\n699\t            \"\\n\"\n700\t            \"## Bugs\\n\"\n701\t            \"- [ ] T-000009: crash on empty PLAN.md\\n\"\n702\t        )\n703\t        plan = parse_plan(text)\n704\t        assert len(plan.phases) == 1\n705\t        phase = plan.phases[0]\n706\t        parent = phase.tasks[0]\n707\t        assert parent.task_id == \"T-000001\"\n708\t        assert parent.flag_tags == (\"BATCH\",)\n709\t        child_a, child_b = parent.children\n710\t        assert child_a.task_id == \"T-000002\"\n711\t        assert tuple(r.text for r in child_a.ruled_out) == (\"tried polling\",)\n712\t        assert child_b.deps == (\"T-000002\",)\n713\t        assert len(phase.subsections) == 1\n714\t        manual = phase.subsections[0]\n715\t        assert manual.title == \"Manual verification\"\n716\t        assert manual.tasks[0].flag_tags == (\"USER\",)\n717\t        assert plan.bugs is not None\n718\t        assert plan.bugs.tasks[0].task_id == \"T-000009\"\n719\t\n720\t    def test_tasks_before_any_section_are_dropped_in_compat_mode(self) -> None:\n721\t        # No phase or bugs heading has been seen yet, so a task line is\n722\t        # an orphan. Compat mode drops silently to match mcloop's\n723\t        # parser, which assigns ``stage=\"\"`` rather than erroring.\n724\t        # Strict mode (Stage 3) will surface this as a PlanSyntaxError.\n725\t        plan = parse_plan(\"- [ ] orphan\\n## Stage 1: Core\\n- [ ] real\\n\")\n726\t        assert len(plan.phases) == 1\n727\t        assert tuple(t.text for t in plan.phases[0].tasks) == (\"real\",)\n728\t\n729\t    def test_source_path_passes_through(self) -> None:\n730\t        path = Path(\"/tmp/PLAN.md\")\n731\t        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\", source_path=path)\n732\t        assert plan.source_path == path\n733\t\n734\t\n735\tclass TestParsePlanProse:\n736\t    \"\"\"Tests for project title, preamble, phase prose, and subsection prose.\n737\t\n738\t    Per design doc section 4.1 grammar, prose is allowed in three places:\n739\t    after the H1 (the preamble), after a phase heading (phase prose),\n740\t    and after a ``###`` subsection heading (subsection prose). Each\n741\t    region ends at the next structural boundary — phase/bugs heading\n742\t    for the preamble, first task or subsection for phase prose, and\n743\t    first task for subsection prose.\n744\t    \"\"\"\n745\t\n746\t    def test_h1_sets_project_title(self) -> None:\n747\t        plan = parse_plan(\"# My Project\\n## Stage 1: Core\\n\")\n748\t        assert plan.project_title == \"My Project\"\n749\t        assert plan.preamble == \"\"\n750\t\n751\t    def test_no_h1_means_empty_title(self) -> None:\n752\t        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n753\t        assert plan.project_title == \"\"\n754\t        assert plan.preamble == \"\"\n755\t\n756\t    def test_h2_with_stage_keyword_does_not_match_h1(self) -> None:\n757\t        # `## Stage 1: Core` is consumed by the phase regex before the\n758\t        # H1 check runs, so it does not leak into the title slot.\n759\t        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n760\t        assert plan.project_title == \"\"\n761\t        assert len(plan.phases) == 1\n762\t\n763\t    def test_preamble_between_h1_and_phase(self) -> None:\n764\t        text = \"# Project\\n\\nIntro paragraph.\\n\\n## Stage 1: Core\\n- [ ] task\\n\"\n765\t        plan = parse_plan(text)\n766\t        assert plan.project_title == \"Project\"\n767\t        assert plan.preamble == \"Intro paragraph.\"\n768\t\n769\t    def test_preamble_multi_paragraph_preserves_blank_lines(self) -> None:\n770\t        text = (\n771\t            \"# Project\\n\\nFirst paragraph.\\n\\nSecond paragraph.\\n\\n## Stage 1: Core\\n\"\n772\t        )\n773\t        plan = parse_plan(text)\n774\t        assert plan.preamble == \"First paragraph.\\n\\nSecond paragraph.\"\n775\t\n776\t    def test_preamble_ends_at_bugs_heading(self) -> None:\n777\t        # Per the grammar, the preamble is followed by ``PhaseOrBugs+`` —\n778\t        # a bugs section is just as valid a terminator as a phase.\n779\t        text = \"# Project\\nIntro.\\n## Bugs\\n- [ ] crash\\n\"\n780\t        plan = parse_plan(text)\n781\t        assert plan.preamble == \"Intro.\"\n782\t        assert plan.bugs is not None\n783\t        assert plan.bugs.tasks[0].text == \"crash\"\n784\t\n785\t    def test_phase_prose_between_heading_and_first_task(self) -> None:\n786\t        text = \"## Stage 1: Core\\n\\nThe goal is X.\\n\\n- [ ] task\\n\"\n787\t        plan = parse_plan(text)\n788\t        assert plan.phases[0].prose == \"The goal is X.\"\n789\t\n790\t    def test_phase_prose_ends_at_subsection(self) -> None:\n791\t        text = (\n792\t            \"## Stage 1: Core\\n\\nPhase intro.\\n\\n### Manual verification\\n- [ ] check\\n\"\n793\t        )\n794\t        plan = parse_plan(text)\n795\t        phase = plan.phases[0]\n796\t        assert phase.prose == \"Phase intro.\"\n797\t        assert phase.subsections[0].prose == \"\"\n798\t\n799\t    def test_subsection_prose_between_heading_and_first_task(self) -> None:\n800\t        text = (\n801\t            \"## Stage 1: Core\\n\"\n802\t            \"- [ ] phase task\\n\"\n803\t            \"### Manual verification\\n\"\n804\t            \"\\n\"\n805\t            \"Run by hand.\\n\"\n806\t            \"\\n\"\n807\t            \"- [ ] check\\n\"\n808\t        )\n809\t        plan = parse_plan(text)\n810\t        sub = plan.phases[0].subsections[0]\n811\t        assert sub.prose == \"Run by hand.\"\n812\t\n813\t    def test_no_prose_when_task_immediately_follows_heading(self) -> None:\n814\t        text = \"# Project\\n## Stage 1: Core\\n- [ ] task\\n\"\n815\t        plan = parse_plan(text)\n816\t        assert plan.preamble == \"\"\n817\t        assert plan.phases[0].prose == \"\"\n818\t\n819\t    def test_lines_before_h1_are_dropped(self) -> None:\n820\t        # Outside any active prose region, prose is dropped — matches the\n821\t        # grammar (Preamble requires an H1 anchor).\n822\t        text = \"noise line\\n# Project\\nIntro.\\n## Stage 1: Core\\n\"\n823\t        plan = parse_plan(text)\n824\t        assert plan.project_title == \"Project\"\n825\t        assert plan.preamble == \"Intro.\"\n826\t\n827\t    def test_prose_after_first_task_in_phase_is_dropped(self) -> None:\n828\t        # Phase prose is \"between the phase heading and the first task\n829\t        # or subsection\". Lines after the first task close the\n830\t        # accumulator and are dropped in compat mode.\n831\t        text = \"## Stage 1: Core\\n- [ ] task\\nstray prose\\n\"\n832\t        plan = parse_plan(text)\n833\t        assert plan.phases[0].prose == \"\"\n834\t        assert plan.phases[0].tasks[0].text == \"task\"\n835\t\n836\t    def test_multiple_phases_each_get_own_prose(self) -> None:\n837\t        text = (\n838\t            \"## Stage 1: A\\n\"\n839\t            \"Prose A.\\n\"\n840\t            \"- [ ] task A\\n\"\n841\t            \"## Stage 2: B\\n\"\n842\t            \"Prose B.\\n\"\n843\t            \"- [ ] task B\\n\"\n844\t        )\n845\t        plan = parse_plan(text)\n846\t        assert plan.phases[0].prose == \"Prose A.\"\n847\t        assert plan.phases[1].prose == \"Prose B.\"\n848\t\n849\t    def test_phase_prose_at_end_of_file_without_tasks(self) -> None:\n850\t        # Final phase has prose but no task to close the accumulator —\n851\t        # the end-of-input close handler must still finalize it.\n852\t        text = \"## Stage 1: Core\\n\\nLone prose.\\n\"\n853\t        plan = parse_plan(text)\n854\t        assert plan.phases[0].prose == \"Lone prose.\"\n855\t        assert plan.phases[0].tasks == ()\n856\t\n857\t\n858\tclass TestParsePlanCompatModeSyntaxErrors:\n859\t    \"\"\"Compat-mode raises :class:`PlanSyntaxError` on genuine syntax breakage.\n860\t\n861\t    Compat mode is intentionally lenient about cases mcloop's parser\n862\t    accepted (orphan tasks before any phase, prose outside accumulators,\n863\t    etc.). But a ``@deps`` line with no preceding task to attach to has\n864\t    no semantic interpretation — the keyword means \"this task depends\n865\t    on\" and there is no task. mcloop never recognized ``@deps`` at all,\n866\t    so there is no compat behavior to preserve. The parser raises\n867\t    :class:`PlanSyntaxError` with the offending line quoted in the\n868\t    message and the source line/column populated.\n869\t    \"\"\"\n870\t\n871\t    def test_orphan_deps_line_before_any_task_raises(self) -> None:\n872\t        text = \"## Stage 1: Core\\n  @deps T-000001\\n\"\n873\t        with pytest.raises(PlanSyntaxError) as exc_info:\n874\t            parse_plan(text)\n875\t        err = exc_info.value\n876\t        assert err.line == 2\n877\t        assert err.column == 3\n878\t        assert \"no preceding task\" in err.message\n879\t        assert \"`  @deps T-000001`\" in err.message\n880\t\n881\t    def test_orphan_deps_with_no_phase_raises(self) -> None:\n882\t        # Even before any section, a stray @deps is malformed: there is\n883\t        # no plausible target. The orphan-task tolerance does not extend\n884\t        # here because @deps has no mcloop precedent.\n885\t        with pytest.raises(PlanSyntaxError) as exc_info:\n886\t            parse_plan(\"@deps T-000001\\n\")\n887\t        assert exc_info.value.line == 1\n888\t        assert exc_info.value.column == 1\n889\t\n890\t    def test_syntax_error_carries_source_path(self) -> None:\n891\t        path = Path(\"/tmp/PLAN.md\")\n892\t        with pytest.raises(PlanSyntaxError) as exc_info:\n893\t            parse_plan(\"@deps T-000001\\n\", source_path=path)\n894\t        assert exc_info.value.path == path\n895\t\n896\t    def test_syntax_error_str_format_matches_design_doc(self) -> None:\n897\t        # Section 9 contract: \"PLAN.md invalid at line N, column M: ...\"\n898\t        with pytest.raises(PlanSyntaxError) as exc_info:\n899\t            parse_plan(\"@deps T-000001\\n\")\n900\t        rendered = str(exc_info.value)\n901\t        assert rendered.startswith(\"PLAN.md invalid at line 1, column 1: \")\n902\t        assert \"@deps T-000001\" in rendered\n903\t"}]},"parent_tool_use_id":null,"session_id":"8967cf94-692c-42c2-9412-97ac73ed5641","uuid":"8a70190a-ef19-43cc-ae34-585678240b74","timestamp":"2026-05-16T03:05:10.952Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"\"\"\"Tests for bob_tools.planfile.parser building blocks.\n\nStage 2 task-line recognizers and tag extractors:\n\n  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n  - ``_parse_task_line`` returns a raw record on checkbox lines and\n    ``None`` on anything else.\n  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n    sibling lines and returns indent, body, and source line number.\n  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n    line: nearest strictly-less-indented open ancestor, with fallback\n    to the most recent root task (mcloop's ``parse`` parity). The\n    parse-then-attach composition test confirms multiple RULEDOUT\n    lines on one task are collected in source order.\n  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n    enforces that at least one ID follows the keyword.\n  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n    sibling line: the innermost open ancestor at strictly-less indent\n    is the strict-form parent; an ancestor at equal indent is the\n    lenient-form parent (caller should warn). No root-task fallback.\n    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n    tokens, in isolation and combination, and leaves non-leading\n    occurrences as prose (design doc section 4.3).\n  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n    treats the rest of the line as its argument string; non-leading\n    occurrences are prose.\n  - ``_extract_annotations`` consumes trailing ``[key: value]``\n    annotations, handles multiple annotations and nested brackets in\n    values, and leaves bracketed prose that is not separated from\n    preceding text by whitespace in place.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom pathlib import Path\n\nimport pytest\n\nfrom bob_tools.planfile.model import PlanSyntaxError, TaskStatus\nfrom bob_tools.planfile.parser import (\n    _CHECKBOX_RE,\n    _DEPS_RE,\n    _attach_deps,\n    _attach_ruledout,\n    _extract_action_tag,\n    _extract_annotations,\n    _extract_flag_tags,\n    _parse_ruledout_line,\n    _parse_task_line,\n    parse_plan,\n)\n\n\n@dataclass\nclass _FakeTask:\n    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n\n    indent_level: int\n    name: str = \"\"\n\n\nclass TestCheckboxRe:\n    @pytest.mark.parametrize(\n        (\"line\", \"indent\", \"marker\", \"text\"),\n        [\n            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n        ],\n    )\n    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n        m = _CHECKBOX_RE.match(line)\n        assert m is not None\n        assert m.group(1) == indent\n        assert m.group(2) == marker\n        assert m.group(3) == text\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"## Stage 1: Core\",\n            \"- [] missing space inside brackets\",\n            \"- [y] unsupported marker\",\n            \"- [ ]\",\n            \"* [ ] wrong bullet\",\n            \"Plain prose line\",\n        ],\n    )\n    def test_non_matches(self, line: str) -> None:\n        assert _CHECKBOX_RE.match(line) is None\n\n\nclass TestParseTaskLine:\n    def test_match_returns_raw_record(self) -> None:\n        rec = _parse_task_line(\"  - [x] foo\", 7)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.status_char == \"x\"\n        assert rec.text == \"foo\"\n        assert rec.line_number == 7\n\n    def test_match_failed_marker(self) -> None:\n        rec = _parse_task_line(\"- [!] bad\", 12)\n        assert rec is not None\n        assert rec.status_char == \"!\"\n        assert rec.line_number == 12\n\n    def test_non_task_returns_none(self) -> None:\n        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n        assert _parse_task_line(\"\", 2) is None\n        assert _parse_task_line(\"Some prose\", 3) is None\n\n\nclass TestParseRuledOutLine:\n    def test_indented_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.text == \"tried restart\"\n        assert rec.line_number == 5\n\n    def test_top_level_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n        assert rec is not None\n        assert rec.indent == \"\"\n        assert rec.text == \"orphan approach\"\n\n    def test_empty_body(self) -> None:\n        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n        assert rec is not None\n        assert rec.indent == \"    \"\n        assert rec.text == \"\"\n\n    def test_trailing_whitespace_stripped(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n        assert rec is not None\n        assert rec.text == \"foo\"\n\n    def test_non_leading_token_is_not_match(self) -> None:\n        # A RULEDOUT token that appears mid-line is prose, not a\n        # RULEDOUT line. Only the leading-position form is recognized.\n        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n\n    def test_similar_token_does_not_match(self) -> None:\n        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n        # immediately after the keyword.\n        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n\n    def test_non_ruledout_lines_return_none(self) -> None:\n        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n        assert _parse_ruledout_line(\"\", 2) is None\n        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n\n\nclass TestAttachRuledOut:\n    def test_nearest_strict_less_indent_wins(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        grand = _FakeTask(indent_level=4, name=\"grand\")\n        # RULEDOUT at indent 4 sits as a sibling under `child`\n        # (indent 2): it attaches to `child`, not to `grand` even\n        # though `grand` is deeper in the stack.\n        attached = _attach_ruledout(4, [root, child, grand], [root])\n        assert attached is child\n\n    def test_skips_equal_indent_in_stack(self) -> None:\n        # Equal indent is not \"strictly less\", so the equal-indent\n        # entry is skipped and the search continues outward.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        same = _FakeTask(indent_level=2, name=\"same\")\n        attached = _attach_ruledout(2, [root, same], [root])\n        assert attached is root\n\n    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n        # A column-0 RULEDOUT after the stack has been popped (e.g.\n        # following a same-indent sibling) finds no strictly-less\n        # ancestor, so it attaches to the last root task.\n        a = _FakeTask(indent_level=0, name=\"a\")\n        b = _FakeTask(indent_level=0, name=\"b\")\n        attached = _attach_ruledout(0, [], [a, b])\n        assert attached is b\n\n    def test_no_ancestors_no_roots_returns_none(self) -> None:\n        # A stray [RULEDOUT] before any task in the phase has nothing\n        # to attach to; the caller is expected to drop it.\n        assert _attach_ruledout(0, [], []) is None\n\n    def test_empty_stack_uses_root_fallback(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        attached = _attach_ruledout(2, [], [root])\n        assert attached is root\n\n    def test_multiple_ruledouts_on_one_task_collected_in_order(self) -> None:\n        # Compose the building blocks the orchestration layer will use:\n        # parse each [RULEDOUT] line, route it to its parent via\n        # _attach_ruledout, then append to the parent's list. Three\n        # sibling RULEDOUTs at the child indent must all land on the\n        # same parent and stay in source order.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        stack = [root, child]\n        roots = [root]\n\n        lines = [\n            (\"    [RULEDOUT] first approach\", 10),\n            (\"    [RULEDOUT] second approach\", 11),\n            (\"    [RULEDOUT] third approach\", 12),\n        ]\n        collected: dict[str, list[tuple[str, int]]] = {}\n        for raw_line, line_number in lines:\n            rec = _parse_ruledout_line(raw_line, line_number)\n            assert rec is not None\n            target = _attach_ruledout(len(rec.indent), stack, roots)\n            assert target is child\n            collected.setdefault(target.name, []).append((rec.text, rec.line_number))\n\n        assert collected == {\n            \"child\": [\n                (\"first approach\", 10),\n                (\"second approach\", 11),\n                (\"third approach\", 12),\n            ],\n        }\n\n\nclass TestDepsRe:\n    def test_single_id(self) -> None:\n        m = _DEPS_RE.match(\"@deps T-000001\")\n        assert m is not None\n        assert m.group(1) == \"\"\n        assert m.group(2).split() == [\"T-000001\"]\n\n    def test_multiple_ids(self) -> None:\n        m = _DEPS_RE.match(\"@deps T-000001 T-000002 T-000003\")\n        assert m is not None\n        assert m.group(1) == \"\"\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\", \"T-000003\"]\n\n    def test_indented_captures_indent(self) -> None:\n        m = _DEPS_RE.match(\"    @deps T-000001 T-000002\")\n        assert m is not None\n        assert m.group(1) == \"    \"\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n\n    def test_extra_inter_id_whitespace_collapses_on_split(self) -> None:\n        # Variable spacing between IDs is normalized by str.split().\n        m = _DEPS_RE.match(\"@deps T-000001    T-000002\")\n        assert m is not None\n        assert m.group(2).split() == [\"T-000001\", \"T-000002\"]\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"- [ ] regular task\",\n            \"@dep T-000001\",\n            \"@deps\",\n            \"@deps \",\n            \" @deps_ T-000001\",\n        ],\n    )\n    def test_non_deps_lines(self, line: str) -> None:\n        assert _DEPS_RE.match(line) is None\n\n\nclass TestAttachDeps:\n    def test_strict_form_deps_indented_under_parent(self) -> None:\n        # Canonical form: @deps is indented strictly more than the\n        # task it references. Parent's indent is strictly less than\n        # the deps line's, so attachment is strict (no warning).\n        parent = _FakeTask(indent_level=0, name=\"parent\")\n        target, lenient = _attach_deps(2, [parent])\n        assert target is parent\n        assert lenient is False\n\n    def test_lenient_form_same_indent_warns(self) -> None:\n        # \"Forgot to indent\" form: @deps at the same indent as its\n        # task. Still attaches, but flagged as lenient so callers can\n        # emit a validation warning.\n        parent = _FakeTask(indent_level=0, name=\"parent\")\n        target, lenient = _attach_deps(0, [parent])\n        assert target is parent\n        assert lenient is True\n\n    def test_strict_attaches_to_innermost_ancestor(self) -> None:\n        # With multiple open ancestors the innermost strictly-less-\n        # indented one wins — not the outermost.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(4, [outer, inner])\n        assert target is inner\n        assert lenient is False\n\n    def test_lenient_uses_top_of_stack_at_same_indent(self) -> None:\n        # Top of stack is at deps' indent — lenient attachment to the\n        # immediately preceding task.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(2, [outer, inner])\n        assert target is inner\n        assert lenient is True\n\n    def test_outdented_deps_walks_past_deeper_top(self) -> None:\n        # The most recent task is more indented than @deps, so it is\n        # skipped; the search continues outward and lands on the\n        # equal-indent ancestor as a lenient match.\n        outer = _FakeTask(indent_level=0, name=\"outer\")\n        inner = _FakeTask(indent_level=2, name=\"inner\")\n        target, lenient = _attach_deps(0, [outer, inner])\n        assert target is outer\n        assert lenient is True\n\n    def test_empty_stack_returns_none(self) -> None:\n        # A @deps line before any task in scope has nothing to attach\n        # to — the caller is expected to drop it. No root-task fallback\n        # is provided, unlike _attach_ruledout.\n        target, lenient = _attach_deps(0, [])\n        assert target is None\n        assert lenient is False\n\n    def test_all_ancestors_more_indented_returns_none(self) -> None:\n        # Pathological: deps outdented past every known ancestor.\n        # Stack-walk finds no candidate at lesser-or-equal indent.\n        deep = _FakeTask(indent_level=4, name=\"deep\")\n        target, lenient = _attach_deps(2, [deep])\n        assert target is None\n        assert lenient is False\n\n    def test_parse_and_attach_to_nested_subtask(self) -> None:\n        # Compose _DEPS_RE with _attach_deps: a deeply-indented @deps\n        # line resolves to the innermost open ancestor at strictly-less\n        # indent — i.e. the nested subtask, not the root task. This is\n        # the end-to-end shape the higher-level parser will use.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        grand = _FakeTask(indent_level=4, name=\"grand\")\n        stack = [root, child, grand]\n\n        m = _DEPS_RE.match(\"      @deps T-000001 T-000002\")\n        assert m is not None\n        indent = len(m.group(1))\n        ids = m.group(2).split()\n\n        target, lenient = _attach_deps(indent, stack)\n        assert target is grand\n        assert lenient is False\n        assert ids == [\"T-000001\", \"T-000002\"]\n\n\nclass TestExtractFlagTags:\n    def test_no_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"plain task text\")\n        assert tags == ()\n        assert rest == \"plain task text\"\n\n    def test_user(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n        assert tags == (\"USER\",)\n        assert rest == \"verify the menu\"\n\n    def test_batch(self) -> None:\n        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n        assert tags == (\"BATCH\",)\n        assert rest == \"sub-task group\"\n\n    def test_user_and_batch_combined(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"both flags\"\n\n    def test_adjacent_tags_without_separator(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"no gap\"\n\n    def test_non_leading_tag_is_prose(self) -> None:\n        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n        assert tags == ()\n        assert rest == \"Document the [USER] tag\"\n\n    def test_only_first_run_is_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n        assert tags == (\"USER\",)\n        assert rest == \"middle [BATCH] later\"\n\n    def test_empty_input(self) -> None:\n        tags, rest = _extract_flag_tags(\"\")\n        assert tags == ()\n        assert rest == \"\"\n\n\nclass TestExtractActionTag:\n    def test_no_action_tag(self) -> None:\n        tag, rest = _extract_action_tag(\"plain task text\")\n        assert tag is None\n        assert rest == \"plain task text\"\n\n    def test_action_with_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n        assert rest == \"\"\n\n    def test_action_without_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n        assert tag == (\"noop\", \"\")\n        assert rest == \"\"\n\n    def test_args_extend_to_end_of_line(self) -> None:\n        # Argument string is text from closing bracket to end of line;\n        # bracketed-looking content in args stays in args.\n        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n        assert tag == (\"run\", \"do [feat: x]\")\n        assert rest == \"\"\n\n    def test_non_leading_auto_is_prose(self) -> None:\n        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n        assert tag is None\n        assert rest == \"Document the [AUTO:run] tag\"\n\n\nclass TestExtractAnnotations:\n    def test_no_annotation(self) -> None:\n        ann, rest = _extract_annotations(\"plain task text\")\n        assert ann == ()\n        assert rest == \"plain task text\"\n\n    def test_single_feat(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n        assert ann == ((\"feat\", '\"menu wired\"'),)\n        assert rest == \"do thing\"\n\n    def test_single_fix(self) -> None:\n        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n        assert ann == ((\"fix\", '\"race\"'),)\n        assert rest == \"fixed it\"\n\n    def test_multiple_annotations_preserve_order(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n        assert ann == (\n            (\"feat\", '\"first\"'),\n            (\"fix\", '\"second\"'),\n        )\n        assert rest == \"do thing\"\n\n    def test_nested_brackets_in_value(self) -> None:\n        # Balanced brackets inside the value are stepped over by the\n        # right-to-left depth scan and stay inside the annotation.\n        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n        assert rest == \"do thing\"\n\n    def test_unquoted_nested_brackets_in_value(self) -> None:\n        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n        assert ann == ((\"feat\", \"a [b] c\"),)\n        assert rest == \"do\"\n\n    def test_prose_bracket_without_separator_is_text(self) -> None:\n        # A `[` abutting a non-whitespace character is task text, not\n        # the start of an annotation.\n        ann, rest = _extract_annotations(\"see config[feat: x]\")\n        assert ann == ()\n        assert rest == \"see config[feat: x]\"\n\n    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n        # `[AUTO:run]` has no whitespace after its colon and so is not\n        # an annotation under this extractor's rules.\n        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n        assert ann == ()\n        assert rest == \"[AUTO:run] cmd\"\n\n    def test_unmatched_open_bracket(self) -> None:\n        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n        assert ann == ()\n        assert rest == \"dangling brackets feat ]\"\n\n    def test_annotation_alone_consumes_to_empty(self) -> None:\n        ann, rest = _extract_annotations('[feat: \"lone\"]')\n        assert ann == ((\"feat\", '\"lone\"'),)\n        assert rest == \"\"\n\n\nclass TestTagInteractions:\n    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n        # Annotation must be stripped before action tag, because action\n        # tag args span to end of line.\n        ann, after_ann = _extract_annotations(text)\n        assert ann == ((\"feat\", '\"done\"'),)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"BATCH\",)\n        action, after_action = _extract_action_tag(after_flags)\n        assert action == (\"run_cli\", \"mcloop --dry-run\")\n        assert after_action == \"\"\n\n    def test_flags_and_plain_text(self) -> None:\n        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n        assert ann == ()\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"USER\", \"BATCH\")\n        action, after_action = _extract_action_tag(after_flags)\n        assert action is None\n        assert after_action == \"verify thing\"\n\n    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n        text = \"Implement [USER] and [AUTO:run] tokenization\"\n        ann, after_ann = _extract_annotations(text)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        action, after_action = _extract_action_tag(after_flags)\n        assert ann == ()\n        assert tags == ()\n        assert action is None\n        assert after_action == text\n\n\nclass TestParsePlanStateMachine:\n    \"\"\"End-to-end tests for the parse_plan walker.\n\n    The state machine in 2.5.2 is responsible for the section-vs-task\n    bookkeeping that earlier building blocks do not own: routing tasks\n    into the right phase or subsection, opening/closing the indent\n    stack at phase/subsection/bugs boundaries, and dispatching ``@deps``\n    and ``[RULEDOUT]`` siblings to the parent task. Tests below\n    exercise each of those responsibilities independently and then in\n    combination on a small but representative plan.\n    \"\"\"\n\n    def test_empty_text_returns_empty_plan(self) -> None:\n        plan = parse_plan(\"\")\n        assert plan.phases == ()\n        assert plan.bugs is None\n        assert plan.project_title == \"\"\n\n    def test_single_phase_with_tasks(self) -> None:\n        text = \"## Stage 1: Core\\n\\n- [ ] first task\\n- [x] second task\\n\"\n        plan = parse_plan(text)\n        assert len(plan.phases) == 1\n        phase = plan.phases[0]\n        assert phase.ordinal == 1\n        assert phase.keyword == \"Stage\"\n        assert phase.title == \"Core\"\n        assert phase.line_number == 1\n        assert len(phase.tasks) == 2\n        assert phase.tasks[0].text == \"first task\"\n        assert phase.tasks[0].status is TaskStatus.TODO\n        assert phase.tasks[0].line_number == 3\n        assert phase.tasks[1].status is TaskStatus.DONE\n\n    def test_phase_heading_keyword_normalized(self) -> None:\n        # \"Phase\" and \"Stage\" are accepted interchangeably and the\n        # keyword captures which form was used (capitalized).\n        plan = parse_plan(\"# Phase 2: Implementation\\n- [ ] x\\n\")\n        assert plan.phases[0].keyword == \"Phase\"\n        assert plan.phases[0].ordinal == 2\n        assert plan.phases[0].title == \"Implementation\"\n\n    def test_phase_with_non_bare_digit_id_is_not_a_phase_heading(self) -> None:\n        # `## Phase phase_001:` is the legacy strict-form heading; per\n        # design doc section 2.5 it does NOT match the bare-digit\n        # STAGE_RE and so is invisible to the compat parser. The tasks\n        # that follow have no enclosing phase and are dropped.\n        text = \"## Phase phase_001: Core\\n- [ ] orphan task\\n\"\n        plan = parse_plan(text)\n        assert plan.phases == ()\n        assert plan.bugs is None\n\n    def test_indent_stack_builds_task_tree(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] parent\\n\"\n            \"  - [ ] child a\\n\"\n            \"    - [ ] grandchild\\n\"\n            \"  - [ ] child b\\n\"\n            \"- [ ] second root\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert len(phase.tasks) == 2\n        parent, second_root = phase.tasks\n        assert parent.text == \"parent\"\n        assert second_root.text == \"second root\"\n        assert len(parent.children) == 2\n        child_a, child_b = parent.children\n        assert child_a.text == \"child a\"\n        assert child_b.text == \"child b\"\n        assert len(child_a.children) == 1\n        assert child_a.children[0].text == \"grandchild\"\n\n    def test_subsection_captures_following_tasks(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] phase task\\n\"\n            \"\\n\"\n            \"### Manual verification\\n\"\n            \"- [ ] sub task one\\n\"\n            \"- [ ] sub task two\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert len(phase.tasks) == 1\n        assert phase.tasks[0].text == \"phase task\"\n        assert len(phase.subsections) == 1\n        sub = phase.subsections[0]\n        assert sub.title == \"Manual verification\"\n        assert tuple(t.text for t in sub.tasks) == (\"sub task one\", \"sub task two\")\n\n    def test_new_phase_resets_indent_stack(self) -> None:\n        # An indented task in the second phase must be treated as a\n        # root of that phase, not as a child of the previous phase's\n        # last task. (mcloop's parser does this via stack.clear().)\n        text = (\n            \"## Stage 1: A\\n- [ ] one\\n  - [ ] one-child\\n## Stage 2: B\\n  - [ ] two\\n\"\n        )\n        plan = parse_plan(text)\n        assert len(plan.phases) == 2\n        assert len(plan.phases[0].tasks) == 1\n        assert plan.phases[0].tasks[0].children[0].text == \"one-child\"\n        assert len(plan.phases[1].tasks) == 1\n        assert plan.phases[1].tasks[0].text == \"two\"\n        assert plan.phases[1].tasks[0].children == ()\n\n    def test_bugs_section_collects_tasks(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] phase task\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] crash on empty input\\n\"\n            \"- [x] fixed memory leak\\n\"\n        )\n        plan = parse_plan(text)\n        assert plan.bugs is not None\n        assert tuple(t.text for t in plan.bugs.tasks) == (\n            \"crash on empty input\",\n            \"fixed memory leak\",\n        )\n        # The phase still owns its own task; bugs is a peer section.\n        assert plan.phases[0].tasks[0].text == \"phase task\"\n\n    def test_task_body_classification_is_applied(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            '- [ ] T-000001: [BATCH] do thing [feat: \"x\"]\\n'\n            \"- [ ] T-000002: [AUTO:run_cli] mcloop --dry-run\\n\"\n        )\n        plan = parse_plan(text)\n        first, second = plan.phases[0].tasks\n        assert first.task_id == \"T-000001\"\n        assert first.flag_tags == (\"BATCH\",)\n        assert first.annotations == ((\"feat\", '\"x\"'),)\n        assert first.text == \"do thing\"\n        assert second.task_id == \"T-000002\"\n        assert second.action_tag == (\"run_cli\", \"mcloop --dry-run\")\n        assert second.text == \"\"\n\n    def test_ruledout_attaches_to_parent_task(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] parent\\n\"\n            \"  [RULEDOUT] tried restart\\n\"\n            \"  [RULEDOUT] tried reinstall\\n\"\n        )\n        plan = parse_plan(text)\n        parent = plan.phases[0].tasks[0]\n        assert tuple(r.text for r in parent.ruled_out) == (\n            \"tried restart\",\n            \"tried reinstall\",\n        )\n\n    def test_deps_attaches_to_preceding_task(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] T-000001: first\\n\"\n            \"- [ ] T-000002: second\\n\"\n            \"  @deps T-000001\\n\"\n        )\n        plan = parse_plan(text)\n        first, second = plan.phases[0].tasks\n        assert first.deps == ()\n        assert second.deps == (\"T-000001\",)\n\n    def test_combined_phase_subsection_bugs_round_trip_structure(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] T-000001: [BATCH] parent\\n\"\n            \"  - [ ] T-000002: child a\\n\"\n            \"    [RULEDOUT] tried polling\\n\"\n            \"  - [ ] T-000003: child b\\n\"\n            \"    @deps T-000002\\n\"\n            \"\\n\"\n            \"### Manual verification\\n\"\n            \"- [ ] T-000004: [USER] run smoke test\\n\"\n            \"\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] T-000009: crash on empty PLAN.md\\n\"\n        )\n        plan = parse_plan(text)\n        assert len(plan.phases) == 1\n        phase = plan.phases[0]\n        parent = phase.tasks[0]\n        assert parent.task_id == \"T-000001\"\n        assert parent.flag_tags == (\"BATCH\",)\n        child_a, child_b = parent.children\n        assert child_a.task_id == \"T-000002\"\n        assert tuple(r.text for r in child_a.ruled_out) == (\"tried polling\",)\n        assert child_b.deps == (\"T-000002\",)\n        assert len(phase.subsections) == 1\n        manual = phase.subsections[0]\n        assert manual.title == \"Manual verification\"\n        assert manual.tasks[0].flag_tags == (\"USER\",)\n        assert plan.bugs is not None\n        assert plan.bugs.tasks[0].task_id == \"T-000009\"\n\n    def test_tasks_before_any_section_are_dropped_in_compat_mode(self) -> None:\n        # No phase or bugs heading has been seen yet, so a task line is\n        # an orphan. Compat mode drops silently to match mcloop's\n        # parser, which assigns ``stage=\"\"`` rather than erroring.\n        # Strict mode (Stage 3) will surface this as a PlanSyntaxError.\n        plan = parse_plan(\"- [ ] orphan\\n## Stage 1: Core\\n- [ ] real\\n\")\n        assert len(plan.phases) == 1\n        assert tuple(t.text for t in plan.phases[0].tasks) == (\"real\",)\n\n    def test_source_path_passes_through(self) -> None:\n        path = Path(\"/tmp/PLAN.md\")\n        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\", source_path=path)\n        assert plan.source_path == path\n\n\nclass TestParsePlanProse:\n    \"\"\"Tests for project title, preamble, phase prose, and subsection prose.\n\n    Per design doc section 4.1 grammar, prose is allowed in three places:\n    after the H1 (the preamble), after a phase heading (phase prose),\n    and after a ``###`` subsection heading (subsection prose). Each\n    region ends at the next structural boundary — phase/bugs heading\n    for the preamble, first task or subsection for phase prose, and\n    first task for subsection prose.\n    \"\"\"\n\n    def test_h1_sets_project_title(self) -> None:\n        plan = parse_plan(\"# My Project\\n## Stage 1: Core\\n\")\n        assert plan.project_title == \"My Project\"\n        assert plan.preamble == \"\"\n\n    def test_no_h1_means_empty_title(self) -> None:\n        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n        assert plan.project_title == \"\"\n        assert plan.preamble == \"\"\n\n    def test_h2_with_stage_keyword_does_not_match_h1(self) -> None:\n        # `## Stage 1: Core` is consumed by the phase regex before the\n        # H1 check runs, so it does not leak into the title slot.\n        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n        assert plan.project_title == \"\"\n        assert len(plan.phases) == 1\n\n    def test_preamble_between_h1_and_phase(self) -> None:\n        text = \"# Project\\n\\nIntro paragraph.\\n\\n## Stage 1: Core\\n- [ ] task\\n\"\n        plan = parse_plan(text)\n        assert plan.project_title == \"Project\"\n        assert plan.preamble == \"Intro paragraph.\"\n\n    def test_preamble_multi_paragraph_preserves_blank_lines(self) -> None:\n        text = (\n            \"# Project\\n\\nFirst paragraph.\\n\\nSecond paragraph.\\n\\n## Stage 1: Core\\n\"\n        )\n        plan = parse_plan(text)\n        assert plan.preamble == \"First paragraph.\\n\\nSecond paragraph.\"\n\n    def test_preamble_ends_at_bugs_heading(self) -> None:\n        # Per the grammar, the preamble is followed by ``PhaseOrBugs+`` —\n        # a bugs section is just as valid a terminator as a phase.\n        text = \"# Project\\nIntro.\\n## Bugs\\n- [ ] crash\\n\"\n        plan = parse_plan(text)\n        assert plan.preamble == \"Intro.\"\n        assert plan.bugs is not None\n        assert plan.bugs.tasks[0].text == \"crash\"\n\n    def test_phase_prose_between_heading_and_first_task(self) -> None:\n        text = \"## Stage 1: Core\\n\\nThe goal is X.\\n\\n- [ ] task\\n\"\n        plan = parse_plan(text)\n        assert plan.phases[0].prose == \"The goal is X.\"\n\n    def test_phase_prose_ends_at_subsection(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\\nPhase intro.\\n\\n### Manual verification\\n- [ ] check\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert phase.prose == \"Phase intro.\"\n        assert phase.subsections[0].prose == \"\"\n\n    def test_subsection_prose_between_heading_and_first_task(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] phase task\\n\"\n            \"### Manual verification\\n\"\n            \"\\n\"\n            \"Run by hand.\\n\"\n            \"\\n\"\n            \"- [ ] check\\n\"\n        )\n        plan = parse_plan(text)\n        sub = plan.phases[0].subsections[0]\n        assert sub.prose == \"Run by hand.\"\n\n    def test_no_prose_when_task_immediately_follows_heading(self) -> None:\n        text = \"# Project\\n## Stage 1: Core\\n- [ ] task\\n\"\n        plan = parse_plan(text)\n        assert plan.preamble == \"\"\n        assert plan.phases[0].prose == \"\"\n\n    def test_lines_before_h1_are_dropped(self) -> None:\n        # Outside any active prose region, prose is dropped — matches the\n        # grammar (Preamble requires an H1 anchor).\n        text = \"noise line\\n# Project\\nIntro.\\n## Stage 1: Core\\n\"\n        plan = parse_plan(text)\n        assert plan.project_title == \"Project\"\n        assert plan.preamble == \"Intro.\"\n\n    def test_prose_after_first_task_in_phase_is_dropped(self) -> None:\n        # Phase prose is \"between the phase heading and the first task\n        # or subsection\". Lines after the first task close the\n        # accumulator and are dropped in compat mode.\n        text = \"## Stage 1: Core\\n- [ ] task\\nstray prose\\n\"\n        plan = parse_plan(text)\n        assert plan.phases[0].prose == \"\"\n        assert plan.phases[0].tasks[0].text == \"task\"\n\n    def test_multiple_phases_each_get_own_prose(self) -> None:\n        text = (\n            \"## Stage 1: A\\n\"\n            \"Prose A.\\n\"\n            \"- [ ] task A\\n\"\n            \"## Stage 2: B\\n\"\n            \"Prose B.\\n\"\n            \"- [ ] task B\\n\"\n        )\n        plan = parse_plan(text)\n        assert plan.phases[0].prose == \"Prose A.\"\n        assert plan.phases[1].prose == \"Prose B.\"\n\n    def test_phase_prose_at_end_of_file_without_tasks(self) -> None:\n        # Final phase has prose but no task to close the accumulator —\n        # the end-of-input close handler must still finalize it.\n        text = \"## Stage 1: Core\\n\\nLone prose.\\n\"\n        plan = parse_plan(text)\n        assert plan.phases[0].prose == \"Lone prose.\"\n        assert plan.phases[0].tasks == ()\n\n\nclass TestParsePlanCompatModeSyntaxErrors:\n    \"\"\"Compat-mode raises :class:`PlanSyntaxError` on genuine syntax breakage.\n\n    Compat mode is intentionally lenient about cases mcloop's parser\n    accepted (orphan tasks before any phase, prose outside accumulators,\n    etc.). But a ``@deps`` line with no preceding task to attach to has\n    no semantic interpretation — the keyword means \"this task depends\n    on\" and there is no task. mcloop never recognized ``@deps`` at all,\n    so there is no compat behavior to preserve. The parser raises\n    :class:`PlanSyntaxError` with the offending line quoted in the\n    message and the source line/column populated.\n    \"\"\"\n\n    def test_orphan_deps_line_before_any_task_raises(self) -> None:\n        text = \"## Stage 1: Core\\n  @deps T-000001\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert err.line == 2\n        assert err.column == 3\n        assert \"no preceding task\" in err.message\n        assert \"`  @deps T-000001`\" in err.message\n\n    def test_orphan_deps_with_no_phase_raises(self) -> None:\n        # Even before any section, a stray @deps is malformed: there is\n        # no plausible target. The orphan-task tolerance does not extend\n        # here because @deps has no mcloop precedent.\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(\"@deps T-000001\\n\")\n        assert exc_info.value.line == 1\n        assert exc_info.value.column == 1\n\n    def test_syntax_error_carries_source_path(self) -> None:\n        path = Path(\"/tmp/PLAN.md\")\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(\"@deps T-000001\\n\", source_path=path)\n        assert exc_info.value.path == path\n\n    def test_syntax_error_str_format_matches_design_doc(self) -> None:\n        # Section 9 contract: \"PLAN.md invalid at line N, column M: ...\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(\"@deps T-000001\\n\")\n        rendered = str(exc_info.value)\n        assert rendered.startswith(\"PLAN.md invalid at line 1, column 1: \")\n        assert \"@deps T-000001\" in rendered\n","numLines":903,"startLine":1,"totalLines":903}}}
