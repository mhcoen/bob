{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012bRFCAxXUoN6uQxcPuY6Mb","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom collections.abc import Sequence\n7\tfrom dataclasses import dataclass\n8\tfrom typing import Protocol, TypeVar\n9\t\n10\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n11\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n12\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n13\t\n14\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n15\t# caller strips any inter-tag whitespace between iterations.\n16\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n17\t\n18\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n19\t# after the closing bracket (with the single separating space removed).\n20\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n21\t\n22\t# Content of an annotation (the bytes between `[` and `]`): an\n23\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n24\t# value. The required whitespace after the colon is what distinguishes\n25\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n26\t# after its colon).\n27\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n28\t\n29\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n30\t# token, and optional trailing text. Matches mcloop's `parse`, which\n31\t# treats a line as RULEDOUT when its stripped form starts with the\n32\t# literal bracket token.\n33\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n34\t\n35\t\n36\t@dataclass(frozen=True)\n37\tclass _RawTaskLine:\n38\t    \"\"\"Recognize-step output of `_parse_task_line`.\n39\t\n40\t    Stage 2 of the parser splits recognize-then-classify. This record\n41\t    is the recognize step: indent text, status marker, body text, and\n42\t    source line number. Higher-level functions classify the body into\n43\t    task id, tags, deps, and prose.\n44\t    \"\"\"\n45\t\n46\t    indent: str\n47\t    status_char: str\n48\t    text: str\n49\t    line_number: int\n50\t\n51\t\n52\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n53\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n54\t    m = _CHECKBOX_RE.match(line)\n55\t    if m is None:\n56\t        return None\n57\t    return _RawTaskLine(\n58\t        indent=m.group(1),\n59\t        status_char=m.group(2),\n60\t        text=m.group(3),\n61\t        line_number=line_number,\n62\t    )\n63\t\n64\t\n65\t@dataclass(frozen=True)\n66\tclass _RawRuledOut:\n67\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n68\t\n69\t    A RULEDOUT line is a sibling of the task it pertains to (design\n70\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n71\t    captures only indent, body text, and source line number; attaching\n72\t    the line to its parent task by indentation is a higher-level step.\n73\t    \"\"\"\n74\t\n75\t    indent: str\n76\t    text: str\n77\t    line_number: int\n78\t\n79\t\n80\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n81\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n82\t\n83\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n84\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n85\t    whitespace on the body text is stripped; an empty body is allowed.\n86\t    \"\"\"\n87\t    m = _RULEDOUT_RE.match(line)\n88\t    if m is None:\n89\t        return None\n90\t    return _RawRuledOut(\n91\t        indent=m.group(1),\n92\t        text=m.group(2).strip(),\n93\t        line_number=line_number,\n94\t    )\n95\t\n96\t\n97\tclass _HasIndentLevel(Protocol):\n98\t    \"\"\"Anything with an integer ``indent_level`` attribute.\n99\t\n100\t    Used by :func:`_attach_ruledout` so it can resolve attachment over\n101\t    either the eventual frozen ``Task`` model objects or the mutable\n102\t    builder records the parser uses while constructing them.\n103\t    \"\"\"\n104\t\n105\t    @property\n106\t    def indent_level(self) -> int: ...\n107\t\n108\t\n109\t_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n110\t\n111\t\n112\tdef _attach_ruledout(\n113\t    indent: int,\n114\t    stack: Sequence[_T],\n115\t    root_tasks: Sequence[_T],\n116\t) -> _T | None:\n117\t    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n118\t\n119\t    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n120\t    the open-ancestor stack from innermost to outermost and return the\n121\t    first task whose indent is strictly less than the RULEDOUT line's\n122\t    indent. If no such ancestor exists in the current phase, fall back\n123\t    to the most recent root task (mcloop's \"orphan\" handling). Returns\n124\t    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n125\t    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n126\t    the caller should drop.\n127\t    \"\"\"\n128\t    for task in reversed(stack):\n129\t        if task.indent_level < indent:\n130\t            return task\n131\t    if root_tasks:\n132\t        return root_tasks[-1]\n133\t    return None\n134\t\n135\t\n136\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n137\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n138\t\n139\t    Per design doc section 4.3, flag tags are recognized only at the\n140\t    leading position. The caller is responsible for stripping the task\n141\t    ID (if any) first. A bracketed flag form appearing later in the\n142\t    text is prose and is left in place.\n143\t    \"\"\"\n144\t    tags: list[str] = []\n145\t    remaining = text\n146\t    while True:\n147\t        m = _FLAG_TAG_RE.match(remaining)\n148\t        if m is None:\n149\t            break\n150\t        tags.append(m.group(1))\n151\t        remaining = remaining[m.end() :].lstrip()\n152\t    return tuple(tags), remaining\n153\t\n154\t\n155\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n156\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n157\t\n158\t    Per design doc section 4.3, the action tag is recognized only at\n159\t    the leading position, after any flag tags. The argument string is\n160\t    the text from the closing bracket to end of line, with the single\n161\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n162\t    are prose and are left in place.\n163\t\n164\t    Returns ``(None, text)`` when no leading action tag is present;\n165\t    otherwise consumes the rest of the line as the argument string\n166\t    and returns ``((action, args), \"\")``.\n167\t    \"\"\"\n168\t    m = _ACTION_TAG_RE.match(text)\n169\t    if m is None:\n170\t        return None, text\n171\t    action = m.group(1)\n172\t    args = text[m.end() :].lstrip()\n173\t    return (action, args), \"\"\n174\t\n175\t\n176\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n177\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n178\t\n179\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n180\t    are bracketed, and are separated from the preceding text by\n181\t    whitespace. Multiple annotations are allowed. Values may contain\n182\t    balanced bracket pairs; this function scans right-to-left with\n183\t    bracket-depth tracking so nested brackets stay inside a single\n184\t    annotation rather than being misparsed as a separate one.\n185\t\n186\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n187\t    accepts any identifier-shaped key. Validation of allowed keys is\n188\t    a separate concern.\n189\t    \"\"\"\n190\t    annotations: list[tuple[str, str]] = []\n191\t    remaining = text\n192\t    while True:\n193\t        rstripped = remaining.rstrip()\n194\t        if not rstripped.endswith(\"]\"):\n195\t            remaining = rstripped\n196\t            break\n197\t        start = _find_matching_open_bracket(rstripped)\n198\t        if start is None:\n199\t            remaining = rstripped\n200\t            break\n201\t        # An annotation must be separated from preceding text by\n202\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n203\t        # character is part of the task text, not an annotation.\n204\t        if start > 0 and not rstripped[start - 1].isspace():\n205\t            remaining = rstripped\n206\t            break\n207\t        content = rstripped[start + 1 : -1]\n208\t        m = _ANNOTATION_CONTENT_RE.match(content)\n209\t        if m is None:\n210\t            remaining = rstripped\n211\t            break\n212\t        annotations.insert(0, (m.group(1), m.group(2)))\n213\t        remaining = rstripped[:start].rstrip()\n214\t    return tuple(annotations), remaining\n215\t\n216\t\n217\tdef _find_matching_open_bracket(s: str) -> int | None:\n218\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n219\t\n220\t    Walks right-to-left tracking bracket depth so balanced nested\n221\t    brackets inside the candidate annotation are stepped over.\n222\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n223\t    opener.\n224\t    \"\"\"\n225\t    if not s.endswith(\"]\"):\n226\t        return None\n227\t    depth = 0\n228\t    for i in range(len(s) - 1, -1, -1):\n229\t        c = s[i]\n230\t        if c == \"]\":\n231\t            depth += 1\n232\t        elif c == \"[\":\n233\t            depth -= 1\n234\t            if depth == 0:\n235\t                return i\n236\t    return None\n237\t"}]},"parent_tool_use_id":null,"session_id":"7daf3165-203a-4a0a-9a4a-c7b8a0f7e266","uuid":"a2afdeae-3a42-4166-a712-f659dbbb8c8d","timestamp":"2026-05-16T02:02:10.431Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections.abc import Sequence\nfrom dataclasses import dataclass\nfrom typing import Protocol, TypeVar\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\nclass _HasIndentLevel(Protocol):\n    \"\"\"Anything with an integer ``indent_level`` attribute.\n\n    Used by :func:`_attach_ruledout` so it can resolve attachment over\n    either the eventual frozen ``Task`` model objects or the mutable\n    builder records the parser uses while constructing them.\n    \"\"\"\n\n    @property\n    def indent_level(self) -> int: ...\n\n\n_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n\n\ndef _attach_ruledout(\n    indent: int,\n    stack: Sequence[_T],\n    root_tasks: Sequence[_T],\n) -> _T | None:\n    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n\n    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n    the open-ancestor stack from innermost to outermost and return the\n    first task whose indent is strictly less than the RULEDOUT line's\n    indent. If no such ancestor exists in the current phase, fall back\n    to the most recent root task (mcloop's \"orphan\" handling). Returns\n    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n    the caller should drop.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task\n    if root_tasks:\n        return root_tasks[-1]\n    return None\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n","numLines":237,"startLine":1,"totalLines":237}}}
