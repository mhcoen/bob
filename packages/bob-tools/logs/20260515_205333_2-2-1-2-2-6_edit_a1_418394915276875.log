{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CDsJXbAmC2YeK4Y7H33NBK","type":"tool_result","content":"1\t\"\"\"Plan Ledger event types and envelope.\n2\t\n3\tThe ledger writes one JSON object per line into ``PLAN.events.jsonl``.\n4\tEach line is an ``Event``: a stable envelope of identification and\n5\tprovenance fields, plus a type-specific ``payload``. The envelope is\n6\tthe part the projector and downstream consumers can rely on across\n7\tevent types; the payload shape is governed by JSON Schema in\n8\t``schema.py``.\n9\t\n10\tReplay ordering is by ``event_id`` (UUIDv7 time-prefix) with\n11\t``(writer_id, seq)`` as a deterministic tiebreaker. ``ts`` is for\n12\thuman audit only, not for replay.\n13\t\n14\tSlice A introduces sixteen active event types plus two reserved types\n15\twhose schemas are validated but whose semantics are deferred. The\n16\tprojector applies the active types and ignores the reserved ones,\n17\trecording their occurrence in ``last_event_id`` only.\n18\t\"\"\"\n19\t\n20\tfrom __future__ import annotations\n21\t\n22\timport json\n23\tfrom collections.abc import Mapping, Sequence\n24\tfrom dataclasses import asdict, dataclass\n25\tfrom enum import StrEnum\n26\tfrom typing import Any\n27\t\n28\tfrom bob_tools.ledger._uuid7 import is_uuid7\n29\t\n30\tSCHEMA_VERSION = \"1.0\"\n31\t\n32\t\n33\tclass EventType(StrEnum):\n34\t    \"\"\"All Slice A event type names.\n35\t\n36\t    The first sixteen are active: the projector applies them. The last\n37\t    two are reserved: their schemas validate, the projector records\n38\t    that they occurred but does not project state from them. They are\n39\t    Slice B's responsibility.\n40\t    \"\"\"\n41\t\n42\t    PHASE_STARTED = \"phase_started\"\n43\t    PHASE_COMPLETED = \"phase_completed\"\n44\t    PHASE_ABANDONED = \"phase_abandoned\"\n45\t    PHASE_BLOCKED = \"phase_blocked\"\n46\t    PHASE_SUPERSEDED = \"phase_superseded\"\n47\t    PHASE_SPLIT = \"phase_split\"\n48\t    PHASE_MERGED = \"phase_merged\"\n49\t    COMMIT_LANDED = \"commit_landed\"\n50\t    TEST_FAILED = \"test_failed\"\n51\t    FINDING_OBSERVED = \"finding_observed\"\n52\t    INVARIANT_DECLARED = \"invariant_declared\"\n53\t    ASSUMPTION_DECLARED = \"assumption_declared\"\n54\t    ASSUMPTION_FALSIFIED = \"assumption_falsified\"\n55\t    WORK_OBSERVED = \"work_observed\"\n56\t    HUMAN_DECISION_RECORDED = \"human_decision_recorded\"\n57\t    DESIGN_REASONING_RECORDED = \"design_reasoning_recorded\"\n58\t    THRESHOLD_CROSSED = \"threshold_crossed\"\n59\t    PLAN_REAUTHORED = \"plan_reauthored\"\n60\t"}]},"parent_tool_use_id":null,"session_id":"3adf629f-43bb-4015-a8e6-d8e6f9cc3300","uuid":"f6d19af9-b6ab-4a73-8125-a2c0c0229da1","timestamp":"2026-05-16T01:47:24.063Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/ledger/events.py","content":"\"\"\"Plan Ledger event types and envelope.\n\nThe ledger writes one JSON object per line into ``PLAN.events.jsonl``.\nEach line is an ``Event``: a stable envelope of identification and\nprovenance fields, plus a type-specific ``payload``. The envelope is\nthe part the projector and downstream consumers can rely on across\nevent types; the payload shape is governed by JSON Schema in\n``schema.py``.\n\nReplay ordering is by ``event_id`` (UUIDv7 time-prefix) with\n``(writer_id, seq)`` as a deterministic tiebreaker. ``ts`` is for\nhuman audit only, not for replay.\n\nSlice A introduces sixteen active event types plus two reserved types\nwhose schemas are validated but whose semantics are deferred. The\nprojector applies the active types and ignores the reserved ones,\nrecording their occurrence in ``last_event_id`` only.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nfrom collections.abc import Mapping, Sequence\nfrom dataclasses import asdict, dataclass\nfrom enum import StrEnum\nfrom typing import Any\n\nfrom bob_tools.ledger._uuid7 import is_uuid7\n\nSCHEMA_VERSION = \"1.0\"\n\n\nclass EventType(StrEnum):\n    \"\"\"All Slice A event type names.\n\n    The first sixteen are active: the projector applies them. The last\n    two are reserved: their schemas validate, the projector records\n    that they occurred but does not project state from them. They are\n    Slice B's responsibility.\n    \"\"\"\n\n    PHASE_STARTED = \"phase_started\"\n    PHASE_COMPLETED = \"phase_completed\"\n    PHASE_ABANDONED = \"phase_abandoned\"\n    PHASE_BLOCKED = \"phase_blocked\"\n    PHASE_SUPERSEDED = \"phase_superseded\"\n    PHASE_SPLIT = \"phase_split\"\n    PHASE_MERGED = \"phase_merged\"\n    COMMIT_LANDED = \"commit_landed\"\n    TEST_FAILED = \"test_failed\"\n    FINDING_OBSERVED = \"finding_observed\"\n    INVARIANT_DECLARED = \"invariant_declared\"\n    ASSUMPTION_DECLARED = \"assumption_declared\"\n    ASSUMPTION_FALSIFIED = \"assumption_falsified\"\n    WORK_OBSERVED = \"work_observed\"\n    HUMAN_DECISION_RECORDED = \"human_decision_recorded\"\n    DESIGN_REASONING_RECORDED = \"design_reasoning_recorded\"\n    THRESHOLD_CROSSED = \"threshold_crossed\"\n    PLAN_REAUTHORED = \"plan_reauthored\"\n","numLines":60,"startLine":1,"totalLines":575}}}
