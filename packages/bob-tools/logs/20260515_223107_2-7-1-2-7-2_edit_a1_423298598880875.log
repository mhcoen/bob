cloop's specific\n1092:        with pytest.raises(PlanSyntaxError) as exc_info:\n1102:        with pytest.raises(PlanSyntaxError) as exc_info:\n1106:    def test_duplicate_phase_ordinals_raise(self) -> None:\n1115:        with pytest.raises(PlanSyntaxError) as exc_info:\n1118:        assert \"duplicate Phase/Stage 1\" in err.message\n1121:    def test_duplicate_ordinal_across_stage_and_phase_keyword_raise(self) -> None:\n1124:        # captured numeric group, not the keyword, so the duplicate is\n1127:        with pytest.raises(PlanSyntaxError) as exc_info:\n1129:        assert \"duplicate Phase/Stage 2\" in exc_info.value.message\n1134:        # single such header is not a duplicate of either kind. Mirrors\n1157:        with pytest.raises(PlanSyntaxError) as exc_info:\n1167:        with pytest.raises(PlanSyntaxError) as exc_info:\n1170:        assert \"duplicate top-level heading '# Dup'\" in err.message\n1171:        assert \"duplicate Phase/Stage 1\" in err.message\n1173:        # Earliest anomaly is the H1 duplicate at line 1.\n1186:    one-based on the :class:`PlanSyntaxError` itself), absolute (not\n1195:    def test_duplicate_h1_three_occurrences_lists_every_line(self) -> None:\n1213:        with pytest.raises(PlanSyntaxError) as exc_info:\n1216:        assert \"duplicate top-level heading '# Same Title'\" in err.message\n1236:        with pytest.raises(PlanSyntaxError) as exc_info:\n1243:    def test_duplicate_phase_ordinals_three_occurrences_lists_every_line(self) -> None:\n1258:        with pytest.raises(PlanSyntaxError) as exc_info:\n1261:        assert \"duplicate Phase/Stage 2\" in err.message\n1268:        # not the 0-based list index used internally. A duplicate H1 on\n1272:        with pytest.raises(PlanSyntaxError) as exc_info:\n1279:    def test_h1_duplicates_reported_in_source_order(self) -> None:\n1280:        # If duplicates appear later in the file in a non-monotonic\n1295:        with pytest.raises(PlanSyntaxError) as exc_info:"}]},"parent_tool_use_id":null,"session_id":"3b1ef66d-baf8-49c8-864c-a73d9129cd6f","uuid":"5c66eb73-51e7-4851-973d-cde8a04ef00b","timestamp":"2026-05-16T03:26:50.174Z","tool_use_result":{"mode":"content","numFiles":0,"filenames":[],"content":"28:  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n31:  - ``_extract_annotations`` consumes trailing ``[key: value]``\n32:    annotations, handles multiple annotations and nested brackets in\n37:from __future__ import annotations\n44:from bob_tools.planfile.model import PlanSyntaxError, TaskStatus\n50:    _extract_action_tag,\n51:    _extract_annotations,\n401:    def test_no_action_tag(self) -> None:\n402:        tag, rest = _extract_action_tag(\"plain task text\")\n407:        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n412:        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n419:        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n424:        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n430:    def test_no_annotation(self) -> None:\n431:        ann, rest = _extract_annotations(\"plain task text\")\n436:        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n441:        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n445:    def test_multiple_annotations_preserve_order(self) -> None:\n446:        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n455:        # right-to-left depth scan and stay inside the annotation.\n456:        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n461:        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n467:        # the start of an annotation.\n468:        ann, rest = _extract_annotations(\"see config[feat: x]\")\n472:    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n474:        # an annotation under this extractor's rules.\n475:        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n480:        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n484:    def test_annotation_alone_consumes_to_empty(self) -> None:\n485:        ann, rest = _extract_annotations('[feat: \"lone\"]')\n491:    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n493:        # Annotation must be stripped before action tag, because action\n495:        ann, after_ann = _extract_annotations(text)\n499:        action, after_action = _extract_action_tag(after_flags)\n504:        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n508:        action, after_action = _extract_action_tag(after_flags)\n514:        ann, after_ann = _extract_annotations(text)\n516:        action, after_action = _extract_action_tag(after_flags)\n656:        assert first.annotations == ((\"feat\", '\"x\"'),)\n659:        assert second.action_tag == (\"run_cli\", \"mcloop --dry-run\")\n724:        # Strict mode (Stage 3) will surface this as a PlanSyntaxError.\n741:    region ends at the next structural boundary — phase/bugs heading\n864:    structural region together — title, preamble, phase prose, phase\n931:        # and raise PlanSyntaxError when it is missing.\n1008:    \"\"\"Compat-mode raises :class:`PlanSyntaxError` on genuine syntax breakage.\n1016:    :class:`PlanSyntaxError` with the offending line quoted in the\n1022:        with pytest.raises(PlanSyntaxError) as exc_info:\n1034:        with pytest.raises(PlanSyntaxError) as exc_info:\n1041:        with pytest.raises(PlanSyntaxError) as exc_info:\n1047:        with pytest.raises(PlanSyntaxError) as exc_info:\n1057:    ``_check_structural_sanity`` is run at the start of ``parse_plan``\n1058:    and raises :class:`PlanSyntaxError` on duplicate H1 titles, multiple\n1059:    Bugs sections (any heading level), and duplicate phase/stage\n1064:    def test_duplicate_h1_titles_raise(self) -> None:\n1066:        with pytest.raises(PlanSyntaxError) as exc_info:\n1070:        assert \"duplicate top-level heading '# My Project'\" in err.message\n1076:        # targets *identical* duplicates, which is mcloop's specific\n1092:        with pytest.raises(PlanSyntaxError) as exc_info:\n1102:        with pytest.raises(PlanSyntaxError) as exc_info:\n1106:    def test_duplicate_phase_ordinals_raise(self) -> None:\n1115:        with pytest.raises(PlanSyntaxError) as exc_info:\n1118:        assert \"duplicate Phase/Stage 1\" in err.message\n1121:    def test_duplicate_ordinal_across_stage_and_phase_keyword_raise(self) -> None:\n1124:        # captured numeric group, not the keyword, so the duplicate is\n1127:        with pytest.raises(PlanSyntaxError) as exc_info:\n1129:        assert \"duplicate Phase/Stage 2\" in exc_info.value.message\n1134:        # single such header is not a duplicate of either kind. Mirrors\n1157:        with pytest.raises(PlanSyntaxError) as exc_info:\n1167:        with pytest.raises(PlanSyntaxError) as exc_info:\n1170:        assert \"duplicate top-level heading '# Dup'\" in err.message\n1171:        assert \"duplicate Phase/Stage 1\" in err.message\n1173:        # Earliest anomaly is the H1 duplicate at line 1.\n1186:    one-based on the :class:`PlanSyntaxError` itself), absolute (not\n1195:    def test_duplicate_h1_three_occurrences_lists_every_line(self) -> None:\n1213:        with pytest.raises(PlanSyntaxError) as exc_info:\n1216:        assert \"duplicate top-level heading '# Same Title'\" in err.message\n1236:        with pytest.raises(PlanSyntaxError) as exc_info:\n1243:    def test_duplicate_phase_ordinals_three_occurrences_lists_every_line(self) -> None:\n1258:        with pytest.raises(PlanSyntaxError) as exc_info:\n1261:        assert \"duplicate Phase/Stage 2\" in err.message\n1268:        # not the 0-based list index used internally. A duplicate H1 on\n1272:        with pytest.raises(PlanSyntaxError) as exc_info:\n1279:    def test_h1_duplicates_reported_in_source_order(self) -> None:\n1280:        # If duplicates appear later in the file i