{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KZi5prkXwjrLe92yXSS3tM","type":"tool_result","content":"28:  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n31:  - ``_extract_annotations`` consumes trailing ``[key: value]``\n32:    annotations, handles multiple annotations and nested brackets in\n37:from __future__ import annotations\n44:from bob_tools.planfile.model import PlanSyntaxError, TaskStatus\n50:    _extract_action_tag,\n51:    _extract_annotations,\n401:    def test_no_action_tag(self) -> None:\n402:        tag, rest = _extract_action_tag(\"plain task text\")\n407:        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n412:        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n419:        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n424:        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n430:    def test_no_annotation(self) -> None:\n431:        ann, rest = _extract_annotations(\"plain task text\")\n436:        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n441:        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n445:    def test_multiple_annotations_preserve_order(self) -> None:\n446:        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n455:        # right-to-left depth scan and stay inside the annotation.\n456:        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n461:        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n467:        # the start of an annotation.\n468:        ann, rest = _extract_annotations(\"see config[feat: x]\")\n472:    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n474:        # an annotation under this extractor's rules.\n475:        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n480:        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n484:    def test_annotati