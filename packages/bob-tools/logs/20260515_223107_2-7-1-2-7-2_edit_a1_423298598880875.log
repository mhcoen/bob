{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GXd2u6Mpe7Gdn9W5yNUJkd","type":"tool_result","content":"1000\t        assert first.tasks[1].status is TaskStatus.DONE\n1001\t\n1002\t        assert second.title == \"Second sub\"\n1003\t        assert tuple(t.text for t in second.tasks) == (\"sub-2-a\",)\n1004\t        assert second.tasks[0].children == ()\n1005\t\n1006\t\n1007\tclass TestParsePlanCompatModeSyntaxErrors:\n1008\t    \"\"\"Compat-mode raises :class:`PlanSyntaxError` on genuine syntax breakage.\n1009\t\n1010\t    Compat mode is intentionally lenient about cases mcloop's parser\n1011\t    accepted (orphan tasks before any phase, prose outside accumulators,\n1012\t    etc.). But a ``@deps`` line with no preceding task to attach to has\n1013\t    no semantic interpretation — the keyword means \"this task depends\n1014\t    on\" and there is no task. mcloop never recognized ``@deps`` at all,\n1015\t    so there is no compat behavior to preserve. The parser raises\n1016\t    :class:`PlanSyntaxError` with the offending line quoted in the\n1017\t    message and the source line/column populated.\n1018\t    \"\"\"\n1019\t\n1020\t    def test_orphan_deps_line_before_any_task_raises(self) -> None:\n1021\t        text = \"## Stage 1: Core\\n  @deps T-000001\\n\"\n1022\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1023\t            parse_plan(text)\n1024\t        err = exc_info.value\n1025\t        assert err.line == 2\n1026\t        assert err.column == 3\n1027\t        assert \"no preceding task\" in err.message\n1028\t        assert \"`  @deps T-000001`\" in err.message\n1029\t\n1030\t    def test_orphan_deps_with_no_phase_raises(self) -> None:\n1031\t        # Even before any section, a stray @deps is malformed: there is\n1032\t        # no plausible target. The orphan-task tolerance does not extend\n1033\t        # here because @deps has no mcloop precedent.\n1034\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1035\t            parse_plan(\"@deps T-000001\\n\")\n1036\t        assert exc_info.value.line == 1\n1037\t        assert exc_info.value.column == 1\n1038\t\n1039\t    def test_syntax_error_carries_source_path(self) -> None:\n1040\t        path = Path(\"/tmp/PLAN.md\")\n1041\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1042\t            parse_plan(\"@deps T-000001\\n\", source_path=path)\n1043\t        assert exc_info.value.path == path\n1044\t\n1045\t    def test_syntax_error_str_format_matches_design_doc(self) -> None:\n1046\t        # Section 9 contract: \"PLAN.md invalid at line N, column M: ...\"\n1047\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1048\t            parse_plan(\"@deps T-000001\\n\")\n1049\t        rendered = str(exc_info.value)\n1050\t        assert rendered.startswith(\"PLAN.md invalid at line 1, column 1: \")\n1051\t        assert \"@deps T-000001\" in rendered\n1052\t\n1053\t\n1054\tclass TestCheckStructuralSanity:\n1055\t    \"\"\"Pre-parse corruption check rejects three anomalies (mcloop parity).\n1056\t\n1057\t    ``_check_structural_sanity`` is run at the start of ``parse_plan``\n1058\t    and raises :class:`PlanSyntaxError` on duplicate H1 titles, multiple\n1059\t    Bugs sections (any heading level), and duplicate phase/stage\n1060\t    ordinals. The rationale (no auto-fix; mutating a corrupted plan\n1061\t    risks compounding the corruption) is preserved from mcloop.\n1062\t    \"\"\"\n1063\t\n1064\t    def test_duplicate_h1_titles_raise(self) -> None:\n1065\t        text = \"# My Project\\n\\n# My Project\\n## Stage 1: Core\\n- [ ] x\\n\"\n1066\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1067\t            parse_plan(text)\n1068\t        err = exc_info.value\n1069\t        assert err.line == 1\n1070\t        assert \"duplicate top-level heading '# My Project'\" in err.message\n1071\t        assert \"lines 1, 3\" in err.message\n1072\t\n1073\t    def test_distinct_h1_titles_do_not_raise(self) -> None:\n1074\t        # Two different H1 titles are still anomalous in strict mode\n1075\t        # (only one H1 is allowed) but are not caught here — the check\n1076\t        # targets *identical* duplicates, which is mcloop's specific\n1077\t        # corruption signal. Distinct-but-multiple is handled by strict\n1078\t        # mode in Stage 3, not by this corruption pre-check.\n1079\t        text = \"# Project A\\n\\n# Project B\\n## Stage 1: Core\\n- [ ] x\\n\"\n1080\t        parse_plan(text)\n1081\t\n1082\t    def test_multiple_bugs_sections_raise(self) -> None:\n1083\t        text = (\n1084\t            \"# Project\\n\"\n1085\t            \"## Stage 1: Core\\n\"\n1086\t            \"- [ ] x\\n\"\n1087\t            \"## Bugs\\n\"\n1088\t            \"- [ ] bug a\\n\"\n1089\t            \"## Bugs\\n\"\n1090\t            \"- [ ] bug b\\n\"\n1091\t        )\n1092\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1093\t            parse_plan(text)\n1094\t        err = exc_info.value\n1095\t        assert \"multiple Bugs sections\" in err.message\n1096\t        assert \"lines 4, 6\" in err.message\n1097\t\n1098\t    def test_multiple_bugs_sections_at_different_heading_levels_raise(self) -> None:\n1099\t        # ``_BUGS_RE`` matches any heading level whose title is ``Bugs``;\n1100\t        # mixing ``## Bugs`` and ``### Bugs`` still trips the check.\n1101\t        text = \"## Stage 1: Core\\n- [ ] x\\n## Bugs\\n- [ ] one\\n### Bugs\\n- [ ] two\\n\"\n1102\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1103\t            parse_plan(text)\n1104\t        assert \"multiple Bugs sections\" in exc_info.value.message\n1105\t\n1106\t    def test_duplicate_phase_ordinals_raise(self) -> None:\n1107\t        text = (\n1108\t            \"## Stage 1: Core\\n\"\n1109\t            \"- [ ] first\\n\"\n1110\t            \"## Stage 2: Polish\\n\"\n1111\t            \"- [ ] second\\n\"\n1112\t            \"## Stage 1: Repeat\\n\"\n1113\t            \"- [ ] third\\n\"\n1114\t        )\n1115\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1116\t            parse_plan(text)\n1117\t        err = exc_info.value\n1118\t        assert \"duplicate Phase/Stage 1\" in err.message\n1119\t        assert \"lines 1, 5\" in err.message\n1120\t\n1121\t    def test_duplicate_ordinal_across_stage_and_phase_keyword_raise(self) -> None:\n1122\t        # Mcloop treats the keyword as cosmetic; ``Stage 2`` and\n1123\t        # ``Phase 2`` both contribute ordinal 2. The check uses the\n1124\t        # captured numeric group, not the keyword, so the duplicate is\n1125\t        # detected regardless of which spelling each header used.\n1126\t        text = \"## Stage 2: A\\n- [ ] x\\n## Phase 2: B\\n- [ ] y\\n\"\n1127\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1128\t            parse_plan(text)\n1129\t        assert \"duplicate Phase/Stage 2\" in exc_info.value.message\n1130\t\n1131\t    def test_h1_phase_heading_not_double_counted(self) -> None:\n1132\t        # ``# Phase 1: ...`` matches both ``_H1_RE`` and ``_STAGE_RE``.\n1133\t        # The check classifies it as a stage header (not an H1) so a\n1134\t        # single such header is not a duplicate of either kind. Mirrors\n1135\t        # mcloop's check order (STAGE_RE first, then BUGS_RE, then H1).\n1136\t        text = \"# Phase 1: Core\\n- [ ] x\\n\"\n1137\t        parse_plan(text)\n1138\t\n1139\t    def test_clean_plan_does_not_raise(self) -> None:\n1140\t        text = (\n1141\t            \"# My Project\\n\\n\"\n1142\t            \"## Stage 1: Core\\n\"\n1143\t            \"- [ ] a\\n\"\n1144\t            \"## Stage 2: Polish\\n\"\n1145\t            \"- [ ] b\\n\"\n1146\t            \"## Bugs\\n\"\n1147\t            \"- [ ] c\\n\"\n1148\t        )\n1149\t        plan = parse_plan(text)\n1150\t        assert plan.project_title == \"My Project\"\n1151\t        assert len(plan.phases) == 2\n1152\t        assert plan.bugs is not None\n1153\t\n1154\t    def test_error_carries_source_path(self) -> None:\n1155\t        path = Path(\"/tmp/PLAN.md\")\n1156\t        text = \"# Dup\\n# Dup\\n\"\n1157\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1158\t            parse_plan(text, source_path=path)\n1159\t        assert exc_info.value.path == path\n1160\t\n1161\t    def test_error_aggregates_all_problems_in_message(self) -> None:\n1162\t        # When multiple corruption signals are present, the single\n1163\t        # raised error lists all of them so the user does not have to\n1164\t        # re-run after each fix. The reported line is the earliest one\n1165\t        # so locators stay monotonic.\n1166\t        text = \"# Dup\\n# Dup\\n## Stage 1: A\\n## Stage 1: B\\n## Bugs\\n## Bugs\\n\"\n1167\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1168\t            parse_plan(text)\n1169\t        err = exc_info.value\n1170\t        assert \"duplicate top-level heading '# Dup'\" in err.message\n1171\t        assert \"duplicate Phase/Stage 1\" in err.message\n1172\t        assert \"multiple Bugs sections\" in err.message\n1173\t        # Earliest anomaly is the H1 duplicate at line 1.\n1174\t        assert err.line == 1\n1175\t\n1176\t\n1177\tclass TestCheckStructuralSanityLineNumberReporting:\n1178\t    \"\"\"Each corruption pattern surfaces every offending line number.\n1179\t\n1180\t    Sibling tests in :class:`TestCheckStructuralSanity` confirm each\n1181\t    anomaly is detected at all; this class targets the contract spelled\n1182\t    out by the 2.6.2 task description specifically: every offending\n1183\t    source line number must appear in the error message so the user can\n1184\t    fix all occurrences in one pass without re-running. The numbers must\n1185\t    be one-based (matching design doc section 9, which makes line/column\n1186\t    one-based on the :class:`PlanSyntaxError` itself), absolute (not\n1187\t    relative to a phase or section), and listed in source order.\n1188\t\n1189\t    Each pattern is exercised with three+ occurrences and at non-trivial\n1190\t    line numbers (i.e. not just the head of the file) so a future\n1191\t    refactor that drops occurrences after the first two, or that emits\n1192\t    zero-based offsets, will be caught.\n1193\t    \"\"\"\n1194\t\n1195\t    def test_duplicate_h1_three_occurrences_lists_every_line(self) -> None:\n1196\t        # Three copies of the same H1 with prose padding between them so\n1197\t        # the offending lines are non-adjacent and at >1-digit positions.\n1198\t        text = (\n1199\t            \"# Same Title\\n\"\n1200\t            \"Intro one.\\n\"\n1201\t            \"\\n\"\n1202\t            \"More prose.\\n\"\n1203\t            \"\\n\"\n1204\t            \"# Same Title\\n\"\n1205\t            \"Intro two.\\n\"\n1206\t            \"\\n\"\n1207\t            \"More prose.\\n\"\n1208\t            \"\\n\"\n1209\t            \"# Same Title\\n\"\n1210\t            \"## Stage 1: Core\\n\"\n1211\t            \"- [ ] x\\n\"\n1212\t        )\n1213\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1214\t            parse_plan(text)\n1215\t        err = exc_info.value\n1216\t        assert \"duplicate top-level heading '# Same Title'\" in err.message\n1217\t        assert \"lines 1, 6, 11\" in err.message\n1218\t        # The exception's own line attribute matches the earliest occurrence.\n1219\t        assert err.line == 1\n1220\t\n1221\t    def test_multiple_bugs_sections_three_occurrences_lists_every_line(self) -> None:\n1222\t        # Three Bugs sections — across multiple heading levels — with\n1223\t        # tasks in between so the offending lines are spread out.\n1224\t        text = (\n1225\t            \"## Stage 1: Core\\n\"\n1226\t            \"- [ ] task one\\n\"\n1227\t            \"- [ ] task two\\n\"\n1228\t            \"## Bugs\\n\"\n1229\t            \"- [ ] bug a\\n\"\n1230\t            \"- [ ] bug b\\n\"\n1231\t            \"### Bugs\\n\"\n1232\t            \"- [ ] bug c\\n\"\n1233\t            \"## Bugs\\n\"\n1234\t            \"- [ ] bug d\\n\"\n1235\t        )\n1236\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1237\t            parse_plan(text)\n1238\t        err = exc_info.value\n1239\t        assert \"multiple Bugs sections\" in err.message\n1240\t        assert \"lines 4, 7, 9\" in err.message\n1241\t        assert err.line == 4\n1242\t\n1243\t    def test_duplicate_phase_ordinals_three_occurrences_lists_every_line(self) -> None:\n1244\t        # Three headers numbered 2 — Stage and Phase keywords mixed —\n1245\t        # at non-adjacent lines. All offending line numbers must appear.\n1246\t        text = (\n1247\t            \"## Stage 1: A\\n\"\n1248\t            \"- [ ] task a\\n\"\n1249\t            \"## Stage 2: B\\n\"\n1250\t            \"- [ ] task b\\n\"\n1251\t            \"## Stage 3: C\\n\"\n1252\t            \"- [ ] task c\\n\"\n1253\t            \"## Phase 2: D\\n\"\n1254\t            \"- [ ] task d\\n\"\n1255\t            \"## Stage 2: E\\n\"\n1256\t            \"- [ ] task e\\n\"\n1257\t        )\n1258\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1259\t            parse_plan(text)\n1260\t        err = exc_info.value\n1261\t        assert \"duplicate Phase/Stage 2\" in err.message\n1262\t        assert \"lines 3, 7, 9\" in err.message\n1263\t        assert err.line == 3\n1264\t\n1265\t    def test_line_numbers_are_one_based(self) -> None:\n1266\t        # Belt-and-suspenders: the offending line numbers in the message\n1267\t        # must match a human reading the file with 1-based numbering,\n1268\t        # not the 0-based list index used internally. A duplicate H1 on\n1269\t        # the very first line therefore reports \"lines 1, ...\" not\n1270\t        # \"lines 0, ...\".\n1271\t        text = \"# Same\\n# Same\\n## Stage 1: Core\\n- [ ] x\\n\"\n1272\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1273\t            parse_plan(text)\n1274\t        err = exc_info.value\n1275\t        assert \"lines 1, 2\" in err.message\n1276\t        assert \"lines 0\" not in err.message\n1277\t        assert err.line == 1\n1278\t\n1279\t    def test_h1_duplicates_reported_in_source_order(self) -> None:\n1280\t        # If duplicates appear later in the file in a non-monotonic\n1281\t        # internal walk (e.g. an order-of-insertion-into-dict accident),\n1282\t        # the listed line numbers must still come out in source order so\n1283\t        # the user reads them as they appear in the editor.\n1284\t        text = (\n1285\t            \"## Stage 1: Core\\n\"\n1286\t            \"- [ ] task\\n\"\n1287\t            \"\\n\"\n1288\t            \"# Echo\\n\"\n1289\t            \"\\n\"\n1290\t            \"## Stage 2: Polish\\n\"\n1291\t            \"- [ ] task\\n\"\n1292\t            \"\\n\"\n1293\t            \"# Echo\\n\"\n1294\t        )\n1295\t        with pytest.raises(PlanSyntaxError) as exc_info:\n1296\t            parse_plan(text)\n1297\t        err = exc_info.value\n1298\t        assert \"lines 4, 9\" in err.message\n1299\t        # ``err.line`` is the earliest anomaly, not the earliest H1\n1300\t        # specifically; here it happens to be both.\n1301\t        assert err.line == 4\n1302\t"}]},"parent_tool_use_id":null,"session_id":"3b1ef66d-baf8-49c8-864c-a73d9129cd6f","uuid":"edd75fee-7270-42ea-95ef-bd3177657757","timestamp":"2026-05-16T03:26:54.244Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"        assert first.tasks[1].status is TaskStatus.DONE\n\n        assert second.title == \"Second sub\"\n        assert tuple(t.text for t in second.tasks) == (\"sub-2-a\",)\n        assert second.tasks[0].children == ()\n\n\nclass TestParsePlanCompatModeSyntaxErrors:\n    \"\"\"Compat-mode raises :class:`PlanSyntaxError` on genuine syntax breakage.\n\n    Compat mode is intentionally lenient about cases mcloop's parser\n    accepted (orphan tasks before any phase, prose outside accumulators,\n    etc.). But a ``@deps`` line with no preceding task to attach to has\n    no semantic interpretation — the keyword means \"this task depends\n    on\" and there is no task. mcloop never recognized ``@deps`` at all,\n    so there is no compat behavior to preserve. The parser raises\n    :class:`PlanSyntaxError` with the offending line quoted in the\n    message and the source line/column populated.\n    \"\"\"\n\n    def test_orphan_deps_line_before_any_task_raises(self) -> None:\n        text = \"## Stage 1: Core\\n  @deps T-000001\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert err.line == 2\n        assert err.column == 3\n        assert \"no preceding task\" in err.message\n        assert \"`  @deps T-000001`\" in err.message\n\n    def test_orphan_deps_with_no_phase_raises(self) -> None:\n        # Even before any section, a stray @deps is malformed: there is\n        # no plausible target. The orphan-task tolerance does not extend\n        # here because @deps has no mcloop precedent.\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(\"@deps T-000001\\n\")\n        assert exc_info.value.line == 1\n        assert exc_info.value.column == 1\n\n    def test_syntax_error_carries_source_path(self) -> None:\n        path = Path(\"/tmp/PLAN.md\")\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(\"@deps T-000001\\n\", source_path=path)\n        assert exc_info.value.path == path\n\n    def test_syntax_error_str_format_matches_design_doc(self) -> None:\n        # Section 9 contract: \"PLAN.md invalid at line N, column M: ...\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(\"@deps T-000001\\n\")\n        rendered = str(exc_info.value)\n        assert rendered.startswith(\"PLAN.md invalid at line 1, column 1: \")\n        assert \"@deps T-000001\" in rendered\n\n\nclass TestCheckStructuralSanity:\n    \"\"\"Pre-parse corruption check rejects three anomalies (mcloop parity).\n\n    ``_check_structural_sanity`` is run at the start of ``parse_plan``\n    and raises :class:`PlanSyntaxError` on duplicate H1 titles, multiple\n    Bugs sections (any heading level), and duplicate phase/stage\n    ordinals. The rationale (no auto-fix; mutating a corrupted plan\n    risks compounding the corruption) is preserved from mcloop.\n    \"\"\"\n\n    def test_duplicate_h1_titles_raise(self) -> None:\n        text = \"# My Project\\n\\n# My Project\\n## Stage 1: Core\\n- [ ] x\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert err.line == 1\n        assert \"duplicate top-level heading '# My Project'\" in err.message\n        assert \"lines 1, 3\" in err.message\n\n    def test_distinct_h1_titles_do_not_raise(self) -> None:\n        # Two different H1 titles are still anomalous in strict mode\n        # (only one H1 is allowed) but are not caught here — the check\n        # targets *identical* duplicates, which is mcloop's specific\n        # corruption signal. Distinct-but-multiple is handled by strict\n        # mode in Stage 3, not by this corruption pre-check.\n        text = \"# Project A\\n\\n# Project B\\n## Stage 1: Core\\n- [ ] x\\n\"\n        parse_plan(text)\n\n    def test_multiple_bugs_sections_raise(self) -> None:\n        text = (\n            \"# Project\\n\"\n            \"## Stage 1: Core\\n\"\n            \"- [ ] x\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] bug a\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] bug b\\n\"\n        )\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"multiple Bugs sections\" in err.message\n        assert \"lines 4, 6\" in err.message\n\n    def test_multiple_bugs_sections_at_different_heading_levels_raise(self) -> None:\n        # ``_BUGS_RE`` matches any heading level whose title is ``Bugs``;\n        # mixing ``## Bugs`` and ``### Bugs`` still trips the check.\n        text = \"## Stage 1: Core\\n- [ ] x\\n## Bugs\\n- [ ] one\\n### Bugs\\n- [ ] two\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        assert \"multiple Bugs sections\" in exc_info.value.message\n\n    def test_duplicate_phase_ordinals_raise(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] first\\n\"\n            \"## Stage 2: Polish\\n\"\n            \"- [ ] second\\n\"\n            \"## Stage 1: Repeat\\n\"\n            \"- [ ] third\\n\"\n        )\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"duplicate Phase/Stage 1\" in err.message\n        assert \"lines 1, 5\" in err.message\n\n    def test_duplicate_ordinal_across_stage_and_phase_keyword_raise(self) -> None:\n        # Mcloop treats the keyword as cosmetic; ``Stage 2`` and\n        # ``Phase 2`` both contribute ordinal 2. The check uses the\n        # captured numeric group, not the keyword, so the duplicate is\n        # detected regardless of which spelling each header used.\n        text = \"## Stage 2: A\\n- [ ] x\\n## Phase 2: B\\n- [ ] y\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        assert \"duplicate Phase/Stage 2\" in exc_info.value.message\n\n    def test_h1_phase_heading_not_double_counted(self) -> None:\n        # ``# Phase 1: ...`` matches both ``_H1_RE`` and ``_STAGE_RE``.\n        # The check classifies it as a stage header (not an H1) so a\n        # single such header is not a duplicate of either kind. Mirrors\n        # mcloop's check order (STAGE_RE first, then BUGS_RE, then H1).\n        text = \"# Phase 1: Core\\n- [ ] x\\n\"\n        parse_plan(text)\n\n    def test_clean_plan_does_not_raise(self) -> None:\n        text = (\n            \"# My Project\\n\\n\"\n            \"## Stage 1: Core\\n\"\n            \"- [ ] a\\n\"\n            \"## Stage 2: Polish\\n\"\n            \"- [ ] b\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] c\\n\"\n        )\n        plan = parse_plan(text)\n        assert plan.project_title == \"My Project\"\n        assert len(plan.phases) == 2\n        assert plan.bugs is not None\n\n    def test_error_carries_source_path(self) -> None:\n        path = Path(\"/tmp/PLAN.md\")\n        text = \"# Dup\\n# Dup\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text, source_path=path)\n        assert exc_info.value.path == path\n\n    def test_error_aggregates_all_problems_in_message(self) -> None:\n        # When multiple corruption signals are present, the single\n        # raised error lists all of them so the user does not have to\n        # re-run after each fix. The reported line is the earliest one\n        # so locators stay monotonic.\n        text = \"# Dup\\n# Dup\\n## Stage 1: A\\n## Stage 1: B\\n## Bugs\\n## Bugs\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"duplicate top-level heading '# Dup'\" in err.message\n        assert \"duplicate Phase/Stage 1\" in err.message\n        assert \"multiple Bugs sections\" in err.message\n        # Earliest anomaly is the H1 duplicate at line 1.\n        assert err.line == 1\n\n\nclass TestCheckStructuralSanityLineNumberReporting:\n    \"\"\"Each corruption pattern surfaces every offending line number.\n\n    Sibling tests in :class:`TestCheckStructuralSanity` confirm each\n    anomaly is detected at all; this class targets the contract spelled\n    out by the 2.6.2 task description specifically: every offending\n    source line number must appear in the error message so the user can\n    fix all occurrences in one pass without re-running. The numbers must\n    be one-based (matching design doc section 9, which makes line/column\n    one-based on the :class:`PlanSyntaxError` itself), absolute (not\n    relative to a phase or section), and listed in source order.\n\n    Each pattern is exercised with three+ occurrences and at non-trivial\n    line numbers (i.e. not just the head of the file) so a future\n    refactor that drops occurrences after the first two, or that emits\n    zero-based offsets, will be caught.\n    \"\"\"\n\n    def test_duplicate_h1_three_occurrences_lists_every_line(self) -> None:\n        # Three copies of the same H1 with prose padding between them so\n        # the offending lines are non-adjacent and at >1-digit positions.\n        text = (\n            \"# Same Title\\n\"\n            \"Intro one.\\n\"\n            \"\\n\"\n            \"More prose.\\n\"\n            \"\\n\"\n            \"# Same Title\\n\"\n            \"Intro two.\\n\"\n            \"\\n\"\n            \"More prose.\\n\"\n            \"\\n\"\n            \"# Same Title\\n\"\n            \"## Stage 1: Core\\n\"\n            \"- [ ] x\\n\"\n        )\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"duplicate top-level heading '# Same Title'\" in err.message\n        assert \"lines 1, 6, 11\" in err.message\n        # The exception's own line attribute matches the earliest occurrence.\n        assert err.line == 1\n\n    def test_multiple_bugs_sections_three_occurrences_lists_every_line(self) -> None:\n        # Three Bugs sections — across multiple heading levels — with\n        # tasks in between so the offending lines are spread out.\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] task one\\n\"\n            \"- [ ] task two\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] bug a\\n\"\n            \"- [ ] bug b\\n\"\n            \"### Bugs\\n\"\n            \"- [ ] bug c\\n\"\n            \"## Bugs\\n\"\n            \"- [ ] bug d\\n\"\n        )\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"multiple Bugs sections\" in err.message\n        assert \"lines 4, 7, 9\" in err.message\n        assert err.line == 4\n\n    def test_duplicate_phase_ordinals_three_occurrences_lists_every_line(self) -> None:\n        # Three headers numbered 2 — Stage and Phase keywords mixed —\n        # at non-adjacent lines. All offending line numbers must appear.\n        text = (\n            \"## Stage 1: A\\n\"\n            \"- [ ] task a\\n\"\n            \"## Stage 2: B\\n\"\n            \"- [ ] task b\\n\"\n            \"## Stage 3: C\\n\"\n            \"- [ ] task c\\n\"\n            \"## Phase 2: D\\n\"\n            \"- [ ] task d\\n\"\n            \"## Stage 2: E\\n\"\n            \"- [ ] task e\\n\"\n        )\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"duplicate Phase/Stage 2\" in err.message\n        assert \"lines 3, 7, 9\" in err.message\n        assert err.line == 3\n\n    def test_line_numbers_are_one_based(self) -> None:\n        # Belt-and-suspenders: the offending line numbers in the message\n        # must match a human reading the file with 1-based numbering,\n        # not the 0-based list index used internally. A duplicate H1 on\n        # the very first line therefore reports \"lines 1, ...\" not\n        # \"lines 0, ...\".\n        text = \"# Same\\n# Same\\n## Stage 1: Core\\n- [ ] x\\n\"\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"lines 1, 2\" in err.message\n        assert \"lines 0\" not in err.message\n        assert err.line == 1\n\n    def test_h1_duplicates_reported_in_source_order(self) -> None:\n        # If duplicates appear later in the file in a non-monotonic\n        # internal walk (e.g. an order-of-insertion-into-dict accident),\n        # the listed line numbers must still come out in source order so\n        # the user reads them as they appear in the editor.\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] task\\n\"\n            \"\\n\"\n            \"# Echo\\n\"\n            \"\\n\"\n            \"## Stage 2: Polish\\n\"\n            \"- [ ] task\\n\"\n            \"\\n\"\n            \"# Echo\\n\"\n        )\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert \"lines 4, 9\" in err.message\n        # ``err.line`` is the earliest anomaly, not the earliest H1\n        # specifically; here it happens to be both.\n        assert err.line == 4\n","numLines":303,"startLine":1000,"totalLines":1302}}}
