{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HbVY9sLmm3ubt3CyYCzFZa","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom collections.abc import Sequence\n7\tfrom dataclasses import dataclass, field\n8\tfrom pathlib import Path\n9\tfrom typing import NoReturn, Protocol, TypeVar\n10\t\n11\tfrom bob_tools.planfile.model import (\n12\t    BugsSection,\n13\t    Phase,\n14\t    Plan,\n15\t    PlanSyntaxError,\n16\t    RuledOut,\n17\t    Subsection,\n18\t    Task,\n19\t    TaskStatus,\n20\t)\n21\t\n22\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n23\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n24\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n25\t\n26\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n27\t# caller strips any inter-tag whitespace between iterations.\n28\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n29\t\n30\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n31\t# after the closing bracket (with the single separating space removed).\n32\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n33\t\n34\t# Content of an annotation (the bytes between `[` and `]`): an\n35\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n36\t# value. The required whitespace after the colon is what distinguishes\n37\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n38\t# after its colon).\n39\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n40\t\n41\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n42\t# token, and optional trailing text. Matches mcloop's `parse`, which\n43\t# treats a line as RULEDOUT when its stripped form starts with the\n44\t# literal bracket token.\n45\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n46\t\n47\t# Deps sibling line: optional indent, the literal `@deps` token, then\n48\t# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n49\t# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n50\t# group captures the remainder of the line; splitting on whitespace\n51\t# and validating each ID is a higher-level step.\n52\t_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n53\t\n54\t# Stage/Phase heading: any heading level whose title contains\n55\t# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n56\t# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n57\t# pattern to also pull out the keyword and the title text after the\n58\t# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n59\t# (no bare digits) — see design doc section 2.5.\n60\t_STAGE_RE = re.compile(\n61\t    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n62\t    re.IGNORECASE,\n63\t)\n64\t\n65\t# Bugs heading: any heading level whose title is exactly ``Bugs``.\n66\t# Mirrors mcloop's ``BUGS_RE``.\n67\t_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n68\t\n69\t# Subsection heading: ``###`` followed by free title text. Only level-3\n70\t# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n71\t# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n72\t# group following tasks until another subsection or phase ends them.\n73\t_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n74\t\n75\t# H1 project-title heading: exactly one ``#`` followed by free title\n76\t# text. Per design doc section 4.1 grammar ``Preamble ← H1 NL Prose?``.\n77\t# H2 (``##``) is consumed earlier by `_STAGE_RE` / `_BUGS_RE`; this\n78\t# regex requires a single leading ``#`` so multi-hash headings cannot\n79\t# match here. Recognized only before the first phase or bugs heading;\n80\t# subsequent H1 lines (malformed in strict mode, dropped in compat\n81\t# mode) fall through to the active prose accumulator.\n82\t_H1_RE = re.compile(r\"^#\\s+(.+?)\\s*$\")\n83\t\n84\t# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n85\t# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n86\t# Recognized only at the start of the task body, before any flag tags.\n87\t_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n88\t\n89\t\n90\tdef parse_plan(\n91\t    text: str,\n92\t    *,\n93\t    strict: bool = False,\n94\t    source_path: Path | None = None,\n95\t) -> Plan:\n96\t    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n97\t\n98\t    ``strict=False`` (the default) is compatibility mode — accepts the\n99\t    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n100\t    line, optional task IDs, no phase-id comments). ``strict=True``\n101\t    enables the format additions in design doc section 4 (magic line,\n102\t    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n103\t\n104\t    Stage 2.5.1 wired the signature; 2.5.2 walks ``text`` line by line,\n105\t    tracking the current phase (or bugs section), the current subsection\n106\t    within a phase, and a stack of open tasks by indent. 2.5.3 extracts\n107\t    the project title from the first H1 and accumulates prose in three\n108\t    regions: the preamble (after the H1, before the first phase or bugs\n109\t    heading), phase prose (after a phase heading, before the first task\n110\t    or subsection), and subsection prose (after a ``###`` heading,\n111\t    before the first task). Prose-region accumulators close when the\n112\t    relevant boundary line is consumed; lines outside any active\n113\t    accumulator (e.g. a task line before any phase, or prose after the\n114\t    first task in a phase) are dropped silently in compat mode (the\n115\t    orphan-task case matches mcloop, which assigns ``stage=\"\"`` rather\n116\t    than erroring; strict mode in Stage 3 will raise). Each task line\n117\t    opens or closes scopes by indent comparison, matching mcloop's logic\n118\t    in ``checklist.py:parse``. ``@deps`` and ``[RULEDOUT]`` sibling\n119\t    lines are routed via :func:`_attach_deps` and :func:`_attach_ruledout`\n120\t    and accumulated on the parent task. 2.5.4 raises\n121\t    :class:`PlanSyntaxError` on syntax violations even in compat mode:\n122\t    today, an ``@deps`` line that cannot attach to any preceding task\n123\t    in the current section. The orphan ``@deps`` case has no semantic\n124\t    interpretation and no mcloop-tolerance to preserve (mcloop never\n125\t    recognized ``@deps`` at all). The error message quotes the offending\n126\t    line so the location is unambiguous to the human fixing the file.\n127\t    2.6.1 (this) runs :func:`_check_structural_sanity` first: it scans\n128\t    the raw lines for duplicate H1 titles, multiple Bugs sections, and\n129\t    duplicate phase/stage ordinals before any structural parsing\n130\t    happens, so the typed model never has to represent a corrupted\n131\t    document. Mirrors mcloop's pre-parse corruption check.\n132\t    \"\"\"\n133\t    del strict\n134\t    lines = text.splitlines()\n135\t    _check_structural_sanity(lines, source_path)\n136\t\n137\t    phases_b: list[_PhaseBuilder] = []\n138\t    bugs_b: _BugsBuilder | None = None\n139\t    current_phase: _PhaseBuilder | None = None\n140\t    current_subsection: _SubsectionBuilder | None = None\n141\t    in_bugs = False\n142\t    stack: list[_TaskBuilder] = []\n143\t\n144\t    project_title = \"\"\n145\t    project_title_seen = False\n146\t    preamble_lines: list[str] = []\n147\t    preamble_active = False\n148\t    phase_prose_lines: list[str] | None = None\n149\t    subsection_prose_lines: list[str] | None = None\n150\t\n151\t    def _close_subsection_prose() -> None:\n152\t        nonlocal subsection_prose_lines\n153\t        if subsection_prose_lines is not None and current_subsection is not None:\n154\t            current_subsection.prose = _finalize_prose(subsection_prose_lines)\n155\t        subsection_prose_lines = None\n156\t\n157\t    def _close_phase_prose() -> None:\n158\t        nonlocal phase_prose_lines\n159\t        if phase_prose_lines is not None and current_phase is not None:\n160\t            current_phase.prose = _finalize_prose(phase_prose_lines)\n161\t        phase_prose_lines = None\n162\t\n163\t    for idx, line in enumerate(lines):\n164\t        line_number = idx + 1\n165\t\n166\t        heading = _parse_phase_heading(line)\n167\t        if heading is not None:\n168\t            _close_subsection_prose()\n169\t            _close_phase_prose()\n170\t            preamble_active = False\n171\t            ordinal, keyword, title = heading\n172\t            current_phase = _PhaseBuilder(\n173\t                ordinal=ordinal,\n174\t                keyword=keyword,\n175\t                title=title,\n176\t                line_number=line_number,\n177\t            )\n178\t            phases_b.append(current_phase)\n179\t            current_subsection = None\n180\t            in_bugs = False\n181\t            stack.clear()\n182\t            phase_prose_lines = []\n183\t            continue\n184\t\n185\t        if _BUGS_RE.match(line):\n186\t            _close_subsection_prose()\n187\t            _close_phase_prose()\n188\t            preamble_active = False\n189\t            bugs_b = _BugsBuilder(line_number=line_number)\n190\t            current_phase = None\n191\t            current_subsection = None\n192\t            in_bugs = True\n193\t            stack.clear()\n194\t            continue\n195\t\n196\t        if current_phase is None and not in_bugs:\n197\t            h1_m = _H1_RE.match(line)\n198\t            if h1_m is not None:\n199\t                if not project_title_seen:\n200\t                    project_title = h1_m.group(1).strip()\n201\t                    project_title_seen = True\n202\t                    preamble_active = True\n203\t                    continue\n204\t                # Subsequent H1 falls through to the preamble accumulator\n205\t                # so the raw text is preserved. Strict mode (Stage 3)\n206\t                # will raise on duplicate H1s.\n207\t\n208\t        if not in_bugs and current_phase is not None:\n209\t            sm = _SUBSECTION_RE.match(line)\n210\t            if sm is not None:\n211\t                _close_subsection_prose()\n212\t                _close_phase_prose()\n213\t                current_subsection = _SubsectionBuilder(\n214\t                    title=sm.group(1).strip(),\n215\t                    line_number=line_number,\n216\t                )\n217\t                current_phase.subsections.append(current_subsection)\n218\t                stack.clear()\n219\t                subsection_prose_lines = []\n220\t                continue\n221\t\n222\t        scope_tasks = _current_scope_tasks(\n223\t            in_bugs=in_bugs,\n224\t            bugs_b=bugs_b,\n225\t            current_subsection=current_subsection,\n226\t            current_phase=current_phase,\n227\t        )\n228\t\n229\t        ro = _parse_ruledout_line(line, line_number)\n230\t        if ro is not None:\n231\t            indent = len(ro.indent)\n232\t            roots = scope_tasks if scope_tasks is not None else []\n233\t            target = _attach_ruledout(indent, stack, roots)\n234\t            if target is not None:\n235\t                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n236\t            continue\n237\t\n238\t        dm = _DEPS_RE.match(line)\n239\t        if dm is not None:\n240\t            indent = len(dm.group(1))\n241\t            target, _lenient = _attach_deps(indent, stack)\n242\t            if target is None:\n243\t                _raise_syntax_error(\n244\t                    \"@deps line has no preceding task to attach to\",\n245\t                    line_text=line,\n246\t                    line_number=line_number,\n247\t                    source_path=source_path,\n248\t                    column=indent + 1,\n249\t                )\n250\t            target.deps.extend(dm.group(2).split())\n251\t            continue\n252\t\n253\t        raw = _parse_task_line(line, line_number)\n254\t        if raw is None:\n255\t            if preamble_active:\n256\t                preamble_lines.append(line)\n257\t            elif subsection_prose_lines is not None:\n258\t                subsection_prose_lines.append(line)\n259\t            elif phase_prose_lines is not None:\n260\t                phase_prose_lines.append(line)\n261\t            # else: line outside any active prose region (e.g. before\n262\t            # the first H1 or after the first task in a section) —\n263\t            # dropped in compat mode.\n264\t            continue\n265\t\n266\t        _close_subsection_prose()\n267\t        _close_phase_prose()\n268\t\n269\t        builder = _build_task(raw)\n270\t        indent = builder.indent_level\n271\t\n272\t        while stack and stack[-1].indent_level >= indent:\n273\t            stack.pop()\n274\t\n275\t        if stack:\n276\t            stack[-1].children.append(builder)\n277\t        elif scope_tasks is not None:\n278\t            scope_tasks.append(builder)\n279\t        # else: task line before any phase/bugs — silently dropped in\n280\t        # compat mode (matches mcloop, which assigns ``stage=\"\"``);\n281\t        # strict mode (Stage 3) will surface this as a PlanSyntaxError.\n282\t\n283\t        stack.append(builder)\n284\t\n285\t    _close_subsection_prose()\n286\t    _close_phase_prose()\n287\t\n288\t    return Plan(\n289\t        magic_version=None,\n290\t        project_title=project_title,\n291\t        preamble=_finalize_prose(preamble_lines),\n292\t        phases=tuple(p.freeze() for p in phases_b),\n293\t        bugs=bugs_b.freeze() if bugs_b is not None else None,\n294\t        source_path=source_path,\n295\t    )\n296\t\n297\t\n298\tdef _check_structural_sanity(\n299\t    lines: list[str],\n300\t    source_path: Path | None,\n301\t) -> None:\n302\t    \"\"\"Scan ``lines`` for structural corruption signals before parsing.\n303\t\n304\t    Three anomalies are flagged, mirroring mcloop's\n305\t    ``_check_structural_sanity`` (``mcloop/checklist.py``):\n306\t\n307\t    1. Duplicate H1 headings with identical title text — typically a\n308\t       botched insertion that left the original tail in place,\n309\t       producing two copies of the document's top header.\n310\t    2. Multiple Bugs sections (any heading level) — there should\n311\t       only ever be one.\n312\t    3. Duplicate phase/stage ordinals across stage headers — two\n313\t       headers numbered ``Phase 2``, for example. This breaks any\n314\t       label that prefixes with the stage number and almost always\n315\t       signals merged content from two attempts at the same phase.\n316\t\n317\t    Each anomaly has been observed in real PLAN.md corruption\n318\t    incidents and none has a legitimate use; auto-fixing is\n319\t    deliberately not attempted because mutating an already-corrupted\n320\t    plan risks compounding the corruption rather than recovering it.\n321\t    Raises :class:`PlanSyntaxError` whose message lists every anomaly\n322\t    found, with one-based source line numbers, so the user can locate\n323\t    and fix the corruption by hand.\n324\t    \"\"\"\n325\t    h1_titles: dict[str, list[int]] = {}\n326\t    bugs_lines: list[int] = []\n327\t    stage_nums: dict[int, list[int]] = {}\n328\t\n329\t    for i, line in enumerate(lines):\n330\t        # Order matters: a single-hash ``# Phase 1: Bootstrapping``\n331\t        # is matched by both ``_STAGE_RE`` and ``_H1_RE``. A header is\n332\t        # either a stage header OR a plain H1 OR a Bugs header — never\n333\t        # two of those at once. Check stage first so ``# Phase N`` is\n334\t        # not double-counted as an H1 duplicate and a stage duplicate.\n335\t        stage_match = _STAGE_RE.match(line)\n336\t        if stage_match is not None:\n337\t            stage_nums.setdefault(int(stage_match.group(\"num\")), []).append(i)\n338\t            continue\n339\t\n340\t        if _BUGS_RE.match(line):\n341\t            bugs_lines.append(i)\n342\t            continue\n343\t\n344\t        h1_match = _H1_RE.match(line)\n345\t        if h1_match is not None:\n346\t            # ``_H1_RE`` requires a single leading ``#``; the explicit\n347\t            # ``not startswith(\"## \")`` guard is belt-and-suspenders so\n348\t            # the intent (true H1 only) is visible in the reader's eye.\n349\t            if line.startswith(\"# \") and not line.startswith(\"## \"):\n350\t                title = h1_match.group(1).strip()\n351\t                h1_titles.setdefault(title, []).append(i)\n352\t\n353\t    problems: list[tuple[int, str]] = []\n354\t\n355\t    for title, line_nums in h1_titles.items():\n356\t        if len(line_nums) > 1:\n357\t            locs = \", \".join(str(n + 1) for n in line_nums)\n358\t            problems.append(\n359\t                (\n360\t                    line_nums[0] + 1,\n361\t                    f\"duplicate top-level heading '# {title}' at lines {locs}\",\n362\t                )\n363\t            )\n364\t\n365\t    if len(bugs_lines) > 1:\n366\t        locs = \", \".join(str(n + 1) for n in bugs_lines)\n367\t        problems.append((bugs_lines[0] + 1, f\"multiple Bugs sections at lines {locs}\"))\n368\t\n369\t    for num, line_nums in stage_nums.items():\n370\t        if len(line_nums) > 1:\n371\t            locs = \", \".join(str(n + 1) for n in line_nums)\n372\t            problems.append(\n373\t                (line_nums[0] + 1, f\"duplicate Phase/Stage {num} at lines {locs}\")\n374\t            )\n375\t\n376\t    if not problems:\n377\t        return\n378\t\n379\t    problems.sort(key=lambda p: p[0])\n380\t    first_line = problems[0][0]\n381\t    body = \"\\n  - \".join(msg for _, msg in problems)\n382\t    raise PlanSyntaxError(\n383\t        f\"structural corruption detected:\\n  - {body}\",\n384\t        first_line,\n385\t        1,\n386\t        source_path,\n387\t    )\n388\t\n389\t\n390\tdef _raise_syntax_error(\n391\t    message: str,\n392\t    *,\n393\t    line_text: str,\n394\t    line_number: int,\n395\t    source_path: Path | None,\n396\t    column: int = 1,\n397\t) -> NoReturn:\n398\t    \"\"\"Raise :class:`PlanSyntaxError` with the offending line quoted.\n399\t\n400\t    Per the design doc section 9 contract, the error carries\n401\t    ``(message, line, column, path)``; ``__str__`` formats them as\n402\t    ``PLAN.md invalid at line N, column M: <message>``. The task\n403\t    description for 2.5.4 adds: the message itself must quote the\n404\t    offending line so the human reading the error can see exactly which\n405\t    text triggered the rejection without having to open the file. The\n406\t    quoted form uses backticks rather than ``repr()`` because the line\n407\t    has already had its trailing newline stripped by ``splitlines()``,\n408\t    so there is no escape-sequence ambiguity to disambiguate.\n409\t    \"\"\"\n410\t    raise PlanSyntaxError(\n411\t        f\"{message}: `{line_text}`\",\n412\t        line_number,\n413\t        column,\n414\t        source_path,\n415\t    )\n416\t\n417\t\n418\tdef _finalize_prose(lines: list[str]) -> str:\n419\t    \"\"\"Join accumulated prose lines, trimming blank lines from the ends.\n420\t\n421\t    Internal blank lines (paragraph breaks) and any leading/trailing\n422\t    whitespace within a non-blank line are preserved — Markdown attaches\n423\t    semantic weight to indent (code blocks, list continuations), so we\n424\t    only strip wholly-blank wrapper lines rather than calling\n425\t    ``str.strip()`` on the joined text.\n426\t    \"\"\"\n427\t    start = 0\n428\t    while start < len(lines) and not lines[start].strip():\n429\t        start += 1\n430\t    end = len(lines)\n431\t    while end > start and not lines[end - 1].strip():\n432\t        end -= 1\n433\t    return \"\\n\".join(lines[start:end])\n434\t\n435\t\n436\tdef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n437\t    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n438\t\n439\t    Returns ``None`` for non-matching lines. The keyword is normalized\n440\t    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n441\t    keeps the keyword cosmetic, so the canonicalizer can choose to\n442\t    preserve original casing if it wants — the typed model only needs\n443\t    one stable form.\n444\t    \"\"\"\n445\t    m = _STAGE_RE.match(line)\n446\t    if m is None:\n447\t        return None\n448\t    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n449\t\n450\t\n451\tdef _extract_task_id(text: str) -> tuple[str | None, str]:\n452\t    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n453\t\n454\t    Per design doc section 4.2 grammar, the task ID is the first token\n455\t    in the body after the checkbox. Returns ``(None, text)`` when no\n456\t    leading task ID is present; task IDs are optional in compat mode\n457\t    and mandatory in strict mode (enforced separately in Stage 3).\n458\t    \"\"\"\n459\t    m = _TASK_ID_RE.match(text)\n460\t    if m is None:\n461\t        return None, text\n462\t    return m.group(1), text[m.end() :]\n463\t\n464\t\n465\tdef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n466\t    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n467\t\n468\t    Order matters: annotations come first (they live at end of line\n469\t    and would otherwise be swallowed by the action tag's args, which\n470\t    span to end of line). Task ID, then flag tags, then action tag run\n471\t    left-to-right. The remaining text is the task description.\n472\t    \"\"\"\n473\t    annotations, remaining = _extract_annotations(raw.text)\n474\t    task_id, remaining = _extract_task_id(remaining)\n475\t    flag_tags, remaining = _extract_flag_tags(remaining)\n476\t    action_tag, remaining = _extract_action_tag(remaining)\n477\t    return _TaskBuilder(\n478\t        task_id=task_id,\n479\t        text=remaining.strip(),\n480\t        status=TaskStatus.from_marker(raw.status_char),\n481\t        flag_tags=flag_tags,\n482\t        action_tag=action_tag,\n483\t        annotations=annotations,\n484\t        indent_level=len(raw.indent),\n485\t        line_number=raw.line_number,\n486\t    )\n487\t\n488\t\n489\tdef _current_scope_tasks(\n490\t    *,\n491\t    in_bugs: bool,\n492\t    bugs_b: _BugsBuilder | None,\n493\t    current_subsection: _SubsectionBuilder | None,\n494\t    current_phase: _PhaseBuilder | None,\n495\t) -> list[_TaskBuilder] | None:\n496\t    \"\"\"Pick the root-task list for the active section.\n497\t\n498\t    The order encodes the grammar: a Bugs section excludes phase scope;\n499\t    inside a phase, a current subsection captures following tasks until\n500\t    the next subsection or phase. Returns ``None`` when no section is\n501\t    active — i.e. the input has not yet introduced a phase or bugs\n502\t    heading, so any task/sibling line is an orphan.\n503\t    \"\"\"\n504\t    if in_bugs:\n505\t        return bugs_b.tasks if bugs_b is not None else None\n506\t    if current_subsection is not None:\n507\t        return current_subsection.tasks\n508\t    if current_phase is not None:\n509\t        return current_phase.tasks\n510\t    return None\n511\t\n512\t\n513\t@dataclass(frozen=True)\n514\tclass _RawTaskLine:\n515\t    \"\"\"Recognize-step output of `_parse_task_line`.\n516\t\n517\t    Stage 2 of the parser splits recognize-then-classify. This record\n518\t    is the recognize step: indent text, status marker, body text, and\n519\t    source line number. Higher-level functions classify the body into\n520\t    task id, tags, deps, and prose.\n521\t    \"\"\"\n522\t\n523\t    indent: str\n524\t    status_char: str\n525\t    text: str\n526\t    line_number: int\n527\t\n528\t\n529\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n530\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n531\t    m = _CHECKBOX_RE.match(line)\n532\t    if m is None:\n533\t        return None\n534\t    return _RawTaskLine(\n535\t        indent=m.group(1),\n536\t        status_char=m.group(2),\n537\t        text=m.group(3),\n538\t        line_number=line_number,\n539\t    )\n540\t\n541\t\n542\t@dataclass(frozen=True)\n543\tclass _RawRuledOut:\n544\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n545\t\n546\t    A RULEDOUT line is a sibling of the task it pertains to (design\n547\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n548\t    captures only indent, body text, and source line number; attaching\n549\t    the line to its parent task by indentation is a higher-level step.\n550\t    \"\"\"\n551\t\n552\t    indent: str\n553\t    text: str\n554\t    line_number: int\n555\t\n556\t\n557\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n558\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n559\t\n560\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n561\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n562\t    whitespace on the body text is stripped; an empty body is allowed.\n563\t    \"\"\"\n564\t    m = _RULEDOUT_RE.match(line)\n565\t    if m is None:\n566\t        return None\n567\t    return _RawRuledOut(\n568\t        indent=m.group(1),\n569\t        text=m.group(2).strip(),\n570\t        line_number=line_number,\n571\t    )\n572\t\n573\t\n574\tclass _HasIndentLevel(Protocol):\n575\t    \"\"\"Anything with an integer ``indent_level`` attribute.\n576\t\n577\t    Used by :func:`_attach_ruledout` so it can resolve attachment over\n578\t    either the eventual frozen ``Task`` model objects or the mutable\n579\t    builder records the parser uses while constructing them.\n580\t    \"\"\"\n581\t\n582\t    @property\n583\t    def indent_level(self) -> int: ...\n584\t\n585\t\n586\t_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n587\t\n588\t\n589\tdef _attach_ruledout(\n590\t    indent: int,\n591\t    stack: Sequence[_T],\n592\t    root_tasks: Sequence[_T],\n593\t) -> _T | None:\n594\t    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n595\t\n596\t    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n597\t    the open-ancestor stack from innermost to outermost and return the\n598\t    first task whose indent is strictly less than the RULEDOUT line's\n599\t    indent. If no such ancestor exists in the current phase, fall back\n600\t    to the most recent root task (mcloop's \"orphan\" handling). Returns\n601\t    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n602\t    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n603\t    the caller should drop.\n604\t    \"\"\"\n605\t    for task in reversed(stack):\n606\t        if task.indent_level < indent:\n607\t            return task\n608\t    if root_tasks:\n609\t        return root_tasks[-1]\n610\t    return None\n611\t\n612\t\n613\tdef _attach_deps(\n614\t    indent: int,\n615\t    stack: Sequence[_T],\n616\t) -> tuple[_T | None, bool]:\n617\t    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n618\t\n619\t    Walks the open-ancestor stack from innermost (top) to outermost.\n620\t    Returns ``(parent, False)`` for the strict form — first ancestor\n621\t    whose indent is strictly less than the deps line's indent. Returns\n622\t    ``(parent, True)`` for the lenient form — first ancestor at the\n623\t    same indent as the deps line, which callers should report as a\n624\t    validation warning (the deps was not indented under its task).\n625\t    Returns ``(None, False)`` when no candidate exists; the caller\n626\t    should drop the line.\n627\t\n628\t    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n629\t    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n630\t    indent is malformed input rather than an orphan that needs adopting.\n631\t    \"\"\"\n632\t    for task in reversed(stack):\n633\t        if task.indent_level < indent:\n634\t            return task, False\n635\t        if task.indent_level == indent:\n636\t            return task, True\n637\t    return None, False\n638\t\n639\t\n640\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n641\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n642\t\n643\t    Per design doc section 4.3, flag tags are recognized only at the\n644\t    leading position. The caller is responsible for stripping the task\n645\t    ID (if any) first. A bracketed flag form appearing later in the\n646\t    text is prose and is left in place.\n647\t    \"\"\"\n648\t    tags: list[str] = []\n649\t    remaining = text\n650\t    while True:\n651\t        m = _FLAG_TAG_RE.match(remaining)\n652\t        if m is None:\n653\t            break\n654\t        tags.append(m.group(1))\n655\t        remaining = remaining[m.end() :].lstrip()\n656\t    return tuple(tags), remaining\n657\t\n658\t\n659\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n660\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n661\t\n662\t    Per design doc section 4.3, the action tag is recognized only at\n663\t    the leading position, after any flag tags. The argument string is\n664\t    the text from the closing bracket to end of line, with the single\n665\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n666\t    are prose and are left in place.\n667\t\n668\t    Returns ``(None, text)`` when no leading action tag is present;\n669\t    otherwise consumes the rest of the line as the argument string\n670\t    and returns ``((action, args), \"\")``.\n671\t    \"\"\"\n672\t    m = _ACTION_TAG_RE.match(text)\n673\t    if m is None:\n674\t        return None, text\n675\t    action = m.group(1)\n676\t    args = text[m.end() :].lstrip()\n677\t    return (action, args), \"\"\n678\t\n679\t\n680\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n681\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n682\t\n683\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n684\t    are bracketed, and are separated from the preceding text by\n685\t    whitespace. Multiple annotations are allowed. Values may contain\n686\t    balanced bracket pairs; this function scans right-to-left with\n687\t    bracket-depth tracking so nested brackets stay inside a single\n688\t    annotation rather than being misparsed as a separate one.\n689\t\n690\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n691\t    accepts any identifier-shaped key. Validation of allowed keys is\n692\t    a separate concern.\n693\t    \"\"\"\n694\t    annotations: list[tuple[str, str]] = []\n695\t    remaining = text\n696\t    while True:\n697\t        rstripped = remaining.rstrip()\n698\t        if not rstripped.endswith(\"]\"):\n699\t            remaining = rstripped\n700\t            break\n701\t        start = _find_matching_open_bracket(rstripped)\n702\t        if start is None:\n703\t            remaining = rstripped\n704\t            break\n705\t        # An annotation must be separated from preceding text by\n706\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n707\t        # character is part of the task text, not an annotation.\n708\t        if start > 0 and not rstripped[start - 1].isspace():\n709\t            remaining = rstripped\n710\t            break\n711\t        content = rstripped[start + 1 : -1]\n712\t        m = _ANNOTATION_CONTENT_RE.match(content)\n713\t        if m is None:\n714\t            remaining = rstripped\n715\t            break\n716\t        annotations.insert(0, (m.group(1), m.group(2)))\n717\t        remaining = rstripped[:start].rstrip()\n718\t    return tuple(annotations), remaining\n719\t\n720\t\n721\tdef _find_matching_open_bracket(s: str) -> int | None:\n722\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n723\t\n724\t    Walks right-to-left tracking bracket depth so balanced nested\n725\t    brackets inside the candidate annotation are stepped over.\n726\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n727\t    opener.\n728\t    \"\"\"\n729\t    if not s.endswith(\"]\"):\n730\t        return None\n731\t    depth = 0\n732\t    for i in range(len(s) - 1, -1, -1):\n733\t        c = s[i]\n734\t        if c == \"]\":\n735\t            depth += 1\n736\t        elif c == \"[\":\n737\t            depth -= 1\n738\t            if depth == 0:\n739\t                return i\n740\t    return None\n741\t\n742\t\n743\t# Mutable builder records used while walking the input. The public\n744\t# model dataclasses are frozen, so the parser builds with these and\n745\t# calls ``freeze`` to produce the immutable tree at the end. Each\n746\t# builder also satisfies the ``_HasIndentLevel`` protocol so the\n747\t# existing ``_attach_*`` helpers operate on them directly.\n748\t\n749\t\n750\t@dataclass\n751\tclass _TaskBuilder:\n752\t    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n753\t\n754\t    task_id: str | None\n755\t    text: str\n756\t    status: TaskStatus\n757\t    flag_tags: tuple[str, ...]\n758\t    action_tag: tuple[str, str] | None\n759\t    annotations: tuple[tuple[str, str], ...]\n760\t    indent_level: int\n761\t    line_number: int\n762\t    deps: list[str] = field(default_factory=list)\n763\t    children: list[_TaskBuilder] = field(default_factory=list)\n764\t    ruled_out: list[RuledOut] = field(default_factory=list)\n765\t\n766\t    def freeze(self) -> Task:\n767\t        return Task(\n768\t            task_id=self.task_id,\n769\t            text=self.text,\n770\t            status=self.status,\n771\t            flag_tags=self.flag_tags,\n772\t            action_tag=self.action_tag,\n773\t            annotations=self.annotations,\n774\t            deps=tuple(self.deps),\n775\t            children=tuple(c.freeze() for c in self.children),\n776\t            ruled_out=tuple(self.ruled_out),\n777\t            indent_level=self.indent_level,\n778\t            line_number=self.line_number,\n779\t        )\n780\t\n781\t\n782\t@dataclass\n783\tclass _SubsectionBuilder:\n784\t    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n785\t\n786\t    title: str\n787\t    line_number: int\n788\t    prose: str = \"\"\n789\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n790\t\n791\t    def freeze(self) -> Subsection:\n792\t        return Subsection(\n793\t            title=self.title,\n794\t            prose=self.prose,\n795\t            tasks=tuple(t.freeze() for t in self.tasks),\n796\t            line_number=self.line_number,\n797\t        )\n798\t\n799\t\n800\t@dataclass\n801\tclass _PhaseBuilder:\n802\t    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n803\t\n804\t    ordinal: int\n805\t    keyword: str\n806\t    title: str\n807\t    line_number: int\n808\t    phase_id: str | None = None\n809\t    phase_id_source: str = \"none\"\n810\t    prose: str = \"\"\n811\t    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n812\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n813\t\n814\t    def freeze(self) -> Phase:\n815\t        return Phase(\n816\t            phase_id=self.phase_id,\n817\t            phase_id_source=self.phase_id_source,\n818\t            ordinal=self.ordinal,\n819\t            keyword=self.keyword,\n820\t            title=self.title,\n821\t            prose=self.prose,\n822\t            subsections=tuple(s.freeze() for s in self.subsections),\n823\t            tasks=tuple(t.freeze() for t in self.tasks),\n824\t            line_number=self.line_number,\n825\t        )\n826\t\n827\t\n828\t@dataclass\n829\tclass _BugsBuilder:\n830\t    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n831\t\n832\t    line_number: int\n833\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n834\t\n835\t    def freeze(self) -> BugsSection:\n836\t        return BugsSection(\n837\t            tasks=tuple(t.freeze() for t in self.tasks),\n838\t            line_number=self.line_number,\n839\t        )\n840\t"}]},"parent_tool_use_id":null,"session_id":"3b1ef66d-baf8-49c8-864c-a73d9129cd6f","uuid":"6b8f2a9b-23a2-4902-b71c-45a88588fbc6","timestamp":"2026-05-16T03:26:35.727Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections.abc import Sequence\nfrom dataclasses import dataclass, field\nfrom pathlib import Path\nfrom typing import NoReturn, Protocol, TypeVar\n\nfrom bob_tools.planfile.model import (\n    BugsSection,\n    Phase,\n    Plan,\n    PlanSyntaxError,\n    RuledOut,\n    Subsection,\n    Task,\n    TaskStatus,\n)\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n# Deps sibling line: optional indent, the literal `@deps` token, then\n# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n# group captures the remainder of the line; splitting on whitespace\n# and validating each ID is a higher-level step.\n_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n\n# Stage/Phase heading: any heading level whose title contains\n# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n# pattern to also pull out the keyword and the title text after the\n# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n# (no bare digits) — see design doc section 2.5.\n_STAGE_RE = re.compile(\n    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n    re.IGNORECASE,\n)\n\n# Bugs heading: any heading level whose title is exactly ``Bugs``.\n# Mirrors mcloop's ``BUGS_RE``.\n_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n\n# Subsection heading: ``###`` followed by free title text. Only level-3\n# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n# group following tasks until another subsection or phase ends them.\n_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n\n# H1 project-title heading: exactly one ``#`` followed by free title\n# text. Per design doc section 4.1 grammar ``Preamble ← H1 NL Prose?``.\n# H2 (``##``) is consumed earlier by `_STAGE_RE` / `_BUGS_RE`; this\n# regex requires a single leading ``#`` so multi-hash headings cannot\n# match here. Recognized only before the first phase or bugs heading;\n# subsequent H1 lines (malformed in strict mode, dropped in compat\n# mode) fall through to the active prose accumulator.\n_H1_RE = re.compile(r\"^#\\s+(.+?)\\s*$\")\n\n# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n# Recognized only at the start of the task body, before any flag tags.\n_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n\n\ndef parse_plan(\n    text: str,\n    *,\n    strict: bool = False,\n    source_path: Path | None = None,\n) -> Plan:\n    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n\n    ``strict=False`` (the default) is compatibility mode — accepts the\n    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n    line, optional task IDs, no phase-id comments). ``strict=True``\n    enables the format additions in design doc section 4 (magic line,\n    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n\n    Stage 2.5.1 wired the signature; 2.5.2 walks ``text`` line by line,\n    tracking the current phase (or bugs section), the current subsection\n    within a phase, and a stack of open tasks by indent. 2.5.3 extracts\n    the project title from the first H1 and accumulates prose in three\n    regions: the preamble (after the H1, before the first phase or bugs\n    heading), phase prose (after a phase heading, before the first task\n    or subsection), and subsection prose (after a ``###`` heading,\n    before the first task). Prose-region accumulators close when the\n    relevant boundary line is consumed; lines outside any active\n    accumulator (e.g. a task line before any phase, or prose after the\n    first task in a phase) are dropped silently in compat mode (the\n    orphan-task case matches mcloop, which assigns ``stage=\"\"`` rather\n    than erroring; strict mode in Stage 3 will raise). Each task line\n    opens or closes scopes by indent comparison, matching mcloop's logic\n    in ``checklist.py:parse``. ``@deps`` and ``[RULEDOUT]`` sibling\n    lines are routed via :func:`_attach_deps` and :func:`_attach_ruledout`\n    and accumulated on the parent task. 2.5.4 raises\n    :class:`PlanSyntaxError` on syntax violations even in compat mode:\n    today, an ``@deps`` line that cannot attach to any preceding task\n    in the current section. The orphan ``@deps`` case has no semantic\n    interpretation and no mcloop-tolerance to preserve (mcloop never\n    recognized ``@deps`` at all). The error message quotes the offending\n    line so the location is unambiguous to the human fixing the file.\n    2.6.1 (this) runs :func:`_check_structural_sanity` first: it scans\n    the raw lines for duplicate H1 titles, multiple Bugs sections, and\n    duplicate phase/stage ordinals before any structural parsing\n    happens, so the typed model never has to represent a corrupted\n    document. Mirrors mcloop's pre-parse corruption check.\n    \"\"\"\n    del strict\n    lines = text.splitlines()\n    _check_structural_sanity(lines, source_path)\n\n    phases_b: list[_PhaseBuilder] = []\n    bugs_b: _BugsBuilder | None = None\n    current_phase: _PhaseBuilder | None = None\n    current_subsection: _SubsectionBuilder | None = None\n    in_bugs = False\n    stack: list[_TaskBuilder] = []\n\n    project_title = \"\"\n    project_title_seen = False\n    preamble_lines: list[str] = []\n    preamble_active = False\n    phase_prose_lines: list[str] | None = None\n    subsection_prose_lines: list[str] | None = None\n\n    def _close_subsection_prose() -> None:\n        nonlocal subsection_prose_lines\n        if subsection_prose_lines is not None and current_subsection is not None:\n            current_subsection.prose = _finalize_prose(subsection_prose_lines)\n        subsection_prose_lines = None\n\n    def _close_phase_prose() -> None:\n        nonlocal phase_prose_lines\n        if phase_prose_lines is not None and current_phase is not None:\n            current_phase.prose = _finalize_prose(phase_prose_lines)\n        phase_prose_lines = None\n\n    for idx, line in enumerate(lines):\n        line_number = idx + 1\n\n        heading = _parse_phase_heading(line)\n        if heading is not None:\n            _close_subsection_prose()\n            _close_phase_prose()\n            preamble_active = False\n            ordinal, keyword, title = heading\n            current_phase = _PhaseBuilder(\n                ordinal=ordinal,\n                keyword=keyword,\n                title=title,\n                line_number=line_number,\n            )\n            phases_b.append(current_phase)\n            current_subsection = None\n            in_bugs = False\n            stack.clear()\n            phase_prose_lines = []\n            continue\n\n        if _BUGS_RE.match(line):\n            _close_subsection_prose()\n            _close_phase_prose()\n            preamble_active = False\n            bugs_b = _BugsBuilder(line_number=line_number)\n            current_phase = None\n            current_subsection = None\n            in_bugs = True\n            stack.clear()\n            continue\n\n        if current_phase is None and not in_bugs:\n            h1_m = _H1_RE.match(line)\n            if h1_m is not None:\n                if not project_title_seen:\n                    project_title = h1_m.group(1).strip()\n                    project_title_seen = True\n                    preamble_active = True\n                    continue\n                # Subsequent H1 falls through to the preamble accumulator\n                # so the raw text is preserved. Strict mode (Stage 3)\n                # will raise on duplicate H1s.\n\n        if not in_bugs and current_phase is not None:\n            sm = _SUBSECTION_RE.match(line)\n            if sm is not None:\n                _close_subsection_prose()\n                _close_phase_prose()\n                current_subsection = _SubsectionBuilder(\n                    title=sm.group(1).strip(),\n                    line_number=line_number,\n                )\n                current_phase.subsections.append(current_subsection)\n                stack.clear()\n                subsection_prose_lines = []\n                continue\n\n        scope_tasks = _current_scope_tasks(\n            in_bugs=in_bugs,\n            bugs_b=bugs_b,\n            current_subsection=current_subsection,\n            current_phase=current_phase,\n        )\n\n        ro = _parse_ruledout_line(line, line_number)\n        if ro is not None:\n            indent = len(ro.indent)\n            roots = scope_tasks if scope_tasks is not None else []\n            target = _attach_ruledout(indent, stack, roots)\n            if target is not None:\n                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n            continue\n\n        dm = _DEPS_RE.match(line)\n        if dm is not None:\n            indent = len(dm.group(1))\n            target, _lenient = _attach_deps(indent, stack)\n            if target is None:\n                _raise_syntax_error(\n                    \"@deps line has no preceding task to attach to\",\n                    line_text=line,\n                    line_number=line_number,\n                    source_path=source_path,\n                    column=indent + 1,\n                )\n            target.deps.extend(dm.group(2).split())\n            continue\n\n        raw = _parse_task_line(line, line_number)\n        if raw is None:\n            if preamble_active:\n                preamble_lines.append(line)\n            elif subsection_prose_lines is not None:\n                subsection_prose_lines.append(line)\n            elif phase_prose_lines is not None:\n                phase_prose_lines.append(line)\n            # else: line outside any active prose region (e.g. before\n            # the first H1 or after the first task in a section) —\n            # dropped in compat mode.\n            continue\n\n        _close_subsection_prose()\n        _close_phase_prose()\n\n        builder = _build_task(raw)\n        indent = builder.indent_level\n\n        while stack and stack[-1].indent_level >= indent:\n            stack.pop()\n\n        if stack:\n            stack[-1].children.append(builder)\n        elif scope_tasks is not None:\n            scope_tasks.append(builder)\n        # else: task line before any phase/bugs — silently dropped in\n        # compat mode (matches mcloop, which assigns ``stage=\"\"``);\n        # strict mode (Stage 3) will surface this as a PlanSyntaxError.\n\n        stack.append(builder)\n\n    _close_subsection_prose()\n    _close_phase_prose()\n\n    return Plan(\n        magic_version=None,\n        project_title=project_title,\n        preamble=_finalize_prose(preamble_lines),\n        phases=tuple(p.freeze() for p in phases_b),\n        bugs=bugs_b.freeze() if bugs_b is not None else None,\n        source_path=source_path,\n    )\n\n\ndef _check_structural_sanity(\n    lines: list[str],\n    source_path: Path | None,\n) -> None:\n    \"\"\"Scan ``lines`` for structural corruption signals before parsing.\n\n    Three anomalies are flagged, mirroring mcloop's\n    ``_check_structural_sanity`` (``mcloop/checklist.py``):\n\n    1. Duplicate H1 headings with identical title text — typically a\n       botched insertion that left the original tail in place,\n       producing two copies of the document's top header.\n    2. Multiple Bugs sections (any heading level) — there should\n       only ever be one.\n    3. Duplicate phase/stage ordinals across stage headers — two\n       headers numbered ``Phase 2``, for example. This breaks any\n       label that prefixes with the stage number and almost always\n       signals merged content from two attempts at the same phase.\n\n    Each anomaly has been observed in real PLAN.md corruption\n    incidents and none has a legitimate use; auto-fixing is\n    deliberately not attempted because mutating an already-corrupted\n    plan risks compounding the corruption rather than recovering it.\n    Raises :class:`PlanSyntaxError` whose message lists every anomaly\n    found, with one-based source line numbers, so the user can locate\n    and fix the corruption by hand.\n    \"\"\"\n    h1_titles: dict[str, list[int]] = {}\n    bugs_lines: list[int] = []\n    stage_nums: dict[int, list[int]] = {}\n\n    for i, line in enumerate(lines):\n        # Order matters: a single-hash ``# Phase 1: Bootstrapping``\n        # is matched by both ``_STAGE_RE`` and ``_H1_RE``. A header is\n        # either a stage header OR a plain H1 OR a Bugs header — never\n        # two of those at once. Check stage first so ``# Phase N`` is\n        # not double-counted as an H1 duplicate and a stage duplicate.\n        stage_match = _STAGE_RE.match(line)\n        if stage_match is not None:\n            stage_nums.setdefault(int(stage_match.group(\"num\")), []).append(i)\n            continue\n\n        if _BUGS_RE.match(line):\n            bugs_lines.append(i)\n            continue\n\n        h1_match = _H1_RE.match(line)\n        if h1_match is not None:\n            # ``_H1_RE`` requires a single leading ``#``; the explicit\n            # ``not startswith(\"## \")`` guard is belt-and-suspenders so\n            # the intent (true H1 only) is visible in the reader's eye.\n            if line.startswith(\"# \") and not line.startswith(\"## \"):\n                title = h1_match.group(1).strip()\n                h1_titles.setdefault(title, []).append(i)\n\n    problems: list[tuple[int, str]] = []\n\n    for title, line_nums in h1_titles.items():\n        if len(line_nums) > 1:\n            locs = \", \".join(str(n + 1) for n in line_nums)\n            problems.append(\n                (\n                    line_nums[0] + 1,\n                    f\"duplicate top-level heading '# {title}' at lines {locs}\",\n                )\n            )\n\n    if len(bugs_lines) > 1:\n        locs = \", \".join(str(n + 1) for n in bugs_lines)\n        problems.append((bugs_lines[0] + 1, f\"multiple Bugs sections at lines {locs}\"))\n\n    for num, line_nums in stage_nums.items():\n        if len(line_nums) > 1:\n            locs = \", \".join(str(n + 1) for n in line_nums)\n            problems.append(\n                (line_nums[0] + 1, f\"duplicate Phase/Stage {num} at lines {locs}\")\n            )\n\n    if not problems:\n        return\n\n    problems.sort(key=lambda p: p[0])\n    first_line = problems[0][0]\n    body = \"\\n  - \".join(msg for _, msg in problems)\n    raise PlanSyntaxError(\n        f\"structural corruption detected:\\n  - {body}\",\n        first_line,\n        1,\n        source_path,\n    )\n\n\ndef _raise_syntax_error(\n    message: str,\n    *,\n    line_text: str,\n    line_number: int,\n    source_path: Path | None,\n    column: int = 1,\n) -> NoReturn:\n    \"\"\"Raise :class:`PlanSyntaxError` with the offending line quoted.\n\n    Per the design doc section 9 contract, the error carries\n    ``(message, line, column, path)``; ``__str__`` formats them as\n    ``PLAN.md invalid at line N, column M: <message>``. The task\n    description for 2.5.4 adds: the message itself must quote the\n    offending line so the human reading the error can see exactly which\n    text triggered the rejection without having to open the file. The\n    quoted form uses backticks rather than ``repr()`` because the line\n    has already had its trailing newline stripped by ``splitlines()``,\n    so there is no escape-sequence ambiguity to disambiguate.\n    \"\"\"\n    raise PlanSyntaxError(\n        f\"{message}: `{line_text}`\",\n        line_number,\n        column,\n        source_path,\n    )\n\n\ndef _finalize_prose(lines: list[str]) -> str:\n    \"\"\"Join accumulated prose lines, trimming blank lines from the ends.\n\n    Internal blank lines (paragraph breaks) and any leading/trailing\n    whitespace within a non-blank line are preserved — Markdown attaches\n    semantic weight to indent (code blocks, list continuations), so we\n    only strip wholly-blank wrapper lines rather than calling\n    ``str.strip()`` on the joined text.\n    \"\"\"\n    start = 0\n    while start < len(lines) and not lines[start].strip():\n        start += 1\n    end = len(lines)\n    while end > start and not lines[end - 1].strip():\n        end -= 1\n    return \"\\n\".join(lines[start:end])\n\n\ndef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n\n    Returns ``None`` for non-matching lines. The keyword is normalized\n    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n    keeps the keyword cosmetic, so the canonicalizer can choose to\n    preserve original casing if it wants — the typed model only needs\n    one stable form.\n    \"\"\"\n    m = _STAGE_RE.match(line)\n    if m is None:\n        return None\n    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n\n\ndef _extract_task_id(text: str) -> tuple[str | None, str]:\n    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n\n    Per design doc section 4.2 grammar, the task ID is the first token\n    in the body after the checkbox. Returns ``(None, text)`` when no\n    leading task ID is present; task IDs are optional in compat mode\n    and mandatory in strict mode (enforced separately in Stage 3).\n    \"\"\"\n    m = _TASK_ID_RE.match(text)\n    if m is None:\n        return None, text\n    return m.group(1), text[m.end() :]\n\n\ndef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n\n    Order matters: annotations come first (they live at end of line\n    and would otherwise be swallowed by the action tag's args, which\n    span to end of line). Task ID, then flag tags, then action tag run\n    left-to-right. The remaining text is the task description.\n    \"\"\"\n    annotations, remaining = _extract_annotations(raw.text)\n    task_id, remaining = _extract_task_id(remaining)\n    flag_tags, remaining = _extract_flag_tags(remaining)\n    action_tag, remaining = _extract_action_tag(remaining)\n    return _TaskBuilder(\n        task_id=task_id,\n        text=remaining.strip(),\n        status=TaskStatus.from_marker(raw.status_char),\n        flag_tags=flag_tags,\n        action_tag=action_tag,\n        annotations=annotations,\n        indent_level=len(raw.indent),\n        line_number=raw.line_number,\n    )\n\n\ndef _current_scope_tasks(\n    *,\n    in_bugs: bool,\n    bugs_b: _BugsBuilder | None,\n    current_subsection: _SubsectionBuilder | None,\n    current_phase: _PhaseBuilder | None,\n) -> list[_TaskBuilder] | None:\n    \"\"\"Pick the root-task list for the active section.\n\n    The order encodes the grammar: a Bugs section excludes phase scope;\n    inside a phase, a current subsection captures following tasks until\n    the next subsection or phase. Returns ``None`` when no section is\n    active — i.e. the input has not yet introduced a phase or bugs\n    heading, so any task/sibling line is an orphan.\n    \"\"\"\n    if in_bugs:\n        return bugs_b.tasks if bugs_b is not None else None\n    if current_subsection is not None:\n        return current_subsection.tasks\n    if current_phase is not None:\n        return current_phase.tasks\n    return None\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\nclass _HasIndentLevel(Protocol):\n    \"\"\"Anything with an integer ``indent_level`` attribute.\n\n    Used by :func:`_attach_ruledout` so it can resolve attachment over\n    either the eventual frozen ``Task`` model objects or the mutable\n    builder records the parser uses while constructing them.\n    \"\"\"\n\n    @property\n    def indent_level(self) -> int: ...\n\n\n_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n\n\ndef _attach_ruledout(\n    indent: int,\n    stack: Sequence[_T],\n    root_tasks: Sequence[_T],\n) -> _T | None:\n    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n\n    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n    the open-ancestor stack from innermost to outermost and return the\n    first task whose indent is strictly less than the RULEDOUT line's\n    indent. If no such ancestor exists in the current phase, fall back\n    to the most recent root task (mcloop's \"orphan\" handling). Returns\n    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n    the caller should drop.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task\n    if root_tasks:\n        return root_tasks[-1]\n    return None\n\n\ndef _attach_deps(\n    indent: int,\n    stack: Sequence[_T],\n) -> tuple[_T | None, bool]:\n    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n\n    Walks the open-ancestor stack from innermost (top) to outermost.\n    Returns ``(parent, False)`` for the strict form — first ancestor\n    whose indent is strictly less than the deps line's indent. Returns\n    ``(parent, True)`` for the lenient form — first ancestor at the\n    same indent as the deps line, which callers should report as a\n    validation warning (the deps was not indented under its task).\n    Returns ``(None, False)`` when no candidate exists; the caller\n    should drop the line.\n\n    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n    indent is malformed input rather than an orphan that needs adopting.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task, False\n        if task.indent_level == indent:\n            return task, True\n    return None, False\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n\n\n# Mutable builder records used while walking the input. The public\n# model dataclasses are frozen, so the parser builds with these and\n# calls ``freeze`` to produce the immutable tree at the end. Each\n# builder also satisfies the ``_HasIndentLevel`` protocol so the\n# existing ``_attach_*`` helpers operate on them directly.\n\n\n@dataclass\nclass _TaskBuilder:\n    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n\n    task_id: str | None\n    text: str\n    status: TaskStatus\n    flag_tags: tuple[str, ...]\n    action_tag: tuple[str, str] | None\n    annotations: tuple[tuple[str, str], ...]\n    indent_level: int\n    line_number: int\n    deps: list[str] = field(default_factory=list)\n    children: list[_TaskBuilder] = field(default_factory=list)\n    ruled_out: list[RuledOut] = field(default_factory=list)\n\n    def freeze(self) -> Task:\n        return Task(\n            task_id=self.task_id,\n            text=self.text,\n            status=self.status,\n            flag_tags=self.flag_tags,\n            action_tag=self.action_tag,\n            annotations=self.annotations,\n            deps=tuple(self.deps),\n            children=tuple(c.freeze() for c in self.children),\n            ruled_out=tuple(self.ruled_out),\n            indent_level=self.indent_level,\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _SubsectionBuilder:\n    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n\n    title: str\n    line_number: int\n    prose: str = \"\"\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Subsection:\n        return Subsection(\n            title=self.title,\n            prose=self.prose,\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _PhaseBuilder:\n    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n\n    ordinal: int\n    keyword: str\n    title: str\n    line_number: int\n    phase_id: str | None = None\n    phase_id_source: str = \"none\"\n    prose: str = \"\"\n    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Phase:\n        return Phase(\n            phase_id=self.phase_id,\n            phase_id_source=self.phase_id_source,\n            ordinal=self.ordinal,\n            keyword=self.keyword,\n            title=self.title,\n            prose=self.prose,\n            subsections=tuple(s.freeze() for s in self.subsections),\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _BugsBuilder:\n    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n\n    line_number: int\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> BugsSection:\n        return BugsSection(\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n","numLines":840,"startLine":1,"totalLines":840}}}
