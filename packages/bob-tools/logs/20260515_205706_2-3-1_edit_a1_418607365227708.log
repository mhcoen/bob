{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NPVELSmbiEQYvQ1UQjVdW9","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom dataclasses import dataclass\n7\t\n8\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n9\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n10\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n11\t\n12\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n13\t# caller strips any inter-tag whitespace between iterations.\n14\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n15\t\n16\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n17\t# after the closing bracket (with the single separating space removed).\n18\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n19\t\n20\t# Content of an annotation (the bytes between `[` and `]`): an\n21\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n22\t# value. The required whitespace after the colon is what distinguishes\n23\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n24\t# after its colon).\n25\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n26\t\n27\t\n28\t@dataclass(frozen=True)\n29\tclass _RawTaskLine:\n30\t    \"\"\"Recognize-step output of `_parse_task_line`.\n31\t\n32\t    Stage 2 of the parser splits recognize-then-classify. This record\n33\t    is the recognize step: indent text, status marker, body text, and\n34\t    source line number. Higher-level functions classify the body into\n35\t    task id, tags, deps, and prose.\n36\t    \"\"\"\n37\t\n38\t    indent: str\n39\t    status_char: str\n40\t    text: str\n41\t    line_number: int\n42\t\n43\t\n44\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n45\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n46\t    m = _CHECKBOX_RE.match(line)\n47\t    if m is None:\n48\t        return None\n49\t    return _RawTaskLine(\n50\t        indent=m.group(1),\n51\t        status_char=m.group(2),\n52\t        text=m.group(3),\n53\t        line_number=line_number,\n54\t    )\n55\t\n56\t\n57\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n58\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n59\t\n60\t    Per design doc section 4.3, flag tags are recognized only at the\n61\t    leading position. The caller is responsible for stripping the task\n62\t    ID (if any) first. A bracketed flag form appearing later in the\n63\t    text is prose and is left in place.\n64\t    \"\"\"\n65\t    tags: list[str] = []\n66\t    remaining = text\n67\t    while True:\n68\t        m = _FLAG_TAG_RE.match(remaining)\n69\t        if m is None:\n70\t            break\n71\t        tags.append(m.group(1))\n72\t        remaining = remaining[m.end() :].lstrip()\n73\t    return tuple(tags), remaining\n74\t\n75\t\n76\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n77\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n78\t\n79\t    Per design doc section 4.3, the action tag is recognized only at\n80\t    the leading position, after any flag tags. The argument string is\n81\t    the text from the closing bracket to end of line, with the single\n82\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n83\t    are prose and are left in place.\n84\t\n85\t    Returns ``(None, text)`` when no leading action tag is present;\n86\t    otherwise consumes the rest of the line as the argument string\n87\t    and returns ``((action, args), \"\")``.\n88\t    \"\"\"\n89\t    m = _ACTION_TAG_RE.match(text)\n90\t    if m is None:\n91\t        return None, text\n92\t    action = m.group(1)\n93\t    args = text[m.end() :].lstrip()\n94\t    return (action, args), \"\"\n95\t\n96\t\n97\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n98\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n99\t\n100\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n101\t    are bracketed, and are separated from the preceding text by\n102\t    whitespace. Multiple annotations are allowed. Values may contain\n103\t    balanced bracket pairs; this function scans right-to-left with\n104\t    bracket-depth tracking so nested brackets stay inside a single\n105\t    annotation rather than being misparsed as a separate one.\n106\t\n107\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n108\t    accepts any identifier-shaped key. Validation of allowed keys is\n109\t    a separate concern.\n110\t    \"\"\"\n111\t    annotations: list[tuple[str, str]] = []\n112\t    remaining = text\n113\t    while True:\n114\t        rstripped = remaining.rstrip()\n115\t        if not rstripped.endswith(\"]\"):\n116\t            remaining = rstripped\n117\t            break\n118\t        start = _find_matching_open_bracket(rstripped)\n119\t        if start is None:\n120\t            remaining = rstripped\n121\t            break\n122\t        # An annotation must be separated from preceding text by\n123\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n124\t        # character is part of the task text, not an annotation.\n125\t        if start > 0 and not rstripped[start - 1].isspace():\n126\t            remaining = rstripped\n127\t            break\n128\t        content = rstripped[start + 1 : -1]\n129\t        m = _ANNOTATION_CONTENT_RE.match(content)\n130\t        if m is None:\n131\t            remaining = rstripped\n132\t            break\n133\t        annotations.insert(0, (m.group(1), m.group(2)))\n134\t        remaining = rstripped[:start].rstrip()\n135\t    return tuple(annotations), remaining\n136\t\n137\t\n138\tdef _find_matching_open_bracket(s: str) -> int | None:\n139\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n140\t\n141\t    Walks right-to-left tracking bracket depth so balanced nested\n142\t    brackets inside the candidate annotation are stepped over.\n143\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n144\t    opener.\n145\t    \"\"\"\n146\t    if not s.endswith(\"]\"):\n147\t        return None\n148\t    depth = 0\n149\t    for i in range(len(s) - 1, -1, -1):\n150\t        c = s[i]\n151\t        if c == \"]\":\n152\t            depth += 1\n153\t        elif c == \"[\":\n154\t            depth -= 1\n155\t            if depth == 0:\n156\t                return i\n157\t    return None\n158\t"}]},"parent_tool_use_id":null,"session_id":"f23808d8-a275-442a-b4ca-44cb559482e9","uuid":"7619c453-93d1-4b24-893d-a9463cd431c2","timestamp":"2026-05-16T01:54:09.788Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom dataclasses import dataclass\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n","numLines":158,"startLine":1,"totalLines":158}}}
