{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ERy1GZoV3Xjxu3opp15kVg","type":"tool_result","content":"1\t\"\"\"Tests for bob_tools.planfile.parser building blocks.\n2\t\n3\tStage 2 task-line recognizers and tag extractors:\n4\t\n5\t  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n6\t    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n7\t  - ``_parse_task_line`` returns a raw record on checkbox lines and\n8\t    ``None`` on anything else.\n9\t  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n10\t    tokens, in isolation and combination, and leaves non-leading\n11\t    occurrences as prose (design doc section 4.3).\n12\t  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n13\t    treats the rest of the line as its argument string; non-leading\n14\t    occurrences are prose.\n15\t  - ``_extract_annotations`` consumes trailing ``[key: value]``\n16\t    annotations, handles multiple annotations and nested brackets in\n17\t    values, and leaves bracketed prose that is not separated from\n18\t    preceding text by whitespace in place.\n19\t\"\"\"\n20\t\n21\tfrom __future__ import annotations\n22\t\n23\timport pytest\n24\t\n25\tfrom bob_tools.planfile.parser import (\n26\t    _CHECKBOX_RE,\n27\t    _extract_action_tag,\n28\t    _extract_annotations,\n29\t    _extract_flag_tags,\n30\t    _parse_task_line,\n31\t)\n32\t\n33\t\n34\tclass TestCheckboxRe:\n35\t    @pytest.mark.parametrize(\n36\t        (\"line\", \"indent\", \"marker\", \"text\"),\n37\t        [\n38\t            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n39\t            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n40\t            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n41\t            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n42\t            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n43\t        ],\n44\t    )\n45\t    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n46\t        m = _CHECKBOX_RE.match(line)\n47\t        assert m is not None\n48\t        assert m.group(1) == indent\n49\t        assert m.group(2) == marker\n50\t        assert m.group(3) == text\n51\t\n52\t    @pytest.mark.parametrize(\n53\t        \"line\",\n54\t        [\n55\t            \"\",\n56\t            \"## Stage 1: Core\",\n57\t            \"- [] missing space inside brackets\",\n58\t            \"- [y] unsupported marker\",\n59\t            \"- [ ]\",\n60\t            \"* [ ] wrong bullet\",\n61\t            \"Plain prose line\",\n62\t        ],\n63\t    )\n64\t    def test_non_matches(self, line: str) -> None:\n65\t        assert _CHECKBOX_RE.match(line) is None\n66\t\n67\t\n68\tclass TestParseTaskLine:\n69\t    def test_match_returns_raw_record(self) -> None:\n70\t        rec = _parse_task_line(\"  - [x] foo\", 7)\n71\t        assert rec is not None\n72\t        assert rec.indent == \"  \"\n73\t        assert rec.status_char == \"x\"\n74\t        assert rec.text == \"foo\"\n75\t        assert rec.line_number == 7\n76\t\n77\t    def test_match_failed_marker(self) -> None:\n78\t        rec = _parse_task_line(\"- [!] bad\", 12)\n79\t        assert rec is not None\n80\t        assert rec.status_char == \"!\"\n81\t        assert rec.line_number == 12\n82\t\n83\t    def test_non_task_returns_none(self) -> None:\n84\t        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n85\t        assert _parse_task_line(\"\", 2) is None\n86\t        assert _parse_task_line(\"Some prose\", 3) is None\n87\t\n88\t\n89\tclass TestExtractFlagTags:\n90\t    def test_no_tags(self) -> None:\n91\t        tags, rest = _extract_flag_tags(\"plain task text\")\n92\t        assert tags == ()\n93\t        assert rest == \"plain task text\"\n94\t\n95\t    def test_user(self) -> None:\n96\t        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n97\t        assert tags == (\"USER\",)\n98\t        assert rest == \"verify the menu\"\n99\t\n100\t    def test_batch(self) -> None:\n101\t        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n102\t        assert tags == (\"BATCH\",)\n103\t        assert rest == \"sub-task group\"\n104\t\n105\t    def test_user_and_batch_combined(self) -> None:\n106\t        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n107\t        assert tags == (\"USER\", \"BATCH\")\n108\t        assert rest == \"both flags\"\n109\t\n110\t    def test_adjacent_tags_without_separator(self) -> None:\n111\t        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n112\t        assert tags == (\"USER\", \"BATCH\")\n113\t        assert rest == \"no gap\"\n114\t\n115\t    def test_non_leading_tag_is_prose(self) -> None:\n116\t        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n117\t        assert tags == ()\n118\t        assert rest == \"Document the [USER] tag\"\n119\t\n120\t    def test_only_first_run_is_tags(self) -> None:\n121\t        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n122\t        assert tags == (\"USER\",)\n123\t        assert rest == \"middle [BATCH] later\"\n124\t\n125\t    def test_empty_input(self) -> None:\n126\t        tags, rest = _extract_flag_tags(\"\")\n127\t        assert tags == ()\n128\t        assert rest == \"\"\n129\t\n130\t\n131\tclass TestExtractActionTag:\n132\t    def test_no_action_tag(self) -> None:\n133\t        tag, rest = _extract_action_tag(\"plain task text\")\n134\t        assert tag is None\n135\t        assert rest == \"plain task text\"\n136\t\n137\t    def test_action_with_args(self) -> None:\n138\t        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n139\t        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n140\t        assert rest == \"\"\n141\t\n142\t    def test_action_without_args(self) -> None:\n143\t        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n144\t        assert tag == (\"noop\", \"\")\n145\t        assert rest == \"\"\n146\t\n147\t    def test_args_extend_to_end_of_line(self) -> None:\n148\t        # Argument string is text from closing bracket to end of line;\n149\t        # bracketed-looking content in args stays in args.\n150\t        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n151\t        assert tag == (\"run\", \"do [feat: x]\")\n152\t        assert rest == \"\"\n153\t\n154\t    def test_non_leading_auto_is_prose(self) -> None:\n155\t        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n156\t        assert tag is None\n157\t        assert rest == \"Document the [AUTO:run] tag\"\n158\t\n159\t\n160\tclass TestExtractAnnotations:\n161\t    def test_no_annotation(self) -> None:\n162\t        ann, rest = _extract_annotations(\"plain task text\")\n163\t        assert ann == ()\n164\t        assert rest == \"plain task text\"\n165\t\n166\t    def test_single_feat(self) -> None:\n167\t        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n168\t        assert ann == ((\"feat\", '\"menu wired\"'),)\n169\t        assert rest == \"do thing\"\n170\t\n171\t    def test_single_fix(self) -> None:\n172\t        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n173\t        assert ann == ((\"fix\", '\"race\"'),)\n174\t        assert rest == \"fixed it\"\n175\t\n176\t    def test_multiple_annotations_preserve_order(self) -> None:\n177\t        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n178\t        assert ann == (\n179\t            (\"feat\", '\"first\"'),\n180\t            (\"fix\", '\"second\"'),\n181\t        )\n182\t        assert rest == \"do thing\"\n183\t\n184\t    def test_nested_brackets_in_value(self) -> None:\n185\t        # Balanced brackets inside the value are stepped over by the\n186\t        # right-to-left depth scan and stay inside the annotation.\n187\t        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n188\t        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n189\t        assert rest == \"do thing\"\n190\t\n191\t    def test_unquoted_nested_brackets_in_value(self) -> None:\n192\t        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n193\t        assert ann == ((\"feat\", \"a [b] c\"),)\n194\t        assert rest == \"do\"\n195\t\n196\t    def test_prose_bracket_without_separator_is_text(self) -> None:\n197\t        # A `[` abutting a non-whitespace character is task text, not\n198\t        # the start of an annotation.\n199\t        ann, rest = _extract_annotations(\"see config[feat: x]\")\n200\t        assert ann == ()\n201\t        assert rest == \"see config[feat: x]\"\n202\t\n203\t    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n204\t        # `[AUTO:run]` has no whitespace after its colon and so is not\n205\t        # an annotation under this extractor's rules.\n206\t        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n207\t        assert ann == ()\n208\t        assert rest == \"[AUTO:run] cmd\"\n209\t\n210\t    def test_unmatched_open_bracket(self) -> None:\n211\t        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n212\t        assert ann == ()\n213\t        assert rest == \"dangling brackets feat ]\"\n214\t\n215\t    def test_annotation_alone_consumes_to_empty(self) -> None:\n216\t        ann, rest = _extract_annotations('[feat: \"lone\"]')\n217\t        assert ann == ((\"feat\", '\"lone\"'),)\n218\t        assert rest == \"\"\n219\t\n220\t\n221\tclass TestTagInteractions:\n222\t    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n223\t        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n224\t        # Annotation must be stripped before action tag, because action\n225\t        # tag args span to end of line.\n226\t        ann, after_ann = _extract_annotations(text)\n227\t        assert ann == ((\"feat\", '\"done\"'),)\n228\t        tags, after_flags = _extract_flag_tags(after_ann)\n229\t        assert tags == (\"BATCH\",)\n230\t        action, after_action = _extract_action_tag(after_flags)\n231\t        assert action == (\"run_cli\", \"mcloop --dry-run\")\n232\t        assert after_action == \"\"\n233\t\n234\t    def test_flags_and_plain_text(self) -> None:\n235\t        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n236\t        assert ann == ()\n237\t        tags, after_flags = _extract_flag_tags(after_ann)\n238\t        assert tags == (\"USER\", \"BATCH\")\n239\t        action, after_action = _extract_action_tag(after_flags)\n240\t        assert action is None\n241\t        assert after_action == \"verify thing\"\n242\t\n243\t    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n244\t        text = \"Implement [USER] and [AUTO:run] tokenization\"\n245\t        ann, after_ann = _extract_annotations(text)\n246\t        tags, after_flags = _extract_flag_tags(after_ann)\n247\t        action, after_action = _extract_action_tag(after_flags)\n248\t        assert ann == ()\n249\t        assert tags == ()\n250\t        assert action is None\n251\t        assert after_action == text\n252\t"}]},"parent_tool_use_id":null,"session_id":"f23808d8-a275-442a-b4ca-44cb559482e9","uuid":"d70ae011-f0d4-4b13-a946-d673f0508e53","timestamp":"2026-05-16T01:54:15.860Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"\"\"\"Tests for bob_tools.planfile.parser building blocks.\n\nStage 2 task-line recognizers and tag extractors:\n\n  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n  - ``_parse_task_line`` returns a raw record on checkbox lines and\n    ``None`` on anything else.\n  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n    tokens, in isolation and combination, and leaves non-leading\n    occurrences as prose (design doc section 4.3).\n  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n    treats the rest of the line as its argument string; non-leading\n    occurrences are prose.\n  - ``_extract_annotations`` consumes trailing ``[key: value]``\n    annotations, handles multiple annotations and nested brackets in\n    values, and leaves bracketed prose that is not separated from\n    preceding text by whitespace in place.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom bob_tools.planfile.parser import (\n    _CHECKBOX_RE,\n    _extract_action_tag,\n    _extract_annotations,\n    _extract_flag_tags,\n    _parse_task_line,\n)\n\n\nclass TestCheckboxRe:\n    @pytest.mark.parametrize(\n        (\"line\", \"indent\", \"marker\", \"text\"),\n        [\n            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n        ],\n    )\n    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n        m = _CHECKBOX_RE.match(line)\n        assert m is not None\n        assert m.group(1) == indent\n        assert m.group(2) == marker\n        assert m.group(3) == text\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"## Stage 1: Core\",\n            \"- [] missing space inside brackets\",\n            \"- [y] unsupported marker\",\n            \"- [ ]\",\n            \"* [ ] wrong bullet\",\n            \"Plain prose line\",\n        ],\n    )\n    def test_non_matches(self, line: str) -> None:\n        assert _CHECKBOX_RE.match(line) is None\n\n\nclass TestParseTaskLine:\n    def test_match_returns_raw_record(self) -> None:\n        rec = _parse_task_line(\"  - [x] foo\", 7)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.status_char == \"x\"\n        assert rec.text == \"foo\"\n        assert rec.line_number == 7\n\n    def test_match_failed_marker(self) -> None:\n        rec = _parse_task_line(\"- [!] bad\", 12)\n        assert rec is not None\n        assert rec.status_char == \"!\"\n        assert rec.line_number == 12\n\n    def test_non_task_returns_none(self) -> None:\n        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n        assert _parse_task_line(\"\", 2) is None\n        assert _parse_task_line(\"Some prose\", 3) is None\n\n\nclass TestExtractFlagTags:\n    def test_no_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"plain task text\")\n        assert tags == ()\n        assert rest == \"plain task text\"\n\n    def test_user(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n        assert tags == (\"USER\",)\n        assert rest == \"verify the menu\"\n\n    def test_batch(self) -> None:\n        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n        assert tags == (\"BATCH\",)\n        assert rest == \"sub-task group\"\n\n    def test_user_and_batch_combined(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"both flags\"\n\n    def test_adjacent_tags_without_separator(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"no gap\"\n\n    def test_non_leading_tag_is_prose(self) -> None:\n        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n        assert tags == ()\n        assert rest == \"Document the [USER] tag\"\n\n    def test_only_first_run_is_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n        assert tags == (\"USER\",)\n        assert rest == \"middle [BATCH] later\"\n\n    def test_empty_input(self) -> None:\n        tags, rest = _extract_flag_tags(\"\")\n        assert tags == ()\n        assert rest == \"\"\n\n\nclass TestExtractActionTag:\n    def test_no_action_tag(self) -> None:\n        tag, rest = _extract_action_tag(\"plain task text\")\n        assert tag is None\n        assert rest == \"plain task text\"\n\n    def test_action_with_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n        assert rest == \"\"\n\n    def test_action_without_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n        assert tag == (\"noop\", \"\")\n        assert rest == \"\"\n\n    def test_args_extend_to_end_of_line(self) -> None:\n        # Argument string is text from closing bracket to end of line;\n        # bracketed-looking content in args stays in args.\n        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n        assert tag == (\"run\", \"do [feat: x]\")\n        assert rest == \"\"\n\n    def test_non_leading_auto_is_prose(self) -> None:\n        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n        assert tag is None\n        assert rest == \"Document the [AUTO:run] tag\"\n\n\nclass TestExtractAnnotations:\n    def test_no_annotation(self) -> None:\n        ann, rest = _extract_annotations(\"plain task text\")\n        assert ann == ()\n        assert rest == \"plain task text\"\n\n    def test_single_feat(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n        assert ann == ((\"feat\", '\"menu wired\"'),)\n        assert rest == \"do thing\"\n\n    def test_single_fix(self) -> None:\n        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n        assert ann == ((\"fix\", '\"race\"'),)\n        assert rest == \"fixed it\"\n\n    def test_multiple_annotations_preserve_order(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n        assert ann == (\n            (\"feat\", '\"first\"'),\n            (\"fix\", '\"second\"'),\n        )\n        assert rest == \"do thing\"\n\n    def test_nested_brackets_in_value(self) -> None:\n        # Balanced brackets inside the value are stepped over by the\n        # right-to-left depth scan and stay inside the annotation.\n        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n        assert rest == \"do thing\"\n\n    def test_unquoted_nested_brackets_in_value(self) -> None:\n        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n        assert ann == ((\"feat\", \"a [b] c\"),)\n        assert rest == \"do\"\n\n    def test_prose_bracket_without_separator_is_text(self) -> None:\n        # A `[` abutting a non-whitespace character is task text, not\n        # the start of an annotation.\n        ann, rest = _extract_annotations(\"see config[feat: x]\")\n        assert ann == ()\n        assert rest == \"see config[feat: x]\"\n\n    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n        # `[AUTO:run]` has no whitespace after its colon and so is not\n        # an annotation under this extractor's rules.\n        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n        assert ann == ()\n        assert rest == \"[AUTO:run] cmd\"\n\n    def test_unmatched_open_bracket(self) -> None:\n        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n        assert ann == ()\n        assert rest == \"dangling brackets feat ]\"\n\n    def test_annotation_alone_consumes_to_empty(self) -> None:\n        ann, rest = _extract_annotations('[feat: \"lone\"]')\n        assert ann == ((\"feat\", '\"lone\"'),)\n        assert rest == \"\"\n\n\nclass TestTagInteractions:\n    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n        # Annotation must be stripped before action tag, because action\n        # tag args span to end of line.\n        ann, after_ann = _extract_annotations(text)\n        assert ann == ((\"feat\", '\"done\"'),)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"BATCH\",)\n        action, after_action = _extract_action_tag(after_flags)\n        assert action == (\"run_cli\", \"mcloop --dry-run\")\n        assert after_action == \"\"\n\n    def test_flags_and_plain_text(self) -> None:\n        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n        assert ann == ()\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"USER\", \"BATCH\")\n        action, after_action = _extract_action_tag(after_flags)\n        assert action is None\n        assert after_action == \"verify thing\"\n\n    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n        text = \"Implement [USER] and [AUTO:run] tokenization\"\n        ann, after_ann = _extract_annotations(text)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        action, after_action = _extract_action_tag(after_flags)\n        assert ann == ()\n        assert tags == ()\n        assert action is None\n        assert after_action == text\n","numLines":252,"startLine":1,"totalLines":252}}}
