 if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3673,"cache_read_input_tokens":49927,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3673},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"f23808d8-a275-442a-b4ca-44cb559482e9","uuid":"aa3ff4d5-40ba-4f29-b887-35085f8db192"}
