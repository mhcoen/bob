{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GqEYVKBR3EjA1W6YiJEZsF","type":"tool_result","content":"700\t            \"- [ ] T-000009: crash on empty PLAN.md\\n\"\n701\t        )\n702\t        plan = parse_plan(text)\n703\t        assert len(plan.phases) == 1\n704\t        phase = plan.phases[0]\n705\t        parent = phase.tasks[0]\n706\t        assert parent.task_id == \"T-000001\"\n707\t        assert parent.flag_tags == (\"BATCH\",)\n708\t        child_a, child_b = parent.children\n709\t        assert child_a.task_id == \"T-000002\"\n710\t        assert tuple(r.text for r in child_a.ruled_out) == (\"tried polling\",)\n711\t        assert child_b.deps == (\"T-000002\",)\n712\t        assert len(phase.subsections) == 1\n713\t        manual = phase.subsections[0]\n714\t        assert manual.title == \"Manual verification\"\n715\t        assert manual.tasks[0].flag_tags == (\"USER\",)\n716\t        assert plan.bugs is not None\n717\t        assert plan.bugs.tasks[0].task_id == \"T-000009\"\n718\t\n719\t    def test_tasks_before_any_section_are_dropped_in_compat_mode(self) -> None:\n720\t        # No phase or bugs heading has been seen yet, so a task line is\n721\t        # an orphan. Compat mode drops silently; strict mode (2.5.4)\n722\t        # will surface this as a PlanSyntaxError. Either way no tasks\n723\t        # appear on the resulting Plan.\n724\t        plan = parse_plan(\"- [ ] orphan\\n## Stage 1: Core\\n- [ ] real\\n\")\n725\t        assert len(plan.phases) == 1\n726\t        assert tuple(t.text for t in plan.phases[0].tasks) == (\"real\",)\n727\t\n728\t    def test_source_path_passes_through(self) -> None:\n729\t        from pathlib import Path\n730\t\n731\t        path = Path(\"/tmp/PLAN.md\")\n732\t        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\", source_path=path)\n733\t        assert plan.source_path == path\n734\t\n735\t\n736\tclass TestParsePlanProse:\n737\t    \"\"\"Tests for project title, preamble, phase prose, and subsection prose.\n738\t\n739\t    Per design doc section 4.1 grammar, prose is allowed in three places:\n740\t    after the H1 (the preamble), after a phase heading (phase prose),\n741\t    and after a ``###`` subsection heading (subsection prose). Each\n742\t    region ends at the next structural boundary — phase/bugs heading\n743\t    for the preamble, first task or subsection for phase prose, and\n744\t    first task for subsection prose.\n745\t    \"\"\"\n746\t\n747\t    def test_h1_sets_project_title(self) -> None:\n748\t        plan = parse_plan(\"# My Project\\n## Stage 1: Core\\n\")\n749\t        assert plan.project_title == \"My Project\"\n750\t        assert plan.preamble == \"\"\n751\t\n752\t    def test_no_h1_means_empty_title(self) -> None:\n753\t        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n754\t        assert plan.project_title == \"\"\n755\t        assert plan.preamble == \"\"\n756\t\n757\t    def test_h2_with_stage_keyword_does_not_match_h1(self) -> None:\n758\t        # `## Stage 1: Core` is consumed by the phase regex before the\n759\t        # H1 check runs, so it does not leak into the title slot.\n760\t        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n761\t        assert plan.project_title == \"\"\n762\t        assert len(plan.phases) == 1\n763\t\n764\t    def test_preamble_between_h1_and_phase(self) -> None:\n765\t        text = \"# Project\\n\\nIntro paragraph.\\n\\n## Stage 1: Core\\n- [ ] task\\n\"\n766\t        plan = parse_plan(text)\n767\t        assert plan.project_title == \"Project\"\n768\t        assert plan.preamble == \"Intro paragraph.\"\n769\t\n770\t    def test_preamble_multi_paragraph_preserves_blank_lines(self) -> None:\n771\t        text = (\n772\t            \"# Project\\n\\nFirst paragraph.\\n\\nSecond paragraph.\\n\\n## Stage 1: Core\\n\"\n773\t        )\n774\t        plan = parse_plan(text)\n775\t        assert plan.preamble == \"First paragraph.\\n\\nSecond paragraph.\"\n776\t\n777\t    def test_preamble_ends_at_bugs_heading(self) -> None:\n778\t        # Per the grammar, the preamble is followed by ``PhaseOrBugs+`` —\n779\t        # a bugs section is just as valid a terminator as a phase.\n780\t        text = \"# Project\\nIntro.\\n## Bugs\\n- [ ] crash\\n\"\n781\t        plan = parse_plan(text)\n782\t        assert plan.preamble == \"Intro.\"\n783\t        assert plan.bugs is not None\n784\t        assert plan.bugs.tasks[0].text == \"crash\"\n785\t\n786\t    def test_phase_prose_between_heading_and_first_task(self) -> None:\n787\t        text = \"## Stage 1: Core\\n\\nThe goal is X.\\n\\n- [ ] task\\n\"\n788\t        plan = parse_plan(text)\n789\t        assert plan.phases[0].prose == \"The goal is X.\"\n790\t\n791\t    def test_phase_prose_ends_at_subsection(self) -> None:\n792\t        text = (\n793\t            \"## Stage 1: Core\\n\\nPhase intro.\\n\\n### Manual verification\\n- [ ] check\\n\"\n794\t        )\n795\t        plan = parse_plan(text)\n796\t        phase = plan.phases[0]\n797\t        assert phase.prose == \"Phase intro.\"\n798\t        assert phase.subsections[0].prose == \"\"\n799\t"}]},"parent_tool_use_id":null,"session_id":"9a449ac0-394d-4684-a780-cf9347c419c5","uuid":"eecd8ad7-ee0f-444e-8630-410851101b90","timestamp":"2026-05-16T02:58:09.739Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"            \"- [ ] T-000009: crash on empty PLAN.md\\n\"\n        )\n        plan = parse_plan(text)\n        assert len(plan.phases) == 1\n        phase = plan.phases[0]\n        parent = phase.tasks[0]\n        assert parent.task_id == \"T-000001\"\n        assert parent.flag_tags == (\"BATCH\",)\n        child_a, child_b = parent.children\n        assert child_a.task_id == \"T-000002\"\n        assert tuple(r.text for r in child_a.ruled_out) == (\"tried polling\",)\n        assert child_b.deps == (\"T-000002\",)\n        assert len(phase.subsections) == 1\n        manual = phase.subsections[0]\n        assert manual.title == \"Manual verification\"\n        assert manual.tasks[0].flag_tags == (\"USER\",)\n        assert plan.bugs is not None\n        assert plan.bugs.tasks[0].task_id == \"T-000009\"\n\n    def test_tasks_before_any_section_are_dropped_in_compat_mode(self) -> None:\n        # No phase or bugs heading has been seen yet, so a task line is\n        # an orphan. Compat mode drops silently; strict mode (2.5.4)\n        # will surface this as a PlanSyntaxError. Either way no tasks\n        # appear on the resulting Plan.\n        plan = parse_plan(\"- [ ] orphan\\n## Stage 1: Core\\n- [ ] real\\n\")\n        assert len(plan.phases) == 1\n        assert tuple(t.text for t in plan.phases[0].tasks) == (\"real\",)\n\n    def test_source_path_passes_through(self) -> None:\n        from pathlib import Path\n\n        path = Path(\"/tmp/PLAN.md\")\n        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\", source_path=path)\n        assert plan.source_path == path\n\n\nclass TestParsePlanProse:\n    \"\"\"Tests for project title, preamble, phase prose, and subsection prose.\n\n    Per design doc section 4.1 grammar, prose is allowed in three places:\n    after the H1 (the preamble), after a phase heading (phase prose),\n    and after a ``###`` subsection heading (subsection prose). Each\n    region ends at the next structural boundary — phase/bugs heading\n    for the preamble, first task or subsection for phase prose, and\n    first task for subsection prose.\n    \"\"\"\n\n    def test_h1_sets_project_title(self) -> None:\n        plan = parse_plan(\"# My Project\\n## Stage 1: Core\\n\")\n        assert plan.project_title == \"My Project\"\n        assert plan.preamble == \"\"\n\n    def test_no_h1_means_empty_title(self) -> None:\n        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n        assert plan.project_title == \"\"\n        assert plan.preamble == \"\"\n\n    def test_h2_with_stage_keyword_does_not_match_h1(self) -> None:\n        # `## Stage 1: Core` is consumed by the phase regex before the\n        # H1 check runs, so it does not leak into the title slot.\n        plan = parse_plan(\"## Stage 1: Core\\n- [ ] x\\n\")\n        assert plan.project_title == \"\"\n        assert len(plan.phases) == 1\n\n    def test_preamble_between_h1_and_phase(self) -> None:\n        text = \"# Project\\n\\nIntro paragraph.\\n\\n## Stage 1: Core\\n- [ ] task\\n\"\n        plan = parse_plan(text)\n        assert plan.project_title == \"Project\"\n        assert plan.preamble == \"Intro paragraph.\"\n\n    def test_preamble_multi_paragraph_preserves_blank_lines(self) -> None:\n        text = (\n            \"# Project\\n\\nFirst paragraph.\\n\\nSecond paragraph.\\n\\n## Stage 1: Core\\n\"\n        )\n        plan = parse_plan(text)\n        assert plan.preamble == \"First paragraph.\\n\\nSecond paragraph.\"\n\n    def test_preamble_ends_at_bugs_heading(self) -> None:\n        # Per the grammar, the preamble is followed by ``PhaseOrBugs+`` —\n        # a bugs section is just as valid a terminator as a phase.\n        text = \"# Project\\nIntro.\\n## Bugs\\n- [ ] crash\\n\"\n        plan = parse_plan(text)\n        assert plan.preamble == \"Intro.\"\n        assert plan.bugs is not None\n        assert plan.bugs.tasks[0].text == \"crash\"\n\n    def test_phase_prose_between_heading_and_first_task(self) -> None:\n        text = \"## Stage 1: Core\\n\\nThe goal is X.\\n\\n- [ ] task\\n\"\n        plan = parse_plan(text)\n        assert plan.phases[0].prose == \"The goal is X.\"\n\n    def test_phase_prose_ends_at_subsection(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\\nPhase intro.\\n\\n### Manual verification\\n- [ ] check\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert phase.prose == \"Phase intro.\"\n        assert phase.subsections[0].prose == \"\"\n","numLines":100,"startLine":700,"totalLines":857}}}
