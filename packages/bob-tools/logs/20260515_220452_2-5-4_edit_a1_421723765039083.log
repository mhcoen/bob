{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F9LCha54x8Lf3N4EJXRLnE","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom collections.abc import Sequence\n7\tfrom dataclasses import dataclass, field\n8\tfrom pathlib import Path\n9\tfrom typing import Protocol, TypeVar\n10\t\n11\tfrom bob_tools.planfile.model import (\n12\t    BugsSection,\n13\t    Phase,\n14\t    Plan,\n15\t    RuledOut,\n16\t    Subsection,\n17\t    Task,\n18\t    TaskStatus,\n19\t)\n20\t\n21\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n22\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n23\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n24\t\n25\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n26\t# caller strips any inter-tag whitespace between iterations.\n27\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n28\t\n29\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n30\t# after the closing bracket (with the single separating space removed).\n31\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n32\t\n33\t# Content of an annotation (the bytes between `[` and `]`): an\n34\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n35\t# value. The required whitespace after the colon is what distinguishes\n36\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n37\t# after its colon).\n38\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n39\t\n40\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n41\t# token, and optional trailing text. Matches mcloop's `parse`, which\n42\t# treats a line as RULEDOUT when its stripped form starts with the\n43\t# literal bracket token.\n44\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n45\t\n46\t# Deps sibling line: optional indent, the literal `@deps` token, then\n47\t# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n48\t# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n49\t# group captures the remainder of the line; splitting on whitespace\n50\t# and validating each ID is a higher-level step.\n51\t_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n52\t\n53\t# Stage/Phase heading: any heading level whose title contains\n54\t# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n55\t# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n56\t# pattern to also pull out the keyword and the title text after the\n57\t# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n58\t# (no bare digits) — see design doc section 2.5.\n59\t_STAGE_RE = re.compile(\n60\t    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n61\t    re.IGNORECASE,\n62\t)\n63\t\n64\t# Bugs heading: any heading level whose title is exactly ``Bugs``.\n65\t# Mirrors mcloop's ``BUGS_RE``.\n66\t_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n67\t\n68\t# Subsection heading: ``###`` followed by free title text. Only level-3\n69\t# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n70\t# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n71\t# group following tasks until another subsection or phase ends them.\n72\t_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n73\t\n74\t# H1 project-title heading: exactly one ``#`` followed by free title\n75\t# text. Per design doc section 4.1 grammar ``Preamble ← H1 NL Prose?``.\n76\t# H2 (``##``) is consumed earlier by `_STAGE_RE` / `_BUGS_RE`; this\n77\t# regex requires a single leading ``#`` so multi-hash headings cannot\n78\t# match here. Recognized only before the first phase or bugs heading;\n79\t# subsequent H1 lines (malformed in strict mode, dropped in compat\n80\t# mode) fall through to the active prose accumulator.\n81\t_H1_RE = re.compile(r\"^#\\s+(.+?)\\s*$\")\n82\t\n83\t# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n84\t# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n85\t# Recognized only at the start of the task body, before any flag tags.\n86\t_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n87\t\n88\t\n89\tdef parse_plan(\n90\t    text: str,\n91\t    *,\n92\t    strict: bool = False,\n93\t    source_path: Path | None = None,\n94\t) -> Plan:\n95\t    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n96\t\n97\t    ``strict=False`` (the default) is compatibility mode — accepts the\n98\t    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n99\t    line, optional task IDs, no phase-id comments). ``strict=True``\n100\t    enables the format additions in design doc section 4 (magic line,\n101\t    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n102\t\n103\t    Stage 2.5.1 wired the signature; 2.5.2 walks ``text`` line by line,\n104\t    tracking the current phase (or bugs section), the current subsection\n105\t    within a phase, and a stack of open tasks by indent. 2.5.3 (this)\n106\t    extracts the project title from the first H1 and accumulates prose\n107\t    in three regions: the preamble (after the H1, before the first\n108\t    phase or bugs heading), phase prose (after a phase heading, before\n109\t    the first task or subsection), and subsection prose (after a ``###``\n110\t    heading, before the first task). Prose-region accumulators close\n111\t    when the relevant boundary line is consumed; lines outside any\n112\t    active accumulator (e.g. a task line before any phase, or prose\n113\t    after the first task in a phase) are dropped silently in compat\n114\t    mode. Each task line opens or closes scopes by indent comparison,\n115\t    matching mcloop's logic in ``checklist.py:parse``. ``@deps`` and\n116\t    ``[RULEDOUT]`` sibling lines are routed via :func:`_attach_deps`\n117\t    and :func:`_attach_ruledout` and accumulated on the parent task.\n118\t    Syntax-error reporting lands in 2.5.4; strict-mode behavior in\n119\t    Stage 3.\n120\t    \"\"\"\n121\t    del strict\n122\t    lines = text.splitlines()\n123\t\n124\t    phases_b: list[_PhaseBuilder] = []\n125\t    bugs_b: _BugsBuilder | None = None\n126\t    current_phase: _PhaseBuilder | None = None\n127\t    current_subsection: _SubsectionBuilder | None = None\n128\t    in_bugs = False\n129\t    stack: list[_TaskBuilder] = []\n130\t\n131\t    project_title = \"\"\n132\t    project_title_seen = False\n133\t    preamble_lines: list[str] = []\n134\t    preamble_active = False\n135\t    phase_prose_lines: list[str] | None = None\n136\t    subsection_prose_lines: list[str] | None = None\n137\t\n138\t    def _close_subsection_prose() -> None:\n139\t        nonlocal subsection_prose_lines\n140\t        if subsection_prose_lines is not None and current_subsection is not None:\n141\t            current_subsection.prose = _finalize_prose(subsection_prose_lines)\n142\t        subsection_prose_lines = None\n143\t\n144\t    def _close_phase_prose() -> None:\n145\t        nonlocal phase_prose_lines\n146\t        if phase_prose_lines is not None and current_phase is not None:\n147\t            current_phase.prose = _finalize_prose(phase_prose_lines)\n148\t        phase_prose_lines = None\n149\t\n150\t    for idx, line in enumerate(lines):\n151\t        line_number = idx + 1\n152\t\n153\t        heading = _parse_phase_heading(line)\n154\t        if heading is not None:\n155\t            _close_subsection_prose()\n156\t            _close_phase_prose()\n157\t            preamble_active = False\n158\t            ordinal, keyword, title = heading\n159\t            current_phase = _PhaseBuilder(\n160\t                ordinal=ordinal,\n161\t                keyword=keyword,\n162\t                title=title,\n163\t                line_number=line_number,\n164\t            )\n165\t            phases_b.append(current_phase)\n166\t            current_subsection = None\n167\t            in_bugs = False\n168\t            stack.clear()\n169\t            phase_prose_lines = []\n170\t            continue\n171\t\n172\t        if _BUGS_RE.match(line):\n173\t            _close_subsection_prose()\n174\t            _close_phase_prose()\n175\t            preamble_active = False\n176\t            bugs_b = _BugsBuilder(line_number=line_number)\n177\t            current_phase = None\n178\t            current_subsection = None\n179\t            in_bugs = True\n180\t            stack.clear()\n181\t            continue\n182\t\n183\t        if current_phase is None and not in_bugs:\n184\t            h1_m = _H1_RE.match(line)\n185\t            if h1_m is not None:\n186\t                if not project_title_seen:\n187\t                    project_title = h1_m.group(1).strip()\n188\t                    project_title_seen = True\n189\t                    preamble_active = True\n190\t                    continue\n191\t                # Subsequent H1 falls through to the preamble accumulator\n192\t                # so the raw text is preserved. Strict mode (Stage 3)\n193\t                # will raise on duplicate H1s.\n194\t\n195\t        if not in_bugs and current_phase is not None:\n196\t            sm = _SUBSECTION_RE.match(line)\n197\t            if sm is not None:\n198\t                _close_subsection_prose()\n199\t                _close_phase_prose()\n200\t                current_subsection = _SubsectionBuilder(\n201\t                    title=sm.group(1).strip(),\n202\t                    line_number=line_number,\n203\t                )\n204\t                current_phase.subsections.append(current_subsection)\n205\t                stack.clear()\n206\t                subsection_prose_lines = []\n207\t                continue\n208\t\n209\t        scope_tasks = _current_scope_tasks(\n210\t            in_bugs=in_bugs,\n211\t            bugs_b=bugs_b,\n212\t            current_subsection=current_subsection,\n213\t            current_phase=current_phase,\n214\t        )\n215\t\n216\t        ro = _parse_ruledout_line(line, line_number)\n217\t        if ro is not None:\n218\t            indent = len(ro.indent)\n219\t            roots = scope_tasks if scope_tasks is not None else []\n220\t            target = _attach_ruledout(indent, stack, roots)\n221\t            if target is not None:\n222\t                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n223\t            continue\n224\t\n225\t        dm = _DEPS_RE.match(line)\n226\t        if dm is not None:\n227\t            indent = len(dm.group(1))\n228\t            target, _lenient = _attach_deps(indent, stack)\n229\t            if target is not None:\n230\t                target.deps.extend(dm.group(2).split())\n231\t            continue\n232\t\n233\t        raw = _parse_task_line(line, line_number)\n234\t        if raw is None:\n235\t            if preamble_active:\n236\t                preamble_lines.append(line)\n237\t            elif subsection_prose_lines is not None:\n238\t                subsection_prose_lines.append(line)\n239\t            elif phase_prose_lines is not None:\n240\t                phase_prose_lines.append(line)\n241\t            # else: line outside any active prose region (e.g. before\n242\t            # the first H1 or after the first task in a section) —\n243\t            # dropped in compat mode.\n244\t            continue\n245\t\n246\t        _close_subsection_prose()\n247\t        _close_phase_prose()\n248\t\n249\t        builder = _build_task(raw)\n250\t        indent = builder.indent_level\n251\t\n252\t        while stack and stack[-1].indent_level >= indent:\n253\t            stack.pop()\n254\t\n255\t        if stack:\n256\t            stack[-1].children.append(builder)\n257\t        elif scope_tasks is not None:\n258\t            scope_tasks.append(builder)\n259\t        # else: task line before any phase/bugs — silently dropped in\n260\t        # compat mode; strict mode (2.5.4) will surface this as a\n261\t        # PlanSyntaxError.\n262\t\n263\t        stack.append(builder)\n264\t\n265\t    _close_subsection_prose()\n266\t    _close_phase_prose()\n267\t\n268\t    return Plan(\n269\t        magic_version=None,\n270\t        project_title=project_title,\n271\t        preamble=_finalize_prose(preamble_lines),\n272\t        phases=tuple(p.freeze() for p in phases_b),\n273\t        bugs=bugs_b.freeze() if bugs_b is not None else None,\n274\t        source_path=source_path,\n275\t    )\n276\t\n277\t\n278\tdef _finalize_prose(lines: list[str]) -> str:\n279\t    \"\"\"Join accumulated prose lines, trimming blank lines from the ends.\n280\t\n281\t    Internal blank lines (paragraph breaks) and any leading/trailing\n282\t    whitespace within a non-blank line are preserved — Markdown attaches\n283\t    semantic weight to indent (code blocks, list continuations), so we\n284\t    only strip wholly-blank wrapper lines rather than calling\n285\t    ``str.strip()`` on the joined text.\n286\t    \"\"\"\n287\t    start = 0\n288\t    while start < len(lines) and not lines[start].strip():\n289\t        start += 1\n290\t    end = len(lines)\n291\t    while end > start and not lines[end - 1].strip():\n292\t        end -= 1\n293\t    return \"\\n\".join(lines[start:end])\n294\t\n295\t\n296\tdef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n297\t    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n298\t\n299\t    Returns ``None`` for non-matching lines. The keyword is normalized\n300\t    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n301\t    keeps the keyword cosmetic, so the canonicalizer can choose to\n302\t    preserve original casing if it wants — the typed model only needs\n303\t    one stable form.\n304\t    \"\"\"\n305\t    m = _STAGE_RE.match(line)\n306\t    if m is None:\n307\t        return None\n308\t    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n309\t\n310\t\n311\tdef _extract_task_id(text: str) -> tuple[str | None, str]:\n312\t    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n313\t\n314\t    Per design doc section 4.2 grammar, the task ID is the first token\n315\t    in the body after the checkbox. Returns ``(None, text)`` when no\n316\t    leading task ID is present; task IDs are optional in compat mode\n317\t    and mandatory in strict mode (enforced separately in Stage 3).\n318\t    \"\"\"\n319\t    m = _TASK_ID_RE.match(text)\n320\t    if m is None:\n321\t        return None, text\n322\t    return m.group(1), text[m.end() :]\n323\t\n324\t\n325\tdef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n326\t    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n327\t\n328\t    Order matters: annotations come first (they live at end of line\n329\t    and would otherwise be swallowed by the action tag's args, which\n330\t    span to end of line). Task ID, then flag tags, then action tag run\n331\t    left-to-right. The remaining text is the task description.\n332\t    \"\"\"\n333\t    annotations, remaining = _extract_annotations(raw.text)\n334\t    task_id, remaining = _extract_task_id(remaining)\n335\t    flag_tags, remaining = _extract_flag_tags(remaining)\n336\t    action_tag, remaining = _extract_action_tag(remaining)\n337\t    return _TaskBuilder(\n338\t        task_id=task_id,\n339\t        text=remaining.strip(),\n340\t        status=TaskStatus.from_marker(raw.status_char),\n341\t        flag_tags=flag_tags,\n342\t        action_tag=action_tag,\n343\t        annotations=annotations,\n344\t        indent_level=len(raw.indent),\n345\t        line_number=raw.line_number,\n346\t    )\n347\t\n348\t\n349\tdef _current_scope_tasks(\n350\t    *,\n351\t    in_bugs: bool,\n352\t    bugs_b: _BugsBuilder | None,\n353\t    current_subsection: _SubsectionBuilder | None,\n354\t    current_phase: _PhaseBuilder | None,\n355\t) -> list[_TaskBuilder] | None:\n356\t    \"\"\"Pick the root-task list for the active section.\n357\t\n358\t    The order encodes the grammar: a Bugs section excludes phase scope;\n359\t    inside a phase, a current subsection captures following tasks until\n360\t    the next subsection or phase. Returns ``None`` when no section is\n361\t    active — i.e. the input has not yet introduced a phase or bugs\n362\t    heading, so any task/sibling line is an orphan.\n363\t    \"\"\"\n364\t    if in_bugs:\n365\t        return bugs_b.tasks if bugs_b is not None else None\n366\t    if current_subsection is not None:\n367\t        return current_subsection.tasks\n368\t    if current_phase is not None:\n369\t        return current_phase.tasks\n370\t    return None\n371\t\n372\t\n373\t@dataclass(frozen=True)\n374\tclass _RawTaskLine:\n375\t    \"\"\"Recognize-step output of `_parse_task_line`.\n376\t\n377\t    Stage 2 of the parser splits recognize-then-classify. This record\n378\t    is the recognize step: indent text, status marker, body text, and\n379\t    source line number. Higher-level functions classify the body into\n380\t    task id, tags, deps, and prose.\n381\t    \"\"\"\n382\t\n383\t    indent: str\n384\t    status_char: str\n385\t    text: str\n386\t    line_number: int\n387\t\n388\t\n389\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n390\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n391\t    m = _CHECKBOX_RE.match(line)\n392\t    if m is None:\n393\t        return None\n394\t    return _RawTaskLine(\n395\t        indent=m.group(1),\n396\t        status_char=m.group(2),\n397\t        text=m.group(3),\n398\t        line_number=line_number,\n399\t    )\n400\t\n401\t\n402\t@dataclass(frozen=True)\n403\tclass _RawRuledOut:\n404\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n405\t\n406\t    A RULEDOUT line is a sibling of the task it pertains to (design\n407\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n408\t    captures only indent, body text, and source line number; attaching\n409\t    the line to its parent task by indentation is a higher-level step.\n410\t    \"\"\"\n411\t\n412\t    indent: str\n413\t    text: str\n414\t    line_number: int\n415\t\n416\t\n417\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n418\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n419\t\n420\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n421\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n422\t    whitespace on the body text is stripped; an empty body is allowed.\n423\t    \"\"\"\n424\t    m = _RULEDOUT_RE.match(line)\n425\t    if m is None:\n426\t        return None\n427\t    return _RawRuledOut(\n428\t        indent=m.group(1),\n429\t        text=m.group(2).strip(),\n430\t        line_number=line_number,\n431\t    )\n432\t\n433\t\n434\tclass _HasIndentLevel(Protocol):\n435\t    \"\"\"Anything with an integer ``indent_level`` attribute.\n436\t\n437\t    Used by :func:`_attach_ruledout` so it can resolve attachment over\n438\t    either the eventual frozen ``Task`` model objects or the mutable\n439\t    builder records the parser uses while constructing them.\n440\t    \"\"\"\n441\t\n442\t    @property\n443\t    def indent_level(self) -> int: ...\n444\t\n445\t\n446\t_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n447\t\n448\t\n449\tdef _attach_ruledout(\n450\t    indent: int,\n451\t    stack: Sequence[_T],\n452\t    root_tasks: Sequence[_T],\n453\t) -> _T | None:\n454\t    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n455\t\n456\t    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n457\t    the open-ancestor stack from innermost to outermost and return the\n458\t    first task whose indent is strictly less than the RULEDOUT line's\n459\t    indent. If no such ancestor exists in the current phase, fall back\n460\t    to the most recent root task (mcloop's \"orphan\" handling). Returns\n461\t    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n462\t    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n463\t    the caller should drop.\n464\t    \"\"\"\n465\t    for task in reversed(stack):\n466\t        if task.indent_level < indent:\n467\t            return task\n468\t    if root_tasks:\n469\t        return root_tasks[-1]\n470\t    return None\n471\t\n472\t\n473\tdef _attach_deps(\n474\t    indent: int,\n475\t    stack: Sequence[_T],\n476\t) -> tuple[_T | None, bool]:\n477\t    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n478\t\n479\t    Walks the open-ancestor stack from innermost (top) to outermost.\n480\t    Returns ``(parent, False)`` for the strict form — first ancestor\n481\t    whose indent is strictly less than the deps line's indent. Returns\n482\t    ``(parent, True)`` for the lenient form — first ancestor at the\n483\t    same indent as the deps line, which callers should report as a\n484\t    validation warning (the deps was not indented under its task).\n485\t    Returns ``(None, False)`` when no candidate exists; the caller\n486\t    should drop the line.\n487\t\n488\t    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n489\t    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n490\t    indent is malformed input rather than an orphan that needs adopting.\n491\t    \"\"\"\n492\t    for task in reversed(stack):\n493\t        if task.indent_level < indent:\n494\t            return task, False\n495\t        if task.indent_level == indent:\n496\t            return task, True\n497\t    return None, False\n498\t\n499\t\n500\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n501\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n502\t\n503\t    Per design doc section 4.3, flag tags are recognized only at the\n504\t    leading position. The caller is responsible for stripping the task\n505\t    ID (if any) first. A bracketed flag form appearing later in the\n506\t    text is prose and is left in place.\n507\t    \"\"\"\n508\t    tags: list[str] = []\n509\t    remaining = text\n510\t    while True:\n511\t        m = _FLAG_TAG_RE.match(remaining)\n512\t        if m is None:\n513\t            break\n514\t        tags.append(m.group(1))\n515\t        remaining = remaining[m.end() :].lstrip()\n516\t    return tuple(tags), remaining\n517\t\n518\t\n519\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n520\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n521\t\n522\t    Per design doc section 4.3, the action tag is recognized only at\n523\t    the leading position, after any flag tags. The argument string is\n524\t    the text from the closing bracket to end of line, with the single\n525\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n526\t    are prose and are left in place.\n527\t\n528\t    Returns ``(None, text)`` when no leading action tag is present;\n529\t    otherwise consumes the rest of the line as the argument string\n530\t    and returns ``((action, args), \"\")``.\n531\t    \"\"\"\n532\t    m = _ACTION_TAG_RE.match(text)\n533\t    if m is None:\n534\t        return None, text\n535\t    action = m.group(1)\n536\t    args = text[m.end() :].lstrip()\n537\t    return (action, args), \"\"\n538\t\n539\t\n540\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n541\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n542\t\n543\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n544\t    are bracketed, and are separated from the preceding text by\n545\t    whitespace. Multiple annotations are allowed. Values may contain\n546\t    balanced bracket pairs; this function scans right-to-left with\n547\t    bracket-depth tracking so nested brackets stay inside a single\n548\t    annotation rather than being misparsed as a separate one.\n549\t\n550\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n551\t    accepts any identifier-shaped key. Validation of allowed keys is\n552\t    a separate concern.\n553\t    \"\"\"\n554\t    annotations: list[tuple[str, str]] = []\n555\t    remaining = text\n556\t    while True:\n557\t        rstripped = remaining.rstrip()\n558\t        if not rstripped.endswith(\"]\"):\n559\t            remaining = rstripped\n560\t            break\n561\t        start = _find_matching_open_bracket(rstripped)\n562\t        if start is None:\n563\t            remaining = rstripped\n564\t            break\n565\t        # An annotation must be separated from preceding text by\n566\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n567\t        # character is part of the task text, not an annotation.\n568\t        if start > 0 and not rstripped[start - 1].isspace():\n569\t            remaining = rstripped\n570\t            break\n571\t        content = rstripped[start + 1 : -1]\n572\t        m = _ANNOTATION_CONTENT_RE.match(content)\n573\t        if m is None:\n574\t            remaining = rstripped\n575\t            break\n576\t        annotations.insert(0, (m.group(1), m.group(2)))\n577\t        remaining = rstripped[:start].rstrip()\n578\t    return tuple(annotations), remaining\n579\t\n580\t\n581\tdef _find_matching_open_bracket(s: str) -> int | None:\n582\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n583\t\n584\t    Walks right-to-left tracking bracket depth so balanced nested\n585\t    brackets inside the candidate annotation are stepped over.\n586\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n587\t    opener.\n588\t    \"\"\"\n589\t    if not s.endswith(\"]\"):\n590\t        return None\n591\t    depth = 0\n592\t    for i in range(len(s) - 1, -1, -1):\n593\t        c = s[i]\n594\t        if c == \"]\":\n595\t            depth += 1\n596\t        elif c == \"[\":\n597\t            depth -= 1\n598\t            if depth == 0:\n599\t                return i\n600\t    return None\n601\t\n602\t\n603\t# Mutable builder records used while walking the input. The public\n604\t# model dataclasses are frozen, so the parser builds with these and\n605\t# calls ``freeze`` to produce the immutable tree at the end. Each\n606\t# builder also satisfies the ``_HasIndentLevel`` protocol so the\n607\t# existing ``_attach_*`` helpers operate on them directly.\n608\t\n609\t\n610\t@dataclass\n611\tclass _TaskBuilder:\n612\t    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n613\t\n614\t    task_id: str | None\n615\t    text: str\n616\t    status: TaskStatus\n617\t    flag_tags: tuple[str, ...]\n618\t    action_tag: tuple[str, str] | None\n619\t    annotations: tuple[tuple[str, str], ...]\n620\t    indent_level: int\n621\t    line_number: int\n622\t    deps: list[str] = field(default_factory=list)\n623\t    children: list[_TaskBuilder] = field(default_factory=list)\n624\t    ruled_out: list[RuledOut] = field(default_factory=list)\n625\t\n626\t    def freeze(self) -> Task:\n627\t        return Task(\n628\t            task_id=self.task_id,\n629\t            text=self.text,\n630\t            status=self.status,\n631\t            flag_tags=self.flag_tags,\n632\t            action_tag=self.action_tag,\n633\t            annotations=self.annotations,\n634\t            deps=tuple(self.deps),\n635\t            children=tuple(c.freeze() for c in self.children),\n636\t            ruled_out=tuple(self.ruled_out),\n637\t            indent_level=self.indent_level,\n638\t            line_number=self.line_number,\n639\t        )\n640\t\n641\t\n642\t@dataclass\n643\tclass _SubsectionBuilder:\n644\t    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n645\t\n646\t    title: str\n647\t    line_number: int\n648\t    prose: str = \"\"\n649\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n650\t\n651\t    def freeze(self) -> Subsection:\n652\t        return Subsection(\n653\t            title=self.title,\n654\t            prose=self.prose,\n655\t            tasks=tuple(t.freeze() for t in self.tasks),\n656\t            line_number=self.line_number,\n657\t        )\n658\t\n659\t\n660\t@dataclass\n661\tclass _PhaseBuilder:\n662\t    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n663\t\n664\t    ordinal: int\n665\t    keyword: str\n666\t    title: str\n667\t    line_number: int\n668\t    phase_id: str | None = None\n669\t    phase_id_source: str = \"none\"\n670\t    prose: str = \"\"\n671\t    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n672\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n673\t\n674\t    def freeze(self) -> Phase:\n675\t        return Phase(\n676\t            phase_id=self.phase_id,\n677\t            phase_id_source=self.phase_id_source,\n678\t            ordinal=self.ordinal,\n679\t            keyword=self.keyword,\n680\t            title=self.title,\n681\t            prose=self.prose,\n682\t            subsections=tuple(s.freeze() for s in self.subsections),\n683\t            tasks=tuple(t.freeze() for t in self.tasks),\n684\t            line_number=self.line_number,\n685\t        )\n686\t\n687\t\n688\t@dataclass\n689\tclass _BugsBuilder:\n690\t    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n691\t\n692\t    line_number: int\n693\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n694\t\n695\t    def freeze(self) -> BugsSection:\n696\t        return BugsSection(\n697\t            tasks=tuple(t.freeze() for t in self.tasks),\n698\t            line_number=self.line_number,\n699\t        )\n700\t"}]},"parent_tool_use_id":null,"session_id":"9a449ac0-394d-4684-a780-cf9347c419c5","uuid":"7deaf63a-c767-47c6-84f7-c934732058e4","timestamp":"2026-05-16T02:55:10.702Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections.abc import Sequence\nfrom dataclasses import dataclass, field\nfrom pathlib import Path\nfrom typing import Protocol, TypeVar\n\nfrom bob_tools.planfile.model import (\n    BugsSection,\n    Phase,\n    Plan,\n    RuledOut,\n    Subsection,\n    Task,\n    TaskStatus,\n)\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n# Deps sibling line: optional indent, the literal `@deps` token, then\n# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n# group captures the remainder of the line; splitting on whitespace\n# and validating each ID is a higher-level step.\n_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n\n# Stage/Phase heading: any heading level whose title contains\n# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n# pattern to also pull out the keyword and the title text after the\n# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n# (no bare digits) — see design doc section 2.5.\n_STAGE_RE = re.compile(\n    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n    re.IGNORECASE,\n)\n\n# Bugs heading: any heading level whose title is exactly ``Bugs``.\n# Mirrors mcloop's ``BUGS_RE``.\n_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n\n# Subsection heading: ``###`` followed by free title text. Only level-3\n# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n# group following tasks until another subsection or phase ends them.\n_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n\n# H1 project-title heading: exactly one ``#`` followed by free title\n# text. Per design doc section 4.1 grammar ``Preamble ← H1 NL Prose?``.\n# H2 (``##``) is consumed earlier by `_STAGE_RE` / `_BUGS_RE`; this\n# regex requires a single leading ``#`` so multi-hash headings cannot\n# match here. Recognized only before the first phase or bugs heading;\n# subsequent H1 lines (malformed in strict mode, dropped in compat\n# mode) fall through to the active prose accumulator.\n_H1_RE = re.compile(r\"^#\\s+(.+?)\\s*$\")\n\n# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n# Recognized only at the start of the task body, before any flag tags.\n_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n\n\ndef parse_plan(\n    text: str,\n    *,\n    strict: bool = False,\n    source_path: Path | None = None,\n) -> Plan:\n    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n\n    ``strict=False`` (the default) is compatibility mode — accepts the\n    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n    line, optional task IDs, no phase-id comments). ``strict=True``\n    enables the format additions in design doc section 4 (magic line,\n    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n\n    Stage 2.5.1 wired the signature; 2.5.2 walks ``text`` line by line,\n    tracking the current phase (or bugs section), the current subsection\n    within a phase, and a stack of open tasks by indent. 2.5.3 (this)\n    extracts the project title from the first H1 and accumulates prose\n    in three regions: the preamble (after the H1, before the first\n    phase or bugs heading), phase prose (after a phase heading, before\n    the first task or subsection), and subsection prose (after a ``###``\n    heading, before the first task). Prose-region accumulators close\n    when the relevant boundary line is consumed; lines outside any\n    active accumulator (e.g. a task line before any phase, or prose\n    after the first task in a phase) are dropped silently in compat\n    mode. Each task line opens or closes scopes by indent comparison,\n    matching mcloop's logic in ``checklist.py:parse``. ``@deps`` and\n    ``[RULEDOUT]`` sibling lines are routed via :func:`_attach_deps`\n    and :func:`_attach_ruledout` and accumulated on the parent task.\n    Syntax-error reporting lands in 2.5.4; strict-mode behavior in\n    Stage 3.\n    \"\"\"\n    del strict\n    lines = text.splitlines()\n\n    phases_b: list[_PhaseBuilder] = []\n    bugs_b: _BugsBuilder | None = None\n    current_phase: _PhaseBuilder | None = None\n    current_subsection: _SubsectionBuilder | None = None\n    in_bugs = False\n    stack: list[_TaskBuilder] = []\n\n    project_title = \"\"\n    project_title_seen = False\n    preamble_lines: list[str] = []\n    preamble_active = False\n    phase_prose_lines: list[str] | None = None\n    subsection_prose_lines: list[str] | None = None\n\n    def _close_subsection_prose() -> None:\n        nonlocal subsection_prose_lines\n        if subsection_prose_lines is not None and current_subsection is not None:\n            current_subsection.prose = _finalize_prose(subsection_prose_lines)\n        subsection_prose_lines = None\n\n    def _close_phase_prose() -> None:\n        nonlocal phase_prose_lines\n        if phase_prose_lines is not None and current_phase is not None:\n            current_phase.prose = _finalize_prose(phase_prose_lines)\n        phase_prose_lines = None\n\n    for idx, line in enumerate(lines):\n        line_number = idx + 1\n\n        heading = _parse_phase_heading(line)\n        if heading is not None:\n            _close_subsection_prose()\n            _close_phase_prose()\n            preamble_active = False\n            ordinal, keyword, title = heading\n            current_phase = _PhaseBuilder(\n                ordinal=ordinal,\n                keyword=keyword,\n                title=title,\n                line_number=line_number,\n            )\n            phases_b.append(current_phase)\n            current_subsection = None\n            in_bugs = False\n            stack.clear()\n            phase_prose_lines = []\n            continue\n\n        if _BUGS_RE.match(line):\n            _close_subsection_prose()\n            _close_phase_prose()\n            preamble_active = False\n            bugs_b = _BugsBuilder(line_number=line_number)\n            current_phase = None\n            current_subsection = None\n            in_bugs = True\n            stack.clear()\n            continue\n\n        if current_phase is None and not in_bugs:\n            h1_m = _H1_RE.match(line)\n            if h1_m is not None:\n                if not project_title_seen:\n                    project_title = h1_m.group(1).strip()\n                    project_title_seen = True\n                    preamble_active = True\n                    continue\n                # Subsequent H1 falls through to the preamble accumulator\n                # so the raw text is preserved. Strict mode (Stage 3)\n                # will raise on duplicate H1s.\n\n        if not in_bugs and current_phase is not None:\n            sm = _SUBSECTION_RE.match(line)\n            if sm is not None:\n                _close_subsection_prose()\n                _close_phase_prose()\n                current_subsection = _SubsectionBuilder(\n                    title=sm.group(1).strip(),\n                    line_number=line_number,\n                )\n                current_phase.subsections.append(current_subsection)\n                stack.clear()\n                subsection_prose_lines = []\n                continue\n\n        scope_tasks = _current_scope_tasks(\n            in_bugs=in_bugs,\n            bugs_b=bugs_b,\n            current_subsection=current_subsection,\n            current_phase=current_phase,\n        )\n\n        ro = _parse_ruledout_line(line, line_number)\n        if ro is not None:\n            indent = len(ro.indent)\n            roots = scope_tasks if scope_tasks is not None else []\n            target = _attach_ruledout(indent, stack, roots)\n            if target is not None:\n                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n            continue\n\n        dm = _DEPS_RE.match(line)\n        if dm is not None:\n            indent = len(dm.group(1))\n            target, _lenient = _attach_deps(indent, stack)\n            if target is not None:\n                target.deps.extend(dm.group(2).split())\n            continue\n\n        raw = _parse_task_line(line, line_number)\n        if raw is None:\n            if preamble_active:\n                preamble_lines.append(line)\n            elif subsection_prose_lines is not None:\n                subsection_prose_lines.append(line)\n            elif phase_prose_lines is not None:\n                phase_prose_lines.append(line)\n            # else: line outside any active prose region (e.g. before\n            # the first H1 or after the first task in a section) —\n            # dropped in compat mode.\n            continue\n\n        _close_subsection_prose()\n        _close_phase_prose()\n\n        builder = _build_task(raw)\n        indent = builder.indent_level\n\n        while stack and stack[-1].indent_level >= indent:\n            stack.pop()\n\n        if stack:\n            stack[-1].children.append(builder)\n        elif scope_tasks is not None:\n            scope_tasks.append(builder)\n        # else: task line before any phase/bugs — silently dropped in\n        # compat mode; strict mode (2.5.4) will surface this as a\n        # PlanSyntaxError.\n\n        stack.append(builder)\n\n    _close_subsection_prose()\n    _close_phase_prose()\n\n    return Plan(\n        magic_version=None,\n        project_title=project_title,\n        preamble=_finalize_prose(preamble_lines),\n        phases=tuple(p.freeze() for p in phases_b),\n        bugs=bugs_b.freeze() if bugs_b is not None else None,\n        source_path=source_path,\n    )\n\n\ndef _finalize_prose(lines: list[str]) -> str:\n    \"\"\"Join accumulated prose lines, trimming blank lines from the ends.\n\n    Internal blank lines (paragraph breaks) and any leading/trailing\n    whitespace within a non-blank line are preserved — Markdown attaches\n    semantic weight to indent (code blocks, list continuations), so we\n    only strip wholly-blank wrapper lines rather than calling\n    ``str.strip()`` on the joined text.\n    \"\"\"\n    start = 0\n    while start < len(lines) and not lines[start].strip():\n        start += 1\n    end = len(lines)\n    while end > start and not lines[end - 1].strip():\n        end -= 1\n    return \"\\n\".join(lines[start:end])\n\n\ndef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n\n    Returns ``None`` for non-matching lines. The keyword is normalized\n    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n    keeps the keyword cosmetic, so the canonicalizer can choose to\n    preserve original casing if it wants — the typed model only needs\n    one stable form.\n    \"\"\"\n    m = _STAGE_RE.match(line)\n    if m is None:\n        return None\n    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n\n\ndef _extract_task_id(text: str) -> tuple[str | None, str]:\n    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n\n    Per design doc section 4.2 grammar, the task ID is the first token\n    in the body after the checkbox. Returns ``(None, text)`` when no\n    leading task ID is present; task IDs are optional in compat mode\n    and mandatory in strict mode (enforced separately in Stage 3).\n    \"\"\"\n    m = _TASK_ID_RE.match(text)\n    if m is None:\n        return None, text\n    return m.group(1), text[m.end() :]\n\n\ndef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n\n    Order matters: annotations come first (they live at end of line\n    and would otherwise be swallowed by the action tag's args, which\n    span to end of line). Task ID, then flag tags, then action tag run\n    left-to-right. The remaining text is the task description.\n    \"\"\"\n    annotations, remaining = _extract_annotations(raw.text)\n    task_id, remaining = _extract_task_id(remaining)\n    flag_tags, remaining = _extract_flag_tags(remaining)\n    action_tag, remaining = _extract_action_tag(remaining)\n    return _TaskBuilder(\n        task_id=task_id,\n        text=remaining.strip(),\n        status=TaskStatus.from_marker(raw.status_char),\n        flag_tags=flag_tags,\n        action_tag=action_tag,\n        annotations=annotations,\n        indent_level=len(raw.indent),\n        line_number=raw.line_number,\n    )\n\n\ndef _current_scope_tasks(\n    *,\n    in_bugs: bool,\n    bugs_b: _BugsBuilder | None,\n    current_subsection: _SubsectionBuilder | None,\n    current_phase: _PhaseBuilder | None,\n) -> list[_TaskBuilder] | None:\n    \"\"\"Pick the root-task list for the active section.\n\n    The order encodes the grammar: a Bugs section excludes phase scope;\n    inside a phase, a current subsection captures following tasks until\n    the next subsection or phase. Returns ``None`` when no section is\n    active — i.e. the input has not yet introduced a phase or bugs\n    heading, so any task/sibling line is an orphan.\n    \"\"\"\n    if in_bugs:\n        return bugs_b.tasks if bugs_b is not None else None\n    if current_subsection is not None:\n        return current_subsection.tasks\n    if current_phase is not None:\n        return current_phase.tasks\n    return None\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\nclass _HasIndentLevel(Protocol):\n    \"\"\"Anything with an integer ``indent_level`` attribute.\n\n    Used by :func:`_attach_ruledout` so it can resolve attachment over\n    either the eventual frozen ``Task`` model objects or the mutable\n    builder records the parser uses while constructing them.\n    \"\"\"\n\n    @property\n    def indent_level(self) -> int: ...\n\n\n_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n\n\ndef _attach_ruledout(\n    indent: int,\n    stack: Sequence[_T],\n    root_tasks: Sequence[_T],\n) -> _T | None:\n    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n\n    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n    the open-ancestor stack from innermost to outermost and return the\n    first task whose indent is strictly less than the RULEDOUT line's\n    indent. If no such ancestor exists in the current phase, fall back\n    to the most recent root task (mcloop's \"orphan\" handling). Returns\n    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n    the caller should drop.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task\n    if root_tasks:\n        return root_tasks[-1]\n    return None\n\n\ndef _attach_deps(\n    indent: int,\n    stack: Sequence[_T],\n) -> tuple[_T | None, bool]:\n    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n\n    Walks the open-ancestor stack from innermost (top) to outermost.\n    Returns ``(parent, False)`` for the strict form — first ancestor\n    whose indent is strictly less than the deps line's indent. Returns\n    ``(parent, True)`` for the lenient form — first ancestor at the\n    same indent as the deps line, which callers should report as a\n    validation warning (the deps was not indented under its task).\n    Returns ``(None, False)`` when no candidate exists; the caller\n    should drop the line.\n\n    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n    indent is malformed input rather than an orphan that needs adopting.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task, False\n        if task.indent_level == indent:\n            return task, True\n    return None, False\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n\n\n# Mutable builder records used while walking the input. The public\n# model dataclasses are frozen, so the parser builds with these and\n# calls ``freeze`` to produce the immutable tree at the end. Each\n# builder also satisfies the ``_HasIndentLevel`` protocol so the\n# existing ``_attach_*`` helpers operate on them directly.\n\n\n@dataclass\nclass _TaskBuilder:\n    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n\n    task_id: str | None\n    text: str\n    status: TaskStatus\n    flag_tags: tuple[str, ...]\n    action_tag: tuple[str, str] | None\n    annotations: tuple[tuple[str, str], ...]\n    indent_level: int\n    line_number: int\n    deps: list[str] = field(default_factory=list)\n    children: list[_TaskBuilder] = field(default_factory=list)\n    ruled_out: list[RuledOut] = field(default_factory=list)\n\n    def freeze(self) -> Task:\n        return Task(\n            task_id=self.task_id,\n            text=self.text,\n            status=self.status,\n            flag_tags=self.flag_tags,\n            action_tag=self.action_tag,\n            annotations=self.annotations,\n            deps=tuple(self.deps),\n            children=tuple(c.freeze() for c in self.children),\n            ruled_out=tuple(self.ruled_out),\n            indent_level=self.indent_level,\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _SubsectionBuilder:\n    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n\n    title: str\n    line_number: int\n    prose: str = \"\"\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Subsection:\n        return Subsection(\n            title=self.title,\n            prose=self.prose,\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _PhaseBuilder:\n    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n\n    ordinal: int\n    keyword: str\n    title: str\n    line_number: int\n    phase_id: str | None = None\n    phase_id_source: str = \"none\"\n    prose: str = \"\"\n    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Phase:\n        return Phase(\n            phase_id=self.phase_id,\n            phase_id_source=self.phase_id_source,\n            ordinal=self.ordinal,\n            keyword=self.keyword,\n            title=self.title,\n            prose=self.prose,\n            subsections=tuple(s.freeze() for s in self.subsections),\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _BugsBuilder:\n    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n\n    line_number: int\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> BugsSection:\n        return BugsSection(\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n","numLines":700,"startLine":1,"totalLines":700}}}
