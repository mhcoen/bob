{"type":"stream_event","event":{"type":"message_delta","delta":{"stop_reason":"tool_use","stop_sequence":null,"stop_details":null},"usage":{"input_tokens":1,"cache_creation_input_tokens":890,"cache_read_input_tokens":98536,"output_tokens":472,"iterations":[{"input_tokens":1,"output_tokens":472,"cache_read_input_tokens":98536,"cache_creation_input_tokens":890,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":890},"type":"message"}]},"context_management":{"applied_edits":[]}},"session_id":"9a449ac0-394d-4684-a780-cf9347c419c5","parent_tool_use_id":null,"uuid":"a375db35-34ae-4f49-979c-9a56dd8bc5d2"}
