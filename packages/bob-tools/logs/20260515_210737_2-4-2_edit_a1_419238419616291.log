{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019UMBbhM1uGmm8PssLEkH3b","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom collections.abc import Sequence\n7\tfrom dataclasses import dataclass\n8\tfrom typing import Protocol, TypeVar\n9\t\n10\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n11\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n12\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n13\t\n14\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n15\t# caller strips any inter-tag whitespace between iterations.\n16\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n17\t\n18\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n19\t# after the closing bracket (with the single separating space removed).\n20\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n21\t\n22\t# Content of an annotation (the bytes between `[` and `]`): an\n23\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n24\t# value. The required whitespace after the colon is what distinguishes\n25\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n26\t# after its colon).\n27\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n28\t\n29\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n30\t# token, and optional trailing text. Matches mcloop's `parse`, which\n31\t# treats a line as RULEDOUT when its stripped form starts with the\n32\t# literal bracket token.\n33\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n34\t\n35\t# Deps sibling line: optional indent, the literal `@deps` token, then\n36\t# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n37\t# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n38\t# group captures the remainder of the line; splitting on whitespace\n39\t# and validating each ID is a higher-level step.\n40\t_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n41\t\n42\t\n43\t@dataclass(frozen=True)\n44\tclass _RawTaskLine:\n45\t    \"\"\"Recognize-step output of `_parse_task_line`.\n46\t\n47\t    Stage 2 of the parser splits recognize-then-classify. This record\n48\t    is the recognize step: indent text, status marker, body text, and\n49\t    source line number. Higher-level functions classify the body into\n50\t    task id, tags, deps, and prose.\n51\t    \"\"\"\n52\t\n53\t    indent: str\n54\t    status_char: str\n55\t    text: str\n56\t    line_number: int\n57\t\n58\t\n59\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n60\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n61\t    m = _CHECKBOX_RE.match(line)\n62\t    if m is None:\n63\t        return None\n64\t    return _RawTaskLine(\n65\t        indent=m.group(1),\n66\t        status_char=m.group(2),\n67\t        text=m.group(3),\n68\t        line_number=line_number,\n69\t    )\n70\t\n71\t\n72\t@dataclass(frozen=True)\n73\tclass _RawRuledOut:\n74\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n75\t\n76\t    A RULEDOUT line is a sibling of the task it pertains to (design\n77\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n78\t    captures only indent, body text, and source line number; attaching\n79\t    the line to its parent task by indentation is a higher-level step.\n80\t    \"\"\"\n81\t\n82\t    indent: str\n83\t    text: str\n84\t    line_number: int\n85\t\n86\t\n87\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n88\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n89\t\n90\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n91\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n92\t    whitespace on the body text is stripped; an empty body is allowed.\n93\t    \"\"\"\n94\t    m = _RULEDOUT_RE.match(line)\n95\t    if m is None:\n96\t        return None\n97\t    return _RawRuledOut(\n98\t        indent=m.group(1),\n99\t        text=m.group(2).strip(),\n100\t        line_number=line_number,\n101\t    )\n102\t\n103\t\n104\tclass _HasIndentLevel(Protocol):\n105\t    \"\"\"Anything with an integer ``indent_level`` attribute.\n106\t\n107\t    Used by :func:`_attach_ruledout` so it can resolve attachment over\n108\t    either the eventual frozen ``Task`` model objects or the mutable\n109\t    builder records the parser uses while constructing them.\n110\t    \"\"\"\n111\t\n112\t    @property\n113\t    def indent_level(self) -> int: ...\n114\t\n115\t\n116\t_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n117\t\n118\t\n119\tdef _attach_ruledout(\n120\t    indent: int,\n121\t    stack: Sequence[_T],\n122\t    root_tasks: Sequence[_T],\n123\t) -> _T | None:\n124\t    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n125\t\n126\t    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n127\t    the open-ancestor stack from innermost to outermost and return the\n128\t    first task whose indent is strictly less than the RULEDOUT line's\n129\t    indent. If no such ancestor exists in the current phase, fall back\n130\t    to the most recent root task (mcloop's \"orphan\" handling). Returns\n131\t    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n132\t    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n133\t    the caller should drop.\n134\t    \"\"\"\n135\t    for task in reversed(stack):\n136\t        if task.indent_level < indent:\n137\t            return task\n138\t    if root_tasks:\n139\t        return root_tasks[-1]\n140\t    return None\n141\t\n142\t\n143\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n144\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n145\t\n146\t    Per design doc section 4.3, flag tags are recognized only at the\n147\t    leading position. The caller is responsible for stripping the task\n148\t    ID (if any) first. A bracketed flag form appearing later in the\n149\t    text is prose and is left in place.\n150\t    \"\"\"\n151\t    tags: list[str] = []\n152\t    remaining = text\n153\t    while True:\n154\t        m = _FLAG_TAG_RE.match(remaining)\n155\t        if m is None:\n156\t            break\n157\t        tags.append(m.group(1))\n158\t        remaining = remaining[m.end() :].lstrip()\n159\t    return tuple(tags), remaining\n160\t\n161\t\n162\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n163\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n164\t\n165\t    Per design doc section 4.3, the action tag is recognized only at\n166\t    the leading position, after any flag tags. The argument string is\n167\t    the text from the closing bracket to end of line, with the single\n168\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n169\t    are prose and are left in place.\n170\t\n171\t    Returns ``(None, text)`` when no leading action tag is present;\n172\t    otherwise consumes the rest of the line as the argument string\n173\t    and returns ``((action, args), \"\")``.\n174\t    \"\"\"\n175\t    m = _ACTION_TAG_RE.match(text)\n176\t    if m is None:\n177\t        return None, text\n178\t    action = m.group(1)\n179\t    args = text[m.end() :].lstrip()\n180\t    return (action, args), \"\"\n181\t\n182\t\n183\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n184\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n185\t\n186\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n187\t    are bracketed, and are separated from the preceding text by\n188\t    whitespace. Multiple annotations are allowed. Values may contain\n189\t    balanced bracket pairs; this function scans right-to-left with\n190\t    bracket-depth tracking so nested brackets stay inside a single\n191\t    annotation rather than being misparsed as a separate one.\n192\t\n193\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n194\t    accepts any identifier-shaped key. Validation of allowed keys is\n195\t    a separate concern.\n196\t    \"\"\"\n197\t    annotations: list[tuple[str, str]] = []\n198\t    remaining = text\n199\t    while True:\n200\t        rstripped = remaining.rstrip()\n201\t        if not rstripped.endswith(\"]\"):\n202\t            remaining = rstripped\n203\t            break\n204\t        start = _find_matching_open_bracket(rstripped)\n205\t        if start is None:\n206\t            remaining = rstripped\n207\t            break\n208\t        # An annotation must be separated from preceding text by\n209\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n210\t        # character is part of the task text, not an annotation.\n211\t        if start > 0 and not rstripped[start - 1].isspace():\n212\t            remaining = rstripped\n213\t            break\n214\t        content = rstripped[start + 1 : -1]\n215\t        m = _ANNOTATION_CONTENT_RE.match(content)\n216\t        if m is None:\n217\t            remaining = rstripped\n218\t            break\n219\t        annotations.insert(0, (m.group(1), m.group(2)))\n220\t        remaining = rstripped[:start].rstrip()\n221\t    return tuple(annotations), remaining\n222\t\n223\t\n224\tdef _find_matching_open_bracket(s: str) -> int | None:\n225\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n226\t\n227\t    Walks right-to-left tracking bracket depth so balanced nested\n228\t    brackets inside the candidate annotation are stepped over.\n229\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n230\t    opener.\n231\t    \"\"\"\n232\t    if not s.endswith(\"]\"):\n233\t        return None\n234\t    depth = 0\n235\t    for i in range(len(s) - 1, -1, -1):\n236\t        c = s[i]\n237\t        if c == \"]\":\n238\t            depth += 1\n239\t        elif c == \"[\":\n240\t            depth -= 1\n241\t            if depth == 0:\n242\t                return i\n243\t    return None\n244\t"}]},"parent_tool_use_id":null,"session_id":"b8b3447c-1a07-4629-9abd-0be553cc3f03","uuid":"ac59fccb-7a19-481d-996a-5b2118937862","timestamp":"2026-05-16T02:03:02.958Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections.abc import Sequence\nfrom dataclasses import dataclass\nfrom typing import Protocol, TypeVar\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n# Deps sibling line: optional indent, the literal `@deps` token, then\n# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n# group captures the remainder of the line; splitting on whitespace\n# and validating each ID is a higher-level step.\n_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\nclass _HasIndentLevel(Protocol):\n    \"\"\"Anything with an integer ``indent_level`` attribute.\n\n    Used by :func:`_attach_ruledout` so it can resolve attachment over\n    either the eventual frozen ``Task`` model objects or the mutable\n    builder records the parser uses while constructing them.\n    \"\"\"\n\n    @property\n    def indent_level(self) -> int: ...\n\n\n_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n\n\ndef _attach_ruledout(\n    indent: int,\n    stack: Sequence[_T],\n    root_tasks: Sequence[_T],\n) -> _T | None:\n    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n\n    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n    the open-ancestor stack from innermost to outermost and return the\n    first task whose indent is strictly less than the RULEDOUT line's\n    indent. If no such ancestor exists in the current phase, fall back\n    to the most recent root task (mcloop's \"orphan\" handling). Returns\n    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n    the caller should drop.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task\n    if root_tasks:\n        return root_tasks[-1]\n    return None\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n","numLines":244,"startLine":1,"totalLines":244}}}
