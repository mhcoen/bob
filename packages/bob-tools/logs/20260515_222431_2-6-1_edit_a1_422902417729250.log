{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W37UWbwc13rfyFSF8VQotQ","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom collections.abc import Sequence\n7\tfrom dataclasses import dataclass, field\n8\tfrom pathlib import Path\n9\tfrom typing import NoReturn, Protocol, TypeVar\n10\t\n11\tfrom bob_tools.planfile.model import (\n12\t    BugsSection,\n13\t    Phase,\n14\t    Plan,\n15\t    PlanSyntaxError,\n16\t    RuledOut,\n17\t    Subsection,\n18\t    Task,\n19\t    TaskStatus,\n20\t)\n21\t\n22\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n23\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n24\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n25\t\n26\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n27\t# caller strips any inter-tag whitespace between iterations.\n28\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n29\t\n30\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n31\t# after the closing bracket (with the single separating space removed).\n32\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n33\t\n34\t# Content of an annotation (the bytes between `[` and `]`): an\n35\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n36\t# value. The required whitespace after the colon is what distinguishes\n37\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n38\t# after its colon).\n39\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n40\t\n41\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n42\t# token, and optional trailing text. Matches mcloop's `parse`, which\n43\t# treats a line as RULEDOUT when its stripped form starts with the\n44\t# literal bracket token.\n45\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n46\t\n47\t# Deps sibling line: optional indent, the literal `@deps` token, then\n48\t# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n49\t# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n50\t# group captures the remainder of the line; splitting on whitespace\n51\t# and validating each ID is a higher-level step.\n52\t_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n53\t\n54\t# Stage/Phase heading: any heading level whose title contains\n55\t# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n56\t# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n57\t# pattern to also pull out the keyword and the title text after the\n58\t# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n59\t# (no bare digits) — see design doc section 2.5.\n60\t_STAGE_RE = re.compile(\n61\t    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n62\t    re.IGNORECASE,\n63\t)\n64\t\n65\t# Bugs heading: any heading level whose title is exactly ``Bugs``.\n66\t# Mirrors mcloop's ``BUGS_RE``.\n67\t_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n68\t\n69\t# Subsection heading: ``###`` followed by free title text. Only level-3\n70\t# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n71\t# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n72\t# group following tasks until another subsection or phase ends them.\n73\t_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n74\t\n75\t# H1 project-title heading: exactly one ``#`` followed by free title\n76\t# text. Per design doc section 4.1 grammar ``Preamble ← H1 NL Prose?``.\n77\t# H2 (``##``) is consumed earlier by `_STAGE_RE` / `_BUGS_RE`; this\n78\t# regex requires a single leading ``#`` so multi-hash headings cannot\n79\t# match here. Recognized only before the first phase or bugs heading;\n80\t# subsequent H1 lines (malformed in strict mode, dropped in compat\n81\t# mode) fall through to the active prose accumulator.\n82\t_H1_RE = re.compile(r\"^#\\s+(.+?)\\s*$\")\n83\t\n84\t# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n85\t# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n86\t# Recognized only at the start of the task body, before any flag tags.\n87\t_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n88\t\n89\t\n90\tdef parse_plan(\n91\t    text: str,\n92\t    *,\n93\t    strict: bool = False,\n94\t    source_path: Path | None = None,\n95\t) -> Plan:\n96\t    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n97\t\n98\t    ``strict=False`` (the default) is compatibility mode — accepts the\n99\t    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n100\t    line, optional task IDs, no phase-id comments). ``strict=True``\n101\t    enables the format additions in design doc section 4 (magic line,\n102\t    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n103\t\n104\t    Stage 2.5.1 wired the signature; 2.5.2 walks ``text`` line by line,\n105\t    tracking the current phase (or bugs section), the current subsection\n106\t    within a phase, and a stack of open tasks by indent. 2.5.3 extracts\n107\t    the project title from the first H1 and accumulates prose in three\n108\t    regions: the preamble (after the H1, before the first phase or bugs\n109\t    heading), phase prose (after a phase heading, before the first task\n110\t    or subsection), and subsection prose (after a ``###`` heading,\n111\t    before the first task). Prose-region accumulators close when the\n112\t    relevant boundary line is consumed; lines outside any active\n113\t    accumulator (e.g. a task line before any phase, or prose after the\n114\t    first task in a phase) are dropped silently in compat mode (the\n115\t    orphan-task case matches mcloop, which assigns ``stage=\"\"`` rather\n116\t    than erroring; strict mode in Stage 3 will raise). Each task line\n117\t    opens or closes scopes by indent comparison, matching mcloop's logic\n118\t    in ``checklist.py:parse``. ``@deps`` and ``[RULEDOUT]`` sibling\n119\t    lines are routed via :func:`_attach_deps` and :func:`_attach_ruledout`\n120\t    and accumulated on the parent task. 2.5.4 (this) raises\n121\t    :class:`PlanSyntaxError` on syntax violations even in compat mode:\n122\t    today, an ``@deps`` line that cannot attach to any preceding task\n123\t    in the current section. The orphan ``@deps`` case has no semantic\n124\t    interpretation and no mcloop-tolerance to preserve (mcloop never\n125\t    recognized ``@deps`` at all). The error message quotes the offending\n126\t    line so the location is unambiguous to the human fixing the file.\n127\t    \"\"\"\n128\t    del strict\n129\t    lines = text.splitlines()\n130\t\n131\t    phases_b: list[_PhaseBuilder] = []\n132\t    bugs_b: _BugsBuilder | None = None\n133\t    current_phase: _PhaseBuilder | None = None\n134\t    current_subsection: _SubsectionBuilder | None = None\n135\t    in_bugs = False\n136\t    stack: list[_TaskBuilder] = []\n137\t\n138\t    project_title = \"\"\n139\t    project_title_seen = False\n140\t    preamble_lines: list[str] = []\n141\t    preamble_active = False\n142\t    phase_prose_lines: list[str] | None = None\n143\t    subsection_prose_lines: list[str] | None = None\n144\t\n145\t    def _close_subsection_prose() -> None:\n146\t        nonlocal subsection_prose_lines\n147\t        if subsection_prose_lines is not None and current_subsection is not None:\n148\t            current_subsection.prose = _finalize_prose(subsection_prose_lines)\n149\t        subsection_prose_lines = None\n150\t\n151\t    def _close_phase_prose() -> None:\n152\t        nonlocal phase_prose_lines\n153\t        if phase_prose_lines is not None and current_phase is not None:\n154\t            current_phase.prose = _finalize_prose(phase_prose_lines)\n155\t        phase_prose_lines = None\n156\t\n157\t    for idx, line in enumerate(lines):\n158\t        line_number = idx + 1\n159\t\n160\t        heading = _parse_phase_heading(line)\n161\t        if heading is not None:\n162\t            _close_subsection_prose()\n163\t            _close_phase_prose()\n164\t            preamble_active = False\n165\t            ordinal, keyword, title = heading\n166\t            current_phase = _PhaseBuilder(\n167\t                ordinal=ordinal,\n168\t                keyword=keyword,\n169\t                title=title,\n170\t                line_number=line_number,\n171\t            )\n172\t            phases_b.append(current_phase)\n173\t            current_subsection = None\n174\t            in_bugs = False\n175\t            stack.clear()\n176\t            phase_prose_lines = []\n177\t            continue\n178\t\n179\t        if _BUGS_RE.match(line):\n180\t            _close_subsection_prose()\n181\t            _close_phase_prose()\n182\t            preamble_active = False\n183\t            bugs_b = _BugsBuilder(line_number=line_number)\n184\t            current_phase = None\n185\t            current_subsection = None\n186\t            in_bugs = True\n187\t            stack.clear()\n188\t            continue\n189\t\n190\t        if current_phase is None and not in_bugs:\n191\t            h1_m = _H1_RE.match(line)\n192\t            if h1_m is not None:\n193\t                if not project_title_seen:\n194\t                    project_title = h1_m.group(1).strip()\n195\t                    project_title_seen = True\n196\t                    preamble_active = True\n197\t                    continue\n198\t                # Subsequent H1 falls through to the preamble accumulator\n199\t                # so the raw text is preserved. Strict mode (Stage 3)\n200\t                # will raise on duplicate H1s.\n201\t\n202\t        if not in_bugs and current_phase is not None:\n203\t            sm = _SUBSECTION_RE.match(line)\n204\t            if sm is not None:\n205\t                _close_subsection_prose()\n206\t                _close_phase_prose()\n207\t                current_subsection = _SubsectionBuilder(\n208\t                    title=sm.group(1).strip(),\n209\t                    line_number=line_number,\n210\t                )\n211\t                current_phase.subsections.append(current_subsection)\n212\t                stack.clear()\n213\t                subsection_prose_lines = []\n214\t                continue\n215\t\n216\t        scope_tasks = _current_scope_tasks(\n217\t            in_bugs=in_bugs,\n218\t            bugs_b=bugs_b,\n219\t            current_subsection=current_subsection,\n220\t            current_phase=current_phase,\n221\t        )\n222\t\n223\t        ro = _parse_ruledout_line(line, line_number)\n224\t        if ro is not None:\n225\t            indent = len(ro.indent)\n226\t            roots = scope_tasks if scope_tasks is not None else []\n227\t            target = _attach_ruledout(indent, stack, roots)\n228\t            if target is not None:\n229\t                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n230\t            continue\n231\t\n232\t        dm = _DEPS_RE.match(line)\n233\t        if dm is not None:\n234\t            indent = len(dm.group(1))\n235\t            target, _lenient = _attach_deps(indent, stack)\n236\t            if target is None:\n237\t                _raise_syntax_error(\n238\t                    \"@deps line has no preceding task to attach to\",\n239\t                    line_text=line,\n240\t                    line_number=line_number,\n241\t                    source_path=source_path,\n242\t                    column=indent + 1,\n243\t                )\n244\t            target.deps.extend(dm.group(2).split())\n245\t            continue\n246\t\n247\t        raw = _parse_task_line(line, line_number)\n248\t        if raw is None:\n249\t            if preamble_active:\n250\t                preamble_lines.append(line)\n251\t            elif subsection_prose_lines is not None:\n252\t                subsection_prose_lines.append(line)\n253\t            elif phase_prose_lines is not None:\n254\t                phase_prose_lines.append(line)\n255\t            # else: line outside any active prose region (e.g. before\n256\t            # the first H1 or after the first task in a section) —\n257\t            # dropped in compat mode.\n258\t            continue\n259\t\n260\t        _close_subsection_prose()\n261\t        _close_phase_prose()\n262\t\n263\t        builder = _build_task(raw)\n264\t        indent = builder.indent_level\n265\t\n266\t        while stack and stack[-1].indent_level >= indent:\n267\t            stack.pop()\n268\t\n269\t        if stack:\n270\t            stack[-1].children.append(builder)\n271\t        elif scope_tasks is not None:\n272\t            scope_tasks.append(builder)\n273\t        # else: task line before any phase/bugs — silently dropped in\n274\t        # compat mode (matches mcloop, which assigns ``stage=\"\"``);\n275\t        # strict mode (Stage 3) will surface this as a PlanSyntaxError.\n276\t\n277\t        stack.append(builder)\n278\t\n279\t    _close_subsection_prose()\n280\t    _close_phase_prose()\n281\t\n282\t    return Plan(\n283\t        magic_version=None,\n284\t        project_title=project_title,\n285\t        preamble=_finalize_prose(preamble_lines),\n286\t        phases=tuple(p.freeze() for p in phases_b),\n287\t        bugs=bugs_b.freeze() if bugs_b is not None else None,\n288\t        source_path=source_path,\n289\t    )\n290\t\n291\t\n292\tdef _raise_syntax_error(\n293\t    message: str,\n294\t    *,\n295\t    line_text: str,\n296\t    line_number: int,\n297\t    source_path: Path | None,\n298\t    column: int = 1,\n299\t) -> NoReturn:\n300\t    \"\"\"Raise :class:`PlanSyntaxError` with the offending line quoted.\n301\t\n302\t    Per the design doc section 9 contract, the error carries\n303\t    ``(message, line, column, path)``; ``__str__`` formats them as\n304\t    ``PLAN.md invalid at line N, column M: <message>``. The task\n305\t    description for 2.5.4 adds: the message itself must quote the\n306\t    offending line so the human reading the error can see exactly which\n307\t    text triggered the rejection without having to open the file. The\n308\t    quoted form uses backticks rather than ``repr()`` because the line\n309\t    has already had its trailing newline stripped by ``splitlines()``,\n310\t    so there is no escape-sequence ambiguity to disambiguate.\n311\t    \"\"\"\n312\t    raise PlanSyntaxError(\n313\t        f\"{message}: `{line_text}`\",\n314\t        line_number,\n315\t        column,\n316\t        source_path,\n317\t    )\n318\t\n319\t\n320\tdef _finalize_prose(lines: list[str]) -> str:\n321\t    \"\"\"Join accumulated prose lines, trimming blank lines from the ends.\n322\t\n323\t    Internal blank lines (paragraph breaks) and any leading/trailing\n324\t    whitespace within a non-blank line are preserved — Markdown attaches\n325\t    semantic weight to indent (code blocks, list continuations), so we\n326\t    only strip wholly-blank wrapper lines rather than calling\n327\t    ``str.strip()`` on the joined text.\n328\t    \"\"\"\n329\t    start = 0\n330\t    while start < len(lines) and not lines[start].strip():\n331\t        start += 1\n332\t    end = len(lines)\n333\t    while end > start and not lines[end - 1].strip():\n334\t        end -= 1\n335\t    return \"\\n\".join(lines[start:end])\n336\t\n337\t\n338\tdef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n339\t    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n340\t\n341\t    Returns ``None`` for non-matching lines. The keyword is normalized\n342\t    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n343\t    keeps the keyword cosmetic, so the canonicalizer can choose to\n344\t    preserve original casing if it wants — the typed model only needs\n345\t    one stable form.\n346\t    \"\"\"\n347\t    m = _STAGE_RE.match(line)\n348\t    if m is None:\n349\t        return None\n350\t    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n351\t\n352\t\n353\tdef _extract_task_id(text: str) -> tuple[str | None, str]:\n354\t    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n355\t\n356\t    Per design doc section 4.2 grammar, the task ID is the first token\n357\t    in the body after the checkbox. Returns ``(None, text)`` when no\n358\t    leading task ID is present; task IDs are optional in compat mode\n359\t    and mandatory in strict mode (enforced separately in Stage 3).\n360\t    \"\"\"\n361\t    m = _TASK_ID_RE.match(text)\n362\t    if m is None:\n363\t        return None, text\n364\t    return m.group(1), text[m.end() :]\n365\t\n366\t\n367\tdef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n368\t    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n369\t\n370\t    Order matters: annotations come first (they live at end of line\n371\t    and would otherwise be swallowed by the action tag's args, which\n372\t    span to end of line). Task ID, then flag tags, then action tag run\n373\t    left-to-right. The remaining text is the task description.\n374\t    \"\"\"\n375\t    annotations, remaining = _extract_annotations(raw.text)\n376\t    task_id, remaining = _extract_task_id(remaining)\n377\t    flag_tags, remaining = _extract_flag_tags(remaining)\n378\t    action_tag, remaining = _extract_action_tag(remaining)\n379\t    return _TaskBuilder(\n380\t        task_id=task_id,\n381\t        text=remaining.strip(),\n382\t        status=TaskStatus.from_marker(raw.status_char),\n383\t        flag_tags=flag_tags,\n384\t        action_tag=action_tag,\n385\t        annotations=annotations,\n386\t        indent_level=len(raw.indent),\n387\t        line_number=raw.line_number,\n388\t    )\n389\t\n390\t\n391\tdef _current_scope_tasks(\n392\t    *,\n393\t    in_bugs: bool,\n394\t    bugs_b: _BugsBuilder | None,\n395\t    current_subsection: _SubsectionBuilder | None,\n396\t    current_phase: _PhaseBuilder | None,\n397\t) -> list[_TaskBuilder] | None:\n398\t    \"\"\"Pick the root-task list for the active section.\n399\t\n400\t    The order encodes the grammar: a Bugs section excludes phase scope;\n401\t    inside a phase, a current subsection captures following tasks until\n402\t    the next subsection or phase. Returns ``None`` when no section is\n403\t    active — i.e. the input has not yet introduced a phase or bugs\n404\t    heading, so any task/sibling line is an orphan.\n405\t    \"\"\"\n406\t    if in_bugs:\n407\t        return bugs_b.tasks if bugs_b is not None else None\n408\t    if current_subsection is not None:\n409\t        return current_subsection.tasks\n410\t    if current_phase is not None:\n411\t        return current_phase.tasks\n412\t    return None\n413\t\n414\t\n415\t@dataclass(frozen=True)\n416\tclass _RawTaskLine:\n417\t    \"\"\"Recognize-step output of `_parse_task_line`.\n418\t\n419\t    Stage 2 of the parser splits recognize-then-classify. This record\n420\t    is the recognize step: indent text, status marker, body text, and\n421\t    source line number. Higher-level functions classify the body into\n422\t    task id, tags, deps, and prose.\n423\t    \"\"\"\n424\t\n425\t    indent: str\n426\t    status_char: str\n427\t    text: str\n428\t    line_number: int\n429\t\n430\t\n431\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n432\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n433\t    m = _CHECKBOX_RE.match(line)\n434\t    if m is None:\n435\t        return None\n436\t    return _RawTaskLine(\n437\t        indent=m.group(1),\n438\t        status_char=m.group(2),\n439\t        text=m.group(3),\n440\t        line_number=line_number,\n441\t    )\n442\t\n443\t\n444\t@dataclass(frozen=True)\n445\tclass _RawRuledOut:\n446\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n447\t\n448\t    A RULEDOUT line is a sibling of the task it pertains to (design\n449\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n450\t    captures only indent, body text, and source line number; attaching\n451\t    the line to its parent task by indentation is a higher-level step.\n452\t    \"\"\"\n453\t\n454\t    indent: str\n455\t    text: str\n456\t    line_number: int\n457\t\n458\t\n459\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n460\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n461\t\n462\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n463\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n464\t    whitespace on the body text is stripped; an empty body is allowed.\n465\t    \"\"\"\n466\t    m = _RULEDOUT_RE.match(line)\n467\t    if m is None:\n468\t        return None\n469\t    return _RawRuledOut(\n470\t        indent=m.group(1),\n471\t        text=m.group(2).strip(),\n472\t        line_number=line_number,\n473\t    )\n474\t\n475\t\n476\tclass _HasIndentLevel(Protocol):\n477\t    \"\"\"Anything with an integer ``indent_level`` attribute.\n478\t\n479\t    Used by :func:`_attach_ruledout` so it can resolve attachment over\n480\t    either the eventual frozen ``Task`` model objects or the mutable\n481\t    builder records the parser uses while constructing them.\n482\t    \"\"\"\n483\t\n484\t    @property\n485\t    def indent_level(self) -> int: ...\n486\t\n487\t\n488\t_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n489\t\n490\t\n491\tdef _attach_ruledout(\n492\t    indent: int,\n493\t    stack: Sequence[_T],\n494\t    root_tasks: Sequence[_T],\n495\t) -> _T | None:\n496\t    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n497\t\n498\t    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n499\t    the open-ancestor stack from innermost to outermost and return the\n500\t    first task whose indent is strictly less than the RULEDOUT line's\n501\t    indent. If no such ancestor exists in the current phase, fall back\n502\t    to the most recent root task (mcloop's \"orphan\" handling). Returns\n503\t    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n504\t    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n505\t    the caller should drop.\n506\t    \"\"\"\n507\t    for task in reversed(stack):\n508\t        if task.indent_level < indent:\n509\t            return task\n510\t    if root_tasks:\n511\t        return root_tasks[-1]\n512\t    return None\n513\t\n514\t\n515\tdef _attach_deps(\n516\t    indent: int,\n517\t    stack: Sequence[_T],\n518\t) -> tuple[_T | None, bool]:\n519\t    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n520\t\n521\t    Walks the open-ancestor stack from innermost (top) to outermost.\n522\t    Returns ``(parent, False)`` for the strict form — first ancestor\n523\t    whose indent is strictly less than the deps line's indent. Returns\n524\t    ``(parent, True)`` for the lenient form — first ancestor at the\n525\t    same indent as the deps line, which callers should report as a\n526\t    validation warning (the deps was not indented under its task).\n527\t    Returns ``(None, False)`` when no candidate exists; the caller\n528\t    should drop the line.\n529\t\n530\t    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n531\t    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n532\t    indent is malformed input rather than an orphan that needs adopting.\n533\t    \"\"\"\n534\t    for task in reversed(stack):\n535\t        if task.indent_level < indent:\n536\t            return task, False\n537\t        if task.indent_level == indent:\n538\t            return task, True\n539\t    return None, False\n540\t\n541\t\n542\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n543\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n544\t\n545\t    Per design doc section 4.3, flag tags are recognized only at the\n546\t    leading position. The caller is responsible for stripping the task\n547\t    ID (if any) first. A bracketed flag form appearing later in the\n548\t    text is prose and is left in place.\n549\t    \"\"\"\n550\t    tags: list[str] = []\n551\t    remaining = text\n552\t    while True:\n553\t        m = _FLAG_TAG_RE.match(remaining)\n554\t        if m is None:\n555\t            break\n556\t        tags.append(m.group(1))\n557\t        remaining = remaining[m.end() :].lstrip()\n558\t    return tuple(tags), remaining\n559\t\n560\t\n561\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n562\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n563\t\n564\t    Per design doc section 4.3, the action tag is recognized only at\n565\t    the leading position, after any flag tags. The argument string is\n566\t    the text from the closing bracket to end of line, with the single\n567\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n568\t    are prose and are left in place.\n569\t\n570\t    Returns ``(None, text)`` when no leading action tag is present;\n571\t    otherwise consumes the rest of the line as the argument string\n572\t    and returns ``((action, args), \"\")``.\n573\t    \"\"\"\n574\t    m = _ACTION_TAG_RE.match(text)\n575\t    if m is None:\n576\t        return None, text\n577\t    action = m.group(1)\n578\t    args = text[m.end() :].lstrip()\n579\t    return (action, args), \"\"\n580\t\n581\t\n582\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n583\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n584\t\n585\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n586\t    are bracketed, and are separated from the preceding text by\n587\t    whitespace. Multiple annotations are allowed. Values may contain\n588\t    balanced bracket pairs; this function scans right-to-left with\n589\t    bracket-depth tracking so nested brackets stay inside a single\n590\t    annotation rather than being misparsed as a separate one.\n591\t\n592\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n593\t    accepts any identifier-shaped key. Validation of allowed keys is\n594\t    a separate concern.\n595\t    \"\"\"\n596\t    annotations: list[tuple[str, str]] = []\n597\t    remaining = text\n598\t    while True:\n599\t        rstripped = remaining.rstrip()\n600\t        if not rstripped.endswith(\"]\"):\n601\t            remaining = rstripped\n602\t            break\n603\t        start = _find_matching_open_bracket(rstripped)\n604\t        if start is None:\n605\t            remaining = rstripped\n606\t            break\n607\t        # An annotation must be separated from preceding text by\n608\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n609\t        # character is part of the task text, not an annotation.\n610\t        if start > 0 and not rstripped[start - 1].isspace():\n611\t            remaining = rstripped\n612\t            break\n613\t        content = rstripped[start + 1 : -1]\n614\t        m = _ANNOTATION_CONTENT_RE.match(content)\n615\t        if m is None:\n616\t            remaining = rstripped\n617\t            break\n618\t        annotations.insert(0, (m.group(1), m.group(2)))\n619\t        remaining = rstripped[:start].rstrip()\n620\t    return tuple(annotations), remaining\n621\t\n622\t\n623\tdef _find_matching_open_bracket(s: str) -> int | None:\n624\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n625\t\n626\t    Walks right-to-left tracking bracket depth so balanced nested\n627\t    brackets inside the candidate annotation are stepped over.\n628\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n629\t    opener.\n630\t    \"\"\"\n631\t    if not s.endswith(\"]\"):\n632\t        return None\n633\t    depth = 0\n634\t    for i in range(len(s) - 1, -1, -1):\n635\t        c = s[i]\n636\t        if c == \"]\":\n637\t            depth += 1\n638\t        elif c == \"[\":\n639\t            depth -= 1\n640\t            if depth == 0:\n641\t                return i\n642\t    return None\n643\t\n644\t\n645\t# Mutable builder records used while walking the input. The public\n646\t# model dataclasses are frozen, so the parser builds with these and\n647\t# calls ``freeze`` to produce the immutable tree at the end. Each\n648\t# builder also satisfies the ``_HasIndentLevel`` protocol so the\n649\t# existing ``_attach_*`` helpers operate on them directly.\n650\t\n651\t\n652\t@dataclass\n653\tclass _TaskBuilder:\n654\t    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n655\t\n656\t    task_id: str | None\n657\t    text: str\n658\t    status: TaskStatus\n659\t    flag_tags: tuple[str, ...]\n660\t    action_tag: tuple[str, str] | None\n661\t    annotations: tuple[tuple[str, str], ...]\n662\t    indent_level: int\n663\t    line_number: int\n664\t    deps: list[str] = field(default_factory=list)\n665\t    children: list[_TaskBuilder] = field(default_factory=list)\n666\t    ruled_out: list[RuledOut] = field(default_factory=list)\n667\t\n668\t    def freeze(self) -> Task:\n669\t        return Task(\n670\t            task_id=self.task_id,\n671\t            text=self.text,\n672\t            status=self.status,\n673\t            flag_tags=self.flag_tags,\n674\t            action_tag=self.action_tag,\n675\t            annotations=self.annotations,\n676\t            deps=tuple(self.deps),\n677\t            children=tuple(c.freeze() for c in self.children),\n678\t            ruled_out=tuple(self.ruled_out),\n679\t            indent_level=self.indent_level,\n680\t            line_number=self.line_number,\n681\t        )\n682\t\n683\t\n684\t@dataclass\n685\tclass _SubsectionBuilder:\n686\t    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n687\t\n688\t    title: str\n689\t    line_number: int\n690\t    prose: str = \"\"\n691\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n692\t\n693\t    def freeze(self) -> Subsection:\n694\t        return Subsection(\n695\t            title=self.title,\n696\t            prose=self.prose,\n697\t            tasks=tuple(t.freeze() for t in self.tasks),\n698\t            line_number=self.line_number,\n699\t        )\n700\t\n701\t\n702\t@dataclass\n703\tclass _PhaseBuilder:\n704\t    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n705\t\n706\t    ordinal: int\n707\t    keyword: str\n708\t    title: str\n709\t    line_number: int\n710\t    phase_id: str | None = None\n711\t    phase_id_source: str = \"none\"\n712\t    prose: str = \"\"\n713\t    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n714\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n715\t\n716\t    def freeze(self) -> Phase:\n717\t        return Phase(\n718\t            phase_id=self.phase_id,\n719\t            phase_id_source=self.phase_id_source,\n720\t            ordinal=self.ordinal,\n721\t            keyword=self.keyword,\n722\t            title=self.title,\n723\t            prose=self.prose,\n724\t            subsections=tuple(s.freeze() for s in self.subsections),\n725\t            tasks=tuple(t.freeze() for t in self.tasks),\n726\t            line_number=self.line_number,\n727\t        )\n728\t\n729\t\n730\t@dataclass\n731\tclass _BugsBuilder:\n732\t    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n733\t\n734\t    line_number: int\n735\t    tasks: list[_TaskBuilder] = field(default_factory=list)\n736\t\n737\t    def freeze(self) -> BugsSection:\n738\t        return BugsSection(\n739\t            tasks=tuple(t.freeze() for t in self.tasks),\n740\t            line_number=self.line_number,\n741\t        )\n742\t"}]},"parent_tool_use_id":null,"session_id":"60d85b9b-07d2-4666-b129-0e41e9f14a76","uuid":"ef4c8c1a-1397-4a94-b5d4-cc7934e0e026","timestamp":"2026-05-16T03:19:12.850Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections.abc import Sequence\nfrom dataclasses import dataclass, field\nfrom pathlib import Path\nfrom typing import NoReturn, Protocol, TypeVar\n\nfrom bob_tools.planfile.model import (\n    BugsSection,\n    Phase,\n    Plan,\n    PlanSyntaxError,\n    RuledOut,\n    Subsection,\n    Task,\n    TaskStatus,\n)\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n# Deps sibling line: optional indent, the literal `@deps` token, then\n# whitespace-separated task IDs (bare `T-NNNNNN`, no trailing colon)\n# per design doc grammar `Indent* \"@deps\" (WS TaskRef)+ NL`. The tail\n# group captures the remainder of the line; splitting on whitespace\n# and validating each ID is a higher-level step.\n_DEPS_RE = re.compile(r\"^(\\s*)@deps\\s+(.+)$\")\n\n# Stage/Phase heading: any heading level whose title contains\n# \"Stage N\" or \"Phase N\" with bare digits. Mirrors mcloop's\n# ``STAGE_RE`` so loose PLAN.md files parse identically; extends the\n# pattern to also pull out the keyword and the title text after the\n# (optional) colon. ``## Phase phase_001:`` is intentionally rejected\n# (no bare digits) — see design doc section 2.5.\n_STAGE_RE = re.compile(\n    r\"^#+\\s+.*?\\b(?P<kw>stage|phase)\\s+(?P<num>\\d+)\\b\\s*:?\\s*(?P<title>.*?)\\s*$\",\n    re.IGNORECASE,\n)\n\n# Bugs heading: any heading level whose title is exactly ``Bugs``.\n# Mirrors mcloop's ``BUGS_RE``.\n_BUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n\n# Subsection heading: ``###`` followed by free title text. Only level-3\n# headings; level-1/2 are handled by ``_STAGE_RE`` / ``_BUGS_RE`` (or\n# the H1 recognizer added in 2.5.3). Subsections sit inside a phase and\n# group following tasks until another subsection or phase ends them.\n_SUBSECTION_RE = re.compile(r\"^###\\s+(.+?)\\s*$\")\n\n# H1 project-title heading: exactly one ``#`` followed by free title\n# text. Per design doc section 4.1 grammar ``Preamble ← H1 NL Prose?``.\n# H2 (``##``) is consumed earlier by `_STAGE_RE` / `_BUGS_RE`; this\n# regex requires a single leading ``#`` so multi-hash headings cannot\n# match here. Recognized only before the first phase or bugs heading;\n# subsequent H1 lines (malformed in strict mode, dropped in compat\n# mode) fall through to the active prose accumulator.\n_H1_RE = re.compile(r\"^#\\s+(.+?)\\s*$\")\n\n# Leading task ID: ``T-NNNNNN:`` followed by mandatory whitespace.\n# Per design doc section 4.2 grammar ``TaskId ← TaskRef \":\" WS``.\n# Recognized only at the start of the task body, before any flag tags.\n_TASK_ID_RE = re.compile(r\"^(T-\\d+):\\s+\")\n\n\ndef parse_plan(\n    text: str,\n    *,\n    strict: bool = False,\n    source_path: Path | None = None,\n) -> Plan:\n    \"\"\"Parse PLAN.md ``text`` into a typed :class:`Plan`.\n\n    ``strict=False`` (the default) is compatibility mode — accepts the\n    PLAN.md format mcloop's ``checklist.py`` accepts today (no magic\n    line, optional task IDs, no phase-id comments). ``strict=True``\n    enables the format additions in design doc section 4 (magic line,\n    mandatory ``T-NNNNNN:`` ids, ``<!-- phase_id: ... -->`` comments).\n\n    Stage 2.5.1 wired the signature; 2.5.2 walks ``text`` line by line,\n    tracking the current phase (or bugs section), the current subsection\n    within a phase, and a stack of open tasks by indent. 2.5.3 extracts\n    the project title from the first H1 and accumulates prose in three\n    regions: the preamble (after the H1, before the first phase or bugs\n    heading), phase prose (after a phase heading, before the first task\n    or subsection), and subsection prose (after a ``###`` heading,\n    before the first task). Prose-region accumulators close when the\n    relevant boundary line is consumed; lines outside any active\n    accumulator (e.g. a task line before any phase, or prose after the\n    first task in a phase) are dropped silently in compat mode (the\n    orphan-task case matches mcloop, which assigns ``stage=\"\"`` rather\n    than erroring; strict mode in Stage 3 will raise). Each task line\n    opens or closes scopes by indent comparison, matching mcloop's logic\n    in ``checklist.py:parse``. ``@deps`` and ``[RULEDOUT]`` sibling\n    lines are routed via :func:`_attach_deps` and :func:`_attach_ruledout`\n    and accumulated on the parent task. 2.5.4 (this) raises\n    :class:`PlanSyntaxError` on syntax violations even in compat mode:\n    today, an ``@deps`` line that cannot attach to any preceding task\n    in the current section. The orphan ``@deps`` case has no semantic\n    interpretation and no mcloop-tolerance to preserve (mcloop never\n    recognized ``@deps`` at all). The error message quotes the offending\n    line so the location is unambiguous to the human fixing the file.\n    \"\"\"\n    del strict\n    lines = text.splitlines()\n\n    phases_b: list[_PhaseBuilder] = []\n    bugs_b: _BugsBuilder | None = None\n    current_phase: _PhaseBuilder | None = None\n    current_subsection: _SubsectionBuilder | None = None\n    in_bugs = False\n    stack: list[_TaskBuilder] = []\n\n    project_title = \"\"\n    project_title_seen = False\n    preamble_lines: list[str] = []\n    preamble_active = False\n    phase_prose_lines: list[str] | None = None\n    subsection_prose_lines: list[str] | None = None\n\n    def _close_subsection_prose() -> None:\n        nonlocal subsection_prose_lines\n        if subsection_prose_lines is not None and current_subsection is not None:\n            current_subsection.prose = _finalize_prose(subsection_prose_lines)\n        subsection_prose_lines = None\n\n    def _close_phase_prose() -> None:\n        nonlocal phase_prose_lines\n        if phase_prose_lines is not None and current_phase is not None:\n            current_phase.prose = _finalize_prose(phase_prose_lines)\n        phase_prose_lines = None\n\n    for idx, line in enumerate(lines):\n        line_number = idx + 1\n\n        heading = _parse_phase_heading(line)\n        if heading is not None:\n            _close_subsection_prose()\n            _close_phase_prose()\n            preamble_active = False\n            ordinal, keyword, title = heading\n            current_phase = _PhaseBuilder(\n                ordinal=ordinal,\n                keyword=keyword,\n                title=title,\n                line_number=line_number,\n            )\n            phases_b.append(current_phase)\n            current_subsection = None\n            in_bugs = False\n            stack.clear()\n            phase_prose_lines = []\n            continue\n\n        if _BUGS_RE.match(line):\n            _close_subsection_prose()\n            _close_phase_prose()\n            preamble_active = False\n            bugs_b = _BugsBuilder(line_number=line_number)\n            current_phase = None\n            current_subsection = None\n            in_bugs = True\n            stack.clear()\n            continue\n\n        if current_phase is None and not in_bugs:\n            h1_m = _H1_RE.match(line)\n            if h1_m is not None:\n                if not project_title_seen:\n                    project_title = h1_m.group(1).strip()\n                    project_title_seen = True\n                    preamble_active = True\n                    continue\n                # Subsequent H1 falls through to the preamble accumulator\n                # so the raw text is preserved. Strict mode (Stage 3)\n                # will raise on duplicate H1s.\n\n        if not in_bugs and current_phase is not None:\n            sm = _SUBSECTION_RE.match(line)\n            if sm is not None:\n                _close_subsection_prose()\n                _close_phase_prose()\n                current_subsection = _SubsectionBuilder(\n                    title=sm.group(1).strip(),\n                    line_number=line_number,\n                )\n                current_phase.subsections.append(current_subsection)\n                stack.clear()\n                subsection_prose_lines = []\n                continue\n\n        scope_tasks = _current_scope_tasks(\n            in_bugs=in_bugs,\n            bugs_b=bugs_b,\n            current_subsection=current_subsection,\n            current_phase=current_phase,\n        )\n\n        ro = _parse_ruledout_line(line, line_number)\n        if ro is not None:\n            indent = len(ro.indent)\n            roots = scope_tasks if scope_tasks is not None else []\n            target = _attach_ruledout(indent, stack, roots)\n            if target is not None:\n                target.ruled_out.append(RuledOut(text=ro.text, line_number=line_number))\n            continue\n\n        dm = _DEPS_RE.match(line)\n        if dm is not None:\n            indent = len(dm.group(1))\n            target, _lenient = _attach_deps(indent, stack)\n            if target is None:\n                _raise_syntax_error(\n                    \"@deps line has no preceding task to attach to\",\n                    line_text=line,\n                    line_number=line_number,\n                    source_path=source_path,\n                    column=indent + 1,\n                )\n            target.deps.extend(dm.group(2).split())\n            continue\n\n        raw = _parse_task_line(line, line_number)\n        if raw is None:\n            if preamble_active:\n                preamble_lines.append(line)\n            elif subsection_prose_lines is not None:\n                subsection_prose_lines.append(line)\n            elif phase_prose_lines is not None:\n                phase_prose_lines.append(line)\n            # else: line outside any active prose region (e.g. before\n            # the first H1 or after the first task in a section) —\n            # dropped in compat mode.\n            continue\n\n        _close_subsection_prose()\n        _close_phase_prose()\n\n        builder = _build_task(raw)\n        indent = builder.indent_level\n\n        while stack and stack[-1].indent_level >= indent:\n            stack.pop()\n\n        if stack:\n            stack[-1].children.append(builder)\n        elif scope_tasks is not None:\n            scope_tasks.append(builder)\n        # else: task line before any phase/bugs — silently dropped in\n        # compat mode (matches mcloop, which assigns ``stage=\"\"``);\n        # strict mode (Stage 3) will surface this as a PlanSyntaxError.\n\n        stack.append(builder)\n\n    _close_subsection_prose()\n    _close_phase_prose()\n\n    return Plan(\n        magic_version=None,\n        project_title=project_title,\n        preamble=_finalize_prose(preamble_lines),\n        phases=tuple(p.freeze() for p in phases_b),\n        bugs=bugs_b.freeze() if bugs_b is not None else None,\n        source_path=source_path,\n    )\n\n\ndef _raise_syntax_error(\n    message: str,\n    *,\n    line_text: str,\n    line_number: int,\n    source_path: Path | None,\n    column: int = 1,\n) -> NoReturn:\n    \"\"\"Raise :class:`PlanSyntaxError` with the offending line quoted.\n\n    Per the design doc section 9 contract, the error carries\n    ``(message, line, column, path)``; ``__str__`` formats them as\n    ``PLAN.md invalid at line N, column M: <message>``. The task\n    description for 2.5.4 adds: the message itself must quote the\n    offending line so the human reading the error can see exactly which\n    text triggered the rejection without having to open the file. The\n    quoted form uses backticks rather than ``repr()`` because the line\n    has already had its trailing newline stripped by ``splitlines()``,\n    so there is no escape-sequence ambiguity to disambiguate.\n    \"\"\"\n    raise PlanSyntaxError(\n        f\"{message}: `{line_text}`\",\n        line_number,\n        column,\n        source_path,\n    )\n\n\ndef _finalize_prose(lines: list[str]) -> str:\n    \"\"\"Join accumulated prose lines, trimming blank lines from the ends.\n\n    Internal blank lines (paragraph breaks) and any leading/trailing\n    whitespace within a non-blank line are preserved — Markdown attaches\n    semantic weight to indent (code blocks, list continuations), so we\n    only strip wholly-blank wrapper lines rather than calling\n    ``str.strip()`` on the joined text.\n    \"\"\"\n    start = 0\n    while start < len(lines) and not lines[start].strip():\n        start += 1\n    end = len(lines)\n    while end > start and not lines[end - 1].strip():\n        end -= 1\n    return \"\\n\".join(lines[start:end])\n\n\ndef _parse_phase_heading(line: str) -> tuple[int, str, str] | None:\n    \"\"\"Match a Stage/Phase heading and return (ordinal, keyword, title).\n\n    Returns ``None`` for non-matching lines. The keyword is normalized\n    to title case (``Stage`` / ``Phase``); design doc section 11 Q4\n    keeps the keyword cosmetic, so the canonicalizer can choose to\n    preserve original casing if it wants — the typed model only needs\n    one stable form.\n    \"\"\"\n    m = _STAGE_RE.match(line)\n    if m is None:\n        return None\n    return int(m.group(\"num\")), m.group(\"kw\").capitalize(), m.group(\"title\").strip()\n\n\ndef _extract_task_id(text: str) -> tuple[str | None, str]:\n    \"\"\"Strip a leading ``T-NNNNNN:`` task ID from ``text``.\n\n    Per design doc section 4.2 grammar, the task ID is the first token\n    in the body after the checkbox. Returns ``(None, text)`` when no\n    leading task ID is present; task IDs are optional in compat mode\n    and mandatory in strict mode (enforced separately in Stage 3).\n    \"\"\"\n    m = _TASK_ID_RE.match(text)\n    if m is None:\n        return None, text\n    return m.group(1), text[m.end() :]\n\n\ndef _build_task(raw: _RawTaskLine) -> _TaskBuilder:\n    \"\"\"Classify a checkbox body into a mutable :class:`_TaskBuilder`.\n\n    Order matters: annotations come first (they live at end of line\n    and would otherwise be swallowed by the action tag's args, which\n    span to end of line). Task ID, then flag tags, then action tag run\n    left-to-right. The remaining text is the task description.\n    \"\"\"\n    annotations, remaining = _extract_annotations(raw.text)\n    task_id, remaining = _extract_task_id(remaining)\n    flag_tags, remaining = _extract_flag_tags(remaining)\n    action_tag, remaining = _extract_action_tag(remaining)\n    return _TaskBuilder(\n        task_id=task_id,\n        text=remaining.strip(),\n        status=TaskStatus.from_marker(raw.status_char),\n        flag_tags=flag_tags,\n        action_tag=action_tag,\n        annotations=annotations,\n        indent_level=len(raw.indent),\n        line_number=raw.line_number,\n    )\n\n\ndef _current_scope_tasks(\n    *,\n    in_bugs: bool,\n    bugs_b: _BugsBuilder | None,\n    current_subsection: _SubsectionBuilder | None,\n    current_phase: _PhaseBuilder | None,\n) -> list[_TaskBuilder] | None:\n    \"\"\"Pick the root-task list for the active section.\n\n    The order encodes the grammar: a Bugs section excludes phase scope;\n    inside a phase, a current subsection captures following tasks until\n    the next subsection or phase. Returns ``None`` when no section is\n    active — i.e. the input has not yet introduced a phase or bugs\n    heading, so any task/sibling line is an orphan.\n    \"\"\"\n    if in_bugs:\n        return bugs_b.tasks if bugs_b is not None else None\n    if current_subsection is not None:\n        return current_subsection.tasks\n    if current_phase is not None:\n        return current_phase.tasks\n    return None\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\nclass _HasIndentLevel(Protocol):\n    \"\"\"Anything with an integer ``indent_level`` attribute.\n\n    Used by :func:`_attach_ruledout` so it can resolve attachment over\n    either the eventual frozen ``Task`` model objects or the mutable\n    builder records the parser uses while constructing them.\n    \"\"\"\n\n    @property\n    def indent_level(self) -> int: ...\n\n\n_T = TypeVar(\"_T\", bound=_HasIndentLevel)\n\n\ndef _attach_ruledout(\n    indent: int,\n    stack: Sequence[_T],\n    root_tasks: Sequence[_T],\n) -> _T | None:\n    \"\"\"Resolve the task a ``[RULEDOUT]`` line should attach to.\n\n    Mirrors mcloop's ``parse`` (``checklist.py`` lines 189-204): walk\n    the open-ancestor stack from innermost to outermost and return the\n    first task whose indent is strictly less than the RULEDOUT line's\n    indent. If no such ancestor exists in the current phase, fall back\n    to the most recent root task (mcloop's \"orphan\" handling). Returns\n    ``None`` only when both ``stack`` and ``root_tasks`` are empty —\n    i.e. a stray ``[RULEDOUT]`` before any task in the phase, which\n    the caller should drop.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task\n    if root_tasks:\n        return root_tasks[-1]\n    return None\n\n\ndef _attach_deps(\n    indent: int,\n    stack: Sequence[_T],\n) -> tuple[_T | None, bool]:\n    \"\"\"Resolve the task a ``@deps`` sibling line should attach to.\n\n    Walks the open-ancestor stack from innermost (top) to outermost.\n    Returns ``(parent, False)`` for the strict form — first ancestor\n    whose indent is strictly less than the deps line's indent. Returns\n    ``(parent, True)`` for the lenient form — first ancestor at the\n    same indent as the deps line, which callers should report as a\n    validation warning (the deps was not indented under its task).\n    Returns ``(None, False)`` when no candidate exists; the caller\n    should drop the line.\n\n    Unlike ``_attach_ruledout`` there is no root-task fallback: a\n    ``@deps`` line not anchored to a preceding task at lesser-or-equal\n    indent is malformed input rather than an orphan that needs adopting.\n    \"\"\"\n    for task in reversed(stack):\n        if task.indent_level < indent:\n            return task, False\n        if task.indent_level == indent:\n            return task, True\n    return None, False\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n\n\n# Mutable builder records used while walking the input. The public\n# model dataclasses are frozen, so the parser builds with these and\n# calls ``freeze`` to produce the immutable tree at the end. Each\n# builder also satisfies the ``_HasIndentLevel`` protocol so the\n# existing ``_attach_*`` helpers operate on them directly.\n\n\n@dataclass\nclass _TaskBuilder:\n    \"\"\"Mutable counterpart of :class:`Task` used during parsing.\"\"\"\n\n    task_id: str | None\n    text: str\n    status: TaskStatus\n    flag_tags: tuple[str, ...]\n    action_tag: tuple[str, str] | None\n    annotations: tuple[tuple[str, str], ...]\n    indent_level: int\n    line_number: int\n    deps: list[str] = field(default_factory=list)\n    children: list[_TaskBuilder] = field(default_factory=list)\n    ruled_out: list[RuledOut] = field(default_factory=list)\n\n    def freeze(self) -> Task:\n        return Task(\n            task_id=self.task_id,\n            text=self.text,\n            status=self.status,\n            flag_tags=self.flag_tags,\n            action_tag=self.action_tag,\n            annotations=self.annotations,\n            deps=tuple(self.deps),\n            children=tuple(c.freeze() for c in self.children),\n            ruled_out=tuple(self.ruled_out),\n            indent_level=self.indent_level,\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _SubsectionBuilder:\n    \"\"\"Mutable counterpart of :class:`Subsection`.\"\"\"\n\n    title: str\n    line_number: int\n    prose: str = \"\"\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Subsection:\n        return Subsection(\n            title=self.title,\n            prose=self.prose,\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _PhaseBuilder:\n    \"\"\"Mutable counterpart of :class:`Phase`.\"\"\"\n\n    ordinal: int\n    keyword: str\n    title: str\n    line_number: int\n    phase_id: str | None = None\n    phase_id_source: str = \"none\"\n    prose: str = \"\"\n    subsections: list[_SubsectionBuilder] = field(default_factory=list)\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> Phase:\n        return Phase(\n            phase_id=self.phase_id,\n            phase_id_source=self.phase_id_source,\n            ordinal=self.ordinal,\n            keyword=self.keyword,\n            title=self.title,\n            prose=self.prose,\n            subsections=tuple(s.freeze() for s in self.subsections),\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n\n\n@dataclass\nclass _BugsBuilder:\n    \"\"\"Mutable counterpart of :class:`BugsSection`.\"\"\"\n\n    line_number: int\n    tasks: list[_TaskBuilder] = field(default_factory=list)\n\n    def freeze(self) -> BugsSection:\n        return BugsSection(\n            tasks=tuple(t.freeze() for t in self.tasks),\n            line_number=self.line_number,\n        )\n","numLines":742,"startLine":1,"totalLines":742}}}
