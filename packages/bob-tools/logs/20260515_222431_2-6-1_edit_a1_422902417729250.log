{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y49X27CkYsiiYLvqaqrPCE","type":"tool_result","content":"1\t\"\"\"Tests for bob_tools.planfile.parser building blocks.\n2\t\n3\tStage 2 task-line recognizers and tag extractors:\n4\t\n5\t  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n6\t    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n7\t  - ``_parse_task_line`` returns a raw record on checkbox lines and\n8\t    ``None`` on anything else.\n9\t  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n10\t    sibling lines and returns indent, body, and source line number.\n11\t  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n12\t    line: nearest strictly-less-indented open ancestor, with fallback\n13\t    to the most recent root task (mcloop's ``parse`` parity). The\n14\t    parse-then-attach composition test confirms multiple RULEDOUT\n15\t    lines on one task are collected in source order.\n16\t  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n17\t    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n18\t    enforces that at least one ID follows the keyword.\n19\t  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n20\t    sibling line: the innermost open ancestor at strictly-less indent\n21\t    is the strict-form parent; an ancestor at equal indent is the\n22\t    lenient-form parent (caller should warn). No root-task fallback.\n23\t    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n24\t    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n25\t  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n26\t    tokens, in isolation and combination, and leaves non-leading\n27\t    occurrences as prose (design doc section 4.3).\n28\t  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n29\t    treats the rest of the line as its argument string; non-leading\n30\t    occurrences are prose.\n31\t  - ``_extract_annotations`` consumes trailing ``[key: value]``\n32\t    annotations, handles multiple annotations and nested brackets in\n33\t    values, and leaves bracketed prose that is not separated from\n34\t    preceding text by whitespace in place.\n35\t\"\"\"\n36\t\n37\tfrom __future__ import annotations\n38\t\n39\tfrom dataclasses import dataclass\n40\tfrom pathlib import Path\n41\t\n42\timport pytest\n43\t\n44\tfrom bob_tools.planfile.model import PlanSyntaxError, TaskStatus\n45\tfrom bob_tools.planfile.parser import (\n46\t    _CHECKBOX_RE,\n47\t    _DEPS_RE,\n48\t    _attach_deps,\n49\t    _attach_ruledout,\n50\t    _extract_action_tag,\n51\t    _extract_annotations,\n52\t    _extract_flag_tags,\n53\t    _parse_ruledout_line,\n54\t    _parse_task_line,\n55\t    parse_plan,\n56\t)\n57\t\n58\t\n59\t@dataclass\n60\tclass _FakeTask:\n61\t    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n62\t\n63\t    indent_level: int\n64\t    name: str = \"\"\n65\t\n66\t\n67\tclass TestCheckboxRe:\n68\t    @pytest.mark.parametrize(\n69\t        (\"line\", \"indent\", \"marker\", \"text\"),\n70\t        [\n71\t            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n72\t            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n73\t            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n74\t            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n75\t            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n76\t        ],\n77\t    )\n78\t    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n79\t        m = _CHECKBOX_RE.match(line)\n80\t        assert m is not None\n81\t        assert m.group(1) == indent\n82\t        assert m.group(2) == marker\n83\t        assert m.group(3) == text\n84\t\n85\t    @pytest.mark.parametrize(\n86\t        \"line\",\n87\t        [\n88\t            \"\",\n89\t            \"## Stage 1: Core\",\n90\t            \"- [] missing space inside brackets\",\n91\t            \"- [y] unsupported marker\",\n92\t            \"- [ ]\",\n93\t            \"* [ ] wrong bullet\",\n94\t            \"Plain prose line\",\n95\t        ],\n96\t    )\n97\t    def test_non_matches(self, line: str) -> None:\n98\t        assert _CHECKBOX_RE.match(line) is None\n99\t\n100\t"}]},"parent_tool_use_id":null,"session_id":"60d85b9b-07d2-4666-b129-0e41e9f14a76","uuid":"a1dfdf54-e836-4b2e-a6dc-700f47397cf8","timestamp":"2026-05-16T03:21:31.083Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"\"\"\"Tests for bob_tools.planfile.parser building blocks.\n\nStage 2 task-line recognizers and tag extractors:\n\n  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n  - ``_parse_task_line`` returns a raw record on checkbox lines and\n    ``None`` on anything else.\n  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n    sibling lines and returns indent, body, and source line number.\n  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n    line: nearest strictly-less-indented open ancestor, with fallback\n    to the most recent root task (mcloop's ``parse`` parity). The\n    parse-then-attach composition test confirms multiple RULEDOUT\n    lines on one task are collected in source order.\n  - ``_DEPS_RE`` recognizes ``@deps`` sibling lines, captures indent\n    and the whitespace-separated tail of bare ``T-NNNNNN`` IDs, and\n    enforces that at least one ID follows the keyword.\n  - ``_attach_deps`` resolves the attachment target for an ``@deps``\n    sibling line: the innermost open ancestor at strictly-less indent\n    is the strict-form parent; an ancestor at equal indent is the\n    lenient-form parent (caller should warn). No root-task fallback.\n    A composition test pairs ``_DEPS_RE`` parsing with ``_attach_deps``\n    to confirm a deeply-indented ``@deps`` lands on a nested subtask.\n  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n    tokens, in isolation and combination, and leaves non-leading\n    occurrences as prose (design doc section 4.3).\n  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n    treats the rest of the line as its argument string; non-leading\n    occurrences are prose.\n  - ``_extract_annotations`` consumes trailing ``[key: value]``\n    annotations, handles multiple annotations and nested brackets in\n    values, and leaves bracketed prose that is not separated from\n    preceding text by whitespace in place.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom pathlib import Path\n\nimport pytest\n\nfrom bob_tools.planfile.model import PlanSyntaxError, TaskStatus\nfrom bob_tools.planfile.parser import (\n    _CHECKBOX_RE,\n    _DEPS_RE,\n    _attach_deps,\n    _attach_ruledout,\n    _extract_action_tag,\n    _extract_annotations,\n    _extract_flag_tags,\n    _parse_ruledout_line,\n    _parse_task_line,\n    parse_plan,\n)\n\n\n@dataclass\nclass _FakeTask:\n    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n\n    indent_level: int\n    name: str = \"\"\n\n\nclass TestCheckboxRe:\n    @pytest.mark.parametrize(\n        (\"line\", \"indent\", \"marker\", \"text\"),\n        [\n            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n        ],\n    )\n    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n        m = _CHECKBOX_RE.match(line)\n        assert m is not None\n        assert m.group(1) == indent\n        assert m.group(2) == marker\n        assert m.group(3) == text\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"## Stage 1: Core\",\n            \"- [] missing space inside brackets\",\n            \"- [y] unsupported marker\",\n            \"- [ ]\",\n            \"* [ ] wrong bullet\",\n            \"Plain prose line\",\n        ],\n    )\n    def test_non_matches(self, line: str) -> None:\n        assert _CHECKBOX_RE.match(line) is None\n\n","numLines":100,"startLine":1,"totalLines":1052}}}
