{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N2VwdsuV2tT4N2De8tjY19","type":"tool_result","content":"525\t\n526\t    The state machine in 2.5.2 is responsible for the section-vs-task\n527\t    bookkeeping that earlier building blocks do not own: routing tasks\n528\t    into the right phase or subsection, opening/closing the indent\n529\t    stack at phase/subsection/bugs boundaries, and dispatching ``@deps``\n530\t    and ``[RULEDOUT]`` siblings to the parent task. Tests below\n531\t    exercise each of those responsibilities independently and then in\n532\t    combination on a small but representative plan.\n533\t    \"\"\"\n534\t\n535\t    def test_empty_text_returns_empty_plan(self) -> None:\n536\t        plan = parse_plan(\"\")\n537\t        assert plan.phases == ()\n538\t        assert plan.bugs is None\n539\t        assert plan.project_title == \"\"\n540\t\n541\t    def test_single_phase_with_tasks(self) -> None:\n542\t        text = \"## Stage 1: Core\\n\\n- [ ] first task\\n- [x] second task\\n\"\n543\t        plan = parse_plan(text)\n544\t        assert len(plan.phases) == 1\n545\t        phase = plan.phases[0]\n546\t        assert phase.ordinal == 1\n547\t        assert phase.keyword == \"Stage\"\n548\t        assert phase.title == \"Core\"\n549\t        assert phase.line_number == 1\n550\t        assert len(phase.tasks) == 2\n551\t        assert phase.tasks[0].text == \"first task\"\n552\t        assert phase.tasks[0].status is TaskStatus.TODO\n553\t        assert phase.tasks[0].line_number == 3\n554\t        assert phase.tasks[1].status is TaskStatus.DONE\n555\t\n556\t    def test_phase_heading_keyword_normalized(self) -> None:\n557\t        # \"Phase\" and \"Stage\" are accepted interchangeably and the\n558\t        # keyword captures which form was used (capitalized).\n559\t        plan = parse_plan(\"# Phase 2: Implementation\\n- [ ] x\\n\")\n560\t        assert plan.phases[0].keyword == \"Phase\"\n561\t        assert plan.phases[0].ordinal == 2\n562\t        assert plan.phases[0].title == \"Implementation\"\n563\t\n564\t    def test_phase_with_non_bare_digit_id_is_not_a_phase_heading(self) -> None:\n565\t        # `## Phase phase_001:` is the legacy strict-form heading; per\n566\t        # design doc section 2.5 it does NOT match the bare-digit\n567\t        # STAGE_RE and so is invisible to the compat parser. The tasks\n568\t        # that follow have no enclosing phase and are dropped.\n569\t        text = \"## Phase phase_001: Core\\n- [ ] orphan task\\n\"\n570\t        plan = parse_plan(text)\n571\t        assert plan.phases == ()\n572\t        assert plan.bugs is None\n573\t\n574\t    def test_indent_stack_builds_task_tree(self) -> None:\n575\t        text = (\n576\t            \"## Stage 1: Core\\n\"\n577\t            \"- [ ] parent\\n\"\n578\t            \"  - [ ] child a\\n\"\n579\t            \"    - [ ] grandchild\\n\"\n580\t            \"  - [ ] child b\\n\"\n581\t            \"- [ ] second root\\n\"\n582\t        )\n583\t        plan = parse_plan(text)\n584\t        phase = plan.phases[0]\n585\t        assert len(phase.tasks) == 2\n586\t        parent, second_root = phase.tasks\n587\t        assert parent.text == \"parent\"\n588\t        assert second_root.text == \"second root\"\n589\t        assert len(parent.children) == 2\n590\t        child_a, child_b = parent.children\n591\t        assert child_a.text == \"child a\"\n592\t        assert child_b.text == \"child b\"\n593\t        assert len(child_a.children) == 1\n594\t        assert child_a.children[0].text == \"grandchild\"\n595\t\n596\t    def test_subsection_captures_following_tasks(self) -> None:\n597\t        text = (\n598\t            \"## Stage 1: Core\\n\"\n599\t            \"- [ ] phase task\\n\"\n600\t            \"\\n\"\n601\t            \"### Manual verification\\n\"\n602\t            \"- [ ] sub task one\\n\"\n603\t            \"- [ ] sub task two\\n\"\n604\t        )\n605\t        plan = parse_plan(text)\n606\t        phase = plan.phases[0]\n607\t        assert len(phase.tasks) == 1\n608\t        assert phase.tasks[0].text == \"phase task\"\n609\t        assert len(phase.subsections) == 1\n610\t        sub = phase.subsections[0]\n611\t        assert sub.title == \"Manual verification\"\n612\t        assert tuple(t.text for t in sub.tasks) == (\"sub task one\", \"sub task two\")\n613\t\n614\t    def test_new_phase_resets_indent_stack(self) -> None:\n615\t        # An indented task in the second phase must be treated as a\n616\t        # root of that phase, not as a child of the previous phase's\n617\t        # last task. (mcloop's parser does this via stack.clear().)\n618\t        text = (\n619\t            \"## Stage 1: A\\n- [ ] one\\n  - [ ] one-child\\n## Stage 2: B\\n  - [ ] two\\n\"\n620\t        )\n621\t        plan = parse_plan(text)\n622\t        assert len(plan.phases) == 2\n623\t        assert len(plan.phases[0].tasks) == 1\n624\t        assert plan.phases[0].tasks[0].children[0].text == \"one-child\""}]},"parent_tool_use_id":null,"session_id":"60d85b9b-07d2-4666-b129-0e41e9f14a76","uuid":"ab9ffa37-48fb-4fde-9977-468bef06e90b","timestamp":"2026-05-16T03:22:47.240Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"\n    The state machine in 2.5.2 is responsible for the section-vs-task\n    bookkeeping that earlier building blocks do not own: routing tasks\n    into the right phase or subsection, opening/closing the indent\n    stack at phase/subsection/bugs boundaries, and dispatching ``@deps``\n    and ``[RULEDOUT]`` siblings to the parent task. Tests below\n    exercise each of those responsibilities independently and then in\n    combination on a small but representative plan.\n    \"\"\"\n\n    def test_empty_text_returns_empty_plan(self) -> None:\n        plan = parse_plan(\"\")\n        assert plan.phases == ()\n        assert plan.bugs is None\n        assert plan.project_title == \"\"\n\n    def test_single_phase_with_tasks(self) -> None:\n        text = \"## Stage 1: Core\\n\\n- [ ] first task\\n- [x] second task\\n\"\n        plan = parse_plan(text)\n        assert len(plan.phases) == 1\n        phase = plan.phases[0]\n        assert phase.ordinal == 1\n        assert phase.keyword == \"Stage\"\n        assert phase.title == \"Core\"\n        assert phase.line_number == 1\n        assert len(phase.tasks) == 2\n        assert phase.tasks[0].text == \"first task\"\n        assert phase.tasks[0].status is TaskStatus.TODO\n        assert phase.tasks[0].line_number == 3\n        assert phase.tasks[1].status is TaskStatus.DONE\n\n    def test_phase_heading_keyword_normalized(self) -> None:\n        # \"Phase\" and \"Stage\" are accepted interchangeably and the\n        # keyword captures which form was used (capitalized).\n        plan = parse_plan(\"# Phase 2: Implementation\\n- [ ] x\\n\")\n        assert plan.phases[0].keyword == \"Phase\"\n        assert plan.phases[0].ordinal == 2\n        assert plan.phases[0].title == \"Implementation\"\n\n    def test_phase_with_non_bare_digit_id_is_not_a_phase_heading(self) -> None:\n        # `## Phase phase_001:` is the legacy strict-form heading; per\n        # design doc section 2.5 it does NOT match the bare-digit\n        # STAGE_RE and so is invisible to the compat parser. The tasks\n        # that follow have no enclosing phase and are dropped.\n        text = \"## Phase phase_001: Core\\n- [ ] orphan task\\n\"\n        plan = parse_plan(text)\n        assert plan.phases == ()\n        assert plan.bugs is None\n\n    def test_indent_stack_builds_task_tree(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] parent\\n\"\n            \"  - [ ] child a\\n\"\n            \"    - [ ] grandchild\\n\"\n            \"  - [ ] child b\\n\"\n            \"- [ ] second root\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert len(phase.tasks) == 2\n        parent, second_root = phase.tasks\n        assert parent.text == \"parent\"\n        assert second_root.text == \"second root\"\n        assert len(parent.children) == 2\n        child_a, child_b = parent.children\n        assert child_a.text == \"child a\"\n        assert child_b.text == \"child b\"\n        assert len(child_a.children) == 1\n        assert child_a.children[0].text == \"grandchild\"\n\n    def test_subsection_captures_following_tasks(self) -> None:\n        text = (\n            \"## Stage 1: Core\\n\"\n            \"- [ ] phase task\\n\"\n            \"\\n\"\n            \"### Manual verification\\n\"\n            \"- [ ] sub task one\\n\"\n            \"- [ ] sub task two\\n\"\n        )\n        plan = parse_plan(text)\n        phase = plan.phases[0]\n        assert len(phase.tasks) == 1\n        assert phase.tasks[0].text == \"phase task\"\n        assert len(phase.subsections) == 1\n        sub = phase.subsections[0]\n        assert sub.title == \"Manual verification\"\n        assert tuple(t.text for t in sub.tasks) == (\"sub task one\", \"sub task two\")\n\n    def test_new_phase_resets_indent_stack(self) -> None:\n        # An indented task in the second phase must be treated as a\n        # root of that phase, not as a child of the previous phase's\n        # last task. (mcloop's parser does this via stack.clear().)\n        text = (\n            \"## Stage 1: A\\n- [ ] one\\n  - [ ] one-child\\n## Stage 2: B\\n  - [ ] two\\n\"\n        )\n        plan = parse_plan(text)\n        assert len(plan.phases) == 2\n        assert len(plan.phases[0].tasks) == 1\n        assert plan.phases[0].tasks[0].children[0].text == \"one-child\"","numLines":100,"startLine":525,"totalLines":1052}}}
