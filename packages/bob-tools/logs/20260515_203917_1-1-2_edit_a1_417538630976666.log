{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JMqzjMDLLPmkPSMGHMMfJy","type":"tool_result","content":"1\t\"\"\"Plan Ledger.\n2\t\n3\tAppend-only event log + deterministic state projection for Bob's plan\n4\tlifecycle. Slice A ships the event schema and validators; Slice B-D\n5\tbuild threshold rules, re-author mode, and McLoop pause-on-threshold\n6\ton top.\n7\t\n8\tSee ``bob/design/plan-ledger.md`` (in the sibling ``bob`` repo) for\n9\tthe design doc, and ``bob_tools/ledger/SCHEMA.md`` for the\n10\thuman-readable schema reference.\n11\t\"\"\"\n12\t\n13\tfrom __future__ import annotations\n14\t\n15\tfrom bob_tools.ledger.events import (\n16\t    ACTIVE_EVENT_TYPES,\n17\t    PAYLOAD_BUILDERS,\n18\t    RESERVED_EVENT_TYPES,\n19\t    SCHEMA_VERSION,\n20\t    AssumptionConfidence,\n21\t    CommitChangeClass,\n22\t    Event,\n23\t    EventType,\n24\t    GitSnapshot,\n25\t    RejectedApproach,\n26\t    is_well_formed_event_id,\n27\t)\n28\tfrom bob_tools.ledger.projector import (\n29\t    AssumptionRecord,\n30\t    HumanDecisionRecord,\n31\t    InvariantRecord,\n32\t    PhaseLineage,\n33\t    PhaseRecord,\n34\t    PhaseStatus,\n35\t    PhaseSupersession,\n36\t    PlanState,\n37\t    project,\n38\t)\n39\tfrom bob_tools.ledger.schema import (\n40\t    ENVELOPE_SCHEMA,\n41\t    EVENT_SCHEMA,\n42\t    PAYLOAD_SCHEMAS,\n43\t    EventSchemaError,\n44\t    iter_validation_errors,\n45\t    validate_event,\n46\t    validate_event_id_format,\n47\t)\n48\tfrom bob_tools.ledger.storage import (\n49\t    EVENTS_FILENAME,\n50\t    WRITERS_DIRNAME,\n51\t    Storage,\n52\t    allocate_writer_id,\n53\t)\n54\tfrom bob_tools.ledger.thresholds import (\n55\t    ALL_RULES,\n56\t    ThresholdCrossing,\n57\t    ThresholdParams,\n58\t    ThresholdRecommendedAction,\n59\t    ThresholdRuleId,\n60\t    ThresholdSeverity,\n61\t    evaluate_thresholds,\n62\t    record_crossings,\n63\t)\n64\t\n65\t__all__ = [\n66\t    \"ACTIVE_EVENT_TYPES\",\n67\t    \"ALL_RULES\",\n68\t    \"ENVELOPE_SCHEMA\",\n69\t    \"EVENTS_FILENAME\",\n70\t    \"EVENT_SCHEMA\",\n71\t    \"PAYLOAD_BUILDERS\",\n72\t    \"PAYLOAD_SCHEMAS\",\n73\t    \"RESERVED_EVENT_TYPES\",\n74\t    \"SCHEMA_VERSION\",\n75\t    \"WRITERS_DIRNAME\",\n76\t    \"AssumptionConfidence\",\n77\t    \"AssumptionRecord\",\n78\t    \"CommitChangeClass\",\n79\t    \"Event\",\n80\t    \"EventSchemaError\",\n81\t    \"EventType\",\n82\t    \"GitSnapshot\",\n83\t    \"HumanDecisionRecord\",\n84\t    \"InvariantRecord\",\n85\t    \"PhaseLineage\",\n86\t    \"PhaseRecord\",\n87\t    \"PhaseStatus\",\n88\t    \"PhaseSupersession\",\n89\t    \"PlanState\",\n90\t    \"RejectedApproach\",\n91\t    \"Storage\",\n92\t    \"ThresholdCrossing\",\n93\t    \"ThresholdParams\",\n94\t    \"ThresholdRecommendedAction\",\n95\t    \"ThresholdRuleId\",\n96\t    \"ThresholdSeverity\",\n97\t    \"allocate_writer_id\",\n98\t    \"evaluate_thresholds\",\n99\t    \"is_well_formed_event_id\",\n100\t    \"iter_validation_errors\",\n101\t    \"project\",\n102\t    \"record_crossings\",\n103\t    \"validate_event\",\n104\t    \"validate_event_id_format\",\n105\t]\n106\t"}]},"parent_tool_use_id":null,"session_id":"e39af262-b2c8-4b32-8dff-71d82baf4eda","uuid":"2fff6912-0992-43be-a082-9d50b72bc54d","timestamp":"2026-05-16T01:37:09.426Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/ledger/__init__.py","content":"\"\"\"Plan Ledger.\n\nAppend-only event log + deterministic state projection for Bob's plan\nlifecycle. Slice A ships the event schema and validators; Slice B-D\nbuild threshold rules, re-author mode, and McLoop pause-on-threshold\non top.\n\nSee ``bob/design/plan-ledger.md`` (in the sibling ``bob`` repo) for\nthe design doc, and ``bob_tools/ledger/SCHEMA.md`` for the\nhuman-readable schema reference.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom bob_tools.ledger.events import (\n    ACTIVE_EVENT_TYPES,\n    PAYLOAD_BUILDERS,\n    RESERVED_EVENT_TYPES,\n    SCHEMA_VERSION,\n    AssumptionConfidence,\n    CommitChangeClass,\n    Event,\n    EventType,\n    GitSnapshot,\n    RejectedApproach,\n    is_well_formed_event_id,\n)\nfrom bob_tools.ledger.projector import (\n    AssumptionRecord,\n    HumanDecisionRecord,\n    InvariantRecord,\n    PhaseLineage,\n    PhaseRecord,\n    PhaseStatus,\n    PhaseSupersession,\n    PlanState,\n    project,\n)\nfrom bob_tools.ledger.schema import (\n    ENVELOPE_SCHEMA,\n    EVENT_SCHEMA,\n    PAYLOAD_SCHEMAS,\n    EventSchemaError,\n    iter_validation_errors,\n    validate_event,\n    validate_event_id_format,\n)\nfrom bob_tools.ledger.storage import (\n    EVENTS_FILENAME,\n    WRITERS_DIRNAME,\n    Storage,\n    allocate_writer_id,\n)\nfrom bob_tools.ledger.thresholds import (\n    ALL_RULES,\n    ThresholdCrossing,\n    ThresholdParams,\n    ThresholdRecommendedAction,\n    ThresholdRuleId,\n    ThresholdSeverity,\n    evaluate_thresholds,\n    record_crossings,\n)\n\n__all__ = [\n    \"ACTIVE_EVENT_TYPES\",\n    \"ALL_RULES\",\n    \"ENVELOPE_SCHEMA\",\n    \"EVENTS_FILENAME\",\n    \"EVENT_SCHEMA\",\n    \"PAYLOAD_BUILDERS\",\n    \"PAYLOAD_SCHEMAS\",\n    \"RESERVED_EVENT_TYPES\",\n    \"SCHEMA_VERSION\",\n    \"WRITERS_DIRNAME\",\n    \"AssumptionConfidence\",\n    \"AssumptionRecord\",\n    \"CommitChangeClass\",\n    \"Event\",\n    \"EventSchemaError\",\n    \"EventType\",\n    \"GitSnapshot\",\n    \"HumanDecisionRecord\",\n    \"InvariantRecord\",\n    \"PhaseLineage\",\n    \"PhaseRecord\",\n    \"PhaseStatus\",\n    \"PhaseSupersession\",\n    \"PlanState\",\n    \"RejectedApproach\",\n    \"Storage\",\n    \"ThresholdCrossing\",\n    \"ThresholdParams\",\n    \"ThresholdRecommendedAction\",\n    \"ThresholdRuleId\",\n    \"ThresholdSeverity\",\n    \"allocate_writer_id\",\n    \"evaluate_thresholds\",\n    \"is_well_formed_event_id\",\n    \"iter_validation_errors\",\n    \"project\",\n    \"record_crossings\",\n    \"validate_event\",\n    \"validate_event_id_format\",\n]\n","numLines":106,"startLine":1,"totalLines":106}}}
