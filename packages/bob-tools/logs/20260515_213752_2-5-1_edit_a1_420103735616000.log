{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MW1royVT3ijPtnCeBTzvqd","type":"tool_result","content":"1\t\"\"\"Pure operations on typed Plan objects (validate, migrate, mutate, schedule).\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom collections.abc import Iterator\n6\t\n7\tfrom bob_tools.planfile.model import Plan, PlanValidationError, Task\n8\t\n9\t\n10\tdef _iter_tasks(tasks: tuple[Task, ...]) -> Iterator[Task]:\n11\t    \"\"\"Yield every task in ``tasks``, descending into ``children`` first.\"\"\"\n12\t    for task in tasks:\n13\t        yield task\n14\t        yield from _iter_tasks(task.children)\n15\t\n16\t\n17\tdef _iter_plan_tasks(plan: Plan) -> Iterator[Task]:\n18\t    \"\"\"Yield every Task in the plan: phase tasks, subsection tasks, bugs.\"\"\"\n19\t    for phase in plan.phases:\n20\t        yield from _iter_tasks(phase.tasks)\n21\t        for subsection in phase.subsections:\n22\t            yield from _iter_tasks(subsection.tasks)\n23\t    if plan.bugs is not None:\n24\t        yield from _iter_tasks(plan.bugs.tasks)\n25\t\n26\t\n27\tdef validate_plan(plan: Plan) -> None:\n28\t    \"\"\"Validate referential integrity of ``@deps`` references in ``plan``.\n29\t\n30\t    Every task ID listed in any task's ``deps`` must resolve to the\n31\t    ``task_id`` of some task in the plan. Otherwise raise\n32\t    :class:`PlanValidationError` carrying one message per missing\n33\t    reference (design doc section 8 phase A: \"validation requires\n34\t    referenced IDs to exist in the plan\").\n35\t\n36\t    Parse-time concerns (syntax, structure) are not re-checked here; the\n37\t    parser raises :class:`PlanSyntaxError` for those. Validation only\n38\t    cross-checks references between already-parsed objects.\n39\t    \"\"\"\n40\t    known_ids: set[str] = {\n41\t        task.task_id for task in _iter_plan_tasks(plan) if task.task_id is not None\n42\t    }\n43\t\n44\t    errors: list[str] = []\n45\t    for task in _iter_plan_tasks(plan):\n46\t        for dep in task.deps:\n47\t            if dep not in known_ids:\n48\t                ref = (\n49\t                    task.task_id\n50\t                    if task.task_id is not None\n51\t                    else (f\"line {task.line_number}\")\n52\t                )\n53\t                errors.append(f\"task {ref} references unknown dep {dep}\")\n54\t\n55\t    if errors:\n56\t        raise PlanValidationError(errors)\n57\t"}]},"parent_tool_use_id":null,"session_id":"228b2004-1673-44ee-a1d9-d52a275764b9","uuid":"d993d693-ad04-45af-b4ce-d310a0a73c44","timestamp":"2026-05-16T02:33:07.419Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/operations.py","content":"\"\"\"Pure operations on typed Plan objects (validate, migrate, mutate, schedule).\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Iterator\n\nfrom bob_tools.planfile.model import Plan, PlanValidationError, Task\n\n\ndef _iter_tasks(tasks: tuple[Task, ...]) -> Iterator[Task]:\n    \"\"\"Yield every task in ``tasks``, descending into ``children`` first.\"\"\"\n    for task in tasks:\n        yield task\n        yield from _iter_tasks(task.children)\n\n\ndef _iter_plan_tasks(plan: Plan) -> Iterator[Task]:\n    \"\"\"Yield every Task in the plan: phase tasks, subsection tasks, bugs.\"\"\"\n    for phase in plan.phases:\n        yield from _iter_tasks(phase.tasks)\n        for subsection in phase.subsections:\n            yield from _iter_tasks(subsection.tasks)\n    if plan.bugs is not None:\n        yield from _iter_tasks(plan.bugs.tasks)\n\n\ndef validate_plan(plan: Plan) -> None:\n    \"\"\"Validate referential integrity of ``@deps`` references in ``plan``.\n\n    Every task ID listed in any task's ``deps`` must resolve to the\n    ``task_id`` of some task in the plan. Otherwise raise\n    :class:`PlanValidationError` carrying one message per missing\n    reference (design doc section 8 phase A: \"validation requires\n    referenced IDs to exist in the plan\").\n\n    Parse-time concerns (syntax, structure) are not re-checked here; the\n    parser raises :class:`PlanSyntaxError` for those. Validation only\n    cross-checks references between already-parsed objects.\n    \"\"\"\n    known_ids: set[str] = {\n        task.task_id for task in _iter_plan_tasks(plan) if task.task_id is not None\n    }\n\n    errors: list[str] = []\n    for task in _iter_plan_tasks(plan):\n        for dep in task.deps:\n            if dep not in known_ids:\n                ref = (\n                    task.task_id\n                    if task.task_id is not None\n                    else (f\"line {task.line_number}\")\n                )\n                errors.append(f\"task {ref} references unknown dep {dep}\")\n\n    if errors:\n        raise PlanValidationError(errors)\n","numLines":57,"startLine":1,"totalLines":57}}}
