{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013rP2u5Hg39gHnLX5ikWKvp","type":"tool_result","content":"1\t\"\"\"Tests for the planfile typed model and exception types.\n2\t\n3\tCovers:\n4\t\n5\t  - ``TaskStatus`` enum membership and the checkbox-marker mapping\n6\t    (space/x/X/!) per design doc section 2.1.\n7\t  - Dataclass construction for ``RuledOut``, ``Task``, ``Subsection``,\n8\t    ``Phase``, ``BugsSection``, and ``Plan`` with the field layout\n9\t    specified in stage 1.2.\n10\t  - Frozen-dataclass behavior: every model dataclass rejects attribute\n11\t    mutation by raising ``dataclasses.FrozenInstanceError``.\n12\t  - ``PlanSyntaxError.__str__`` formatting matches design doc section 9\n13\t    (\"PLAN.md invalid at line N, column M: ...\").\n14\t  - ``PlanValidationError`` and ``PlanInconsistencyError`` carry their\n15\t    messages list and survive round-tripping through ``str``.\n16\t\"\"\"\n17\t\n18\tfrom __future__ import annotations\n19\t\n20\tfrom dataclasses import FrozenInstanceError\n21\tfrom pathlib import Path\n22\t\n23\timport pytest\n24\t\n25\tfrom bob_tools.planfile.model import (\n26\t    CHECKBOX_MARKER_TO_STATUS,\n27\t    BugsSection,\n28\t    Phase,\n29\t    Plan,\n30\t    PlanInconsistencyError,\n31\t    PlanSyntaxError,\n32\t    PlanValidationError,\n33\t    RuledOut,\n34\t    Subsection,\n35\t    Task,\n36\t    TaskStatus,\n37\t)\n38\t\n39\t\n40\tdef _make_task(**overrides: object) -> Task:\n41\t    \"\"\"Helper: build a Task with sensible defaults for tests.\"\"\"\n42\t    base: dict[str, object] = {\n43\t        \"task_id\": \"T-000001\",\n44\t        \"text\": \"Do the thing\",\n45\t        \"status\": TaskStatus.TODO,\n46\t        \"flag_tags\": (),\n47\t        \"action_tag\": None,\n48\t        \"annotations\": (),\n49\t        \"deps\": (),\n50\t        \"children\": (),\n51\t        \"ruled_out\": (),\n52\t        \"indent_level\": 0,\n53\t        \"line_number\": 10,\n54\t    }\n55\t    base.update(overrides)\n56\t    return Task(**base)  # type: ignore[arg-type]\n57\t\n58\t\n59\tclass TestTaskStatus:\n60\t    def test_three_members(self) -> None:\n61\t        assert {s.name for s in TaskStatus} == {\"TODO\", \"DONE\", \"FAILED\"}\n62\t\n63\t    @pytest.mark.parametrize(\n64\t        (\"marker\", \"expected\"),\n65\t        [\n66\t            (\" \", TaskStatus.TODO),\n67\t            (\"x\", TaskStatus.DONE),\n68\t            (\"X\", TaskStatus.DONE),\n69\t            (\"!\", TaskStatus.FAILED),\n70\t        ],\n71\t    )\n72\t    def test_from_marker(self, marker: str, expected: TaskStatus) -> None:\n73\t        assert TaskStatus.from_marker(marker) == expected\n74\t\n75\t    def test_marker_table_matches_from_marker(self) -> None:\n76\t        for marker, status in CHECKBOX_MARKER_TO_STATUS.items():\n77\t            assert TaskStatus.from_marker(marker) == status\n78\t\n79\t    def test_from_marker_unknown(self) -> None:\n80\t        with pytest.raises(ValueError, match=\"unknown checkbox marker\"):\n81\t            TaskStatus.from_marker(\"?\")\n82\t\n83\t\n84\tclass TestRuledOut:\n85\t    def test_construction(self) -> None:\n86\t        ro = RuledOut(text=\"Tried X; failed because Y.\", line_number=42)\n87\t        assert ro.text == \"Tried X; failed because Y.\"\n88\t        assert ro.line_number == 42\n89\t\n90\t    def test_frozen(self) -> None:\n91\t        ro = RuledOut(text=\"x\", line_number=1)\n92\t        with pytest.raises(FrozenInstanceError):\n93\t            ro.text = \"mutated\"  # type: ignore[misc]\n94\t\n95\t\n96\tclass TestTask:\n97\t    def test_default_construction(self) -> None:\n98\t        task = _make_task()\n99\t        assert task.task_id == \"T-000001\"\n100\t        assert task.status is TaskStatus.TODO\n101\t        assert task.flag_tags == ()\n102\t        assert task.action_tag is None\n103\t        assert task.children == ()\n104\t\n105\t    def test_task_id_can_be_none_for_compat(self) -> None:\n106\t        # design doc section 7.2: IDs are optional in compatibility mode.\n107\t        task = _make_task(task_id=None)\n108\t        assert task.task_id is None\n109\t\n110\t    def test_flag_tags_bare_names(self) -> None:\n111\t        # design doc section 4.3: flag tag members are bare names; the\n112\t        # brackets live only in serialized form.\n113\t        task = _make_task(flag_tags=(\"USER\", \"BATCH\"))\n114\t        assert task.flag_tags == (\"USER\", \"BATCH\")\n115\t\n116\t    def test_action_tag_pair(self) -> None:\n117\t        task = _make_task(action_tag=(\"run_cli\", \"mcloop --dry-run\"))\n118\t        assert task.action_tag == (\"run_cli\", \"mcloop --dry-run\")\n119\t\n120\t    def test_annotations_and_deps(self) -> None:\n121\t        task = _make_task(\n122\t            annotations=((\"feat\", \"menu wired\"), (\"fix\", \"race condition\")),\n123\t            deps=(\"T-000002\", \"T-000003\"),\n124\t        )\n125\t        assert task.annotations[0] == (\"feat\", \"menu wired\")\n126\t        assert task.deps == (\"T-000002\", \"T-000003\")\n127\t\n128\t    def test_children_and_ruled_out(self) -> None:\n129\t        child = _make_task(task_id=\"T-000002\", indent_level=1, line_number=11)\n130\t        ruled = RuledOut(text=\"don't do Y\", line_number=12)\n131\t        task = _make_task(children=(child,), ruled_out=(ruled,))\n132\t        assert task.children == (child,)\n133\t        assert task.ruled_out == (ruled,)\n134\t\n135\t    def test_frozen(self) -> None:\n136\t        task = _make_task()\n137\t        with pytest.raises(FrozenInstanceError):\n138\t            task.text = \"mutated\"  # type: ignore[misc]\n139\t\n140\t\n141\tclass TestSubsection:\n142\t    def test_construction(self) -> None:\n143\t        task = _make_task()\n144\t        sub = Subsection(\n145\t            title=\"Manual verification\",\n146\t            prose=\"\",\n147\t            tasks=(task,),\n148\t            line_number=20,\n149\t        )\n150\t        assert sub.title == \"Manual verification\"\n151\t        assert sub.tasks == (task,)\n152\t\n153\t    def test_frozen(self) -> None:\n154\t        sub = Subsection(title=\"x\", prose=\"\", tasks=(), line_number=1)\n155\t        with pytest.raises(FrozenInstanceError):\n156\t            sub.title = \"mutated\"  # type: ignore[misc]\n157\t\n158\t\n159\tclass TestPhase:\n160\t    def test_construction(self) -> None:\n161\t        task = _make_task()\n162\t        phase = Phase(\n163\t            phase_id=\"phase_001\",\n164\t            phase_id_source=\"explicit_comment\",\n165\t            ordinal=1,\n166\t            keyword=\"Stage\",\n167\t            title=\"Core\",\n168\t            prose=\"\",\n169\t            subsections=(),\n170\t            tasks=(task,),\n171\t            line_number=5,\n172\t        )\n173\t        assert phase.phase_id == \"phase_001\"\n174\t        assert phase.phase_id_source == \"explicit_comment\"\n175\t        assert phase.keyword == \"Stage\"\n176\t        assert phase.tasks == (task,)\n177\t\n178\t    def test_phase_id_can_be_none_with_none_source(self) -> None:\n179\t        phase = Phase(\n180\t            phase_id=None,\n181\t            phase_id_source=\"none\",\n182\t            ordinal=2,\n183\t            keyword=\"Phase\",\n184\t            title=\"Bare\",\n185\t            prose=\"\",\n186\t            subsections=(),\n187\t            tasks=(),\n188\t            line_number=30,\n189\t        )\n190\t        assert phase.phase_id is None\n191\t        assert phase.phase_id_source == \"none\"\n192\t\n193\t    def test_frozen(self) -> None:\n194\t        phase = Phase(\n195\t            phase_id=\"phase_001\",\n196\t            phase_id_source=\"explicit_comment\",\n197\t            ordinal=1,\n198\t            keyword=\"Stage\",\n199\t            title=\"Core\",\n200\t            prose=\"\",\n201\t            subsections=(),\n202\t            tasks=(),\n203\t            line_number=5,\n204\t        )\n205\t        with pytest.raises(FrozenInstanceError):\n206\t            phase.title = \"mutated\"  # type: ignore[misc]\n207\t\n208\t\n209\tclass TestBugsSection:\n210\t    def test_construction(self) -> None:\n211\t        task = _make_task()\n212\t        bugs = BugsSection(tasks=(task,), line_number=100)\n213\t        assert bugs.tasks == (task,)\n214\t        assert bugs.line_number == 100\n215\t\n216\t    def test_frozen(self) -> None:\n217\t        bugs = BugsSection(tasks=(), line_number=1)\n218\t        with pytest.raises(FrozenInstanceError):\n219\t            bugs.line_number = 2  # type: ignore[misc]\n220\t\n221\t\n222\tclass TestPlan:\n223\t    def test_construction(self) -> None:\n224\t        phase = Phase(\n225\t            phase_id=\"phase_001\",\n226\t            phase_id_source=\"explicit_comment\",\n227\t            ordinal=1,\n228\t            keyword=\"Stage\",\n229\t            title=\"Core\",\n230\t            prose=\"\",\n231\t            subsections=(),\n232\t            tasks=(),\n233\t            line_number=5,\n234\t        )\n235\t        plan = Plan(\n236\t            magic_version=1,\n237\t            project_title=\"Project\",\n238\t            preamble=\"\",\n239\t            phases=(phase,),\n240\t            bugs=None,\n241\t            source_path=Path(\"/tmp/PLAN.md\"),\n242\t        )\n243\t        assert plan.magic_version == 1\n244\t        assert plan.phases == (phase,)\n245\t        assert plan.bugs is None\n246\t        assert plan.source_path == Path(\"/tmp/PLAN.md\")\n247\t\n248\t    def test_optional_fields(self) -> None:\n249\t        plan = Plan(\n250\t            magic_version=None,\n251\t            project_title=\"Project\",\n252\t            preamble=\"\",\n253\t            phases=(),\n254\t            bugs=None,\n255\t            source_path=None,\n256\t        )\n257\t        assert plan.magic_version is None\n258\t        assert plan.source_path is None\n259\t\n260\t    def test_frozen(self) -> None:\n261\t        plan = Plan(\n262\t            magic_version=None,\n263\t            project_title=\"x\",\n264\t            preamble=\"\",\n265\t            phases=(),\n266\t            bugs=None,\n267\t            source_path=None,\n268\t        )\n269\t        with pytest.raises(FrozenInstanceError):\n270\t            plan.project_title = \"mutated\"  # type: ignore[misc]\n271\t\n272\t\n273\tclass TestPlanSyntaxError:\n274\t    def test_attributes(self) -> None:\n275\t        err = PlanSyntaxError(\"expected task id\", 17, 5, Path(\"/tmp/PLAN.md\"))\n276\t        assert err.message == \"expected task id\"\n277\t        assert err.line == 17\n278\t        assert err.column == 5\n279\t        assert err.path == Path(\"/tmp/PLAN.md\")\n280\t\n281\t    def test_str_matches_design_doc_format(self) -> None:\n282\t        # design doc section 9: \"PLAN.md invalid at line N, column M: ...\"\n283\t        err = PlanSyntaxError(\n284\t            \"expected task id like T-000123 after checkbox marker\",\n285\t            17,\n286\t            5,\n287\t            Path(\"/tmp/PLAN.md\"),\n288\t        )\n289\t        assert str(err) == (\n290\t            \"PLAN.md invalid at line 17, column 5: \"\n291\t            \"expected task id like T-000123 after checkbox marker\"\n292\t        )\n293\t\n294\t    def test_path_optional(self) -> None:\n295\t        err = PlanSyntaxError(\"bad\", 1, 1)\n296\t        assert err.path is None\n297\t        assert str(err) == \"PLAN.md invalid at line 1, column 1: bad\"\n298\t\n299\t\n300\tclass TestPlanValidationError:\n301\t    def test_messages_preserved(self) -> None:\n302\t        err = PlanValidationError([\"dep T-000999 not found\", \"duplicate id T-000001\"])\n303\t        assert err.messages == [\n304\t            \"dep T-000999 not found\",\n305\t            \"duplicate id T-000001\",\n306\t        ]\n307\t\n308\t    def test_str_joins_messages(self) -> None:\n309\t        err = PlanValidationError([\"a\", \"b\"])\n310\t        assert \"a\" in str(err)\n311\t        assert \"b\" in str(err)\n312\t\n313\t    def test_empty_messages(self) -> None:\n314\t        err = PlanValidationError([])\n315\t        assert err.messages == []\n316\t        assert str(err) == \"\"\n317\t\n318\t\n319\tclass TestPlanInconsistencyError:\n320\t    def test_messages_preserved(self) -> None:\n321\t        err = PlanInconsistencyError([\"task T-000001 [x] but no commit_landed event\"])\n322\t        assert err.messages == [\"task T-000001 [x] but no commit_landed event\"]\n323\t\n324\t    def test_str_joins_messages(self) -> None:\n325\t        err = PlanInconsistencyError([\"x\", \"y\"])\n326\t        assert \"x\" in str(err)\n327\t        assert \"y\" in str(err)\n328\t"}]},"parent_tool_use_id":null,"session_id":"228b2004-1673-44ee-a1d9-d52a275764b9","uuid":"702815e2-1e36-483e-8181-23cc50199afc","timestamp":"2026-05-16T02:35:18.126Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_model.py","content":"\"\"\"Tests for the planfile typed model and exception types.\n\nCovers:\n\n  - ``TaskStatus`` enum membership and the checkbox-marker mapping\n    (space/x/X/!) per design doc section 2.1.\n  - Dataclass construction for ``RuledOut``, ``Task``, ``Subsection``,\n    ``Phase``, ``BugsSection``, and ``Plan`` with the field layout\n    specified in stage 1.2.\n  - Frozen-dataclass behavior: every model dataclass rejects attribute\n    mutation by raising ``dataclasses.FrozenInstanceError``.\n  - ``PlanSyntaxError.__str__`` formatting matches design doc section 9\n    (\"PLAN.md invalid at line N, column M: ...\").\n  - ``PlanValidationError`` and ``PlanInconsistencyError`` carry their\n    messages list and survive round-tripping through ``str``.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import FrozenInstanceError\nfrom pathlib import Path\n\nimport pytest\n\nfrom bob_tools.planfile.model import (\n    CHECKBOX_MARKER_TO_STATUS,\n    BugsSection,\n    Phase,\n    Plan,\n    PlanInconsistencyError,\n    PlanSyntaxError,\n    PlanValidationError,\n    RuledOut,\n    Subsection,\n    Task,\n    TaskStatus,\n)\n\n\ndef _make_task(**overrides: object) -> Task:\n    \"\"\"Helper: build a Task with sensible defaults for tests.\"\"\"\n    base: dict[str, object] = {\n        \"task_id\": \"T-000001\",\n        \"text\": \"Do the thing\",\n        \"status\": TaskStatus.TODO,\n        \"flag_tags\": (),\n        \"action_tag\": None,\n        \"annotations\": (),\n        \"deps\": (),\n        \"children\": (),\n        \"ruled_out\": (),\n        \"indent_level\": 0,\n        \"line_number\": 10,\n    }\n    base.update(overrides)\n    return Task(**base)  # type: ignore[arg-type]\n\n\nclass TestTaskStatus:\n    def test_three_members(self) -> None:\n        assert {s.name for s in TaskStatus} == {\"TODO\", \"DONE\", \"FAILED\"}\n\n    @pytest.mark.parametrize(\n        (\"marker\", \"expected\"),\n        [\n            (\" \", TaskStatus.TODO),\n            (\"x\", TaskStatus.DONE),\n            (\"X\", TaskStatus.DONE),\n            (\"!\", TaskStatus.FAILED),\n        ],\n    )\n    def test_from_marker(self, marker: str, expected: TaskStatus) -> None:\n        assert TaskStatus.from_marker(marker) == expected\n\n    def test_marker_table_matches_from_marker(self) -> None:\n        for marker, status in CHECKBOX_MARKER_TO_STATUS.items():\n            assert TaskStatus.from_marker(marker) == status\n\n    def test_from_marker_unknown(self) -> None:\n        with pytest.raises(ValueError, match=\"unknown checkbox marker\"):\n            TaskStatus.from_marker(\"?\")\n\n\nclass TestRuledOut:\n    def test_construction(self) -> None:\n        ro = RuledOut(text=\"Tried X; failed because Y.\", line_number=42)\n        assert ro.text == \"Tried X; failed because Y.\"\n        assert ro.line_number == 42\n\n    def test_frozen(self) -> None:\n        ro = RuledOut(text=\"x\", line_number=1)\n        with pytest.raises(FrozenInstanceError):\n            ro.text = \"mutated\"  # type: ignore[misc]\n\n\nclass TestTask:\n    def test_default_construction(self) -> None:\n        task = _make_task()\n        assert task.task_id == \"T-000001\"\n        assert task.status is TaskStatus.TODO\n        assert task.flag_tags == ()\n        assert task.action_tag is None\n        assert task.children == ()\n\n    def test_task_id_can_be_none_for_compat(self) -> None:\n        # design doc section 7.2: IDs are optional in compatibility mode.\n        task = _make_task(task_id=None)\n        assert task.task_id is None\n\n    def test_flag_tags_bare_names(self) -> None:\n        # design doc section 4.3: flag tag members are bare names; the\n        # brackets live only in serialized form.\n        task = _make_task(flag_tags=(\"USER\", \"BATCH\"))\n        assert task.flag_tags == (\"USER\", \"BATCH\")\n\n    def test_action_tag_pair(self) -> None:\n        task = _make_task(action_tag=(\"run_cli\", \"mcloop --dry-run\"))\n        assert task.action_tag == (\"run_cli\", \"mcloop --dry-run\")\n\n    def test_annotations_and_deps(self) -> None:\n        task = _make_task(\n            annotations=((\"feat\", \"menu wired\"), (\"fix\", \"race condition\")),\n            deps=(\"T-000002\", \"T-000003\"),\n        )\n        assert task.annotations[0] == (\"feat\", \"menu wired\")\n        assert task.deps == (\"T-000002\", \"T-000003\")\n\n    def test_children_and_ruled_out(self) -> None:\n        child = _make_task(task_id=\"T-000002\", indent_level=1, line_number=11)\n        ruled = RuledOut(text=\"don't do Y\", line_number=12)\n        task = _make_task(children=(child,), ruled_out=(ruled,))\n        assert task.children == (child,)\n        assert task.ruled_out == (ruled,)\n\n    def test_frozen(self) -> None:\n        task = _make_task()\n        with pytest.raises(FrozenInstanceError):\n            task.text = \"mutated\"  # type: ignore[misc]\n\n\nclass TestSubsection:\n    def test_construction(self) -> None:\n        task = _make_task()\n        sub = Subsection(\n            title=\"Manual verification\",\n            prose=\"\",\n            tasks=(task,),\n            line_number=20,\n        )\n        assert sub.title == \"Manual verification\"\n        assert sub.tasks == (task,)\n\n    def test_frozen(self) -> None:\n        sub = Subsection(title=\"x\", prose=\"\", tasks=(), line_number=1)\n        with pytest.raises(FrozenInstanceError):\n            sub.title = \"mutated\"  # type: ignore[misc]\n\n\nclass TestPhase:\n    def test_construction(self) -> None:\n        task = _make_task()\n        phase = Phase(\n            phase_id=\"phase_001\",\n            phase_id_source=\"explicit_comment\",\n            ordinal=1,\n            keyword=\"Stage\",\n            title=\"Core\",\n            prose=\"\",\n            subsections=(),\n            tasks=(task,),\n            line_number=5,\n        )\n        assert phase.phase_id == \"phase_001\"\n        assert phase.phase_id_source == \"explicit_comment\"\n        assert phase.keyword == \"Stage\"\n        assert phase.tasks == (task,)\n\n    def test_phase_id_can_be_none_with_none_source(self) -> None:\n        phase = Phase(\n            phase_id=None,\n            phase_id_source=\"none\",\n            ordinal=2,\n            keyword=\"Phase\",\n            title=\"Bare\",\n            prose=\"\",\n            subsections=(),\n            tasks=(),\n            line_number=30,\n        )\n        assert phase.phase_id is None\n        assert phase.phase_id_source == \"none\"\n\n    def test_frozen(self) -> None:\n        phase = Phase(\n            phase_id=\"phase_001\",\n            phase_id_source=\"explicit_comment\",\n            ordinal=1,\n            keyword=\"Stage\",\n            title=\"Core\",\n            prose=\"\",\n            subsections=(),\n            tasks=(),\n            line_number=5,\n        )\n        with pytest.raises(FrozenInstanceError):\n            phase.title = \"mutated\"  # type: ignore[misc]\n\n\nclass TestBugsSection:\n    def test_construction(self) -> None:\n        task = _make_task()\n        bugs = BugsSection(tasks=(task,), line_number=100)\n        assert bugs.tasks == (task,)\n        assert bugs.line_number == 100\n\n    def test_frozen(self) -> None:\n        bugs = BugsSection(tasks=(), line_number=1)\n        with pytest.raises(FrozenInstanceError):\n            bugs.line_number = 2  # type: ignore[misc]\n\n\nclass TestPlan:\n    def test_construction(self) -> None:\n        phase = Phase(\n            phase_id=\"phase_001\",\n            phase_id_source=\"explicit_comment\",\n            ordinal=1,\n            keyword=\"Stage\",\n            title=\"Core\",\n            prose=\"\",\n            subsections=(),\n            tasks=(),\n            line_number=5,\n        )\n        plan = Plan(\n            magic_version=1,\n            project_title=\"Project\",\n            preamble=\"\",\n            phases=(phase,),\n            bugs=None,\n            source_path=Path(\"/tmp/PLAN.md\"),\n        )\n        assert plan.magic_version == 1\n        assert plan.phases == (phase,)\n        assert plan.bugs is None\n        assert plan.source_path == Path(\"/tmp/PLAN.md\")\n\n    def test_optional_fields(self) -> None:\n        plan = Plan(\n            magic_version=None,\n            project_title=\"Project\",\n            preamble=\"\",\n            phases=(),\n            bugs=None,\n            source_path=None,\n        )\n        assert plan.magic_version is None\n        assert plan.source_path is None\n\n    def test_frozen(self) -> None:\n        plan = Plan(\n            magic_version=None,\n            project_title=\"x\",\n            preamble=\"\",\n            phases=(),\n            bugs=None,\n            source_path=None,\n        )\n        with pytest.raises(FrozenInstanceError):\n            plan.project_title = \"mutated\"  # type: ignore[misc]\n\n\nclass TestPlanSyntaxError:\n    def test_attributes(self) -> None:\n        err = PlanSyntaxError(\"expected task id\", 17, 5, Path(\"/tmp/PLAN.md\"))\n        assert err.message == \"expected task id\"\n        assert err.line == 17\n        assert err.column == 5\n        assert err.path == Path(\"/tmp/PLAN.md\")\n\n    def test_str_matches_design_doc_format(self) -> None:\n        # design doc section 9: \"PLAN.md invalid at line N, column M: ...\"\n        err = PlanSyntaxError(\n            \"expected task id like T-000123 after checkbox marker\",\n            17,\n            5,\n            Path(\"/tmp/PLAN.md\"),\n        )\n        assert str(err) == (\n            \"PLAN.md invalid at line 17, column 5: \"\n            \"expected task id like T-000123 after checkbox marker\"\n        )\n\n    def test_path_optional(self) -> None:\n        err = PlanSyntaxError(\"bad\", 1, 1)\n        assert err.path is None\n        assert str(err) == \"PLAN.md invalid at line 1, column 1: bad\"\n\n\nclass TestPlanValidationError:\n    def test_messages_preserved(self) -> None:\n        err = PlanValidationError([\"dep T-000999 not found\", \"duplicate id T-000001\"])\n        assert err.messages == [\n            \"dep T-000999 not found\",\n            \"duplicate id T-000001\",\n        ]\n\n    def test_str_joins_messages(self) -> None:\n        err = PlanValidationError([\"a\", \"b\"])\n        assert \"a\" in str(err)\n        assert \"b\" in str(err)\n\n    def test_empty_messages(self) -> None:\n        err = PlanValidationError([])\n        assert err.messages == []\n        assert str(err) == \"\"\n\n\nclass TestPlanInconsistencyError:\n    def test_messages_preserved(self) -> None:\n        err = PlanInconsistencyError([\"task T-000001 [x] but no commit_landed event\"])\n        assert err.messages == [\"task T-000001 [x] but no commit_landed event\"]\n\n    def test_str_joins_messages(self) -> None:\n        err = PlanInconsistencyError([\"x\", \"y\"])\n        assert \"x\" in str(err)\n        assert \"y\" in str(err)\n","numLines":328,"startLine":1,"totalLines":328}}}
