cies = [\n    \"jsonschema>=4.21\",\n]\n\n[project.optional-dependencies]\ndev = [\n    \"pytest>=8.0\",\n    \"ruff>=0.6\",\n    \"mypy>=1.10\",\n    \"pytest-xdist>=3.5\",\n    \"pytest-timeout>=2.3\",\n]\n\n[tool.setuptools.packages.find]\nwhere = [\".\"]\ninclude = [\"bob_tools*\"]\n\n[tool.pytest.ini_options]\naddopts = \"-n auto\"\ntimeout = 60\ntestpaths = [\"bob_tools/ledger/tests\", \"bob_tools/planfile/tests\"]\n\n[tool.ruff]\ntarget-version = \"py312\"\nline-length = 88\nextend-exclude = [\"build\", \"dist\", \".venv\"]\n\n[tool.ruff.lint]\nselect = [\"E\", \"F\", \"W\", \"I\", \"B\", \"UP\", \"RUF\"]\n\n[tool.mypy]\nstrict = true\npython_version = \"3.12\"\nfiles = [\"bob_tools\"]\nexclude = ['build/', 'dist/', '\\.venv/']\n\n[[tool.mypy.overrides]]\nmodule = \"jsonschema.*\"\nignore_missing_imports = true\n","numLines":49,"startLine":1,"totalLines":49}}}
