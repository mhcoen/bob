{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MN7zQjHcycZ3EdL49AL7aw","type":"tool_result","content":"1\t\"\"\"Tests for bob_tools.planfile.operations.\n2\t\n3\tCovers :func:`validate_plan` referential-integrity checks for ``@deps``:\n4\t\n5\t  - Plans with no tasks and plans whose ``@deps`` all resolve return\n6\t    ``None`` (no error).\n7\t  - Unknown dep references — at the root, on nested children, in a\n8\t    subsection task, or on a bug task — raise\n9\t    :class:`PlanValidationError` with one message per missing reference.\n10\t  - Tasks without a ``task_id`` (compat mode) still have their ``deps``\n11\t    checked; the error message identifies the offender by source line.\n12\t  - Cross-section references resolve: a phase task may depend on a bug\n13\t    task or vice versa, and a task may depend on another task's child.\n14\t  - Validation reports every error in a single raise rather than\n15\t    short-circuiting on the first failure.\n16\t\"\"\"\n17\t\n18\tfrom __future__ import annotations\n19\t\n20\tfrom pathlib import Path\n21\t\n22\timport pytest\n23\t\n24\tfrom bob_tools.planfile.model import (\n25\t    BugsSection,\n26\t    Phase,\n27\t    Plan,\n28\t    PlanValidationError,\n29\t    Subsection,\n30\t    Task,\n31\t    TaskStatus,\n32\t)\n33\tfrom bob_tools.planfile.operations import validate_plan\n34\t\n35\t\n36\tdef _task(\n37\t    *,\n38\t    task_id: str | None,\n39\t    deps: tuple[str, ...] = (),\n40\t    children: tuple[Task, ...] = (),\n41\t    indent_level: int = 0,\n42\t    line_number: int = 1,\n43\t    text: str = \"do thing\",\n44\t) -> Task:\n45\t    return Task(\n46\t        task_id=task_id,\n47\t        text=text,\n48\t        status=TaskStatus.TODO,\n49\t        flag_tags=(),\n50\t        action_tag=None,\n51\t        annotations=(),\n52\t        deps=deps,\n53\t        children=children,\n54\t        ruled_out=(),\n55\t        indent_level=indent_level,\n56\t        line_number=line_number,\n57\t    )\n58\t\n59\t\n60\tdef _phase(tasks: tuple[Task, ...], subsections: tuple[Subsection, ...] = ()) -> Phase:\n61\t    return Phase(\n62\t        phase_id=\"phase_001\",\n63\t        phase_id_source=\"explicit_comment\",\n64\t        ordinal=1,\n65\t        keyword=\"Stage\",\n66\t        title=\"Core\",\n67\t        prose=\"\",\n68\t        subsections=subsections,\n69\t        tasks=tasks,\n70\t        line_number=5,\n71\t    )\n72\t\n73\t\n74\tdef _plan(\n75\t    phases: tuple[Phase, ...] = (),\n76\t    bugs: BugsSection | None = None,\n77\t) -> Plan:\n78\t    return Plan(\n79\t        magic_version=1,\n80\t        project_title=\"Project\",\n81\t        preamble=\"\",\n82\t        phases=phases,\n83\t        bugs=bugs,\n84\t        source_path=Path(\"/tmp/PLAN.md\"),\n85\t    )\n86\t\n87\t\n88\tclass TestValidatePlan:\n89\t    def test_empty_plan_is_valid(self) -> None:\n90\t        validate_plan(_plan())\n91\t\n92\t    def test_plan_with_no_deps_is_valid(self) -> None:\n93\t        plan = _plan(\n94\t            phases=(\n95\t                _phase(tasks=(_task(task_id=\"T-000001\"), _task(task_id=\"T-000002\"))),\n96\t            )\n97\t        )\n98\t        validate_plan(plan)\n99\t\n100\t    def test_dep_resolves_to_sibling(self) -> None:\n101\t        plan = _plan(\n102\t            phases=(\n103\t                _phase(\n104\t                    tasks=(\n105\t                        _task(task_id=\"T-000001\"),\n106\t                        _task(task_id=\"T-000002\", deps=(\"T-000001\",)),\n107\t                    )\n108\t                ),\n109\t            )\n110\t        )\n111\t        validate_plan(plan)\n112\t\n113\t    def test_dep_resolves_to_nested_child(self) -> None:\n114\t        # Deps may point at a deeply nested task; _iter_plan_tasks must\n115\t        # walk children so child IDs end up in the known set.\n116\t        child = _task(task_id=\"T-000002\", indent_level=2)\n117\t        parent = _task(task_id=\"T-000001\", children=(child,))\n118\t        other = _task(task_id=\"T-000003\", deps=(\"T-000002\",))\n119\t        plan = _plan(phases=(_phase(tasks=(parent, other)),))\n120\t        validate_plan(plan)\n121\t\n122\t    def test_unknown_dep_raises(self) -> None:\n123\t        plan = _plan(\n124\t            phases=(_phase(tasks=(_task(task_id=\"T-000001\", deps=(\"T-000999\",)),)),)\n125\t        )\n126\t        with pytest.raises(PlanValidationError) as exc_info:\n127\t            validate_plan(plan)\n128\t        assert exc_info.value.messages == [\n129\t            \"task T-000001 references unknown dep T-000999\",\n130\t        ]\n131\t\n132\t    def test_reports_every_error_not_just_first(self) -> None:\n133\t        # validate_plan should not short-circuit; every missing\n134\t        # reference appears in `messages` so a single run surfaces all\n135\t        # of them to the user.\n136\t        plan = _plan(\n137\t            phases=(\n138\t                _phase(\n139\t                    tasks=(\n140\t                        _task(task_id=\"T-000001\", deps=(\"T-000998\",)),\n141\t                        _task(task_id=\"T-000002\", deps=(\"T-000999\",)),\n142\t                    )\n143\t                ),\n144\t            )\n145\t        )\n146\t        with pytest.raises(PlanValidationError) as exc_info:\n147\t            validate_plan(plan)\n148\t        assert exc_info.value.messages == [\n149\t            \"task T-000001 references unknown dep T-000998\",\n150\t            \"task T-000002 references unknown dep T-000999\",\n151\t        ]\n152\t\n153\t    def test_multiple_deps_on_one_task_each_checked(self) -> None:\n154\t        plan = _plan(\n155\t            phases=(\n156\t                _phase(\n157\t                    tasks=(\n158\t                        _task(task_id=\"T-000001\"),\n159\t                        _task(\n160\t                            task_id=\"T-000002\",\n161\t                            deps=(\"T-000001\", \"T-000888\", \"T-000999\"),\n162\t                        ),\n163\t                    )\n164\t                ),\n165\t            )\n166\t        )\n167\t        with pytest.raises(PlanValidationError) as exc_info:\n168\t            validate_plan(plan)\n169\t        assert exc_info.value.messages == [\n170\t            \"task T-000002 references unknown dep T-000888\",\n171\t            \"task T-000002 references unknown dep T-000999\",\n172\t        ]\n173\t\n174\t    def test_dep_on_nested_child_unknown_raises(self) -> None:\n175\t        # An unknown dep on a deeply nested child must surface; iteration\n176\t        # has to recurse for deps checking, not just for ID collection.\n177\t        bad_child = _task(\n178\t            task_id=\"T-000002\",\n179\t            deps=(\"T-000999\",),\n180\t            indent_level=2,\n181\t            line_number=11,\n182\t        )\n183\t        parent = _task(task_id=\"T-000001\", children=(bad_child,))\n184\t        plan = _plan(phases=(_phase(tasks=(parent,)),))\n185\t        with pytest.raises(PlanValidationError) as exc_info:\n186\t            validate_plan(plan)\n187\t        assert exc_info.value.messages == [\n188\t            \"task T-000002 references unknown dep T-000999\",\n189\t        ]\n190\t\n191\t    def test_dep_can_reference_bugs_task(self) -> None:\n192\t        # Bug tasks are part of the plan; their IDs are valid dep\n193\t        # targets for phase tasks (and vice versa).\n194\t        bug = _task(task_id=\"T-000900\", line_number=100)\n195\t        plan = _plan(\n196\t            phases=(_phase(tasks=(_task(task_id=\"T-000001\", deps=(\"T-000900\",)),)),),\n197\t            bugs=BugsSection(tasks=(bug,), line_number=99),\n198\t        )\n199\t        validate_plan(plan)\n200\t\n201\t    def test_bug_task_with_unknown_dep_raises(self) -> None:\n202\t        plan = _plan(\n203\t            bugs=BugsSection(\n204\t                tasks=(_task(task_id=\"T-000900\", deps=(\"T-000999\",), line_number=100),),\n205\t                line_number=99,\n206\t            ),\n207\t        )\n208\t        with pytest.raises(PlanValidationError) as exc_info:\n209\t            validate_plan(plan)\n210\t        assert exc_info.value.messages == [\n211\t            \"task T-000900 references unknown dep T-000999\",\n212\t        ]\n213\t\n214\t    def test_subsection_task_ids_known_and_checked(self) -> None:\n215\t        # Subsection tasks are visible both as ID sources (a phase task\n216\t        # may depend on one) and as dep-bearers (an unknown ref on a\n217\t        # subsection task must raise).\n218\t        sub = Subsection(\n219\t            title=\"Manual verification\",\n220\t            prose=\"\",\n221\t            tasks=(\n222\t                _task(task_id=\"T-000010\", line_number=20),\n223\t                _task(task_id=\"T-000011\", deps=(\"T-000999\",), line_number=21),\n224\t            ),\n225\t            line_number=19,\n226\t        )\n227\t        phase = _phase(\n228\t            tasks=(_task(task_id=\"T-000001\", deps=(\"T-000010\",)),),\n229\t            subsections=(sub,),\n230\t        )\n231\t        with pytest.raises(PlanValidationError) as exc_info:\n232\t            validate_plan(_plan(phases=(phase,)))\n233\t        assert exc_info.value.messages == [\n234\t            \"task T-000011 references unknown dep T-000999\",\n235\t        ]\n236\t\n237\t    def test_task_without_id_still_has_deps_checked(self) -> None:\n238\t        # Compat-mode tasks have no ID but may still have @deps. The\n239\t        # error message falls back to the source line number so the\n240\t        # user can locate the offending line.\n241\t        plan = _plan(\n242\t            phases=(\n243\t                _phase(\n244\t                    tasks=(_task(task_id=None, deps=(\"T-000999\",), line_number=42),)\n245\t                ),\n246\t            )\n247\t        )\n248\t        with pytest.raises(PlanValidationError) as exc_info:\n249\t            validate_plan(plan)\n250\t        assert exc_info.value.messages == [\n251\t            \"task line 42 references unknown dep T-000999\",\n252\t        ]\n253\t"}]},"parent_tool_use_id":null,"session_id":"228b2004-1673-44ee-a1d9-d52a275764b9","uuid":"3fd1a246-ce2c-4ff8-935a-3127871eeb61","timestamp":"2026-05-16T02:33:26.842Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_operations.py","content":"\"\"\"Tests for bob_tools.planfile.operations.\n\nCovers :func:`validate_plan` referential-integrity checks for ``@deps``:\n\n  - Plans with no tasks and plans whose ``@deps`` all resolve return\n    ``None`` (no error).\n  - Unknown dep references — at the root, on nested children, in a\n    subsection task, or on a bug task — raise\n    :class:`PlanValidationError` with one message per missing reference.\n  - Tasks without a ``task_id`` (compat mode) still have their ``deps``\n    checked; the error message identifies the offender by source line.\n  - Cross-section references resolve: a phase task may depend on a bug\n    task or vice versa, and a task may depend on another task's child.\n  - Validation reports every error in a single raise rather than\n    short-circuiting on the first failure.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\n\nimport pytest\n\nfrom bob_tools.planfile.model import (\n    BugsSection,\n    Phase,\n    Plan,\n    PlanValidationError,\n    Subsection,\n    Task,\n    TaskStatus,\n)\nfrom bob_tools.planfile.operations import validate_plan\n\n\ndef _task(\n    *,\n    task_id: str | None,\n    deps: tuple[str, ...] = (),\n    children: tuple[Task, ...] = (),\n    indent_level: int = 0,\n    line_number: int = 1,\n    text: str = \"do thing\",\n) -> Task:\n    return Task(\n        task_id=task_id,\n        text=text,\n        status=TaskStatus.TODO,\n        flag_tags=(),\n        action_tag=None,\n        annotations=(),\n        deps=deps,\n        children=children,\n        ruled_out=(),\n        indent_level=indent_level,\n        line_number=line_number,\n    )\n\n\ndef _phase(tasks: tuple[Task, ...], subsections: tuple[Subsection, ...] = ()) -> Phase:\n    return Phase(\n        phase_id=\"phase_001\",\n        phase_id_source=\"explicit_comment\",\n        ordinal=1,\n        keyword=\"Stage\",\n        title=\"Core\",\n        prose=\"\",\n        subsections=subsections,\n        tasks=tasks,\n        line_number=5,\n    )\n\n\ndef _plan(\n    phases: tuple[Phase, ...] = (),\n    bugs: BugsSection | None = None,\n) -> Plan:\n    return Plan(\n        magic_version=1,\n        project_title=\"Project\",\n        preamble=\"\",\n        phases=phases,\n        bugs=bugs,\n        source_path=Path(\"/tmp/PLAN.md\"),\n    )\n\n\nclass TestValidatePlan:\n    def test_empty_plan_is_valid(self) -> None:\n        validate_plan(_plan())\n\n    def test_plan_with_no_deps_is_valid(self) -> None:\n        plan = _plan(\n            phases=(\n                _phase(tasks=(_task(task_id=\"T-000001\"), _task(task_id=\"T-000002\"))),\n            )\n        )\n        validate_plan(plan)\n\n    def test_dep_resolves_to_sibling(self) -> None:\n        plan = _plan(\n            phases=(\n                _phase(\n                    tasks=(\n                        _task(task_id=\"T-000001\"),\n                        _task(task_id=\"T-000002\", deps=(\"T-000001\",)),\n                    )\n                ),\n            )\n        )\n        validate_plan(plan)\n\n    def test_dep_resolves_to_nested_child(self) -> None:\n        # Deps may point at a deeply nested task; _iter_plan_tasks must\n        # walk children so child IDs end up in the known set.\n        child = _task(task_id=\"T-000002\", indent_level=2)\n        parent = _task(task_id=\"T-000001\", children=(child,))\n        other = _task(task_id=\"T-000003\", deps=(\"T-000002\",))\n        plan = _plan(phases=(_phase(tasks=(parent, other)),))\n        validate_plan(plan)\n\n    def test_unknown_dep_raises(self) -> None:\n        plan = _plan(\n            phases=(_phase(tasks=(_task(task_id=\"T-000001\", deps=(\"T-000999\",)),)),)\n        )\n        with pytest.raises(PlanValidationError) as exc_info:\n            validate_plan(plan)\n        assert exc_info.value.messages == [\n            \"task T-000001 references unknown dep T-000999\",\n        ]\n\n    def test_reports_every_error_not_just_first(self) -> None:\n        # validate_plan should not short-circuit; every missing\n        # reference appears in `messages` so a single run surfaces all\n        # of them to the user.\n        plan = _plan(\n            phases=(\n                _phase(\n                    tasks=(\n                        _task(task_id=\"T-000001\", deps=(\"T-000998\",)),\n                        _task(task_id=\"T-000002\", deps=(\"T-000999\",)),\n                    )\n                ),\n            )\n        )\n        with pytest.raises(PlanValidationError) as exc_info:\n            validate_plan(plan)\n        assert exc_info.value.messages == [\n            \"task T-000001 references unknown dep T-000998\",\n            \"task T-000002 references unknown dep T-000999\",\n        ]\n\n    def test_multiple_deps_on_one_task_each_checked(self) -> None:\n        plan = _plan(\n            phases=(\n                _phase(\n                    tasks=(\n                        _task(task_id=\"T-000001\"),\n                        _task(\n                            task_id=\"T-000002\",\n                            deps=(\"T-000001\", \"T-000888\", \"T-000999\"),\n                        ),\n                    )\n                ),\n            )\n        )\n        with pytest.raises(PlanValidationError) as exc_info:\n            validate_plan(plan)\n        assert exc_info.value.messages == [\n            \"task T-000002 references unknown dep T-000888\",\n            \"task T-000002 references unknown dep T-000999\",\n        ]\n\n    def test_dep_on_nested_child_unknown_raises(self) -> None:\n        # An unknown dep on a deeply nested child must surface; iteration\n        # has to recurse for deps checking, not just for ID collection.\n        bad_child = _task(\n            task_id=\"T-000002\",\n            deps=(\"T-000999\",),\n            indent_level=2,\n            line_number=11,\n        )\n        parent = _task(task_id=\"T-000001\", children=(bad_child,))\n        plan = _plan(phases=(_phase(tasks=(parent,)),))\n        with pytest.raises(PlanValidationError) as exc_info:\n            validate_plan(plan)\n        assert exc_info.value.messages == [\n            \"task T-000002 references unknown dep T-000999\",\n        ]\n\n    def test_dep_can_reference_bugs_task(self) -> None:\n        # Bug tasks are part of the plan; their IDs are valid dep\n        # targets for phase tasks (and vice versa).\n        bug = _task(task_id=\"T-000900\", line_number=100)\n        plan = _plan(\n            phases=(_phase(tasks=(_task(task_id=\"T-000001\", deps=(\"T-000900\",)),)),),\n            bugs=BugsSection(tasks=(bug,), line_number=99),\n        )\n        validate_plan(plan)\n\n    def test_bug_task_with_unknown_dep_raises(self) -> None:\n        plan = _plan(\n            bugs=BugsSection(\n                tasks=(_task(task_id=\"T-000900\", deps=(\"T-000999\",), line_number=100),),\n                line_number=99,\n            ),\n        )\n        with pytest.raises(PlanValidationError) as exc_info:\n            validate_plan(plan)\n        assert exc_info.value.messages == [\n            \"task T-000900 references unknown dep T-000999\",\n        ]\n\n    def test_subsection_task_ids_known_and_checked(self) -> None:\n        # Subsection tasks are visible both as ID sources (a phase task\n        # may depend on one) and as dep-bearers (an unknown ref on a\n        # subsection task must raise).\n        sub = Subsection(\n            title=\"Manual verification\",\n            prose=\"\",\n            tasks=(\n                _task(task_id=\"T-000010\", line_number=20),\n                _task(task_id=\"T-000011\", deps=(\"T-000999\",), line_number=21),\n            ),\n            line_number=19,\n        )\n        phase = _phase(\n            tasks=(_task(task_id=\"T-000001\", deps=(\"T-000010\",)),),\n            subsections=(sub,),\n        )\n        with pytest.raises(PlanValidationError) as exc_info:\n            validate_plan(_plan(phases=(phase,)))\n        assert exc_info.value.messages == [\n            \"task T-000011 references unknown dep T-000999\",\n        ]\n\n    def test_task_without_id_still_has_deps_checked(self) -> None:\n        # Compat-mode tasks have no ID but may still have @deps. The\n        # error message falls back to the source line number so the\n        # user can locate the offending line.\n        plan = _plan(\n            phases=(\n                _phase(\n                    tasks=(_task(task_id=None, deps=(\"T-000999\",), line_number=42),)\n                ),\n            )\n        )\n        with pytest.raises(PlanValidationError) as exc_info:\n            validate_plan(plan)\n        assert exc_info.value.messages == [\n            \"task line 42 references unknown dep T-000999\",\n        ]\n","numLines":253,"startLine":1,"totalLines":253}}}
