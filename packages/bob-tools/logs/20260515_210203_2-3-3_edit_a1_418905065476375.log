{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GdHus2wHPqYatJu2n5UhXn","type":"tool_result","content":"1\t\"\"\"Tests for bob_tools.planfile.parser building blocks.\n2\t\n3\tStage 2 task-line recognizers and tag extractors:\n4\t\n5\t  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n6\t    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n7\t  - ``_parse_task_line`` returns a raw record on checkbox lines and\n8\t    ``None`` on anything else.\n9\t  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n10\t    sibling lines and returns indent, body, and source line number.\n11\t  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n12\t    line: nearest strictly-less-indented open ancestor, with fallback\n13\t    to the most recent root task (mcloop's ``parse`` parity).\n14\t  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n15\t    tokens, in isolation and combination, and leaves non-leading\n16\t    occurrences as prose (design doc section 4.3).\n17\t  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n18\t    treats the rest of the line as its argument string; non-leading\n19\t    occurrences are prose.\n20\t  - ``_extract_annotations`` consumes trailing ``[key: value]``\n21\t    annotations, handles multiple annotations and nested brackets in\n22\t    values, and leaves bracketed prose that is not separated from\n23\t    preceding text by whitespace in place.\n24\t\"\"\"\n25\t\n26\tfrom __future__ import annotations\n27\t\n28\tfrom dataclasses import dataclass\n29\t\n30\timport pytest\n31\t\n32\tfrom bob_tools.planfile.parser import (\n33\t    _CHECKBOX_RE,\n34\t    _attach_ruledout,\n35\t    _extract_action_tag,\n36\t    _extract_annotations,\n37\t    _extract_flag_tags,\n38\t    _parse_ruledout_line,\n39\t    _parse_task_line,\n40\t)\n41\t\n42\t\n43\t@dataclass\n44\tclass _FakeTask:\n45\t    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n46\t\n47\t    indent_level: int\n48\t    name: str = \"\"\n49\t\n50\t\n51\tclass TestCheckboxRe:\n52\t    @pytest.mark.parametrize(\n53\t        (\"line\", \"indent\", \"marker\", \"text\"),\n54\t        [\n55\t            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n56\t            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n57\t            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n58\t            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n59\t            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n60\t        ],\n61\t    )\n62\t    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n63\t        m = _CHECKBOX_RE.match(line)\n64\t        assert m is not None\n65\t        assert m.group(1) == indent\n66\t        assert m.group(2) == marker\n67\t        assert m.group(3) == text\n68\t\n69\t    @pytest.mark.parametrize(\n70\t        \"line\",\n71\t        [\n72\t            \"\",\n73\t            \"## Stage 1: Core\",\n74\t            \"- [] missing space inside brackets\",\n75\t            \"- [y] unsupported marker\",\n76\t            \"- [ ]\",\n77\t            \"* [ ] wrong bullet\",\n78\t            \"Plain prose line\",\n79\t        ],\n80\t    )\n81\t    def test_non_matches(self, line: str) -> None:\n82\t        assert _CHECKBOX_RE.match(line) is None\n83\t\n84\t\n85\tclass TestParseTaskLine:\n86\t    def test_match_returns_raw_record(self) -> None:\n87\t        rec = _parse_task_line(\"  - [x] foo\", 7)\n88\t        assert rec is not None\n89\t        assert rec.indent == \"  \"\n90\t        assert rec.status_char == \"x\"\n91\t        assert rec.text == \"foo\"\n92\t        assert rec.line_number == 7\n93\t\n94\t    def test_match_failed_marker(self) -> None:\n95\t        rec = _parse_task_line(\"- [!] bad\", 12)\n96\t        assert rec is not None\n97\t        assert rec.status_char == \"!\"\n98\t        assert rec.line_number == 12\n99\t\n100\t    def test_non_task_returns_none(self) -> None:\n101\t        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n102\t        assert _parse_task_line(\"\", 2) is None\n103\t        assert _parse_task_line(\"Some prose\", 3) is None\n104\t\n105\t\n106\tclass TestParseRuledOutLine:\n107\t    def test_indented_with_text(self) -> None:\n108\t        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n109\t        assert rec is not None\n110\t        assert rec.indent == \"  \"\n111\t        assert rec.text == \"tried restart\"\n112\t        assert rec.line_number == 5\n113\t\n114\t    def test_top_level_with_text(self) -> None:\n115\t        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n116\t        assert rec is not None\n117\t        assert rec.indent == \"\"\n118\t        assert rec.text == \"orphan approach\"\n119\t\n120\t    def test_empty_body(self) -> None:\n121\t        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n122\t        assert rec is not None\n123\t        assert rec.indent == \"    \"\n124\t        assert rec.text == \"\"\n125\t\n126\t    def test_trailing_whitespace_stripped(self) -> None:\n127\t        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n128\t        assert rec is not None\n129\t        assert rec.text == \"foo\"\n130\t\n131\t    def test_non_leading_token_is_not_match(self) -> None:\n132\t        # A RULEDOUT token that appears mid-line is prose, not a\n133\t        # RULEDOUT line. Only the leading-position form is recognized.\n134\t        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n135\t\n136\t    def test_similar_token_does_not_match(self) -> None:\n137\t        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n138\t        # immediately after the keyword.\n139\t        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n140\t\n141\t    def test_non_ruledout_lines_return_none(self) -> None:\n142\t        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n143\t        assert _parse_ruledout_line(\"\", 2) is None\n144\t        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n145\t\n146\t\n147\tclass TestAttachRuledOut:\n148\t    def test_nearest_strict_less_indent_wins(self) -> None:\n149\t        root = _FakeTask(indent_level=0, name=\"root\")\n150\t        child = _FakeTask(indent_level=2, name=\"child\")\n151\t        grand = _FakeTask(indent_level=4, name=\"grand\")\n152\t        # RULEDOUT at indent 4 sits as a sibling under `child`\n153\t        # (indent 2): it attaches to `child`, not to `grand` even\n154\t        # though `grand` is deeper in the stack.\n155\t        attached = _attach_ruledout(4, [root, child, grand], [root])\n156\t        assert attached is child\n157\t\n158\t    def test_skips_equal_indent_in_stack(self) -> None:\n159\t        # Equal indent is not \"strictly less\", so the equal-indent\n160\t        # entry is skipped and the search continues outward.\n161\t        root = _FakeTask(indent_level=0, name=\"root\")\n162\t        same = _FakeTask(indent_level=2, name=\"same\")\n163\t        attached = _attach_ruledout(2, [root, same], [root])\n164\t        assert attached is root\n165\t\n166\t    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n167\t        # A column-0 RULEDOUT after the stack has been popped (e.g.\n168\t        # following a same-indent sibling) finds no strictly-less\n169\t        # ancestor, so it attaches to the last root task.\n170\t        a = _FakeTask(indent_level=0, name=\"a\")\n171\t        b = _FakeTask(indent_level=0, name=\"b\")\n172\t        attached = _attach_ruledout(0, [], [a, b])\n173\t        assert attached is b\n174\t\n175\t    def test_no_ancestors_no_roots_returns_none(self) -> None:\n176\t        # A stray [RULEDOUT] before any task in the phase has nothing\n177\t        # to attach to; the caller is expected to drop it.\n178\t        assert _attach_ruledout(0, [], []) is None\n179\t\n180\t    def test_empty_stack_uses_root_fallback(self) -> None:\n181\t        root = _FakeTask(indent_level=0, name=\"root\")\n182\t        attached = _attach_ruledout(2, [], [root])\n183\t        assert attached is root\n184\t\n185\t\n186\tclass TestExtractFlagTags:\n187\t    def test_no_tags(self) -> None:\n188\t        tags, rest = _extract_flag_tags(\"plain task text\")\n189\t        assert tags == ()\n190\t        assert rest == \"plain task text\"\n191\t\n192\t    def test_user(self) -> None:\n193\t        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n194\t        assert tags == (\"USER\",)\n195\t        assert rest == \"verify the menu\"\n196\t\n197\t    def test_batch(self) -> None:\n198\t        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n199\t        assert tags == (\"BATCH\",)\n200\t        assert rest == \"sub-task group\"\n201\t\n202\t    def test_user_and_batch_combined(self) -> None:\n203\t        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n204\t        assert tags == (\"USER\", \"BATCH\")\n205\t        assert rest == \"both flags\"\n206\t\n207\t    def test_adjacent_tags_without_separator(self) -> None:\n208\t        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n209\t        assert tags == (\"USER\", \"BATCH\")\n210\t        assert rest == \"no gap\"\n211\t\n212\t    def test_non_leading_tag_is_prose(self) -> None:\n213\t        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n214\t        assert tags == ()\n215\t        assert rest == \"Document the [USER] tag\"\n216\t\n217\t    def test_only_first_run_is_tags(self) -> None:\n218\t        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n219\t        assert tags == (\"USER\",)\n220\t        assert rest == \"middle [BATCH] later\"\n221\t\n222\t    def test_empty_input(self) -> None:\n223\t        tags, rest = _extract_flag_tags(\"\")\n224\t        assert tags == ()\n225\t        assert rest == \"\"\n226\t\n227\t\n228\tclass TestExtractActionTag:\n229\t    def test_no_action_tag(self) -> None:\n230\t        tag, rest = _extract_action_tag(\"plain task text\")\n231\t        assert tag is None\n232\t        assert rest == \"plain task text\"\n233\t\n234\t    def test_action_with_args(self) -> None:\n235\t        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n236\t        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n237\t        assert rest == \"\"\n238\t\n239\t    def test_action_without_args(self) -> None:\n240\t        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n241\t        assert tag == (\"noop\", \"\")\n242\t        assert rest == \"\"\n243\t\n244\t    def test_args_extend_to_end_of_line(self) -> None:\n245\t        # Argument string is text from closing bracket to end of line;\n246\t        # bracketed-looking content in args stays in args.\n247\t        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n248\t        assert tag == (\"run\", \"do [feat: x]\")\n249\t        assert rest == \"\"\n250\t\n251\t    def test_non_leading_auto_is_prose(self) -> None:\n252\t        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n253\t        assert tag is None\n254\t        assert rest == \"Document the [AUTO:run] tag\"\n255\t\n256\t\n257\tclass TestExtractAnnotations:\n258\t    def test_no_annotation(self) -> None:\n259\t        ann, rest = _extract_annotations(\"plain task text\")\n260\t        assert ann == ()\n261\t        assert rest == \"plain task text\"\n262\t\n263\t    def test_single_feat(self) -> None:\n264\t        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n265\t        assert ann == ((\"feat\", '\"menu wired\"'),)\n266\t        assert rest == \"do thing\"\n267\t\n268\t    def test_single_fix(self) -> None:\n269\t        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n270\t        assert ann == ((\"fix\", '\"race\"'),)\n271\t        assert rest == \"fixed it\"\n272\t\n273\t    def test_multiple_annotations_preserve_order(self) -> None:\n274\t        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n275\t        assert ann == (\n276\t            (\"feat\", '\"first\"'),\n277\t            (\"fix\", '\"second\"'),\n278\t        )\n279\t        assert rest == \"do thing\"\n280\t\n281\t    def test_nested_brackets_in_value(self) -> None:\n282\t        # Balanced brackets inside the value are stepped over by the\n283\t        # right-to-left depth scan and stay inside the annotation.\n284\t        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n285\t        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n286\t        assert rest == \"do thing\"\n287\t\n288\t    def test_unquoted_nested_brackets_in_value(self) -> None:\n289\t        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n290\t        assert ann == ((\"feat\", \"a [b] c\"),)\n291\t        assert rest == \"do\"\n292\t\n293\t    def test_prose_bracket_without_separator_is_text(self) -> None:\n294\t        # A `[` abutting a non-whitespace character is task text, not\n295\t        # the start of an annotation.\n296\t        ann, rest = _extract_annotations(\"see config[feat: x]\")\n297\t        assert ann == ()\n298\t        assert rest == \"see config[feat: x]\"\n299\t\n300\t    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n301\t        # `[AUTO:run]` has no whitespace after its colon and so is not\n302\t        # an annotation under this extractor's rules.\n303\t        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n304\t        assert ann == ()\n305\t        assert rest == \"[AUTO:run] cmd\"\n306\t\n307\t    def test_unmatched_open_bracket(self) -> None:\n308\t        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n309\t        assert ann == ()\n310\t        assert rest == \"dangling brackets feat ]\"\n311\t\n312\t    def test_annotation_alone_consumes_to_empty(self) -> None:\n313\t        ann, rest = _extract_annotations('[feat: \"lone\"]')\n314\t        assert ann == ((\"feat\", '\"lone\"'),)\n315\t        assert rest == \"\"\n316\t\n317\t\n318\tclass TestTagInteractions:\n319\t    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n320\t        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n321\t        # Annotation must be stripped before action tag, because action\n322\t        # tag args span to end of line.\n323\t        ann, after_ann = _extract_annotations(text)\n324\t        assert ann == ((\"feat\", '\"done\"'),)\n325\t        tags, after_flags = _extract_flag_tags(after_ann)\n326\t        assert tags == (\"BATCH\",)\n327\t        action, after_action = _extract_action_tag(after_flags)\n328\t        assert action == (\"run_cli\", \"mcloop --dry-run\")\n329\t        assert after_action == \"\"\n330\t\n331\t    def test_flags_and_plain_text(self) -> None:\n332\t        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n333\t        assert ann == ()\n334\t        tags, after_flags = _extract_flag_tags(after_ann)\n335\t        assert tags == (\"USER\", \"BATCH\")\n336\t        action, after_action = _extract_action_tag(after_flags)\n337\t        assert action is None\n338\t        assert after_action == \"verify thing\"\n339\t\n340\t    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n341\t        text = \"Implement [USER] and [AUTO:run] tokenization\"\n342\t        ann, after_ann = _extract_annotations(text)\n343\t        tags, after_flags = _extract_flag_tags(after_ann)\n344\t        action, after_action = _extract_action_tag(after_flags)\n345\t        assert ann == ()\n346\t        assert tags == ()\n347\t        assert action is None\n348\t        assert after_action == text\n349\t"}]},"parent_tool_use_id":null,"session_id":"3bad2bc3-33da-48ff-a215-28efdbb09e24","uuid":"6cb4ba36-ba06-4284-a943-1f0679fd8584","timestamp":"2026-05-16T02:00:33.543Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser.py","content":"\"\"\"Tests for bob_tools.planfile.parser building blocks.\n\nStage 2 task-line recognizers and tag extractors:\n\n  - ``_CHECKBOX_RE`` matches indented/bare checkboxes for every status\n    marker (space, ``x``, ``X``, ``!``); rejects malformed forms.\n  - ``_parse_task_line`` returns a raw record on checkbox lines and\n    ``None`` on anything else.\n  - ``_parse_ruledout_line`` recognizes leading-position ``[RULEDOUT]``\n    sibling lines and returns indent, body, and source line number.\n  - ``_attach_ruledout`` resolves the attachment target for a RULEDOUT\n    line: nearest strictly-less-indented open ancestor, with fallback\n    to the most recent root task (mcloop's ``parse`` parity).\n  - ``_extract_flag_tags`` consumes leading ``[USER]`` / ``[BATCH]``\n    tokens, in isolation and combination, and leaves non-leading\n    occurrences as prose (design doc section 4.3).\n  - ``_extract_action_tag`` consumes a leading ``[AUTO:<action>]`` and\n    treats the rest of the line as its argument string; non-leading\n    occurrences are prose.\n  - ``_extract_annotations`` consumes trailing ``[key: value]``\n    annotations, handles multiple annotations and nested brackets in\n    values, and leaves bracketed prose that is not separated from\n    preceding text by whitespace in place.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\n\nimport pytest\n\nfrom bob_tools.planfile.parser import (\n    _CHECKBOX_RE,\n    _attach_ruledout,\n    _extract_action_tag,\n    _extract_annotations,\n    _extract_flag_tags,\n    _parse_ruledout_line,\n    _parse_task_line,\n)\n\n\n@dataclass\nclass _FakeTask:\n    \"\"\"Minimal indent-bearing stand-in for the attachment-logic tests.\"\"\"\n\n    indent_level: int\n    name: str = \"\"\n\n\nclass TestCheckboxRe:\n    @pytest.mark.parametrize(\n        (\"line\", \"indent\", \"marker\", \"text\"),\n        [\n            (\"- [ ] do thing\", \"\", \" \", \"do thing\"),\n            (\"  - [x] done thing\", \"  \", \"x\", \"done thing\"),\n            (\"    - [X] also done\", \"    \", \"X\", \"also done\"),\n            (\"- [!] failed thing\", \"\", \"!\", \"failed thing\"),\n            (\"   - [ ] three-space indent\", \"   \", \" \", \"three-space indent\"),\n        ],\n    )\n    def test_matches(self, line: str, indent: str, marker: str, text: str) -> None:\n        m = _CHECKBOX_RE.match(line)\n        assert m is not None\n        assert m.group(1) == indent\n        assert m.group(2) == marker\n        assert m.group(3) == text\n\n    @pytest.mark.parametrize(\n        \"line\",\n        [\n            \"\",\n            \"## Stage 1: Core\",\n            \"- [] missing space inside brackets\",\n            \"- [y] unsupported marker\",\n            \"- [ ]\",\n            \"* [ ] wrong bullet\",\n            \"Plain prose line\",\n        ],\n    )\n    def test_non_matches(self, line: str) -> None:\n        assert _CHECKBOX_RE.match(line) is None\n\n\nclass TestParseTaskLine:\n    def test_match_returns_raw_record(self) -> None:\n        rec = _parse_task_line(\"  - [x] foo\", 7)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.status_char == \"x\"\n        assert rec.text == \"foo\"\n        assert rec.line_number == 7\n\n    def test_match_failed_marker(self) -> None:\n        rec = _parse_task_line(\"- [!] bad\", 12)\n        assert rec is not None\n        assert rec.status_char == \"!\"\n        assert rec.line_number == 12\n\n    def test_non_task_returns_none(self) -> None:\n        assert _parse_task_line(\"## Stage 1: Core\", 1) is None\n        assert _parse_task_line(\"\", 2) is None\n        assert _parse_task_line(\"Some prose\", 3) is None\n\n\nclass TestParseRuledOutLine:\n    def test_indented_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] tried restart\", 5)\n        assert rec is not None\n        assert rec.indent == \"  \"\n        assert rec.text == \"tried restart\"\n        assert rec.line_number == 5\n\n    def test_top_level_with_text(self) -> None:\n        rec = _parse_ruledout_line(\"[RULEDOUT] orphan approach\", 1)\n        assert rec is not None\n        assert rec.indent == \"\"\n        assert rec.text == \"orphan approach\"\n\n    def test_empty_body(self) -> None:\n        rec = _parse_ruledout_line(\"    [RULEDOUT]\", 9)\n        assert rec is not None\n        assert rec.indent == \"    \"\n        assert rec.text == \"\"\n\n    def test_trailing_whitespace_stripped(self) -> None:\n        rec = _parse_ruledout_line(\"  [RULEDOUT] foo   \", 3)\n        assert rec is not None\n        assert rec.text == \"foo\"\n\n    def test_non_leading_token_is_not_match(self) -> None:\n        # A RULEDOUT token that appears mid-line is prose, not a\n        # RULEDOUT line. Only the leading-position form is recognized.\n        assert _parse_ruledout_line(\"- [ ] talk about [RULEDOUT] later\", 1) is None\n\n    def test_similar_token_does_not_match(self) -> None:\n        # `startswith(\"[RULEDOUT]\")` semantics: the bracket must close\n        # immediately after the keyword.\n        assert _parse_ruledout_line(\"[RULEDOUT_OTHER] foo\", 1) is None\n\n    def test_non_ruledout_lines_return_none(self) -> None:\n        assert _parse_ruledout_line(\"- [ ] regular task\", 1) is None\n        assert _parse_ruledout_line(\"\", 2) is None\n        assert _parse_ruledout_line(\"## Stage 1\", 3) is None\n\n\nclass TestAttachRuledOut:\n    def test_nearest_strict_less_indent_wins(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        child = _FakeTask(indent_level=2, name=\"child\")\n        grand = _FakeTask(indent_level=4, name=\"grand\")\n        # RULEDOUT at indent 4 sits as a sibling under `child`\n        # (indent 2): it attaches to `child`, not to `grand` even\n        # though `grand` is deeper in the stack.\n        attached = _attach_ruledout(4, [root, child, grand], [root])\n        assert attached is child\n\n    def test_skips_equal_indent_in_stack(self) -> None:\n        # Equal indent is not \"strictly less\", so the equal-indent\n        # entry is skipped and the search continues outward.\n        root = _FakeTask(indent_level=0, name=\"root\")\n        same = _FakeTask(indent_level=2, name=\"same\")\n        attached = _attach_ruledout(2, [root, same], [root])\n        assert attached is root\n\n    def test_top_level_falls_back_to_most_recent_root(self) -> None:\n        # A column-0 RULEDOUT after the stack has been popped (e.g.\n        # following a same-indent sibling) finds no strictly-less\n        # ancestor, so it attaches to the last root task.\n        a = _FakeTask(indent_level=0, name=\"a\")\n        b = _FakeTask(indent_level=0, name=\"b\")\n        attached = _attach_ruledout(0, [], [a, b])\n        assert attached is b\n\n    def test_no_ancestors_no_roots_returns_none(self) -> None:\n        # A stray [RULEDOUT] before any task in the phase has nothing\n        # to attach to; the caller is expected to drop it.\n        assert _attach_ruledout(0, [], []) is None\n\n    def test_empty_stack_uses_root_fallback(self) -> None:\n        root = _FakeTask(indent_level=0, name=\"root\")\n        attached = _attach_ruledout(2, [], [root])\n        assert attached is root\n\n\nclass TestExtractFlagTags:\n    def test_no_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"plain task text\")\n        assert tags == ()\n        assert rest == \"plain task text\"\n\n    def test_user(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] verify the menu\")\n        assert tags == (\"USER\",)\n        assert rest == \"verify the menu\"\n\n    def test_batch(self) -> None:\n        tags, rest = _extract_flag_tags(\"[BATCH] sub-task group\")\n        assert tags == (\"BATCH\",)\n        assert rest == \"sub-task group\"\n\n    def test_user_and_batch_combined(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] [BATCH] both flags\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"both flags\"\n\n    def test_adjacent_tags_without_separator(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER][BATCH] no gap\")\n        assert tags == (\"USER\", \"BATCH\")\n        assert rest == \"no gap\"\n\n    def test_non_leading_tag_is_prose(self) -> None:\n        tags, rest = _extract_flag_tags(\"Document the [USER] tag\")\n        assert tags == ()\n        assert rest == \"Document the [USER] tag\"\n\n    def test_only_first_run_is_tags(self) -> None:\n        tags, rest = _extract_flag_tags(\"[USER] middle [BATCH] later\")\n        assert tags == (\"USER\",)\n        assert rest == \"middle [BATCH] later\"\n\n    def test_empty_input(self) -> None:\n        tags, rest = _extract_flag_tags(\"\")\n        assert tags == ()\n        assert rest == \"\"\n\n\nclass TestExtractActionTag:\n    def test_no_action_tag(self) -> None:\n        tag, rest = _extract_action_tag(\"plain task text\")\n        assert tag is None\n        assert rest == \"plain task text\"\n\n    def test_action_with_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:run_cli] mcloop --dry-run\")\n        assert tag == (\"run_cli\", \"mcloop --dry-run\")\n        assert rest == \"\"\n\n    def test_action_without_args(self) -> None:\n        tag, rest = _extract_action_tag(\"[AUTO:noop]\")\n        assert tag == (\"noop\", \"\")\n        assert rest == \"\"\n\n    def test_args_extend_to_end_of_line(self) -> None:\n        # Argument string is text from closing bracket to end of line;\n        # bracketed-looking content in args stays in args.\n        tag, rest = _extract_action_tag(\"[AUTO:run] do [feat: x]\")\n        assert tag == (\"run\", \"do [feat: x]\")\n        assert rest == \"\"\n\n    def test_non_leading_auto_is_prose(self) -> None:\n        tag, rest = _extract_action_tag(\"Document the [AUTO:run] tag\")\n        assert tag is None\n        assert rest == \"Document the [AUTO:run] tag\"\n\n\nclass TestExtractAnnotations:\n    def test_no_annotation(self) -> None:\n        ann, rest = _extract_annotations(\"plain task text\")\n        assert ann == ()\n        assert rest == \"plain task text\"\n\n    def test_single_feat(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"menu wired\"]')\n        assert ann == ((\"feat\", '\"menu wired\"'),)\n        assert rest == \"do thing\"\n\n    def test_single_fix(self) -> None:\n        ann, rest = _extract_annotations('fixed it [fix: \"race\"]')\n        assert ann == ((\"fix\", '\"race\"'),)\n        assert rest == \"fixed it\"\n\n    def test_multiple_annotations_preserve_order(self) -> None:\n        ann, rest = _extract_annotations('do thing [feat: \"first\"] [fix: \"second\"]')\n        assert ann == (\n            (\"feat\", '\"first\"'),\n            (\"fix\", '\"second\"'),\n        )\n        assert rest == \"do thing\"\n\n    def test_nested_brackets_in_value(self) -> None:\n        # Balanced brackets inside the value are stepped over by the\n        # right-to-left depth scan and stay inside the annotation.\n        ann, rest = _extract_annotations('do thing [feat: \"see [issue #42]\"]')\n        assert ann == ((\"feat\", '\"see [issue #42]\"'),)\n        assert rest == \"do thing\"\n\n    def test_unquoted_nested_brackets_in_value(self) -> None:\n        ann, rest = _extract_annotations(\"do [feat: a [b] c]\")\n        assert ann == ((\"feat\", \"a [b] c\"),)\n        assert rest == \"do\"\n\n    def test_prose_bracket_without_separator_is_text(self) -> None:\n        # A `[` abutting a non-whitespace character is task text, not\n        # the start of an annotation.\n        ann, rest = _extract_annotations(\"see config[feat: x]\")\n        assert ann == ()\n        assert rest == \"see config[feat: x]\"\n\n    def test_no_whitespace_after_colon_is_not_annotation(self) -> None:\n        # `[AUTO:run]` has no whitespace after its colon and so is not\n        # an annotation under this extractor's rules.\n        ann, rest = _extract_annotations(\"[AUTO:run] cmd\")\n        assert ann == ()\n        assert rest == \"[AUTO:run] cmd\"\n\n    def test_unmatched_open_bracket(self) -> None:\n        ann, rest = _extract_annotations(\"dangling brackets feat ]\")\n        assert ann == ()\n        assert rest == \"dangling brackets feat ]\"\n\n    def test_annotation_alone_consumes_to_empty(self) -> None:\n        ann, rest = _extract_annotations('[feat: \"lone\"]')\n        assert ann == ((\"feat\", '\"lone\"'),)\n        assert rest == \"\"\n\n\nclass TestTagInteractions:\n    def test_full_pipeline_with_flag_action_and_annotation(self) -> None:\n        text = '[BATCH] [AUTO:run_cli] mcloop --dry-run [feat: \"done\"]'\n        # Annotation must be stripped before action tag, because action\n        # tag args span to end of line.\n        ann, after_ann = _extract_annotations(text)\n        assert ann == ((\"feat\", '\"done\"'),)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"BATCH\",)\n        action, after_action = _extract_action_tag(after_flags)\n        assert action == (\"run_cli\", \"mcloop --dry-run\")\n        assert after_action == \"\"\n\n    def test_flags_and_plain_text(self) -> None:\n        ann, after_ann = _extract_annotations(\"[USER] [BATCH] verify thing\")\n        assert ann == ()\n        tags, after_flags = _extract_flag_tags(after_ann)\n        assert tags == (\"USER\", \"BATCH\")\n        action, after_action = _extract_action_tag(after_flags)\n        assert action is None\n        assert after_action == \"verify thing\"\n\n    def test_tag_like_substrings_in_prose_are_unchanged(self) -> None:\n        text = \"Implement [USER] and [AUTO:run] tokenization\"\n        ann, after_ann = _extract_annotations(text)\n        tags, after_flags = _extract_flag_tags(after_ann)\n        action, after_action = _extract_action_tag(after_flags)\n        assert ann == ()\n        assert tags == ()\n        assert action is None\n        assert after_action == text\n","numLines":349,"startLine":1,"totalLines":349}}}
