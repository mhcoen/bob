{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018sKFQyXYggnPQbtvmRn29s","type":"tool_result","content":"1\t\"\"\"Malformed-input rejection coverage (Codex pile-5 acceptance gap).\n2\t\n3\tStage 2.7.1 in PLAN.md lists eight rejection conditions: the three\n4\tstructural anomalies caught by ``_check_structural_sanity`` (duplicate\n5\tH1, multiple Bugs sections, duplicate phase/stage ordinals) and five\n6\ttag-level malformations (annotations with an unclosed bracket, a\n7\tmissing colon, or an empty value; action tags missing the colon or the\n8\taction name).\n9\t\n10\tThe structural anomalies do raise in compat mode and are exercised in\n11\t:class:`TestStructuralCorruptionRejection` with a minimal failing\n12\tfixture per case, asserting the user-facing error substring and the\n13\t1-based source line of the first offending heading.\n14\t\n15\tThe tag-level malformations do NOT raise in compat mode: every such\n16\tpattern is treated as prose so legacy hand-written PLAN.md files keep\n17\tparsing through the compat parser. The ``[feat: ]`` empty-value case is\n18\tin fact accepted as a *valid* annotation because the grammar only\n19\trequires whitespace after the colon (the value after it may be empty).\n20\tStrict mode in Stage 3 is the right place to add these rejections;\n21\t:class:`TestCompatModeToleratesMalformedTags` pins the current lenient\n22\tbehavior so a silent regression in compat mode shows up in the diff,\n23\tand the gap between the task description and the parser implementation\n24\tis recorded in NOTES.md [2.7.1-2.7.2].\n25\t\"\"\"\n26\t\n27\tfrom __future__ import annotations\n28\t\n29\timport pytest\n30\t\n31\tfrom bob_tools.planfile.model import PlanSyntaxError\n32\tfrom bob_tools.planfile.parser import parse_plan\n33\t\n34\t\n35\tclass TestStructuralCorruptionRejection:\n36\t    \"\"\"Each structural anomaly raises with a quotable message and line.\"\"\"\n37\t\n38\t    @pytest.mark.parametrize(\n39\t        (\"text\", \"expected_substring\", \"expected_line\"),\n40\t        [\n41\t            pytest.param(\n42\t                \"# Same\\n## Stage 1: A\\n- [ ] x\\n# Same\\n\",\n43\t                \"duplicate top-level heading '# Same'\",\n44\t                1,\n45\t                id=\"duplicate_h1\",\n46\t            ),\n47\t            pytest.param(\n48\t                \"# P\\n## Stage 1: A\\n- [ ] x\\n## Bugs\\n- [ ] one\\n## Bugs\\n- [ ] two\\n\",\n49\t                \"multiple Bugs sections\",\n50\t                4,\n51\t                id=\"multiple_bugs_sections\",\n52\t            ),\n53\t            pytest.param(\n54\t                \"# P\\n## Stage 1: A\\n- [ ] x\\n## Stage 1: B\\n- [ ] y\\n\",\n55\t                \"duplicate Phase/Stage 1\",\n56\t                2,\n57\t                id=\"duplicate_phase_ordinals\",\n58\t            ),\n59\t        ],\n60\t    )\n61\t    def test_rejection_raises_with_message_and_line(\n62\t        self,\n63\t        text: str,\n64\t        expected_substring: str,\n65\t        expected_line: int,\n66\t    ) -> None:\n67\t        with pytest.raises(PlanSyntaxError) as exc_info:\n68\t            parse_plan(text)\n69\t        err = exc_info.value\n70\t        assert expected_substring in err.message, (\n71\t            f\"expected substring {expected_substring!r} in error message; \"\n72\t            f\"got {err.message!r}\"\n73\t        )\n74\t        assert err.line == expected_line, (\n75\t            f\"expected line {expected_line}; got {err.line}\"\n76\t        )\n77\t\n78\t\n79\tclass TestCompatModeToleratesMalformedTags:\n80\t    \"\"\"Compat-mode lenience pinning for the five tag-level cases.\n81\t\n82\t    Each fixture is the minimal task body that the task description\n83\t    lists as a rejection condition. Compat mode currently leaves the\n84\t    malformed bracket text inside the task description (or, for\n85\t    ``[feat: ]``, captures it as an annotation with empty value),\n86\t    matching mcloop's tolerant behavior. Stage 3 strict mode is the\n87\t    right home for the rejections; the assertion here is only that no\n88\t    :class:`PlanSyntaxError` is raised today.\n89\t    \"\"\"\n90\t\n91\t    @pytest.mark.parametrize(\n92\t        \"text\",\n93\t        [\n94\t            pytest.param(\n95\t                '# P\\n## Stage 1: A\\n- [ ] hello [feat: \"x\"\\n',\n96\t                id=\"annotation_unclosed_bracket\",\n97\t            ),\n98\t            pytest.param(\n99\t                '# P\\n## Stage 1: A\\n- [ ] hello [feat \"x\"]\\n',\n100\t                id=\"annotation_missing_colon\",\n101\t            ),\n102\t            pytest.param(\n103\t                \"# P\\n## Stage 1: A\\n- [ ] hello [feat: ]\\n\",\n104\t                id=\"annotation_empty_value\",\n105\t            ),\n106\t            pytest.param(\n107\t                \"# P\\n## Stage 1: A\\n- [ ] [AUTO] do thing\\n\",\n108\t                id=\"action_tag_without_colon\",\n109\t            ),\n110\t            pytest.param(\n111\t                \"# P\\n## Stage 1: A\\n- [ ] [AUTO:] do thing\\n\",\n112\t                id=\"action_tag_empty_action_name\",\n113\t            ),\n114\t        ],\n115\t    )\n116\t    def test_malformed_tag_does_not_raise_in_compat_mode(self, text: str) -> None:\n117\t        parse_plan(text)\n118\t"}]},"parent_tool_use_id":null,"session_id":"1d5a0bb2-dafd-476c-8755-3edf150f4691","uuid":"d2735170-6d78-4daa-8fad-5c15a933d456","timestamp":"2026-05-16T13:29:59.432Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/tests/test_parser_rejections.py","content":"\"\"\"Malformed-input rejection coverage (Codex pile-5 acceptance gap).\n\nStage 2.7.1 in PLAN.md lists eight rejection conditions: the three\nstructural anomalies caught by ``_check_structural_sanity`` (duplicate\nH1, multiple Bugs sections, duplicate phase/stage ordinals) and five\ntag-level malformations (annotations with an unclosed bracket, a\nmissing colon, or an empty value; action tags missing the colon or the\naction name).\n\nThe structural anomalies do raise in compat mode and are exercised in\n:class:`TestStructuralCorruptionRejection` with a minimal failing\nfixture per case, asserting the user-facing error substring and the\n1-based source line of the first offending heading.\n\nThe tag-level malformations do NOT raise in compat mode: every such\npattern is treated as prose so legacy hand-written PLAN.md files keep\nparsing through the compat parser. The ``[feat: ]`` empty-value case is\nin fact accepted as a *valid* annotation because the grammar only\nrequires whitespace after the colon (the value after it may be empty).\nStrict mode in Stage 3 is the right place to add these rejections;\n:class:`TestCompatModeToleratesMalformedTags` pins the current lenient\nbehavior so a silent regression in compat mode shows up in the diff,\nand the gap between the task description and the parser implementation\nis recorded in NOTES.md [2.7.1-2.7.2].\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom bob_tools.planfile.model import PlanSyntaxError\nfrom bob_tools.planfile.parser import parse_plan\n\n\nclass TestStructuralCorruptionRejection:\n    \"\"\"Each structural anomaly raises with a quotable message and line.\"\"\"\n\n    @pytest.mark.parametrize(\n        (\"text\", \"expected_substring\", \"expected_line\"),\n        [\n            pytest.param(\n                \"# Same\\n## Stage 1: A\\n- [ ] x\\n# Same\\n\",\n                \"duplicate top-level heading '# Same'\",\n                1,\n                id=\"duplicate_h1\",\n            ),\n            pytest.param(\n                \"# P\\n## Stage 1: A\\n- [ ] x\\n## Bugs\\n- [ ] one\\n## Bugs\\n- [ ] two\\n\",\n                \"multiple Bugs sections\",\n                4,\n                id=\"multiple_bugs_sections\",\n            ),\n            pytest.param(\n                \"# P\\n## Stage 1: A\\n- [ ] x\\n## Stage 1: B\\n- [ ] y\\n\",\n                \"duplicate Phase/Stage 1\",\n                2,\n                id=\"duplicate_phase_ordinals\",\n            ),\n        ],\n    )\n    def test_rejection_raises_with_message_and_line(\n        self,\n        text: str,\n        expected_substring: str,\n        expected_line: int,\n    ) -> None:\n        with pytest.raises(PlanSyntaxError) as exc_info:\n            parse_plan(text)\n        err = exc_info.value\n        assert expected_substring in err.message, (\n            f\"expected substring {expected_substring!r} in error message; \"\n            f\"got {err.message!r}\"\n        )\n        assert err.line == expected_line, (\n            f\"expected line {expected_line}; got {err.line}\"\n        )\n\n\nclass TestCompatModeToleratesMalformedTags:\n    \"\"\"Compat-mode lenience pinning for the five tag-level cases.\n\n    Each fixture is the minimal task body that the task description\n    lists as a rejection condition. Compat mode currently leaves the\n    malformed bracket text inside the task description (or, for\n    ``[feat: ]``, captures it as an annotation with empty value),\n    matching mcloop's tolerant behavior. Stage 3 strict mode is the\n    right home for the rejections; the assertion here is only that no\n    :class:`PlanSyntaxError` is raised today.\n    \"\"\"\n\n    @pytest.mark.parametrize(\n        \"text\",\n        [\n            pytest.param(\n                '# P\\n## Stage 1: A\\n- [ ] hello [feat: \"x\"\\n',\n                id=\"annotation_unclosed_bracket\",\n            ),\n            pytest.param(\n                '# P\\n## Stage 1: A\\n- [ ] hello [feat \"x\"]\\n',\n                id=\"annotation_missing_colon\",\n            ),\n            pytest.param(\n                \"# P\\n## Stage 1: A\\n- [ ] hello [feat: ]\\n\",\n                id=\"annotation_empty_value\",\n            ),\n            pytest.param(\n                \"# P\\n## Stage 1: A\\n- [ ] [AUTO] do thing\\n\",\n                id=\"action_tag_without_colon\",\n            ),\n            pytest.param(\n                \"# P\\n## Stage 1: A\\n- [ ] [AUTO:] do thing\\n\",\n                id=\"action_tag_empty_action_name\",\n            ),\n        ],\n    )\n    def test_malformed_tag_does_not_raise_in_compat_mode(self, text: str) -> None:\n        parse_plan(text)\n","numLines":118,"startLine":1,"totalLines":118}}}
