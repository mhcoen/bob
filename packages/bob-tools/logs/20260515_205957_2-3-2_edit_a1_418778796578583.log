{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N5UkMR9937ixMqPKCMmAhJ","type":"tool_result","content":"1\t\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom dataclasses import dataclass\n7\t\n8\t# Checkbox line: indent, status marker, body text. Matches mcloop's\n9\t# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n10\t_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n11\t\n12\t# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n13\t# caller strips any inter-tag whitespace between iterations.\n14\t_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n15\t\n16\t# Leading action tag: [AUTO:<word>]. The argument string is everything\n17\t# after the closing bracket (with the single separating space removed).\n18\t_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n19\t\n20\t# Content of an annotation (the bytes between `[` and `]`): an\n21\t# identifier-shaped key, a colon, then mandatory whitespace, then the\n22\t# value. The required whitespace after the colon is what distinguishes\n23\t# an annotation from an action tag (`[AUTO:run]` has no whitespace\n24\t# after its colon).\n25\t_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n26\t\n27\t# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n28\t# token, and optional trailing text. Matches mcloop's `parse`, which\n29\t# treats a line as RULEDOUT when its stripped form starts with the\n30\t# literal bracket token.\n31\t_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n32\t\n33\t\n34\t@dataclass(frozen=True)\n35\tclass _RawTaskLine:\n36\t    \"\"\"Recognize-step output of `_parse_task_line`.\n37\t\n38\t    Stage 2 of the parser splits recognize-then-classify. This record\n39\t    is the recognize step: indent text, status marker, body text, and\n40\t    source line number. Higher-level functions classify the body into\n41\t    task id, tags, deps, and prose.\n42\t    \"\"\"\n43\t\n44\t    indent: str\n45\t    status_char: str\n46\t    text: str\n47\t    line_number: int\n48\t\n49\t\n50\tdef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n51\t    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n52\t    m = _CHECKBOX_RE.match(line)\n53\t    if m is None:\n54\t        return None\n55\t    return _RawTaskLine(\n56\t        indent=m.group(1),\n57\t        status_char=m.group(2),\n58\t        text=m.group(3),\n59\t        line_number=line_number,\n60\t    )\n61\t\n62\t\n63\t@dataclass(frozen=True)\n64\tclass _RawRuledOut:\n65\t    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n66\t\n67\t    A RULEDOUT line is a sibling of the task it pertains to (design\n68\t    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n69\t    captures only indent, body text, and source line number; attaching\n70\t    the line to its parent task by indentation is a higher-level step.\n71\t    \"\"\"\n72\t\n73\t    indent: str\n74\t    text: str\n75\t    line_number: int\n76\t\n77\t\n78\tdef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n79\t    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n80\t\n81\t    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n82\t    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n83\t    whitespace on the body text is stripped; an empty body is allowed.\n84\t    \"\"\"\n85\t    m = _RULEDOUT_RE.match(line)\n86\t    if m is None:\n87\t        return None\n88\t    return _RawRuledOut(\n89\t        indent=m.group(1),\n90\t        text=m.group(2).strip(),\n91\t        line_number=line_number,\n92\t    )\n93\t\n94\t\n95\tdef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n96\t    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n97\t\n98\t    Per design doc section 4.3, flag tags are recognized only at the\n99\t    leading position. The caller is responsible for stripping the task\n100\t    ID (if any) first. A bracketed flag form appearing later in the\n101\t    text is prose and is left in place.\n102\t    \"\"\"\n103\t    tags: list[str] = []\n104\t    remaining = text\n105\t    while True:\n106\t        m = _FLAG_TAG_RE.match(remaining)\n107\t        if m is None:\n108\t            break\n109\t        tags.append(m.group(1))\n110\t        remaining = remaining[m.end() :].lstrip()\n111\t    return tuple(tags), remaining\n112\t\n113\t\n114\tdef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n115\t    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n116\t\n117\t    Per design doc section 4.3, the action tag is recognized only at\n118\t    the leading position, after any flag tags. The argument string is\n119\t    the text from the closing bracket to end of line, with the single\n120\t    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n121\t    are prose and are left in place.\n122\t\n123\t    Returns ``(None, text)`` when no leading action tag is present;\n124\t    otherwise consumes the rest of the line as the argument string\n125\t    and returns ``((action, args), \"\")``.\n126\t    \"\"\"\n127\t    m = _ACTION_TAG_RE.match(text)\n128\t    if m is None:\n129\t        return None, text\n130\t    action = m.group(1)\n131\t    args = text[m.end() :].lstrip()\n132\t    return (action, args), \"\"\n133\t\n134\t\n135\tdef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n136\t    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n137\t\n138\t    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n139\t    are bracketed, and are separated from the preceding text by\n140\t    whitespace. Multiple annotations are allowed. Values may contain\n141\t    balanced bracket pairs; this function scans right-to-left with\n142\t    bracket-depth tracking so nested brackets stay inside a single\n143\t    annotation rather than being misparsed as a separate one.\n144\t\n145\t    Annotation keys today are ``feat`` and ``fix``; this extractor\n146\t    accepts any identifier-shaped key. Validation of allowed keys is\n147\t    a separate concern.\n148\t    \"\"\"\n149\t    annotations: list[tuple[str, str]] = []\n150\t    remaining = text\n151\t    while True:\n152\t        rstripped = remaining.rstrip()\n153\t        if not rstripped.endswith(\"]\"):\n154\t            remaining = rstripped\n155\t            break\n156\t        start = _find_matching_open_bracket(rstripped)\n157\t        if start is None:\n158\t            remaining = rstripped\n159\t            break\n160\t        # An annotation must be separated from preceding text by\n161\t        # whitespace (or be at column 0). A `[` abutting a non-WS\n162\t        # character is part of the task text, not an annotation.\n163\t        if start > 0 and not rstripped[start - 1].isspace():\n164\t            remaining = rstripped\n165\t            break\n166\t        content = rstripped[start + 1 : -1]\n167\t        m = _ANNOTATION_CONTENT_RE.match(content)\n168\t        if m is None:\n169\t            remaining = rstripped\n170\t            break\n171\t        annotations.insert(0, (m.group(1), m.group(2)))\n172\t        remaining = rstripped[:start].rstrip()\n173\t    return tuple(annotations), remaining\n174\t\n175\t\n176\tdef _find_matching_open_bracket(s: str) -> int | None:\n177\t    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n178\t\n179\t    Walks right-to-left tracking bracket depth so balanced nested\n180\t    brackets inside the candidate annotation are stepped over.\n181\t    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n182\t    opener.\n183\t    \"\"\"\n184\t    if not s.endswith(\"]\"):\n185\t        return None\n186\t    depth = 0\n187\t    for i in range(len(s) - 1, -1, -1):\n188\t        c = s[i]\n189\t        if c == \"]\":\n190\t            depth += 1\n191\t        elif c == \"[\":\n192\t            depth -= 1\n193\t            if depth == 0:\n194\t                return i\n195\t    return None\n196\t"}]},"parent_tool_use_id":null,"session_id":"3c62b045-7b08-4482-8a85-a083b3158292","uuid":"1af697e2-ef3e-4228-aa61-0ba38d7471ec","timestamp":"2026-05-16T01:57:25.663Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/parser.py","content":"\"\"\"Parse PLAN.md text into a typed Plan object.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom dataclasses import dataclass\n\n# Checkbox line: indent, status marker, body text. Matches mcloop's\n# CHECKBOX_RE so loose-edited PLAN.md files parse identically.\n_CHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n\n# Leading flag tag: [USER] or [BATCH] anchored at start of input. The\n# caller strips any inter-tag whitespace between iterations.\n_FLAG_TAG_RE = re.compile(r\"^\\[(USER|BATCH)\\]\")\n\n# Leading action tag: [AUTO:<word>]. The argument string is everything\n# after the closing bracket (with the single separating space removed).\n_ACTION_TAG_RE = re.compile(r\"^\\[AUTO:(\\w+)\\]\")\n\n# Content of an annotation (the bytes between `[` and `]`): an\n# identifier-shaped key, a colon, then mandatory whitespace, then the\n# value. The required whitespace after the colon is what distinguishes\n# an annotation from an action tag (`[AUTO:run]` has no whitespace\n# after its colon).\n_ANNOTATION_CONTENT_RE = re.compile(r\"^([A-Za-z_]\\w*):\\s+(.*)$\", re.DOTALL)\n\n# RULEDOUT sibling line: optional indent, the literal `[RULEDOUT]`\n# token, and optional trailing text. Matches mcloop's `parse`, which\n# treats a line as RULEDOUT when its stripped form starts with the\n# literal bracket token.\n_RULEDOUT_RE = re.compile(r\"^(\\s*)\\[RULEDOUT\\](.*)$\")\n\n\n@dataclass(frozen=True)\nclass _RawTaskLine:\n    \"\"\"Recognize-step output of `_parse_task_line`.\n\n    Stage 2 of the parser splits recognize-then-classify. This record\n    is the recognize step: indent text, status marker, body text, and\n    source line number. Higher-level functions classify the body into\n    task id, tags, deps, and prose.\n    \"\"\"\n\n    indent: str\n    status_char: str\n    text: str\n    line_number: int\n\n\ndef _parse_task_line(line: str, line_number: int) -> _RawTaskLine | None:\n    \"\"\"Match a single checkbox task line. Returns None if not a task.\"\"\"\n    m = _CHECKBOX_RE.match(line)\n    if m is None:\n        return None\n    return _RawTaskLine(\n        indent=m.group(1),\n        status_char=m.group(2),\n        text=m.group(3),\n        line_number=line_number,\n    )\n\n\n@dataclass(frozen=True)\nclass _RawRuledOut:\n    \"\"\"Recognize-step output of `_parse_ruledout_line`.\n\n    A RULEDOUT line is a sibling of the task it pertains to (design\n    doc grammar `Indent* \"[RULEDOUT]\" WS Text NL`). The recognizer\n    captures only indent, body text, and source line number; attaching\n    the line to its parent task by indentation is a higher-level step.\n    \"\"\"\n\n    indent: str\n    text: str\n    line_number: int\n\n\ndef _parse_ruledout_line(line: str, line_number: int) -> _RawRuledOut | None:\n    \"\"\"Match a single ``[RULEDOUT]`` sibling line. Returns None otherwise.\n\n    Per mcloop's ``parse``, a line is a RULEDOUT line when its stripped\n    form starts with the literal ``[RULEDOUT]`` bracket token. Trailing\n    whitespace on the body text is stripped; an empty body is allowed.\n    \"\"\"\n    m = _RULEDOUT_RE.match(line)\n    if m is None:\n        return None\n    return _RawRuledOut(\n        indent=m.group(1),\n        text=m.group(2).strip(),\n        line_number=line_number,\n    )\n\n\ndef _extract_flag_tags(text: str) -> tuple[tuple[str, ...], str]:\n    \"\"\"Strip leading USER/BATCH flag tags from ``text``.\n\n    Per design doc section 4.3, flag tags are recognized only at the\n    leading position. The caller is responsible for stripping the task\n    ID (if any) first. A bracketed flag form appearing later in the\n    text is prose and is left in place.\n    \"\"\"\n    tags: list[str] = []\n    remaining = text\n    while True:\n        m = _FLAG_TAG_RE.match(remaining)\n        if m is None:\n            break\n        tags.append(m.group(1))\n        remaining = remaining[m.end() :].lstrip()\n    return tuple(tags), remaining\n\n\ndef _extract_action_tag(text: str) -> tuple[tuple[str, str] | None, str]:\n    \"\"\"Strip a leading ``[AUTO:<action>] <args>`` tag from ``text``.\n\n    Per design doc section 4.3, the action tag is recognized only at\n    the leading position, after any flag tags. The argument string is\n    the text from the closing bracket to end of line, with the single\n    separating whitespace removed. Non-leading ``[AUTO:...]`` tokens\n    are prose and are left in place.\n\n    Returns ``(None, text)`` when no leading action tag is present;\n    otherwise consumes the rest of the line as the argument string\n    and returns ``((action, args), \"\")``.\n    \"\"\"\n    m = _ACTION_TAG_RE.match(text)\n    if m is None:\n        return None, text\n    action = m.group(1)\n    args = text[m.end() :].lstrip()\n    return (action, args), \"\"\n\n\ndef _extract_annotations(text: str) -> tuple[tuple[tuple[str, str], ...], str]:\n    \"\"\"Strip trailing ``[key: value]`` annotations from ``text``.\n\n    Per design doc sections 4.2 and 4.3, annotations sit at end of line,\n    are bracketed, and are separated from the preceding text by\n    whitespace. Multiple annotations are allowed. Values may contain\n    balanced bracket pairs; this function scans right-to-left with\n    bracket-depth tracking so nested brackets stay inside a single\n    annotation rather than being misparsed as a separate one.\n\n    Annotation keys today are ``feat`` and ``fix``; this extractor\n    accepts any identifier-shaped key. Validation of allowed keys is\n    a separate concern.\n    \"\"\"\n    annotations: list[tuple[str, str]] = []\n    remaining = text\n    while True:\n        rstripped = remaining.rstrip()\n        if not rstripped.endswith(\"]\"):\n            remaining = rstripped\n            break\n        start = _find_matching_open_bracket(rstripped)\n        if start is None:\n            remaining = rstripped\n            break\n        # An annotation must be separated from preceding text by\n        # whitespace (or be at column 0). A `[` abutting a non-WS\n        # character is part of the task text, not an annotation.\n        if start > 0 and not rstripped[start - 1].isspace():\n            remaining = rstripped\n            break\n        content = rstripped[start + 1 : -1]\n        m = _ANNOTATION_CONTENT_RE.match(content)\n        if m is None:\n            remaining = rstripped\n            break\n        annotations.insert(0, (m.group(1), m.group(2)))\n        remaining = rstripped[:start].rstrip()\n    return tuple(annotations), remaining\n\n\ndef _find_matching_open_bracket(s: str) -> int | None:\n    \"\"\"Return the index of the ``[`` matching the final ``]`` in ``s``.\n\n    Walks right-to-left tracking bracket depth so balanced nested\n    brackets inside the candidate annotation are stepped over.\n    Returns ``None`` if ``s`` does not end in ``]`` with a matching\n    opener.\n    \"\"\"\n    if not s.endswith(\"]\"):\n        return None\n    depth = 0\n    for i in range(len(s) - 1, -1, -1):\n        c = s[i]\n        if c == \"]\":\n            depth += 1\n        elif c == \"[\":\n            depth -= 1\n            if depth == 0:\n                return i\n    return None\n","numLines":196,"startLine":1,"totalLines":196}}}
