{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TnPKeDevXUgYh2HQFNDERJ","type":"tool_result","content":"1\t\"\"\"Markdown checklist parser. Reads and writes `- [ ]` items.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport re\n6\tfrom dataclasses import dataclass, field\n7\tfrom pathlib import Path\n8\t\n9\tCHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n10\t# Section headers: any heading level (# or more) whose title contains\n11\t# \"Stage N\" or \"Phase N\" anywhere in the line. The number is captured.\n12\tSTAGE_RE = re.compile(r\"^#+\\s+.*?\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n13\t# Bugs header: any heading level followed by \"Bugs\" as the title.\n14\tBUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n15\t# H1 headers (single `#` followed by space). Used by the structural\n16\t# sanity check to detect duplicated top-level headings (a hallmark\n17\t# corruption pattern in PLAN.md files that have been bad-edited).\n18\t_H1_RE = re.compile(r\"^#\\s+(.+)$\")\n19\t# Pattern for extracting a stage/phase number from a stage string\n20\t# (the header text with leading # and whitespace stripped).\n21\t_STAGE_NUM_RE = re.compile(r\"\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n22\t_USER_TAG = \"[USER]\"\n23\t_BATCH_TAG = \"[BATCH]\"\n24\t_AUTO_TAG_RE = re.compile(r\"\\[AUTO:(\\w+)\\]\")\n25\t\n26\t\n27\tclass PlanCorruptionError(Exception):\n28\t    \"\"\"Raised when parse() detects structural corruption in a checklist.\n29\t\n30\t    The check is conservative: only flags anomalies that are very\n31\t    unlikely to be intentional (duplicate top-level headings, multiple\n32\t    ``## Bugs`` sections, repeated phase/stage numbers). Auto-fixing\n33\t    is deliberately not attempted; an attempt to silently \"correct\"\n34\t    structural corruption is exactly the operation that produces it.\n35\t\n36\t    Callers that intentionally pass malformed input (tests, dry-run\n37\t    inspection of an in-progress edit) can pass ``check_structure=False``\n38\t    to ``parse()``.\n39\t    \"\"\"\n40\t\n41\t\n42\t@dataclass\n43\tclass Task:\n44\t    text: str\n45\t    checked: bool\n46\t    failed: bool\n47\t    line_number: int\n48\t    indent_level: int\n49\t    stage: str = \"\"\n50\t    children: list[Task] = field(default_factory=list)\n51\t    eliminated: list[str] = field(default_factory=list)\n52\t\n53\t\n54\tdef count_unchecked(tasks: list[Task]) -> int:\n55\t    \"\"\"Recursively count unchecked, non-failed tasks.\"\"\"\n56\t    n = 0\n57\t    for t in tasks:\n58\t        if not t.checked and not t.failed:\n59\t            n += 1\n60\t        n += count_unchecked(t.children)\n61\t    return n\n62\t\n63\t\n64\tdef parse_description(path: str | Path) -> str:\n65\t    \"\"\"Extract prose before the first checkbox as a project description.\"\"\"\n66\t    lines = Path(path).read_text().splitlines()\n67\t    desc_lines = []\n68\t    for line in lines:\n69\t        if CHECKBOX_RE.match(line):\n70\t            break\n71\t        desc_lines.append(line)\n72\t    return \"\\n\".join(desc_lines).strip()\n73\t\n74\t\n75\tdef _check_structural_sanity(lines: list[str], path: str | Path) -> None:\n76\t    \"\"\"Scan a checklist file for structural corruption signals.\n77\t\n78\t    Three anomalies are flagged. Each has been observed in real\n79\t    PLAN.md corruption incidents and none has a legitimate use:\n80\t\n81\t    1. Duplicate H1 headings with identical title text — typically\n82\t       indicates a botched insertion that left the original tail in\n83\t       place, producing two copies of the document's top header.\n84\t    2. Multiple ``## Bugs`` sections (any heading level) — there\n85\t       should only ever be one.\n86\t    3. Duplicate phase/stage numbers across stage headers — e.g. two\n87\t       different headers both numbered ``Phase 2``. This breaks\n88\t       ``task_label`` (which prefixes labels with the stage number)\n89\t       and almost always signals merged content from two attempts at\n90\t       the same phase."}]},"parent_tool_use_id":null,"session_id":"3c62b045-7b08-4482-8a85-a083b3158292","uuid":"ed981183-fe14-4860-9589-4f7b88993f9f","timestamp":"2026-05-16T01:58:00.565Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/mcloop/mcloop/checklist.py","content":"\"\"\"Markdown checklist parser. Reads and writes `- [ ]` items.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom dataclasses import dataclass, field\nfrom pathlib import Path\n\nCHECKBOX_RE = re.compile(r\"^(\\s*)- \\[([ xX!])\\] (.+)$\")\n# Section headers: any heading level (# or more) whose title contains\n# \"Stage N\" or \"Phase N\" anywhere in the line. The number is captured.\nSTAGE_RE = re.compile(r\"^#+\\s+.*?\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n# Bugs header: any heading level followed by \"Bugs\" as the title.\nBUGS_RE = re.compile(r\"^#+\\s+Bugs\\s*$\", re.IGNORECASE)\n# H1 headers (single `#` followed by space). Used by the structural\n# sanity check to detect duplicated top-level headings (a hallmark\n# corruption pattern in PLAN.md files that have been bad-edited).\n_H1_RE = re.compile(r\"^#\\s+(.+)$\")\n# Pattern for extracting a stage/phase number from a stage string\n# (the header text with leading # and whitespace stripped).\n_STAGE_NUM_RE = re.compile(r\"\\b(?:stage|phase)\\s+(\\d+)\\b\", re.IGNORECASE)\n_USER_TAG = \"[USER]\"\n_BATCH_TAG = \"[BATCH]\"\n_AUTO_TAG_RE = re.compile(r\"\\[AUTO:(\\w+)\\]\")\n\n\nclass PlanCorruptionError(Exception):\n    \"\"\"Raised when parse() detects structural corruption in a checklist.\n\n    The check is conservative: only flags anomalies that are very\n    unlikely to be intentional (duplicate top-level headings, multiple\n    ``## Bugs`` sections, repeated phase/stage numbers). Auto-fixing\n    is deliberately not attempted; an attempt to silently \"correct\"\n    structural corruption is exactly the operation that produces it.\n\n    Callers that intentionally pass malformed input (tests, dry-run\n    inspection of an in-progress edit) can pass ``check_structure=False``\n    to ``parse()``.\n    \"\"\"\n\n\n@dataclass\nclass Task:\n    text: str\n    checked: bool\n    failed: bool\n    line_number: int\n    indent_level: int\n    stage: str = \"\"\n    children: list[Task] = field(default_factory=list)\n    eliminated: list[str] = field(default_factory=list)\n\n\ndef count_unchecked(tasks: list[Task]) -> int:\n    \"\"\"Recursively count unchecked, non-failed tasks.\"\"\"\n    n = 0\n    for t in tasks:\n        if not t.checked and not t.failed:\n            n += 1\n        n += count_unchecked(t.children)\n    return n\n\n\ndef parse_description(path: str | Path) -> str:\n    \"\"\"Extract prose before the first checkbox as a project description.\"\"\"\n    lines = Path(path).read_text().splitlines()\n    desc_lines = []\n    for line in lines:\n        if CHECKBOX_RE.match(line):\n            break\n        desc_lines.append(line)\n    return \"\\n\".join(desc_lines).strip()\n\n\ndef _check_structural_sanity(lines: list[str], path: str | Path) -> None:\n    \"\"\"Scan a checklist file for structural corruption signals.\n\n    Three anomalies are flagged. Each has been observed in real\n    PLAN.md corruption incidents and none has a legitimate use:\n\n    1. Duplicate H1 headings with identical title text — typically\n       indicates a botched insertion that left the original tail in\n       place, producing two copies of the document's top header.\n    2. Multiple ``## Bugs`` sections (any heading level) — there\n       should only ever be one.\n    3. Duplicate phase/stage numbers across stage headers — e.g. two\n       different headers both numbered ``Phase 2``. This breaks\n       ``task_label`` (which prefixes labels with the stage number)\n       and almost always signals merged content from two attempts at\n       the same phase.","numLines":90,"startLine":1,"totalLines":795}}}
