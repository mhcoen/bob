{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C3RHafrC9xRweHEfjjkvKA","type":"tool_result","content":"1\t\"\"\"Typed dataclasses for the parsed plan and the planfile exception types.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom dataclasses import dataclass\n6\tfrom enum import Enum\n7\tfrom pathlib import Path\n8\t\n9\t\n10\tclass TaskStatus(Enum):\n11\t    \"\"\"Three-valued checkbox state for PLAN.md tasks.\n12\t\n13\t    Per design doc section 2.1: the PLAN.md checkbox is three-valued\n14\t    (``[ ] / [x] / [!]``). Both ``x`` and ``X`` map to ``DONE``.\n15\t    \"\"\"\n16\t\n17\t    TODO = \"TODO\"\n18\t    DONE = \"DONE\"\n19\t    FAILED = \"FAILED\"\n20\t\n21\t    @classmethod\n22\t    def from_marker(cls, marker: str) -> TaskStatus:\n23\t        try:\n24\t            return CHECKBOX_MARKER_TO_STATUS[marker]\n25\t        except KeyError as exc:\n26\t            raise ValueError(\n27\t                f\"unknown checkbox marker {marker!r}; \"\n28\t                \"expected one of ' ', 'x', 'X', '!'\"\n29\t            ) from exc\n30\t\n31\t\n32\tCHECKBOX_MARKER_TO_STATUS = {\n33\t    \" \": TaskStatus.TODO,\n34\t    \"x\": TaskStatus.DONE,\n35\t    \"X\": TaskStatus.DONE,\n36\t    \"!\": TaskStatus.FAILED,\n37\t}\n38\t\n39\t\n40\t@dataclass(frozen=True)\n41\tclass RuledOut:\n42\t    \"\"\"An indent-attached ``[RULEDOUT]`` line under a parent task.\n43\t\n44\t    Per design doc section 4.2 and section 11 question 3: ``[RULEDOUT]``\n45\t    is a sibling line at the child indent under the task it pertains\n46\t    to; it is not a task tag and has no checkbox of its own.\n47\t    \"\"\"\n48\t\n49\t    text: str\n50\t    line_number: int\n51\t\n52\t\n53\t@dataclass(frozen=True)\n54\tclass Task:\n55\t    \"\"\"A single PLAN.md task entry, including nested children and tags.\"\"\"\n56\t\n57\t    task_id: str | None\n58\t    text: str\n59\t    status: TaskStatus\n60\t    flag_tags: tuple[str, ...]\n61\t    action_tag: tuple[str, str] | None\n62\t    annotations: tuple[tuple[str, str], ...]\n63\t    deps: tuple[str, ...]\n64\t    children: tuple[Task, ...]\n65\t    ruled_out: tuple[RuledOut, ...]\n66\t    indent_level: int\n67\t    line_number: int\n68\t\n69\t\n70\t@dataclass(frozen=True)\n71\tclass Subsection:\n72\t    \"\"\"A ``###`` subsection inside a phase, grouping tasks for humans.\n73\t\n74\t    Per design doc section 11 question 5: subsections are parsed as\n75\t    structural and preserved through round-trip; they have no semantic\n76\t    effect on ``next_tasks`` or ``phase_id``.\n77\t    \"\"\"\n78\t\n79\t    title: str\n80\t    prose: str\n81\t    tasks: tuple[Task, ...]\n82\t    line_number: int\n83\t\n84\t\n85\t@dataclass(frozen=True)\n86\tclass Phase:\n87\t    \"\"\"A phase or stage section with its tasks and optional subsections.\n88\t\n89\t    Per design doc section 2.5 and section 7.1: ``keyword`` is either\n90\t    ``\"Stage\"`` or ``\"Phase\"`` (cosmetic; identity travels via\n91\t    ``phase_id``). ``phase_id_source`` records how the id was resolved:\n92\t    ``\"explicit_comment\"`` (``<!-- phase_id: ... -->``),\n93\t    ``\"explicit_header\"`` (legacy ``## Phase phase_NNN: ...`` form),\n94\t    ``\"ordinal\"`` (degraded fallback), or ``\"none\"``.\n95\t    \"\"\"\n96\t\n97\t    phase_id: str | None\n98\t    phase_id_source: str\n99\t    ordinal: int\n100\t    keyword: str\n101\t    title: str\n102\t    prose: str\n103\t    subsections: tuple[Subsection, ...]\n104\t    tasks: tuple[Task, ...]\n105\t    line_number: int\n106\t\n107\t\n108\t@dataclass(frozen=True)\n109\tclass BugsSection:\n110\t    \"\"\"The ``## Bugs`` priority section. Per design doc section 6.\"\"\"\n111\t\n112\t    tasks: tuple[Task, ...]\n113\t    line_number: int\n114\t\n115\t\n116\t@dataclass(frozen=True)\n117\tclass Plan:\n118\t    \"\"\"The top-level parsed PLAN.md document.\"\"\"\n119\t\n120\t    magic_version: int | None\n121\t    project_title: str\n122\t    preamble: str\n123\t    phases: tuple[Phase, ...]\n124\t    bugs: BugsSection | None\n125\t    source_path: Path | None\n126\t\n127\t\n128\tclass PlanSyntaxError(Exception):\n129\t    \"\"\"Raised on malformed PLAN.md syntax. Carries line/column locator.\"\"\"\n130\t\n131\t    def __init__(\n132\t        self,\n133\t        message: str,\n134\t        line: int,\n135\t        column: int,\n136\t        path: Path | None = None,\n137\t    ) -> None:\n138\t        super().__init__(message)\n139\t        self.message = message\n140\t        self.line = line\n141\t        self.column = column\n142\t        self.path = path\n143\t\n144\t    def __str__(self) -> str:\n145\t        return (\n146\t            f\"PLAN.md invalid at line {self.line}, column {self.column}: {self.message}\"\n147\t        )\n148\t\n149\t\n150\tclass PlanValidationError(Exception):\n151\t    \"\"\"Raised when a parsed Plan fails validation. Carries every error.\"\"\"\n152\t\n153\t    def __init__(self, messages: list[str]) -> None:\n154\t        super().__init__(\"; \".join(messages) if messages else \"\")\n155\t        self.messages = list(messages)\n156\t\n157\t\n158\tclass PlanInconsistencyError(Exception):\n159\t    \"\"\"Raised when PLAN.md and the ledger disagree about settlement state.\"\"\"\n160\t\n161\t    def __init__(self, messages: list[str]) -> None:\n162\t        super().__init__(\"; \".join(messages) if messages else \"\")\n163\t        self.messages = list(messages)\n164\t"}]},"parent_tool_use_id":null,"session_id":"3c62b045-7b08-4482-8a85-a083b3158292","uuid":"ba1b5195-0467-4976-8f86-eecca3bb60d4","timestamp":"2026-05-16T01:58:08.540Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/mhcoen/proj/bob-tools/bob_tools/planfile/model.py","content":"\"\"\"Typed dataclasses for the parsed plan and the planfile exception types.\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom enum import Enum\nfrom pathlib import Path\n\n\nclass TaskStatus(Enum):\n    \"\"\"Three-valued checkbox state for PLAN.md tasks.\n\n    Per design doc section 2.1: the PLAN.md checkbox is three-valued\n    (``[ ] / [x] / [!]``). Both ``x`` and ``X`` map to ``DONE``.\n    \"\"\"\n\n    TODO = \"TODO\"\n    DONE = \"DONE\"\n    FAILED = \"FAILED\"\n\n    @classmethod\n    def from_marker(cls, marker: str) -> TaskStatus:\n        try:\n            return CHECKBOX_MARKER_TO_STATUS[marker]\n        except KeyError as exc:\n            raise ValueError(\n                f\"unknown checkbox marker {marker!r}; \"\n                \"expected one of ' ', 'x', 'X', '!'\"\n            ) from exc\n\n\nCHECKBOX_MARKER_TO_STATUS = {\n    \" \": TaskStatus.TODO,\n    \"x\": TaskStatus.DONE,\n    \"X\": TaskStatus.DONE,\n    \"!\": TaskStatus.FAILED,\n}\n\n\n@dataclass(frozen=True)\nclass RuledOut:\n    \"\"\"An indent-attached ``[RULEDOUT]`` line under a parent task.\n\n    Per design doc section 4.2 and section 11 question 3: ``[RULEDOUT]``\n    is a sibling line at the child indent under the task it pertains\n    to; it is not a task tag and has no checkbox of its own.\n    \"\"\"\n\n    text: str\n    line_number: int\n\n\n@dataclass(frozen=True)\nclass Task:\n    \"\"\"A single PLAN.md task entry, including nested children and tags.\"\"\"\n\n    task_id: str | None\n    text: str\n    status: TaskStatus\n    flag_tags: tuple[str, ...]\n    action_tag: tuple[str, str] | None\n    annotations: tuple[tuple[str, str], ...]\n    deps: tuple[str, ...]\n    children: tuple[Task, ...]\n    ruled_out: tuple[RuledOut, ...]\n    indent_level: int\n    line_number: int\n\n\n@dataclass(frozen=True)\nclass Subsection:\n    \"\"\"A ``###`` subsection inside a phase, grouping tasks for humans.\n\n    Per design doc section 11 question 5: subsections are parsed as\n    structural and preserved through round-trip; they have no semantic\n    effect on ``next_tasks`` or ``phase_id``.\n    \"\"\"\n\n    title: str\n    prose: str\n    tasks: tuple[Task, ...]\n    line_number: int\n\n\n@dataclass(frozen=True)\nclass Phase:\n    \"\"\"A phase or stage section with its tasks and optional subsections.\n\n    Per design doc section 2.5 and section 7.1: ``keyword`` is either\n    ``\"Stage\"`` or ``\"Phase\"`` (cosmetic; identity travels via\n    ``phase_id``). ``phase_id_source`` records how the id was resolved:\n    ``\"explicit_comment\"`` (``<!-- phase_id: ... -->``),\n    ``\"explicit_header\"`` (legacy ``## Phase phase_NNN: ...`` form),\n    ``\"ordinal\"`` (degraded fallback), or ``\"none\"``.\n    \"\"\"\n\n    phase_id: str | None\n    phase_id_source: str\n    ordinal: int\n    keyword: str\n    title: str\n    prose: str\n    subsections: tuple[Subsection, ...]\n    tasks: tuple[Task, ...]\n    line_number: int\n\n\n@dataclass(frozen=True)\nclass BugsSection:\n    \"\"\"The ``## Bugs`` priority section. Per design doc section 6.\"\"\"\n\n    tasks: tuple[Task, ...]\n    line_number: int\n\n\n@dataclass(frozen=True)\nclass Plan:\n    \"\"\"The top-level parsed PLAN.md document.\"\"\"\n\n    magic_version: int | None\n    project_title: str\n    preamble: str\n    phases: tuple[Phase, ...]\n    bugs: BugsSection | None\n    source_path: Path | None\n\n\nclass PlanSyntaxError(Exception):\n    \"\"\"Raised on malformed PLAN.md syntax. Carries line/column locator.\"\"\"\n\n    def __init__(\n        self,\n        message: str,\n        line: int,\n        column: int,\n        path: Path | None = None,\n    ) -> None:\n        super().__init__(message)\n        self.message = message\n        self.line = line\n        self.column = column\n        self.path = path\n\n    def __str__(self) -> str:\n        return (\n            f\"PLAN.md invalid at line {self.line}, column {self.column}: {self.message}\"\n        )\n\n\nclass PlanValidationError(Exception):\n    \"\"\"Raised when a parsed Plan fails validation. Carries every error.\"\"\"\n\n    def __init__(self, messages: list[str]) -> None:\n        super().__init__(\"; \".join(messages) if messages else \"\")\n        self.messages = list(messages)\n\n\nclass PlanInconsistencyError(Exception):\n    \"\"\"Raised when PLAN.md and the ledger disagree about settlement state.\"\"\"\n\n    def __init__(self, messages: list[str]) -> None:\n        super().__init__(\"; \".join(messages) if messages else \"\")\n        self.messages = list(messages)\n","numLines":164,"startLine":1,"totalLines":164}}}
