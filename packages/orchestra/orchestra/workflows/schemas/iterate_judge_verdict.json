{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["decision", "feedback"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["accept", "iterate", "stuck"]
    },
    "feedback": {
      "type": "string"
    },
    "criteria_compliance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion_id", "observed_value", "compliant"],
        "properties": {
          "criterion_id": {
            "type": "string",
            "minLength": 1
          },
          "observed_value": {
            "type": "string"
          },
          "compliant": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
