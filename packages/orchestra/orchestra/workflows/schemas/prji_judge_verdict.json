{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["decision", "feedback", "fix_instructions"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["accept", "implement", "rereview", "reframe"]
    },
    "feedback": {
      "type": "string"
    },
    "fix_instructions": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
