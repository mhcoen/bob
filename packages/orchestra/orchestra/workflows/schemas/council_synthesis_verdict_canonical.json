{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["decision", "feedback", "agreements", "disagreements", "rejected_options"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["accept", "reframe", "stuck"]
    },
    "feedback": {
      "type": "string"
    },
    "agreements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "positions"],
        "properties": {
          "topic": {
            "type": "string",
            "minLength": 1
          },
          "positions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "rejected_options": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "criteria_compliance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion_id", "observed_value", "compliant"],
        "properties": {
          "criterion_id": {
            "type": "string",
            "minLength": 1
          },
          "observed_value": {
            "type": "string"
          },
          "compliant": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "commit_attributions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["commit_sha", "phase_id", "rationale"],
        "properties": {
          "commit_sha": {
            "type": "string",
            "minLength": 7,
            "maxLength": 64
          },
          "phase_id": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
